; C24 Compiler Output - hello
; Target: Z80
; Generated by uc80

	.Z80

	CSEG

	EXTRN	_puts
	PUBLIC	_main

; Function main
_main:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	LD	HL,@STR1
	PUSH	HL
	CALL	_puts
	POP	DE
	LD	HL,0
	JP	@main_ret
@main_ret:
	LD	SP,IX
	POP	IX
	RET


; String literals
	DSEG
@STR1:
	DB	'Hello, World!',0

; Global variables
	DSEG

	END