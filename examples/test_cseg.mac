; Test with string in CSEG instead of DSEG
	.Z80

	PUBLIC	_main
	EXTRN	_putchar

	CSEG

_main:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	LD	HL,-4
	ADD	HL,SP
	LD	SP,HL

	; s = @STR1 at IX-2/-1
	LD	HL,@STR1
	LD	(IX-2),L
	LD	(IX-1),H

	; i = 0 at IX-4/-3
	LD	HL,0
	LD	(IX-4),L
	LD	(IX-3),H

loop:
	; Compute s[i]
	LD	L,(IX-4)
	LD	H,(IX-3)
	PUSH	HL
	LD	L,(IX-2)
	LD	H,(IX-1)
	POP	DE
	ADD	HL,DE
	LD	L,(HL)
	LD	H,0

	; Check if zero
	LD	A,H
	OR	L
	JP	Z,done

	; Print char via _putchar
	PUSH	HL
	CALL	_putchar
	POP	DE

	; i = i + 1
	LD	L,(IX-4)
	LD	H,(IX-3)
	INC	HL
	LD	(IX-4),L
	LD	(IX-3),H
	JP	loop

done:
	LD	E,0DH
	LD	C,2
	CALL	5
	LD	E,0AH
	LD	C,2
	CALL	5

	LD	HL,0
	LD	SP,IX
	POP	IX
	RET

; String in CSEG instead of DSEG
@STR1:
	DB	'ABC',0

	END
