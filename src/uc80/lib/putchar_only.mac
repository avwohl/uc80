; Minimal putchar only
	.Z80

BDOS	EQU	5
CONOUT	EQU	2

	CSEG

	PUBLIC	_putchar
_putchar:
	; Stack at entry: [ret_addr][arg]
	POP	HL		; Get return address
	POP	DE		; Get argument (char in E)
	PUSH	DE		; Restore arg for caller cleanup
	PUSH	HL		; Restore return address

	LD	C,CONOUT
	CALL	BDOS

	; Return value
	LD	HL,2
	ADD	HL,SP
	LD	L,(HL)
	LD	H,0
	RET

	END
