	EXX	;Er 5 bytes klaret?
	DEC	L
	EXX
	JR	Z, mm48__divi4	;Ja => DIVI4
	LD	A,8	;8 bits

mm48__divi3:

	CALL	mm48__sleft	;Skift AC til venstre
	JR	NC, mm48__divi1	;Ingen carry => DIVI1

	EX	AF,AF'
	CALL	mm48__subac	;MANT=MANT-MANT'
	OR	A	;Nulstil carry
	JR	mm48__divi2

mm48__divi4:

	CALL	mm48__sleft	;Udregn afrundingsbit
	JR	C, mm48__divi5
