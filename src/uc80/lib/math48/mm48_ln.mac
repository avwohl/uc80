	CALL	mm48__acln2
	DEC	L	;AC = ln(2)/2

	CALL	mm48_fpadd	;AC'= z + ln(2)/2 = w

	EXX

	POP	AF

	PUSH	BC	; save w
	PUSH	DE
	PUSH	HL

	LD	L,A
	LD	H,0
	JR	NC, mm48__ln1
