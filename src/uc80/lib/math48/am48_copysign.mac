; double copysign(double x, double y)



am48_copysign:

   ; Make sign of AC' the same as sign of AC
   ;
   ; enter : AC' = double x
   ;         AC  = double y
   ;
   ; exit  : AC' = abs(x) * sgn(y)
   ;
   ; uses  : af, b'

