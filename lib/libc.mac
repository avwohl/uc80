; libc.mac - generated by build_libs.py from lc/ modules
; DO NOT EDIT - edit the individual module files instead

	.Z80

; CP/M BDOS function numbers
BDOS	EQU	5		; BDOS entry point
CONOUT	EQU	2		; Console output (char in E)
CONIN	EQU	1		; Console input (char returned in A)
PRTSTR	EQU	9		; Print string (address in DE, '$' terminated)

	CSEG

; ============================================================
; lc_acos.mac
; ============================================================
	CSEG
; lc_acos.mac - acos, acosf (depends on asin)


	EXTRN	__fsub
	EXTRN	__tmp32

	CSEG

; ============================================================
; acos(x) = pi/2 - asin(x)
; ============================================================
	PUBLIC	_acos
	PUBLIC	_acosf
_acos:
_acosf:
	PUSH	IX
	PUSH	BC
	LD	IX,0
	ADD	IX,SP

	CALL	_math_getarg
	PUSH	DE
	PUSH	HL
	CALL	_asinf
	POP	BC
	POP	BC

	; pi/2 - result (pi/2 = 1.5707963 = 3FC90FDB)
	LD	(__tmp32),HL
	LD	(__tmp32+2),DE
	LD	HL,0FDBH
	LD	DE,3FC9H
	CALL	__fsub

	POP	BC
	POP	IX
	RET


; ============================================================
; lc_acosh.mac
; ============================================================
	CSEG
; lc_acosh.mac - acosh, acoshf
; acosh(x) = log(x + sqrt(x^2 - 1)), x >= 1


	EXTRN	__fadd
	EXTRN	__fsub
	EXTRN	__fmul
	EXTRN	__tmp32

	CSEG

	PUBLIC	_acosh
	PUBLIC	_acoshf
_acosh:
_acoshf:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP

	; Load x
	LD	L,(IX+4)
	LD	H,(IX+5)
	LD	E,(IX+6)
	LD	D,(IX+7)
	LD	(_acosh_x),HL
	LD	(_acosh_x+2),DE

	; x^2
	LD	(__tmp32),HL
	LD	(__tmp32+2),DE
	CALL	__fmul
	LD	(_acosh_t),HL
	LD	(_acosh_t+2),DE

	; x^2 - 1.0: put 1.0 in __tmp32, x^2 in DEHL
	LD	HL,0
	LD	DE,3F80H	; 1.0
	LD	(__tmp32),HL
	LD	(__tmp32+2),DE
	LD	HL,(_acosh_t)
	LD	DE,(_acosh_t+2)
	CALL	__fsub		; x^2 - 1.0

	; sqrt(x^2 - 1)
	PUSH	DE
	PUSH	HL
	CALL	_sqrtf
	POP	BC
	POP	BC

	; x + sqrt(x^2 - 1)
	LD	A,(_acosh_x)
	LD	(__tmp32),A
	LD	A,(_acosh_x+1)
	LD	(__tmp32+1),A
	LD	A,(_acosh_x+2)
	LD	(__tmp32+2),A
	LD	A,(_acosh_x+3)
	LD	(__tmp32+3),A
	CALL	__fadd

	; log
	PUSH	DE
	PUSH	HL
	CALL	_logf
	POP	BC
	POP	BC

	POP	IX
	RET

	DSEG

_acosh_x:	DS	4
_acosh_t:	DS	4


; ============================================================
; lc_asin.mac
; ============================================================
	CSEG
; lc_asin.mac - asin, asinf (depends on sqrt, atan)


	EXTRN	__fmul
	EXTRN	__fsub
	EXTRN	__fdiv
	EXTRN	__tmp32

	CSEG

; ============================================================
; asin(x) = atan(x / sqrt(1-x^2))
; ============================================================
	PUBLIC	_asin
	PUBLIC	_asinf
_asin:
_asinf:
	PUSH	IX
	PUSH	BC
	LD	IX,0
	ADD	IX,SP

	CALL	_math_getarg
	LD	(_asin_x),HL
	LD	(_asin_x+2),DE

	; 1 - x^2
	LD	(__tmp32),HL
	LD	(__tmp32+2),DE
	CALL	__fmul		; x^2
	LD	(__tmp32),HL
	LD	(__tmp32+2),DE
	LD	HL,0
	LD	DE,3F80H	; 1.0
	CALL	__fsub		; 1-x^2

	; sqrt(1-x^2)
	PUSH	DE
	PUSH	HL
	CALL	_sqrtf
	POP	BC
	POP	BC

	; x / sqrt(1-x^2)
	LD	(__tmp32),HL
	LD	(__tmp32+2),DE
	LD	HL,(_asin_x)
	LD	DE,(_asin_x+2)
	CALL	__fdiv

	; atan
	PUSH	DE
	PUSH	HL
	CALL	_atanf
	POP	BC
	POP	BC

	POP	BC
	POP	IX
	RET

	DSEG

_asin_x:	DS	4


; ============================================================
; lc_asinh.mac
