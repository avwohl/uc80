	EXTRN	__tmp32

	CSEG

	PUBLIC	_asinh
	PUBLIC	_asinhf
_asinh:
_asinhf:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP

	; Load x
	LD	L,(IX+4)
	LD	H,(IX+5)
	LD	E,(IX+6)
	LD	D,(IX+7)
	LD	(_asinh_x),HL
	LD	(_asinh_x+2),DE

	; x^2
	LD	(__tmp32),HL
	LD	(__tmp32+2),DE
	CALL	__fmul

	; x^2 + 1.0
	LD	(__tmp32),HL
	LD	(__tmp32+2),DE
	LD	HL,0
	LD	DE,3F80H	; 1.0
	CALL	__fadd

	; sqrt(x^2 + 1)
	PUSH	DE
	PUSH	HL
	CALL	_sqrtf
	POP	BC
	POP	BC

	; x + sqrt(x^2 + 1)
	LD	A,(_asinh_x)
	LD	(__tmp32),A
	LD	A,(_asinh_x+1)
	LD	(__tmp32+1),A
	LD	A,(_asinh_x+2)
	LD	(__tmp32+2),A
	LD	A,(_asinh_x+3)
	LD	(__tmp32+3),A
	CALL	__fadd

	; log(x + sqrt(x^2 + 1))
	PUSH	DE
	PUSH	HL
	CALL	_logf
	POP	BC
	POP	BC

	POP	IX
	RET

	DSEG

_asinh_x:	DS	4


; ============================================================
; lc_assert.mac
; ============================================================
	CSEG
; lc_assert.mac - assert support




	CSEG

; ============================================================
; void _assert_fail(const char *file, int line)
; Called when an assertion fails
; Prints message and exits
; ============================================================
	PUBLIC	__assert_fail
__assert_fail:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP

	; Print "Assert: "
	LD	HL,_assert_msg
	CALL	_assert_puts

	; Print filename
	LD	L,(IX+4)
	LD	H,(IX+5)
	CALL	_assert_puts

	; Print ":"
	LD	E,':'
	LD	C,2
	CALL	5

	; Print line number
	LD	L,(IX+6)
	LD	H,(IX+7)
	CALL	_assert_prt_dec

	; Print newline
	LD	E,0DH
	LD	C,2
	CALL	5
	LD	E,0AH
	LD	C,2
	CALL	5

	; Exit
	JP	0

; Internal: print string at HL
_assert_puts:
	LD	A,(HL)
	OR	A
	RET	Z
	LD	E,A
	PUSH	HL
	LD	C,2
	CALL	5
	POP	HL
	INC	HL
	JR	_assert_puts

; Internal: print HL as decimal
_assert_prt_dec:
	PUSH	BC
	PUSH	DE
	LD	DE,10
	LD	B,0
_assert_dec_loop:
	CALL	_assert_div
	PUSH	DE
	INC	B
	LD	A,H
	OR	L
	JR	NZ,_assert_dec_loop
_assert_dec_out:
	POP	DE
	LD	A,E
	ADD	A,'0'
	LD	E,A
	PUSH	BC
	LD	C,2
	CALL	5
	POP	BC
	DJNZ	_assert_dec_out
	POP	DE
	POP	BC
	RET

; Simple division: HL = HL / 10, DE = HL % 10
_assert_div:
	PUSH	BC
	LD	BC,0
_assert_div_lp:
	LD	A,H
	OR	A
	JR	NZ,_assert_div_sub
	LD	A,L
	CP	10
	JR	C,_assert_div_dn
_assert_div_sub:
	LD	A,L
	SUB	10
	LD	L,A
	LD	A,H
	SBC	A,0
	LD	H,A
	INC	BC
	JR	_assert_div_lp
_assert_div_dn:
	LD	E,L
	LD	D,0
	LD	H,B
	LD	L,C
	POP	BC
	RET

	DSEG

_assert_msg:	DB	'Assert: ',0


; ============================================================
; lc_atan.mac
; ============================================================
	CSEG
; lc_atan.mac - atan, atanf
; Range reduction: |x|>=2 -> pi/2-atan(1/x), 0.5<=|x|<2 -> pi/4+atan((x-1)/(x+1))


	EXTRN	__fadd
	EXTRN	__fsub
	EXTRN	__fmul
	EXTRN	__fdiv
	EXTRN	__itof
	EXTRN	__tmp32

	CSEG

; ============================================================
; atan(x) with range reduction
; ============================================================
	PUBLIC	_atan
	PUBLIC	_atanf
_atan:
_atanf:
	PUSH	IX
	PUSH	BC
	LD	IX,0
	ADD	IX,SP

	CALL	_math_getarg

	; Save and strip sign
	LD	A,D
	AND	80H
	LD	(_atan_sign),A
	LD	A,D
	AND	7FH
	LD	D,A
	; DEHL = |x|
	LD	(_atan_val),HL
	LD	(_atan_val+2),DE

	; Init flags
	XOR	A
	LD	(_atan_inv),A
	LD	(_atan_off),A

	; Extract biased exponent
	LD	A,D
	ADD	A,A
	LD	B,A
	LD	A,E
	RLCA
	AND	1
	OR	B		; A = biased exponent

	CP	128
	JR	NC,_atan_invert	; |x| >= 2.0
	CP	126
	JR	NC,_atan_offset	; 0.5 <= |x| < 2.0
	JR	_atan_series	; |x| < 0.5

_atan_invert:
	; atan(|x|) = pi/2 - atan(1/|x|)
	LD	A,1
	LD	(_atan_inv),A
	LD	HL,(_atan_val)
	LD	DE,(_atan_val+2)
	LD	(__tmp32),HL
	LD	(__tmp32+2),DE
	LD	HL,0
	LD	DE,3F80H	; 1.0
	CALL	__fdiv		; 1/|x|
	LD	(_atan_val),HL
	LD	(_atan_val+2),DE
	JR	_atan_series

_atan_offset:
	; atan(|x|) = pi/4 + atan((|x|-1)/(|x|+1))
	LD	A,1
	LD	(_atan_off),A
	; |x| - 1
	LD	HL,0
	LD	DE,3F80H	; 1.0
	LD	(__tmp32),HL
	LD	(__tmp32+2),DE
	LD	HL,(_atan_val)
	LD	DE,(_atan_val+2)
	CALL	__fsub		; |x| - 1
	LD	(_atan_num),HL
	LD	(_atan_num+2),DE
	; |x| + 1
	LD	HL,0
	LD	DE,3F80H
	LD	(__tmp32),HL
	LD	(__tmp32+2),DE
	LD	HL,(_atan_val)
	LD	DE,(_atan_val+2)
	CALL	__fadd		; |x| + 1
	; z = (|x|-1)/(|x|+1)
	LD	(__tmp32),HL
	LD	(__tmp32+2),DE
	LD	HL,(_atan_num)
	LD	DE,(_atan_num+2)
	CALL	__fdiv
	LD	(_atan_val),HL
	LD	(_atan_val+2),DE

_atan_series:
	; Taylor: val - val^3/3 + val^5/5 - ...
	; |val| <= 0.5, 8 terms for good accuracy
	LD	HL,(_atan_val)
	LD	DE,(_atan_val+2)
	LD	(_atan_sum),HL
	LD	(_atan_sum+2),DE
	LD	(_atan_term),HL
	LD	(_atan_term+2),DE

	; val^2
	LD	(__tmp32),HL
	LD	(__tmp32+2),DE
	CALL	__fmul
	LD	(_atan_v2),HL
	LD	(_atan_v2+2),DE

	LD	B,8
	LD	C,3

_atan_loop:
	PUSH	BC

	; term *= val^2
	LD	HL,(_atan_term)
	LD	DE,(_atan_term+2)
	LD	A,(_atan_v2)
	LD	(__tmp32),A
	LD	A,(_atan_v2+1)
	LD	(__tmp32+1),A
	LD	A,(_atan_v2+2)
	LD	(__tmp32+2),A
	LD	A,(_atan_v2+3)
	LD	(__tmp32+3),A
	CALL	__fmul

	; Negate
	LD	A,D
	XOR	80H
	LD	D,A
	LD	(_atan_term),HL
	LD	(_atan_term+2),DE

	; Divide by n
	POP	BC
	LD	L,C
	INC	C
	INC	C		; Advance to next odd
	PUSH	BC		; Save updated B and C
	LD	H,0
	LD	E,H
	LD	D,H		; DEHL = n as 32-bit int
	CALL	__itof
	LD	(__tmp32),HL
	LD	(__tmp32+2),DE
	LD	HL,(_atan_term)
	LD	DE,(_atan_term+2)
	CALL	__fdiv

	; Add to sum
	LD	A,(_atan_sum)
	LD	(__tmp32),A
	LD	A,(_atan_sum+1)
	LD	(__tmp32+1),A
	LD	A,(_atan_sum+2)
	LD	(__tmp32+2),A
	LD	A,(_atan_sum+3)
	LD	(__tmp32+3),A
	CALL	__fadd
	LD	(_atan_sum),HL
	LD	(_atan_sum+2),DE

	POP	BC
	DJNZ	_atan_loop

	LD	HL,(_atan_sum)
	LD	DE,(_atan_sum+2)

	; If off_flag: result += pi/4 (3F490FDB)
	LD	A,(_atan_off)
	OR	A
	JR	Z,_atan_no_off
	LD	A,0DBH
	LD	(__tmp32),A
	LD	A,0FH
	LD	(__tmp32+1),A
	LD	A,49H
	LD	(__tmp32+2),A
	LD	A,3FH
	LD	(__tmp32+3),A
	CALL	__fadd
_atan_no_off:

	; If inv_flag: result = pi/2 - result (3FC90FDB)
	LD	A,(_atan_inv)
	OR	A
	JR	Z,_atan_no_inv
	LD	(__tmp32),HL
	LD	(__tmp32+2),DE
	LD	HL,0FDBH
	LD	DE,3FC9H
	CALL	__fsub
_atan_no_inv:

	; Apply sign
	LD	A,(_atan_sign)
	OR	D
	LD	D,A

	POP	BC
	POP	IX
	RET

	DSEG

_atan_val:	DS	4
_atan_v2:	DS	4
_atan_sum:	DS	4
_atan_term:	DS	4
_atan_num:	DS	4
_atan_sign:	DS	1
_atan_inv:	DS	1
_atan_off:	DS	1


; ============================================================
; lc_atan2.mac
; ============================================================
	CSEG
; lc_atan2.mac - atan2, atan2f (depends on atan)


	EXTRN	__fdiv
	EXTRN	__tmp32

	CSEG

; ============================================================
; atan2(y, x) - two-argument arctangent
; ============================================================
	PUBLIC	_atan2
	PUBLIC	_atan2f
_atan2:
_atan2f:
	PUSH	IX
	PUSH	BC
	LD	IX,0
	ADD	IX,SP

	; y at IX+6, x at IX+10
	CALL	_math_getarg	; y
	LD	(_atan2_y),HL
	LD	(_atan2_y+2),DE
	CALL	_math_getarg2	; x to __tmp32
	LD	HL,(__tmp32)
	LD	DE,(__tmp32+2)
	LD	(_atan2_x),HL
	LD	(_atan2_x+2),DE

	; Compute y/x
	LD	(__tmp32),HL
	LD	(__tmp32+2),DE
	LD	HL,(_atan2_y)
	LD	DE,(_atan2_y+2)
	CALL	__fdiv

	; atan(y/x)
	PUSH	DE
	PUSH	HL
	CALL	_atanf
	POP	BC
	POP	BC

	; Adjust quadrant based on signs (simplified - just return atan(y/x))
	POP	BC
	POP	IX
	RET

	DSEG

_atan2_x:	DS	4
_atan2_y:	DS	4


; ============================================================
; lc_atanh.mac
; ============================================================
	CSEG
; lc_atanh.mac - atanh, atanhf
; atanh(x) = 0.5 * log((1+x) / (1-x)), |x| < 1


	EXTRN	__fadd
	EXTRN	__fsub
	EXTRN	__fdiv
	EXTRN	__fmul
	EXTRN	__tmp32

	CSEG

	PUBLIC	_atanh
	PUBLIC	_atanhf
_atanh:
_atanhf:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP

	; Load x
	LD	L,(IX+4)
	LD	H,(IX+5)
	LD	E,(IX+6)
	LD	D,(IX+7)
	LD	(_atanh_x),HL
	LD	(_atanh_x+2),DE

	; 1 + x: put x in __tmp32, 1.0 in DEHL
	LD	(__tmp32),HL
	LD	(__tmp32+2),DE
	LD	HL,0
	LD	DE,3F80H	; 1.0
	CALL	__fadd		; 1.0 + x
	LD	(_atanh_num),HL
	LD	(_atanh_num+2),DE

	; 1 - x: put x in __tmp32, 1.0 in DEHL
	LD	A,(_atanh_x)
	LD	(__tmp32),A
	LD	A,(_atanh_x+1)
	LD	(__tmp32+1),A
	LD	A,(_atanh_x+2)
	LD	(__tmp32+2),A
	LD	A,(_atanh_x+3)
	LD	(__tmp32+3),A
	LD	HL,0
	LD	DE,3F80H	; 1.0
	CALL	__fsub		; 1.0 - x

	; (1+x) / (1-x): denom in __tmp32, num in DEHL
	LD	(__tmp32),HL
	LD	(__tmp32+2),DE
	LD	HL,(_atanh_num)
	LD	DE,(_atanh_num+2)
	CALL	__fdiv

	; log((1+x)/(1-x))
	PUSH	DE
	PUSH	HL
	CALL	_logf
	POP	BC
	POP	BC

	; * 0.5
	LD	(__tmp32),HL
	LD	(__tmp32+2),DE
	LD	HL,0
	LD	DE,3F00H	; 0.5
	CALL	__fmul

	POP	IX
	RET

	DSEG

_atanh_x:	DS	4
_atanh_num:	DS	4


; ============================================================
; lc_atof.mac
; ============================================================
	CSEG
; lc_atof.mac - string to float conversion



	EXTRN	__ltof
	EXTRN	__fadd
	EXTRN	__fsub
	EXTRN	__fmul
	EXTRN	__fdiv
	EXTRN	__tmp32

	CSEG

; ============================================================
; double atof(const char *nptr)
; Convert string to double (IEEE 754 single precision)
; ============================================================
	PUBLIC	_atof
_atof:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	PUSH	BC

	; Call strtod with NULL endptr
	LD	L,(IX+4)
	LD	H,(IX+5)	; HL = nptr
	PUSH	HL
	LD	HL,0
	PUSH	HL		; endptr = NULL
	CALL	_strtod
	POP	BC
	POP	BC

	POP	BC
	POP	IX
	RET

; ============================================================
; double strtod(const char *nptr, char **endptr)
; Convert string to double (IEEE 754 single precision)
; Format: [ws][sign][digits][.digits][e[sign]digits]
; Returns result in DEHL
; ============================================================
	PUBLIC	_strtod
	PUBLIC	_strtof		; Same as strtod for our implementation
	PUBLIC	_strtold	; Same as strtod for our implementation
_strtof:
_strtold:
_strtod:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	PUSH	BC

	LD	L,(IX+4)
	LD	H,(IX+5)	; HL = nptr
	XOR	A
	LD	(_strtod_neg),A	; Clear negative flag
	LD	(_strtod_expneg),A	; Clear exponent negative
	LD	A,1
	LD	(_strtod_expadj),A	; Exponent adjustment (1.0 default)
	LD	(_strtod_expadj+1),A

	; Initialize result to 0.0
	XOR	A
	LD	(_strtod_result),A
	LD	(_strtod_result+1),A
	LD	(_strtod_result+2),A
	LD	(_strtod_result+3),A

	; Skip leading whitespace
_strtod_skip:
	LD	A,(HL)
	CP	' '
	JR	Z,_strtod_skipnext
	CP	09H
	JR	Z,_strtod_skipnext
	CP	0AH
	JR	Z,_strtod_skipnext
	CP	0DH
	JR	Z,_strtod_skipnext
	JR	_strtod_sign
_strtod_skipnext:
	INC	HL
	JR	_strtod_skip

_strtod_sign:
	PUSH	HL		; Save start position for endptr
	LD	A,(HL)
	CP	'-'
	JR	NZ,_strtod_chkplus
	LD	A,1
	LD	(_strtod_neg),A
	INC	HL
	JR	_strtod_intpart
_strtod_chkplus:
	CP	'+'
	JR	NZ,_strtod_intpart
	INC	HL

_strtod_intpart:
	; Parse integer part: accumulate digits
	; Use 32-bit integer accumulator first
	XOR	A
	LD	(_strtod_intacc),A
	LD	(_strtod_intacc+1),A
	LD	(_strtod_intacc+2),A
	LD	(_strtod_intacc+3),A
	LD	(_strtod_gotdigit),A	; No digits yet

_strtod_intloop:
	LD	A,(HL)
	CP	'0'
	JR	C,_strtod_intdone
	CP	'9'+1
	JR	NC,_strtod_intdone
	; Got a digit
	LD	B,1
	LD	(_strtod_gotdigit),A
	SUB	'0'
	LD	C,A		; C = digit value

	; Multiply accumulator by 10 and add digit
	PUSH	HL
	PUSH	BC

	; Load accumulator
	LD	HL,(_strtod_intacc)
	LD	DE,(_strtod_intacc+2)
	; Multiply by 10: DEHL * 10
	; Save original
	PUSH	DE
	PUSH	HL
	; *2
	ADD	HL,HL
	RL	E
	RL	D
	; *4
	ADD	HL,HL
	RL	E
	RL	D
	; *8 + *2 = *10
	POP	BC		; Original low
	EX	(SP),HL		; Swap with original high, get *8 low
	ADD	HL,BC		; *8 low + *2 low
	EX	DE,HL		; DE = new low
	POP	BC		; Original high
	LD	A,H
	ADC	A,C
	LD	H,A
	LD	A,L
	ADC	A,B
	LD	L,A		; HL = high, DE = low (wrong order)
	EX	DE,HL		; DEHL = result*10
	; Now add digit in C
	POP	BC		; Get digit back
	LD	A,L
	ADD	A,C
	LD	L,A
	JR	NC,_strtod_noc1
	INC	H
	JR	NZ,_strtod_noc1
	INC	DE
_strtod_noc1:
	; Store back
	LD	(_strtod_intacc),HL
	LD	(_strtod_intacc+2),DE
	POP	HL
	INC	HL
	JR	_strtod_intloop

_strtod_intdone:
	; Check for decimal point
	LD	A,(HL)
	CP	'.'
	JR	NZ,_strtod_chkexp

	INC	HL		; Skip decimal point
	; Parse fractional part
	LD	DE,1		; Divisor starts at 1
	LD	(_strtod_divisor),DE
	LD	DE,0
	LD	(_strtod_divisor+2),DE
	XOR	A
	LD	(_strtod_fracacc),A
	LD	(_strtod_fracacc+1),A
	LD	(_strtod_fracacc+2),A
	LD	(_strtod_fracacc+3),A

_strtod_fracloop:
	LD	A,(HL)
	CP	'0'
	JR	C,_strtod_fracdone
	CP	'9'+1
	JR	NC,_strtod_fracdone
	; Got a fractional digit
	LD	B,1
	LD	(_strtod_gotdigit),A
	SUB	'0'
	LD	C,A

	; Multiply divisor by 10
	PUSH	HL
	PUSH	BC
	LD	HL,(_strtod_divisor)
	LD	DE,(_strtod_divisor+2)
	; *10 (same as above)
	PUSH	DE
	PUSH	HL
	ADD	HL,HL
	RL	E
	RL	D
	ADD	HL,HL
	RL	E
	RL	D
	POP	BC
	EX	(SP),HL
	ADD	HL,BC
	EX	DE,HL
	POP	BC
	LD	A,H
	ADC	A,C
	LD	H,A
	LD	A,L
	ADC	A,B
	LD	L,A
	EX	DE,HL
	LD	(_strtod_divisor),HL
	LD	(_strtod_divisor+2),DE

	; Multiply fracacc by 10 and add digit
	LD	HL,(_strtod_fracacc)
	LD	DE,(_strtod_fracacc+2)
	PUSH	DE
	PUSH	HL
	ADD	HL,HL
	RL	E
	RL	D
	ADD	HL,HL
	RL	E
	RL	D
	POP	BC
	EX	(SP),HL
	ADD	HL,BC
	EX	DE,HL
	POP	BC
	LD	A,H
	ADC	A,C
	LD	H,A
	LD	A,L
	ADC	A,B
	LD	L,A
	EX	DE,HL
	; Add digit
	POP	BC
	LD	A,L
	ADD	A,C
	LD	L,A
	JR	NC,_strtod_noc2
	INC	H
	JR	NZ,_strtod_noc2
	INC	DE
_strtod_noc2:
	LD	(_strtod_fracacc),HL
	LD	(_strtod_fracacc+2),DE
	POP	HL
	INC	HL
	JR	_strtod_fracloop

_strtod_fracdone:

_strtod_chkexp:
	; Check for exponent
	LD	A,(HL)
	CP	'e'
	JR	Z,_strtod_parseexp
	CP	'E'
	JR	Z,_strtod_parseexp
	JR	_strtod_convert

_strtod_parseexp:
	INC	HL		; Skip 'e'
	XOR	A
	LD	(_strtod_expneg),A
	LD	(_strtod_exp),A
	LD	(_strtod_exp+1),A

	LD	A,(HL)
	CP	'-'
	JR	NZ,_strtod_expplus
	LD	A,1
	LD	(_strtod_expneg),A
	INC	HL
	JR	_strtod_expdigits
_strtod_expplus:
	CP	'+'
	JR	NZ,_strtod_expdigits
	INC	HL

_strtod_expdigits:
	LD	A,(HL)
	CP	'0'
	JR	C,_strtod_convert
	CP	'9'+1
	JR	NC,_strtod_convert
	SUB	'0'
	LD	C,A
	; exp = exp * 10 + digit
	PUSH	HL
	LD	HL,(_strtod_exp)
	LD	D,H
	LD	E,L
	ADD	HL,HL		; *2
	ADD	HL,HL		; *4
	ADD	HL,DE		; *5
	ADD	HL,HL		; *10
	LD	D,0
	LD	E,C
	ADD	HL,DE
	LD	(_strtod_exp),HL
	POP	HL
	INC	HL
	JR	_strtod_expdigits

_strtod_convert:
	; Save end position
	EX	(SP),HL		; HL = start, (SP) = end

	; Check if we got any digits
	LD	A,(_strtod_gotdigit)
	OR	A
	JR	NZ,_strtod_hasdigits
	; No digits - return 0.0 with endptr = nptr
	POP	HL		; Discard end
	; HL = start (nptr)
	JR	_strtod_storendptr

_strtod_hasdigits:
	POP	HL		; HL = end position
	PUSH	HL		; Save it back

	; Convert integer part to float
	PUSH	HL
	LD	HL,(_strtod_intacc)
	LD	DE,(_strtod_intacc+2)
	CALL	__ltof		; Convert long to float
	LD	(_strtod_result),HL
	LD	(_strtod_result+2),DE
	POP	HL

	; Add fractional part if any
	LD	A,(_strtod_divisor)
	DEC	A
	OR	A
	JR	NZ,_strtod_addfrac
	LD	A,(_strtod_divisor+1)
	OR	A
	JR	NZ,_strtod_addfrac
	LD	A,(_strtod_divisor+2)
	OR	A
	JR	NZ,_strtod_addfrac
	LD	A,(_strtod_divisor+3)
	OR	A
	JR	Z,_strtod_applyexp

_strtod_addfrac:
	; Convert fracacc to float
	PUSH	HL
	LD	HL,(_strtod_fracacc)
	LD	DE,(_strtod_fracacc+2)
	CALL	__ltof
	; Divide by divisor
	LD	(_strtod_tmp),HL
	LD	(_strtod_tmp+2),DE
	LD	HL,(_strtod_divisor)
	LD	DE,(_strtod_divisor+2)
	CALL	__ltof
	LD	(__tmp32),HL
	LD	(__tmp32+2),DE
	LD	HL,(_strtod_tmp)
	LD	DE,(_strtod_tmp+2)
	CALL	__fdiv
	; Add to result
	LD	(__tmp32),HL
	LD	(__tmp32+2),DE
	LD	HL,(_strtod_result)
	LD	DE,(_strtod_result+2)
	CALL	__fadd
	LD	(_strtod_result),HL
	LD	(_strtod_result+2),DE
	POP	HL

_strtod_applyexp:
	; Apply exponent if any
	LD	DE,(_strtod_exp)
	LD	A,D
	OR	E
	JR	Z,_strtod_applysign

	; Build 10^exp
	PUSH	HL
	LD	HL,(_strtod_result)
	LD	DE,(_strtod_result+2)
	LD	BC,(_strtod_exp)

_strtod_exploop:
	LD	A,B
	OR	C
	JR	Z,_strtod_expdone
	; Multiply or divide by 10
	LD	A,(_strtod_expneg)
	OR	A
	JR	NZ,_strtod_expdiv

	; Multiply by 10
	PUSH	BC
	LD	BC,00004120H	; 10.0 in IEEE 754
	LD	(__tmp32),BC
	LD	BC,00000000H
	LD	(__tmp32+2),BC
	CALL	__fmul
	POP	BC
	DEC	BC
	JR	_strtod_exploop

_strtod_expdiv:
	; Divide by 10
	PUSH	BC
	LD	BC,00004120H	; 10.0 in IEEE 754
	LD	(__tmp32),BC
	LD	BC,00000000H
	LD	(__tmp32+2),BC
	CALL	__fdiv
	POP	BC
	DEC	BC
	JR	_strtod_exploop

_strtod_expdone:
	LD	(_strtod_result),HL
	LD	(_strtod_result+2),DE
	POP	HL

_strtod_applysign:
	; Apply negative sign if needed
	LD	A,(_strtod_neg)
	OR	A
	JR	Z,_strtod_storendptr

	; Negate: flip sign bit
	LD	HL,(_strtod_result+2)
	LD	A,H
	XOR	80H
	LD	H,A
	LD	(_strtod_result+2),HL

_strtod_storendptr:
	; Store endptr if not NULL
	POP	HL		; HL = end position
	LD	C,(IX+6)
	LD	B,(IX+7)	; BC = endptr
	LD	A,B
	OR	C
	JR	Z,_strtod_retval
	; Store HL at *endptr
	LD	A,L
	LD	(BC),A
	INC	BC
	LD	A,H
	LD	(BC),A

_strtod_retval:
	LD	HL,(_strtod_result)
	LD	DE,(_strtod_result+2)
	POP	BC
	POP	IX
	RET

	EXTRN	__ltof
	EXTRN	__fadd
	EXTRN	__fsub
	EXTRN	__fmul
	EXTRN	__fdiv
	EXTRN	__tmp32

; strtod work variables
_strtod_neg:	DB	0
_strtod_expneg:	DB	0
_strtod_gotdigit: DB	0
_strtod_exp:	DW	0
_strtod_expadj:	DW	1
_strtod_intacc:	DS	4
_strtod_fracacc: DS	4
_strtod_divisor: DS	4
_strtod_result:	DS	4
_strtod_tmp:	DS	4

; ============================================================
; Multibyte/Wide Character Conversion Functions
; Minimal implementation for C locale (1:1 char mapping)
; ============================================================

; int mblen(const char *s, size_t n)
; Determine bytes in multibyte character


; ============================================================
; lc_atoi.mac
; ============================================================
	CSEG
; lc_atoi.mac - string to integer conversion


	CSEG

; ============================================================
; int atoi(const char *nptr)
; Convert string to integer
; Handles optional leading whitespace and sign
; ============================================================
	PUBLIC	_atoi
_atoi:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP

	LD	L,(IX+4)	; HL = string pointer
	LD	H,(IX+5)

	; Skip leading whitespace
_atoi_skip:
	LD	A,(HL)
	CP	' '
	JR	Z,_atoi_skipnext
	CP	09H		; tab
	JR	Z,_atoi_skipnext
	CP	0AH		; newline
	JR	Z,_atoi_skipnext
	CP	0DH		; carriage return
	JR	Z,_atoi_skipnext
	JR	_atoi_sign
_atoi_skipnext:
	INC	HL
	JR	_atoi_skip

_atoi_sign:
	LD	C,0		; C = sign flag (0=positive)
	LD	A,(HL)
	CP	'-'
	JR	NZ,_atoi_chkplus
	LD	C,1		; Negative
	INC	HL
	JR	_atoi_digits
_atoi_chkplus:
	CP	'+'
	JR	NZ,_atoi_digits
	INC	HL

_atoi_digits:
	; DE = accumulator (result)
	LD	DE,0

_atoi_loop:
	LD	A,(HL)
	SUB	'0'
	JR	C,_atoi_done	; < '0'
	CP	10
	JR	NC,_atoi_done	; > '9'

	; DE = DE * 10 + digit
	PUSH	HL
	PUSH	BC
	PUSH	AF		; Save digit

	; DE * 10 = DE * 8 + DE * 2
	LD	H,D
	LD	L,E		; HL = DE
	ADD	HL,HL		; HL = DE * 2
	LD	B,H
	LD	C,L		; BC = DE * 2
	ADD	HL,HL		; HL = DE * 4
	ADD	HL,HL		; HL = DE * 8
	ADD	HL,BC		; HL = DE * 10
	EX	DE,HL		; DE = DE * 10

	POP	AF		; Get digit back
	LD	L,A
	LD	H,0
	ADD	HL,DE		; HL = DE * 10 + digit
	EX	DE,HL		; DE = result

	POP	BC
	POP	HL
	INC	HL
	JR	_atoi_loop

_atoi_done:
	; Apply sign
	LD	H,D
	LD	L,E		; HL = result
	LD	A,C
	OR	A
	JR	Z,_atoi_ret
	; Negate: 0 - HL
	EX	DE,HL
	LD	HL,0
	OR	A
	SBC	HL,DE

_atoi_ret:
	POP	IX
	RET

; ============================================================
; long atol(const char *nptr)
; Convert string to long (32-bit)
; Returns result in DEHL
; ============================================================
	PUBLIC	_atol
_atol:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	PUSH	BC

	LD	L,(IX+4)	; HL = string pointer
	LD	H,(IX+5)

	; Skip leading whitespace
_atol_skip:
	LD	A,(HL)
	CP	' '
	JR	Z,_atol_skipnext
	CP	09H
	JR	Z,_atol_skipnext
	CP	0AH
	JR	Z,_atol_skipnext
	CP	0DH
	JR	Z,_atol_skipnext
	JR	_atol_sign
_atol_skipnext:
	INC	HL
	JR	_atol_skip

_atol_sign:
	LD	C,0		; C = sign flag
	LD	A,(HL)
	CP	'-'
	JR	NZ,_atol_chkplus
	LD	C,1
	INC	HL
	JR	_atol_digits
_atol_chkplus:
	CP	'+'
	JR	NZ,_atol_digits
	INC	HL

_atol_digits:
	; Result in __atol_acc (32-bit)
	XOR	A
	LD	(_atol_acc),A
	LD	(_atol_acc+1),A
	LD	(_atol_acc+2),A
	LD	(_atol_acc+3),A

_atol_loop:
	LD	A,(HL)
	SUB	'0'
	JR	C,_atol_done
	CP	10
	JR	NC,_atol_done

	; acc = acc * 10 + digit
	PUSH	HL
	PUSH	BC
	PUSH	AF		; Save digit

	; Multiply acc by 10 using shifts: x*10 = x*8 + x*2
	; First, copy acc to tmp
	LD	HL,(_atol_acc)
	LD	(_atol_tmp),HL
	LD	HL,(_atol_acc+2)
	LD	(_atol_tmp+2),HL

	; acc = acc * 2
	LD	HL,(_atol_acc)
	ADD	HL,HL
	LD	(_atol_acc),HL
	LD	HL,(_atol_acc+2)
	ADC	HL,HL
	LD	(_atol_acc+2),HL

	; tmp = tmp * 8 (shift left 3 more times = total 4)
	; Actually: acc*2 already done, so tmp*8 means shift tmp left 3 times
	LD	B,3
_atol_shift8:
	LD	HL,(_atol_tmp)
	ADD	HL,HL
	LD	(_atol_tmp),HL
	LD	HL,(_atol_tmp+2)
	ADC	HL,HL
	LD	(_atol_tmp+2),HL
	DJNZ	_atol_shift8

	; acc = acc + tmp (acc*2 + acc*8 = acc*10)
	LD	HL,(_atol_acc)
	LD	DE,(_atol_tmp)
	ADD	HL,DE
	LD	(_atol_acc),HL
	LD	HL,(_atol_acc+2)
	LD	DE,(_atol_tmp+2)
	ADC	HL,DE
	LD	(_atol_acc+2),HL

	; Add digit
	POP	AF
	LD	E,A
	LD	D,0
	LD	HL,(_atol_acc)
	ADD	HL,DE
	LD	(_atol_acc),HL
	JR	NC,_atol_noc
	LD	HL,(_atol_acc+2)
	INC	HL
	LD	(_atol_acc+2),HL
_atol_noc:
	POP	BC
	POP	HL
	INC	HL
	JR	_atol_loop

_atol_done:
	; Load result into DEHL
	LD	HL,(_atol_acc)
	LD	DE,(_atol_acc+2)

	; Apply sign
	LD	A,C
	OR	A
	JR	Z,_atol_ret

	; Negate DEHL
	PUSH	BC
	LD	BC,0
	LD	A,C
	SUB	L
	LD	L,A
	LD	A,C
	SBC	A,H
	LD	H,A
	LD	A,C
	SBC	A,E
	LD	E,A
	LD	A,C
	SBC	A,D
	LD	D,A
	POP	BC

_atol_ret:
	POP	BC
	POP	IX
	RET

; ============================================================
; long strtol(const char *nptr, char **endptr, int base)
; Convert string to long (32-bit signed)
; Supports base 0 (auto-detect), 8, 10, 16
; Returns result in DEHL
; ============================================================
	PUBLIC	_strtol
_strtol:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	PUSH	BC

	LD	L,(IX+4)	; HL = nptr
	LD	H,(IX+5)
	LD	A,(IX+8)	; A = base (low byte only matters)
	LD	(_strtol_base),A
	XOR	A
	LD	(_strtol_neg),A	; Clear negative flag

	; Skip leading whitespace
_strtol_skip:
	LD	A,(HL)
	CP	' '
	JR	Z,_strtol_skipnext
	CP	09H
	JR	Z,_strtol_skipnext
	CP	0AH
	JR	Z,_strtol_skipnext
	CP	0DH
	JR	Z,_strtol_skipnext
	JR	_strtol_sign
_strtol_skipnext:
	INC	HL
	JR	_strtol_skip

_strtol_sign:
	LD	A,(HL)
	CP	'-'
	JR	NZ,_strtol_chkplus
	LD	A,1
	LD	(_strtol_neg),A
	INC	HL
	JR	_strtol_prefix
_strtol_chkplus:
	CP	'+'
	JR	NZ,_strtol_prefix
	INC	HL

_strtol_prefix:
	; Check for 0x or 0 prefix if base==0 or base==16/8
	LD	A,(_strtol_base)
	OR	A
	JR	Z,_strtol_auto	; Auto-detect base
	CP	16
	JR	Z,_strtol_chk0x
	JR	_strtol_init

_strtol_auto:
	LD	A,(HL)
	CP	'0'
	JR	NZ,_strtol_base10
	INC	HL
	LD	A,(HL)
	CP	'x'
	JR	Z,_strtol_hexauto
	CP	'X'
	JR	Z,_strtol_hexauto
	; Octal
	DEC	HL
	LD	A,8
	LD	(_strtol_base),A
	JR	_strtol_init

_strtol_hexauto:
	INC	HL		; Skip 'x'
	LD	A,16
	LD	(_strtol_base),A
	JR	_strtol_init

_strtol_base10:
	LD	A,10
	LD	(_strtol_base),A
	JR	_strtol_init

_strtol_chk0x:
	; For explicit base 16, skip optional 0x prefix
	LD	A,(HL)
	CP	'0'
	JR	NZ,_strtol_init
	INC	HL
	LD	A,(HL)
	CP	'x'
	JR	Z,_strtol_skip0x
	CP	'X'
	JR	Z,_strtol_skip0x
	DEC	HL
	JR	_strtol_init
_strtol_skip0x:
	INC	HL

_strtol_init:
	; Initialize result to 0
	XOR	A
	LD	(_strtol_acc),A
	LD	(_strtol_acc+1),A
	LD	(_strtol_acc+2),A
	LD	(_strtol_acc+3),A

_strtol_loop:
	LD	A,(HL)
	; Convert digit
	CP	'0'
	JR	C,_strtol_done
	CP	'9'+1
	JR	C,_strtol_digit
	; Check for hex digits
	CP	'A'
	JR	C,_strtol_done
	CP	'Z'+1
	JR	C,_strtol_upper
	CP	'a'
	JR	C,_strtol_done
	CP	'z'+1
	JR	NC,_strtol_done
	SUB	'a'-10
	JR	_strtol_gotdig

_strtol_upper:
	SUB	'A'-10
	JR	_strtol_gotdig

_strtol_digit:
	SUB	'0'

_strtol_gotdig:
	; A = digit value, check against base
	LD	B,A
	LD	A,(_strtol_base)
	CP	B
	JR	C,_strtol_done	; digit >= base
	JR	Z,_strtol_done	; digit >= base
	LD	A,B

	; acc = acc * base + digit
	PUSH	HL
	PUSH	AF		; Save digit

	; Multiply acc by base
	LD	A,(_strtol_base)
	CALL	_strtol_mult

	; Add digit
	POP	AF
	LD	E,A
	LD	D,0
	LD	HL,(_strtol_acc)
	ADD	HL,DE
	LD	(_strtol_acc),HL
	JR	NC,_strtol_noc
	LD	HL,(_strtol_acc+2)
	INC	HL
	LD	(_strtol_acc+2),HL
_strtol_noc:
	POP	HL
	INC	HL
	JR	_strtol_loop

_strtol_done:
	; Save end pointer if endptr != NULL
	LD	E,(IX+6)	; DE = endptr
	LD	D,(IX+7)
	LD	A,D
	OR	E
	JR	Z,_strtol_noend
	; *endptr = HL
	EX	DE,HL
	LD	(HL),E
	INC	HL
	LD	(HL),D
_strtol_noend:

	; Load result into DEHL
	LD	HL,(_strtol_acc)
	LD	DE,(_strtol_acc+2)

	; Apply sign
	LD	A,(_strtol_neg)
	OR	A
	JR	Z,_strtol_ret

	; Negate DEHL
	PUSH	BC
	LD	BC,0
	LD	A,C
	SUB	L
	LD	L,A
	LD	A,C
	SBC	A,H
	LD	H,A
	LD	A,C
	SBC	A,E
	LD	E,A
	LD	A,C
	SBC	A,D
	LD	D,A
	POP	BC

_strtol_ret:
	POP	BC
	POP	IX
	RET

; Internal: multiply _strtol_acc by A
_strtol_mult:
	PUSH	BC
	LD	B,A		; B = multiplier

	; Copy acc to tmp
	LD	HL,(_strtol_acc)
	LD	(_strtol_tmp),HL
	LD	HL,(_strtol_acc+2)
	LD	(_strtol_tmp+2),HL

	; Clear acc
	XOR	A
	LD	(_strtol_acc),A
	LD	(_strtol_acc+1),A
	LD	(_strtol_acc+2),A
	LD	(_strtol_acc+3),A

	; Multiply by shifts and adds
_strtol_mult_loop:
	LD	A,B
	OR	A
	JR	Z,_strtol_mult_done
	RRA			; Carry = LSB
	LD	B,A
	JR	NC,_strtol_mult_shift

	; Add tmp to acc
	LD	HL,(_strtol_acc)
	LD	DE,(_strtol_tmp)
	ADD	HL,DE
	LD	(_strtol_acc),HL
	LD	HL,(_strtol_acc+2)
	LD	DE,(_strtol_tmp+2)
	ADC	HL,DE
	LD	(_strtol_acc+2),HL

_strtol_mult_shift:
	; tmp = tmp * 2
	LD	HL,(_strtol_tmp)
	ADD	HL,HL
	LD	(_strtol_tmp),HL
	LD	HL,(_strtol_tmp+2)
	ADC	HL,HL
	LD	(_strtol_tmp+2),HL
	JR	_strtol_mult_loop

_strtol_mult_done:
	POP	BC
	RET

; ============================================================
; unsigned long strtoul(const char *nptr, char **endptr, int base)
; Convert string to unsigned long (32-bit)
; Same as strtol but ignores minus sign
; ============================================================
	PUBLIC	_strtoul
_strtoul:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	PUSH	BC

	LD	L,(IX+4)	; HL = nptr
	LD	H,(IX+5)
	LD	A,(IX+8)	; A = base
	LD	(_strtol_base),A
	XOR	A
	LD	(_strtol_neg),A	; Always unsigned

	; Skip leading whitespace
_strtoul_skip:
	LD	A,(HL)
	CP	' '
	JR	Z,_strtoul_skipnext
	CP	09H
	JR	Z,_strtoul_skipnext
	CP	0AH
	JR	Z,_strtoul_skipnext
	CP	0DH
	JR	Z,_strtoul_skipnext
	JR	_strtoul_sign
_strtoul_skipnext:
	INC	HL
	JR	_strtoul_skip

_strtoul_sign:
	; Skip optional + sign, ignore - sign
	LD	A,(HL)
	CP	'+'
	JR	NZ,_strtoul_pref
	INC	HL

_strtoul_pref:
	JP	_strtol_prefix	; Share the rest of strtol code

	DSEG

; atol working storage
_atol_acc:	DS	4
_atol_tmp:	DS	4

; strtol working storage
_strtol_acc:	DS	4
_strtol_tmp:	DS	4
_strtol_base:	DS	1
_strtol_neg:	DS	1


; ============================================================
; lc_atomic.mac
; ============================================================
	CSEG
; lc_atomic.mac - atomic operations


	CSEG

	PUBLIC	_atomic_flag_test_and_set
	PUBLIC	_atomic_flag_test_and_set_explicit
_atomic_flag_test_and_set_explicit:
_atomic_flag_test_and_set:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP

	LD	L,(IX+4)
	LD	H,(IX+5)	; HL = obj

	DI
	LD	A,(HL)		; Get current value
	LD	E,A		; Save for return
	LD	(HL),1		; Set flag
	EI

	LD	L,E
	LD	H,0		; Return old value
	POP	IX
	RET

; void atomic_flag_clear(volatile atomic_flag *obj)
	PUBLIC	_atomic_flag_clear
	PUBLIC	_atomic_flag_clear_explicit
_atomic_flag_clear_explicit:
_atomic_flag_clear:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP

	LD	L,(IX+4)
	LD	H,(IX+5)

	DI
	LD	(HL),0		; Clear flag
	EI

	POP	IX
	RET

; ============================================================
; 1-byte atomic operations
; ============================================================

; void __atomic_store_1(volatile void *obj, unsigned char val)
	PUBLIC	___atomic_store_1
___atomic_store_1:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP

	LD	L,(IX+4)
	LD	H,(IX+5)	; HL = obj
	LD	A,(IX+6)	; val

	DI
	LD	(HL),A
	EI

	POP	IX
	RET

; unsigned char __atomic_load_1(volatile void *obj)
	PUBLIC	___atomic_load_1
___atomic_load_1:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP

	LD	L,(IX+4)
	LD	H,(IX+5)

	DI
	LD	A,(HL)
	EI

	LD	L,A
	LD	H,0
	POP	IX
	RET

; unsigned char __atomic_exchange_1(volatile void *obj, unsigned char val)
	PUBLIC	___atomic_exchange_1
___atomic_exchange_1:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP

	LD	L,(IX+4)
	LD	H,(IX+5)
	LD	A,(IX+6)

	DI
	LD	E,(HL)		; Get old value
	LD	(HL),A		; Store new value
	EI

	LD	L,E
	LD	H,0
	POP	IX
	RET

; _Bool __atomic_compare_exchange_1(volatile void *obj, void *expected, unsigned char desired)
	PUBLIC	___atomic_compare_exchange_1
___atomic_compare_exchange_1:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP

	LD	L,(IX+4)
	LD	H,(IX+5)	; obj
	LD	E,(IX+6)
	LD	D,(IX+7)	; expected
	LD	A,(IX+8)	; desired

	DI
	LD	C,(HL)		; Current value
	PUSH	DE
	EX	DE,HL
	LD	B,(HL)		; Expected value
	EX	DE,HL
	POP	DE
	LD	A,C
	CP	B		; Compare
	JR	NZ,_cmpxchg1_fail

	; Equal - store desired
	LD	A,(IX+8)
	LD	(HL),A
	EI
	LD	HL,1
	POP	IX
	RET

_cmpxchg1_fail:
	; Not equal - store current in *expected
	LD	A,C
	LD	(DE),A
	EI
	LD	HL,0
	POP	IX
	RET

; unsigned char __atomic_fetch_add_1(volatile void *obj, unsigned char val)
	PUBLIC	___atomic_fetch_add_1
___atomic_fetch_add_1:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP

	LD	L,(IX+4)
	LD	H,(IX+5)
	LD	A,(IX+6)
	LD	C,A		; C = val

	DI
	LD	A,(HL)		; Get old value
	LD	E,A		; Save for return
	ADD	A,C		; Add
	LD	(HL),A		; Store result
	EI

	LD	L,E
	LD	H,0
	POP	IX
	RET

; unsigned char __atomic_fetch_sub_1(volatile void *obj, unsigned char val)
	PUBLIC	___atomic_fetch_sub_1
___atomic_fetch_sub_1:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP

	LD	L,(IX+4)
	LD	H,(IX+5)
	LD	A,(IX+6)
	LD	C,A

	DI
	LD	A,(HL)
	LD	E,A
	SUB	C
	LD	(HL),A
	EI

	LD	L,E
	LD	H,0
	POP	IX
	RET

; unsigned char __atomic_fetch_or_1(volatile void *obj, unsigned char val)
	PUBLIC	___atomic_fetch_or_1
___atomic_fetch_or_1:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP

	LD	L,(IX+4)
	LD	H,(IX+5)
	LD	A,(IX+6)
	LD	C,A

	DI
	LD	A,(HL)
	LD	E,A
	OR	C
	LD	(HL),A
	EI

	LD	L,E
	LD	H,0
	POP	IX
	RET

; unsigned char __atomic_fetch_xor_1(volatile void *obj, unsigned char val)
	PUBLIC	___atomic_fetch_xor_1
___atomic_fetch_xor_1:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP

	LD	L,(IX+4)
	LD	H,(IX+5)
	LD	A,(IX+6)
	LD	C,A

	DI
	LD	A,(HL)
	LD	E,A
	XOR	C
	LD	(HL),A
	EI

	LD	L,E
	LD	H,0
	POP	IX
	RET

; unsigned char __atomic_fetch_and_1(volatile void *obj, unsigned char val)
	PUBLIC	___atomic_fetch_and_1
___atomic_fetch_and_1:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP

	LD	L,(IX+4)
	LD	H,(IX+5)
	LD	A,(IX+6)
	LD	C,A

	DI
	LD	A,(HL)
	LD	E,A
	AND	C
	LD	(HL),A
	EI

	LD	L,E
	LD	H,0
	POP	IX
	RET

; ============================================================
; 2-byte atomic operations
; ============================================================

; void __atomic_store_2(volatile void *obj, unsigned int val)
	PUBLIC	___atomic_store_2
___atomic_store_2:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP

	LD	L,(IX+4)
	LD	H,(IX+5)	; obj
	LD	E,(IX+6)
	LD	D,(IX+7)	; val

	DI
	LD	(HL),E
	INC	HL
	LD	(HL),D
	EI

	POP	IX
	RET

; unsigned int __atomic_load_2(volatile void *obj)
	PUBLIC	___atomic_load_2
___atomic_load_2:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP

	LD	L,(IX+4)
	LD	H,(IX+5)

	DI
	LD	E,(HL)
	INC	HL
	LD	D,(HL)
	EI

	EX	DE,HL
	POP	IX
	RET

; unsigned int __atomic_exchange_2(volatile void *obj, unsigned int val)
	PUBLIC	___atomic_exchange_2
___atomic_exchange_2:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	PUSH	BC

	LD	L,(IX+4)
	LD	H,(IX+5)	; obj
	LD	E,(IX+6)
	LD	D,(IX+7)	; val

	DI
	LD	C,(HL)
	INC	HL
	LD	B,(HL)		; BC = old value
	LD	(HL),D
	DEC	HL
	LD	(HL),E		; Store new
	EI

	LD	H,B
	LD	L,C
	POP	BC
	POP	IX
	RET

; _Bool __atomic_compare_exchange_2(volatile void *obj, void *expected, unsigned int desired)
	PUBLIC	___atomic_compare_exchange_2
___atomic_compare_exchange_2:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	PUSH	BC

	LD	L,(IX+4)
	LD	H,(IX+5)	; obj

	DI
	LD	C,(HL)
	INC	HL
	LD	B,(HL)		; BC = current value
	DEC	HL

	; Get expected
	PUSH	HL
	LD	L,(IX+6)
	LD	H,(IX+7)	; expected ptr
	LD	E,(HL)
	INC	HL
	LD	D,(HL)		; DE = expected
	POP	HL

	; Compare BC with DE
	LD	A,C
	CP	E
	JR	NZ,_cmpxchg2_fail
	LD	A,B
	CP	D
	JR	NZ,_cmpxchg2_fail

	; Equal - store desired
	LD	E,(IX+8)
	LD	D,(IX+9)
	LD	(HL),E
	INC	HL
	LD	(HL),D
	EI
	LD	HL,1
	POP	BC
	POP	IX
	RET

_cmpxchg2_fail:
	; Store current in *expected
	PUSH	HL
	LD	L,(IX+6)
	LD	H,(IX+7)
	LD	(HL),C
	INC	HL
	LD	(HL),B
	POP	HL
	EI
	LD	HL,0
	POP	BC
	POP	IX
	RET

; unsigned int __atomic_fetch_add_2(volatile void *obj, unsigned int val)
	PUBLIC	___atomic_fetch_add_2
___atomic_fetch_add_2:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	PUSH	BC

	LD	L,(IX+4)
	LD	H,(IX+5)	; obj

	DI
	LD	E,(HL)
	INC	HL
	LD	D,(HL)		; DE = old value
	DEC	HL
	PUSH	DE		; Save old

	LD	C,(IX+6)
	LD	B,(IX+7)	; BC = val
	EX	DE,HL
	ADD	HL,BC		; HL = old + val
	EX	DE,HL		; DE = result

	LD	L,(IX+4)
	LD	H,(IX+5)
	LD	(HL),E
	INC	HL
	LD	(HL),D
	EI

	POP	HL		; Return old value
	POP	BC
	POP	IX
	RET

; unsigned int __atomic_fetch_sub_2(volatile void *obj, unsigned int val)
	PUBLIC	___atomic_fetch_sub_2
___atomic_fetch_sub_2:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	PUSH	BC

	LD	L,(IX+4)
	LD	H,(IX+5)

	DI
	LD	E,(HL)
	INC	HL
	LD	D,(HL)		; DE = old
	DEC	HL
	PUSH	DE

	LD	C,(IX+6)
	LD	B,(IX+7)
	EX	DE,HL
	OR	A
	SBC	HL,BC		; HL = old - val
	EX	DE,HL

	LD	L,(IX+4)
	LD	H,(IX+5)
	LD	(HL),E
	INC	HL
	LD	(HL),D
	EI

	POP	HL
	POP	BC
	POP	IX
	RET

; unsigned int __atomic_fetch_or_2(volatile void *obj, unsigned int val)
	PUBLIC	___atomic_fetch_or_2
___atomic_fetch_or_2:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	PUSH	BC

	LD	L,(IX+4)
	LD	H,(IX+5)

	DI
	LD	E,(HL)
	INC	HL
	LD	D,(HL)
	DEC	HL
	PUSH	DE		; Save old

	LD	A,E
	OR	(IX+6)
	LD	E,A
	LD	A,D
	OR	(IX+7)
	LD	D,A

	LD	(HL),E
	INC	HL
	LD	(HL),D
	EI

	POP	HL
	POP	BC
	POP	IX
	RET

; unsigned int __atomic_fetch_xor_2(volatile void *obj, unsigned int val)
	PUBLIC	___atomic_fetch_xor_2
___atomic_fetch_xor_2:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	PUSH	BC

	LD	L,(IX+4)
	LD	H,(IX+5)

	DI
	LD	E,(HL)
	INC	HL
	LD	D,(HL)
	DEC	HL
	PUSH	DE

	LD	A,E
	XOR	(IX+6)
	LD	E,A
	LD	A,D
	XOR	(IX+7)
	LD	D,A

	LD	(HL),E
	INC	HL
	LD	(HL),D
	EI

	POP	HL
	POP	BC
	POP	IX
	RET

; unsigned int __atomic_fetch_and_2(volatile void *obj, unsigned int val)
	PUBLIC	___atomic_fetch_and_2
___atomic_fetch_and_2:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	PUSH	BC

	LD	L,(IX+4)
	LD	H,(IX+5)

	DI
	LD	E,(HL)
	INC	HL
	LD	D,(HL)
	DEC	HL
	PUSH	DE

	LD	A,E
	AND	(IX+6)
	LD	E,A
	LD	A,D
	AND	(IX+7)
	LD	D,A

	LD	(HL),E
	INC	HL
	LD	(HL),D
	EI

	POP	HL
	POP	BC
	POP	IX
	RET

; ============================================================
; 4-byte atomic operations (for long)
; ============================================================

; void __atomic_store_4(volatile void *obj, unsigned long val)
	PUBLIC	___atomic_store_4
___atomic_store_4:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP

	LD	L,(IX+4)
	LD	H,(IX+5)	; obj

	DI
	LD	A,(IX+6)
	LD	(HL),A
	INC	HL
	LD	A,(IX+7)
	LD	(HL),A
	INC	HL
	LD	A,(IX+8)
	LD	(HL),A
	INC	HL
	LD	A,(IX+9)
	LD	(HL),A
	EI

	POP	IX
	RET

; unsigned long __atomic_load_4(volatile void *obj)
	PUBLIC	___atomic_load_4
___atomic_load_4:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP

	LD	L,(IX+4)
	LD	H,(IX+5)

	DI
	LD	E,(HL)
	INC	HL
	LD	D,(HL)
	INC	HL
	LD	C,(HL)
	INC	HL
	LD	B,(HL)
	EI

	; Return DEHL for long
	LD	L,E
	LD	H,D
	LD	E,C
	LD	D,B
	POP	IX
	RET

; unsigned long __atomic_exchange_4(volatile void *obj, unsigned long val)
	PUBLIC	___atomic_exchange_4
___atomic_exchange_4:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	PUSH	BC

	LD	L,(IX+4)
	LD	H,(IX+5)	; obj

	DI
	; Read old value
	LD	E,(HL)
	INC	HL
	LD	D,(HL)
	INC	HL
	LD	C,(HL)
	INC	HL
	LD	B,(HL)		; BCDE = old
	; Store new value
	LD	A,(IX+9)
	LD	(HL),A
	DEC	HL
	LD	A,(IX+8)
	LD	(HL),A
	DEC	HL
	LD	A,(IX+7)
	LD	(HL),A
	DEC	HL
	LD	A,(IX+6)
	LD	(HL),A
	EI

	; Return old in DEHL
	LD	L,E
	LD	H,D
	LD	E,C
	LD	D,B
	POP	BC
	POP	IX
	RET

; _Bool __atomic_compare_exchange_4(volatile void *obj, void *expected, unsigned long desired)
	PUBLIC	___atomic_compare_exchange_4
___atomic_compare_exchange_4:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	PUSH	BC

	LD	L,(IX+4)
	LD	H,(IX+5)	; obj

	DI
	; Load current value into stack temp area
	PUSH	HL
	LD	E,(HL)
	INC	HL
	LD	D,(HL)
	INC	HL
	LD	C,(HL)
	INC	HL
	LD	B,(HL)		; BCDE = current
	POP	HL

	; Load expected
	PUSH	HL
	PUSH	BC
	PUSH	DE
	LD	L,(IX+6)
	LD	H,(IX+7)	; expected ptr
	LD	E,(HL)
	INC	HL
	LD	D,(HL)
	INC	HL
	LD	C,(HL)
	INC	HL
	LD	B,(HL)		; BCDE = expected

	; Compare (stack has current)
	POP	HL		; current low
	LD	A,L
	CP	E
	JR	NZ,_cmpxchg4_fail
	LD	A,H
	CP	D
	JR	NZ,_cmpxchg4_fail
	POP	HL		; current high
	LD	A,L
	CP	C
	JR	NZ,_cmpxchg4_f2
	LD	A,H
	CP	B
	JR	NZ,_cmpxchg4_f2

	; Equal - store desired
	POP	HL		; obj
	LD	A,(IX+10)
	LD	(HL),A
	INC	HL
	LD	A,(IX+11)
	LD	(HL),A
	INC	HL
	LD	A,(IX+12)
	LD	(HL),A
	INC	HL
	LD	A,(IX+13)
	LD	(HL),A
	EI
	LD	HL,1
	POP	BC
	POP	IX
	RET

_cmpxchg4_f2:
	PUSH	HL		; Push back to balance stack
_cmpxchg4_fail:
	; Store current in *expected
	POP	DE		; current high (or junk)
	POP	HL		; current low (or high if came from f2)
	; This is getting complex, let me simplify...
	; Just re-read and store
	POP	HL		; obj
	PUSH	HL
	LD	E,(HL)
	INC	HL
	LD	D,(HL)
	INC	HL
	LD	C,(HL)
	INC	HL
	LD	B,(HL)		; BCDE = current
	LD	L,(IX+6)
	LD	H,(IX+7)
	LD	(HL),E
	INC	HL
	LD	(HL),D
	INC	HL
	LD	(HL),C
	INC	HL
	LD	(HL),B
	POP	HL		; Discard obj
	EI
	LD	HL,0
	POP	BC
	POP	IX
	RET

; unsigned long __atomic_fetch_add_4(volatile void *obj, unsigned long val)
	PUBLIC	___atomic_fetch_add_4
___atomic_fetch_add_4:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	PUSH	BC

	LD	L,(IX+4)
	LD	H,(IX+5)	; obj

	DI
	; Load current into temp
	LD	E,(HL)
	INC	HL
	LD	D,(HL)
	INC	HL
	PUSH	DE		; Save low word of old
	LD	E,(HL)
	INC	HL
	LD	D,(HL)
	PUSH	DE		; Save high word of old

	; Add val
	POP	DE		; high
	POP	HL		; low
	PUSH	DE
	PUSH	HL		; Save old for return

	LD	C,(IX+6)
	LD	B,(IX+7)
	ADD	HL,BC		; Add low
	EX	DE,HL
	LD	C,(IX+8)
	LD	B,(IX+9)
	ADC	HL,BC		; Add high with carry
	EX	DE,HL		; DEHL = result

	; Store result
	PUSH	HL
	PUSH	DE
	LD	L,(IX+4)
	LD	H,(IX+5)
	POP	DE
	POP	BC		; DEBC = result
	LD	(HL),C
	INC	HL
	LD	(HL),B
	INC	HL
	LD	(HL),E
	INC	HL
	LD	(HL),D
	EI

	; Return old value
	POP	HL		; low
	POP	DE		; high
	POP	BC
	POP	IX
	RET

; unsigned long __atomic_fetch_sub_4(volatile void *obj, unsigned long val)
	PUBLIC	___atomic_fetch_sub_4
___atomic_fetch_sub_4:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	PUSH	BC

	LD	L,(IX+4)
	LD	H,(IX+5)

	DI
	LD	E,(HL)
	INC	HL
	LD	D,(HL)
	INC	HL
	PUSH	DE
	LD	E,(HL)
	INC	HL
	LD	D,(HL)
	PUSH	DE

	POP	DE
	POP	HL
	PUSH	DE
	PUSH	HL

	LD	C,(IX+6)
	LD	B,(IX+7)
	OR	A
	SBC	HL,BC
	EX	DE,HL
	LD	C,(IX+8)
	LD	B,(IX+9)
	SBC	HL,BC
	EX	DE,HL

	PUSH	HL
	PUSH	DE
	LD	L,(IX+4)
	LD	H,(IX+5)
	POP	DE
	POP	BC
	LD	(HL),C
	INC	HL
	LD	(HL),B
	INC	HL
	LD	(HL),E
	INC	HL
	LD	(HL),D
	EI

	POP	HL
	POP	DE
	POP	BC
	POP	IX
	RET

; unsigned long __atomic_fetch_or_4(volatile void *obj, unsigned long val)
	PUBLIC	___atomic_fetch_or_4
___atomic_fetch_or_4:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	PUSH	BC

	LD	L,(IX+4)
	LD	H,(IX+5)

	DI
	LD	E,(HL)
	INC	HL
	LD	D,(HL)
	INC	HL
	PUSH	DE
	LD	E,(HL)
	INC	HL
	LD	D,(HL)
	PUSH	DE

	; Compute OR
	POP	BC		; high
	POP	DE		; low
	PUSH	DE
	PUSH	BC		; Save old

	LD	A,E
	OR	(IX+6)
	LD	E,A
	LD	A,D
	OR	(IX+7)
	LD	D,A
	LD	A,C
	OR	(IX+8)
	LD	C,A
	LD	A,B
	OR	(IX+9)
	LD	B,A		; BCDE = result

	LD	L,(IX+4)
	LD	H,(IX+5)
	LD	(HL),E
	INC	HL
	LD	(HL),D
	INC	HL
	LD	(HL),C
	INC	HL
	LD	(HL),B
	EI

	POP	DE		; high of old
	POP	HL		; low of old
	; Swap for return convention
	EX	DE,HL
	POP	BC
	POP	IX
	RET

; unsigned long __atomic_fetch_xor_4(volatile void *obj, unsigned long val)
	PUBLIC	___atomic_fetch_xor_4
___atomic_fetch_xor_4:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	PUSH	BC

	LD	L,(IX+4)
	LD	H,(IX+5)

	DI
	LD	E,(HL)
	INC	HL
	LD	D,(HL)
	INC	HL
	PUSH	DE
	LD	E,(HL)
	INC	HL
	LD	D,(HL)
	PUSH	DE

	POP	BC
	POP	DE
	PUSH	DE
	PUSH	BC

	LD	A,E
	XOR	(IX+6)
	LD	E,A
	LD	A,D
	XOR	(IX+7)
	LD	D,A
	LD	A,C
	XOR	(IX+8)
	LD	C,A
	LD	A,B
	XOR	(IX+9)
	LD	B,A

	LD	L,(IX+4)
	LD	H,(IX+5)
	LD	(HL),E
	INC	HL
	LD	(HL),D
	INC	HL
	LD	(HL),C
	INC	HL
	LD	(HL),B
	EI

	POP	DE
	POP	HL
	EX	DE,HL
	POP	BC
	POP	IX
	RET

; unsigned long __atomic_fetch_and_4(volatile void *obj, unsigned long val)
	PUBLIC	___atomic_fetch_and_4
___atomic_fetch_and_4:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	PUSH	BC

	LD	L,(IX+4)
	LD	H,(IX+5)

	DI
	LD	E,(HL)
	INC	HL
	LD	D,(HL)
	INC	HL
	PUSH	DE
	LD	E,(HL)
	INC	HL
	LD	D,(HL)
	PUSH	DE

	POP	BC
	POP	DE
	PUSH	DE
	PUSH	BC

	LD	A,E
	AND	(IX+6)
	LD	E,A
	LD	A,D
	AND	(IX+7)
	LD	D,A
	LD	A,C
	AND	(IX+8)
	LD	C,A
	LD	A,B
	AND	(IX+9)
	LD	B,A

	LD	L,(IX+4)
	LD	H,(IX+5)
	LD	(HL),E
	INC	HL
	LD	(HL),D
	INC	HL
	LD	(HL),C
	INC	HL
	LD	(HL),B
	EI

	POP	DE
	POP	HL
	EX	DE,HL
	POP	BC
	POP	IX
	RET


; ============================================================
; lc_cbrt.mac
; ============================================================
	CSEG
; lc_cbrt.mac - cbrt, cbrtf


	EXTRN	__fadd
	EXTRN	__fmul
	EXTRN	__fdiv
	EXTRN	__tmp32

	CSEG

; ============================================================
; cbrt(x) - Cube root
; Uses Newton-Raphson: x_{n+1} = (2*x_n + S/x_n^2) / 3
; ============================================================
	PUBLIC	_cbrt
	PUBLIC	_cbrtf
_cbrt:
_cbrtf:
	PUSH	IX
	PUSH	BC
	LD	IX,0
	ADD	IX,SP

	CALL	_math_getarg

	; Save sign and work with |x|
	LD	A,D
	AND	80H
	LD	(_cbrt_sign),A
	LD	A,D
	AND	7FH
	LD	D,A

	; Check for zero
	OR	E
	OR	H
	OR	L
	JR	Z,_cbrt_zero

	LD	(_cbrt_x),HL
	LD	(_cbrt_x+2),DE

	; Initial guess: x/3 (rough)
	; Better: use exponent/3
	LD	(_cbrt_g),HL
	LD	(_cbrt_g+2),DE

	LD	B,8

_cbrt_loop:
	PUSH	BC

	; g^2
	LD	HL,(_cbrt_g)
	LD	DE,(_cbrt_g+2)
	LD	(__tmp32),HL
	LD	(__tmp32+2),DE
	CALL	__fmul
	LD	(_cbrt_g2),HL
	LD	(_cbrt_g2+2),DE

	; x / g^2
	LD	(__tmp32),HL
	LD	(__tmp32+2),DE
	LD	HL,(_cbrt_x)
	LD	DE,(_cbrt_x+2)
	CALL	__fdiv
	LD	(_cbrt_t),HL
	LD	(_cbrt_t+2),DE

	; 2*g
	LD	HL,(_cbrt_g)
	LD	DE,(_cbrt_g+2)
	LD	(__tmp32),HL
	LD	(__tmp32+2),DE
	CALL	__fadd

	; 2*g + x/g^2
	LD	A,(_cbrt_t)
	LD	(__tmp32),A
	LD	A,(_cbrt_t+1)
	LD	(__tmp32+1),A
	LD	A,(_cbrt_t+2)
	LD	(__tmp32+2),A
	LD	A,(_cbrt_t+3)
	LD	(__tmp32+3),A
	CALL	__fadd

	; Divide by 3
	LD	A,0
	LD	(__tmp32),A
	LD	A,0
	LD	(__tmp32+1),A
	LD	A,40H
	LD	(__tmp32+2),A
	LD	A,40H		; 3.0 = 40400000
	LD	(__tmp32+3),A
	CALL	__fdiv

	LD	(_cbrt_g),HL
	LD	(_cbrt_g+2),DE

	POP	BC
	DJNZ	_cbrt_loop

	LD	HL,(_cbrt_g)
	LD	DE,(_cbrt_g+2)
	LD	A,(_cbrt_sign)
	OR	D
	LD	D,A
	JR	_cbrt_done

_cbrt_zero:
	LD	HL,0
	LD	DE,0

_cbrt_done:
	POP	BC
	POP	IX
	RET

	DSEG

_cbrt_sign:	DS	1
_cbrt_x:	DS	4
_cbrt_g:	DS	4
_cbrt_g2:	DS	4
_cbrt_t:	DS	4


; ============================================================
; lc_complex.mac
; ============================================================
	CSEG
; lc_complex.mac - complex number functions



	EXTRN	__fadd
	EXTRN	__fsub
	EXTRN	__fmul
	EXTRN	__fdiv
	EXTRN	__fcmp
	EXTRN	__itof
	EXTRN	__ftoi
	EXTRN	__tmp32
	EXTRN	__cadd
	EXTRN	__csub
	EXTRN	__cmul
	EXTRN	__cdiv
	EXTRN	__cplx_l
	EXTRN	__cplx_r
	EXTRN	__cplx_result
	EXTRN	__cplx_tmp

	CSEG

	PUBLIC	_creal,_crealf,_creall
	PUBLIC	_cimag,_cimagf,_cimagl
	PUBLIC	_cabs,_cabsf,_cabsl
	PUBLIC	_carg,_cargf,_cargl
	PUBLIC	_conj,_conjf,_conjl
	PUBLIC	_cproj,_cprojf,_cprojl
	PUBLIC	_cexp,_cexpf
	PUBLIC	_clog,_clogf
	PUBLIC	_cpow,_cpowf
	PUBLIC	_csqrt,_csqrtf
	PUBLIC	_csin,_csinf
	PUBLIC	_ccos,_ccosf
	PUBLIC	_ctan,_ctanf
	PUBLIC	_casin,_cacos,_catan
	PUBLIC	_csinh,_ccosh,_ctanh
	PUBLIC	_casinh,_cacosh,_catanh

; __I_const: Imaginary unit constant (0.0 + 1.0i)
; real = 0x00000000 (0.0), imag = 0x3F800000 (1.0)
	PUBLIC	___I_const
___I_const:
	DW	0,0		; Real = 0.0
	DW	0,3F80H		; Imag = 1.0

; __make_complex: Create complex from two doubles
; Input: real at IX+4 (4 bytes), imag at IX+8 (4 bytes)
; Output: pointer to result in HL
	PUBLIC	___make_complex,___make_complexf
___make_complex:
___make_complexf:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	LD	L,(IX+4)
	LD	H,(IX+5)
	LD	(_cplx_res),HL
	LD	L,(IX+6)
	LD	H,(IX+7)
	LD	(_cplx_res+2),HL
	LD	L,(IX+8)
	LD	H,(IX+9)
	LD	(_cplx_res+4),HL
	LD	L,(IX+10)
	LD	H,(IX+11)
	LD	(_cplx_res+6),HL
	LD	HL,_cplx_res
	POP	IX
	RET

; creal: Get real part of complex
; Input: complex pointer at IX+4
; Output: float in DEHL
_creal:
_crealf:
_creall:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	LD	L,(IX+4)
	LD	H,(IX+5)
	LD	E,(HL)
	INC	HL
	LD	D,(HL)
	INC	HL
	PUSH	DE
	LD	E,(HL)
	INC	HL
	LD	D,(HL)
	POP	HL
	POP	IX
	RET

; cimag: Get imaginary part of complex
; Input: complex pointer at IX+4
; Output: float in DEHL
_cimag:
_cimagf:
_cimagl:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	LD	L,(IX+4)
	LD	H,(IX+5)
	LD	BC,4
	ADD	HL,BC
	LD	E,(HL)
	INC	HL
	LD	D,(HL)
	INC	HL
	PUSH	DE
	LD	E,(HL)
	INC	HL
	LD	D,(HL)
	POP	HL
	POP	IX
	RET

; cabs: |z| = sqrt(re² + im²)
_cabs:
_cabsf:
_cabsl:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	LD	L,(IX+4)
	LD	H,(IX+5)
	; Get real part
	LD	E,(HL)
	INC	HL
	LD	D,(HL)
	INC	HL
	LD	C,(HL)
	INC	HL
	LD	B,(HL)
	INC	HL
	PUSH	BC
	PUSH	DE
	POP	HL
	POP	DE		; DEHL = real
	LD	(__tmp32),HL
	LD	(__tmp32+2),DE
	CALL	__fmul		; real²
	LD	(_cplx_z),HL
	LD	(_cplx_z+2),DE
	; Get imag part
	LD	L,(IX+4)
	LD	H,(IX+5)
	LD	BC,4
	ADD	HL,BC
	LD	E,(HL)
	INC	HL
	LD	D,(HL)
	INC	HL
	LD	C,(HL)
	INC	HL
	LD	B,(HL)
	PUSH	BC
	PUSH	DE
	POP	HL
	POP	DE		; DEHL = imag
	LD	(__tmp32),HL
	LD	(__tmp32+2),DE
	CALL	__fmul		; imag²
	; Add real² + imag²
	LD	(__tmp32),HL
	LD	(__tmp32+2),DE
	LD	HL,(_cplx_z)
	LD	DE,(_cplx_z+2)
	CALL	__fadd
	; sqrt
	PUSH	DE
	PUSH	HL
	CALL	_sqrt
	POP	BC
	POP	BC
	POP	IX
	RET

; carg: arg(z) = atan2(im, re)
_carg:
_cargf:
_cargl:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	LD	L,(IX+4)
	LD	H,(IX+5)
	; Push real (x) first
	LD	E,(HL)
	INC	HL
	LD	D,(HL)
	INC	HL
	LD	C,(HL)
	INC	HL
	LD	B,(HL)
	INC	HL
	PUSH	BC
	PUSH	DE
	; Push imag (y)
	LD	E,(HL)
	INC	HL
	LD	D,(HL)
	INC	HL
	LD	C,(HL)
	INC	HL
	LD	B,(HL)
	PUSH	BC
	PUSH	DE
	CALL	_atan2
	POP	BC
	POP	BC
	POP	BC
	POP	BC
	POP	IX
	RET

; conj: conjugate z* = re - i*im
_conj:
_conjf:
_conjl:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	LD	L,(IX+4)
	LD	H,(IX+5)
	; Copy real unchanged
	LD	DE,_cplx_res
	LD	BC,4
	LDIR
	; Copy and negate imag
	LD	E,(HL)
	INC	HL
	LD	D,(HL)
	INC	HL
	LD	C,(HL)
	INC	HL
	LD	B,(HL)
	LD	A,B
	XOR	80H
	LD	B,A
	LD	HL,_cplx_res+4
	LD	(HL),E
	INC	HL
	LD	(HL),D
	INC	HL
	LD	(HL),C
	INC	HL
	LD	(HL),B
	LD	HL,_cplx_res
	POP	IX
	RET

; cproj: projection (for finite numbers returns input)
_cproj:
_cprojf:
_cprojl:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	LD	L,(IX+4)
	LD	H,(IX+5)
	POP	IX
	RET

; cexp: e^z = e^re * (cos(im) + i*sin(im))
_cexp:
_cexpf:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	LD	L,(IX+4)
	LD	H,(IX+5)
	LD	DE,_cplx_z
	LD	BC,8
	LDIR
	; e^re
	LD	HL,(_cplx_z)
	LD	DE,(_cplx_z+2)
	PUSH	DE
	PUSH	HL
	CALL	_exp
	POP	BC
	POP	BC
	LD	(_cplx_w),HL
	LD	(_cplx_w+2),DE
	; cos(im)
	LD	HL,(_cplx_z+4)
	LD	DE,(_cplx_z+6)
	PUSH	DE
	PUSH	HL
	CALL	_cos
	POP	BC
	POP	BC
	; Real = e^re * cos(im)
	LD	(__tmp32),HL
	LD	(__tmp32+2),DE
	LD	HL,(_cplx_w)
	LD	DE,(_cplx_w+2)
	CALL	__fmul
	LD	(_cplx_res),HL
	LD	(_cplx_res+2),DE
	; sin(im)
	LD	HL,(_cplx_z+4)
	LD	DE,(_cplx_z+6)
	PUSH	DE
	PUSH	HL
	CALL	_sin
	POP	BC
	POP	BC
	; Imag = e^re * sin(im)
	LD	(__tmp32),HL
	LD	(__tmp32+2),DE
	LD	HL,(_cplx_w)
	LD	DE,(_cplx_w+2)
	CALL	__fmul
	LD	(_cplx_res+4),HL
	LD	(_cplx_res+6),DE
	LD	HL,_cplx_res
	POP	IX
	RET

; clog: log(z) = log(|z|) + i*arg(z)
_clog:
_clogf:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	LD	L,(IX+4)
	LD	H,(IX+5)
	PUSH	HL
	; |z|
	PUSH	HL
	CALL	_cabs
	POP	BC
	; log(|z|)
	PUSH	DE
	PUSH	HL
	CALL	_log
	POP	BC
	POP	BC
	LD	(_cplx_res),HL
	LD	(_cplx_res+2),DE
	; arg(z)
	POP	HL
	PUSH	HL
	CALL	_carg
	POP	BC
	LD	(_cplx_res+4),HL
	LD	(_cplx_res+6),DE
	LD	HL,_cplx_res
	POP	IX
	RET

; csqrt: sqrt(z) using polar form
_csqrt:
_csqrtf:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	LD	L,(IX+4)
	LD	H,(IX+5)
	PUSH	HL
	; sqrt(|z|)
	PUSH	HL
	CALL	_cabs
	POP	BC
	PUSH	DE
	PUSH	HL
	CALL	_sqrt
	POP	BC
	POP	BC
	LD	(_cplx_w),HL	; r = sqrt(|z|)
	LD	(_cplx_w+2),DE
	; arg(z)/2
	POP	HL
	PUSH	HL
	CALL	_carg
	POP	BC
	; Divide by 2: multiply by 0.5 (0x3F000000)
	LD	(__tmp32),HL
	LD	(__tmp32+2),DE
	LD	HL,0
	LD	DE,3F00H
	CALL	__fmul
	LD	(_cplx_w+4),HL
	LD	(_cplx_w+6),DE
	; Real = r * cos(θ/2)
	PUSH	DE
	PUSH	HL
	CALL	_cos
	POP	BC
	POP	BC
	LD	(__tmp32),HL
	LD	(__tmp32+2),DE
	LD	HL,(_cplx_w)
	LD	DE,(_cplx_w+2)
	CALL	__fmul
	LD	(_cplx_res),HL
	LD	(_cplx_res+2),DE
	; Imag = r * sin(θ/2)
	LD	HL,(_cplx_w+4)
	LD	DE,(_cplx_w+6)
	PUSH	DE
	PUSH	HL
	CALL	_sin
	POP	BC
	POP	BC
	LD	(__tmp32),HL
	LD	(__tmp32+2),DE
	LD	HL,(_cplx_w)
	LD	DE,(_cplx_w+2)
	CALL	__fmul
	LD	(_cplx_res+4),HL
	LD	(_cplx_res+6),DE
	LD	HL,_cplx_res
	POP	IX
	RET

; cpow: z^w = e^(w*log(z))
_cpow:
_cpowf:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	; z at IX+4, w at IX+6
	LD	L,(IX+4)
	LD	H,(IX+5)
	; log(z)
	PUSH	HL
	CALL	_clog
	POP	BC
	LD	DE,__cplx_l
	LD	BC,8
	LDIR
	; Load w
	LD	L,(IX+6)
	LD	H,(IX+7)
	LD	DE,__cplx_r
	LD	BC,8
	LDIR
	; w * log(z)
	CALL	__cmul
	; e^(w*log(z))
	LD	HL,__cplx_result
	PUSH	HL
	CALL	_cexp
	POP	BC
	POP	IX
	RET

; csin: sin(z) = sin(re)*cosh(im) + i*cos(re)*sinh(im)
_csin:
_csinf:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	LD	L,(IX+4)
	LD	H,(IX+5)
	LD	DE,_cplx_z
	LD	BC,8
	LDIR
	; sin(re)
	LD	HL,(_cplx_z)
	LD	DE,(_cplx_z+2)
	PUSH	DE
	PUSH	HL
	CALL	_sin
	POP	BC
	POP	BC
	LD	(_cplx_w),HL
	LD	(_cplx_w+2),DE
	; cosh(im)
	LD	HL,(_cplx_z+4)
	LD	DE,(_cplx_z+6)
	PUSH	DE
	PUSH	HL
	CALL	_cosh
	POP	BC
	POP	BC
	; Real = sin(re) * cosh(im)
	LD	(__tmp32),HL
	LD	(__tmp32+2),DE
	LD	HL,(_cplx_w)
	LD	DE,(_cplx_w+2)
	CALL	__fmul
	LD	(_cplx_res),HL
	LD	(_cplx_res+2),DE
	; cos(re)
	LD	HL,(_cplx_z)
	LD	DE,(_cplx_z+2)
	PUSH	DE
	PUSH	HL
	CALL	_cos
	POP	BC
	POP	BC
	LD	(_cplx_w),HL
	LD	(_cplx_w+2),DE
	; sinh(im)
	LD	HL,(_cplx_z+4)
	LD	DE,(_cplx_z+6)
	PUSH	DE
	PUSH	HL
	CALL	_sinh
	POP	BC
	POP	BC
	; Imag = cos(re) * sinh(im)
	LD	(__tmp32),HL
	LD	(__tmp32+2),DE
	LD	HL,(_cplx_w)
	LD	DE,(_cplx_w+2)
	CALL	__fmul
	LD	(_cplx_res+4),HL
	LD	(_cplx_res+6),DE
	LD	HL,_cplx_res
	POP	IX
	RET

; ccos: cos(z) = cos(re)*cosh(im) - i*sin(re)*sinh(im)
_ccos:
_ccosf:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	LD	L,(IX+4)
	LD	H,(IX+5)
	LD	DE,_cplx_z
	LD	BC,8
	LDIR
	; cos(re)
	LD	HL,(_cplx_z)
	LD	DE,(_cplx_z+2)
	PUSH	DE
	PUSH	HL
	CALL	_cos
	POP	BC
	POP	BC
	LD	(_cplx_w),HL
	LD	(_cplx_w+2),DE
	; cosh(im)
	LD	HL,(_cplx_z+4)
	LD	DE,(_cplx_z+6)
	PUSH	DE
	PUSH	HL
	CALL	_cosh
	POP	BC
	POP	BC
	; Real = cos(re) * cosh(im)
	LD	(__tmp32),HL
	LD	(__tmp32+2),DE
	LD	HL,(_cplx_w)
	LD	DE,(_cplx_w+2)
	CALL	__fmul
	LD	(_cplx_res),HL
	LD	(_cplx_res+2),DE
	; sin(re)
	LD	HL,(_cplx_z)
	LD	DE,(_cplx_z+2)
	PUSH	DE
	PUSH	HL
	CALL	_sin
	POP	BC
	POP	BC
	LD	(_cplx_w),HL
	LD	(_cplx_w+2),DE
	; sinh(im)
	LD	HL,(_cplx_z+4)
	LD	DE,(_cplx_z+6)
	PUSH	DE
	PUSH	HL
	CALL	_sinh
	POP	BC
	POP	BC
	; Imag = -sin(re) * sinh(im)
	LD	(__tmp32),HL
	LD	(__tmp32+2),DE
	LD	HL,(_cplx_w)
	LD	DE,(_cplx_w+2)
	CALL	__fmul
	LD	A,D
	XOR	80H
	LD	D,A
	LD	(_cplx_res+4),HL
	LD	(_cplx_res+6),DE
	LD	HL,_cplx_res
	POP	IX
	RET

; ctan: tan(z) = sin(z) / cos(z)
_ctan:
_ctanf:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	LD	L,(IX+4)
	LD	H,(IX+5)
	; sin(z)
	PUSH	HL
	CALL	_csin
	POP	BC
	LD	DE,__cplx_l
	LD	BC,8
	LDIR
	; cos(z)
	LD	L,(IX+4)
	LD	H,(IX+5)
	PUSH	HL
	CALL	_ccos
	POP	BC
	LD	DE,__cplx_r
	LD	BC,8
	LDIR
	CALL	__cdiv
	LD	DE,_cplx_res
	LD	BC,8
	LDIR
	LD	HL,_cplx_res
	POP	IX
	RET

; csinh: sinh(z) = sinh(re)*cos(im) + i*cosh(re)*sin(im)
_csinh:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	LD	L,(IX+4)
	LD	H,(IX+5)
	LD	DE,_cplx_z
	LD	BC,8
	LDIR
	; sinh(re)
	LD	HL,(_cplx_z)
	LD	DE,(_cplx_z+2)
	PUSH	DE
	PUSH	HL
	CALL	_sinh
	POP	BC
	POP	BC
	LD	(_cplx_w),HL
	LD	(_cplx_w+2),DE
	; cos(im)
	LD	HL,(_cplx_z+4)
	LD	DE,(_cplx_z+6)
	PUSH	DE
	PUSH	HL
	CALL	_cos
	POP	BC
	POP	BC
	; Real = sinh(re) * cos(im)
	LD	(__tmp32),HL
	LD	(__tmp32+2),DE
	LD	HL,(_cplx_w)
	LD	DE,(_cplx_w+2)
	CALL	__fmul
	LD	(_cplx_res),HL
	LD	(_cplx_res+2),DE
	; cosh(re)
	LD	HL,(_cplx_z)
	LD	DE,(_cplx_z+2)
	PUSH	DE
	PUSH	HL
	CALL	_cosh
	POP	BC
	POP	BC
	LD	(_cplx_w),HL
	LD	(_cplx_w+2),DE
	; sin(im)
	LD	HL,(_cplx_z+4)
	LD	DE,(_cplx_z+6)
	PUSH	DE
	PUSH	HL
	CALL	_sin
	POP	BC
	POP	BC
	; Imag = cosh(re) * sin(im)
	LD	(__tmp32),HL
	LD	(__tmp32+2),DE
	LD	HL,(_cplx_w)
	LD	DE,(_cplx_w+2)
	CALL	__fmul
	LD	(_cplx_res+4),HL
	LD	(_cplx_res+6),DE
	LD	HL,_cplx_res
	POP	IX
	RET

; ccosh: cosh(z) = cosh(re)*cos(im) + i*sinh(re)*sin(im)
_ccosh:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	LD	L,(IX+4)
	LD	H,(IX+5)
	LD	DE,_cplx_z
	LD	BC,8
	LDIR
	; cosh(re)
	LD	HL,(_cplx_z)
	LD	DE,(_cplx_z+2)
	PUSH	DE
	PUSH	HL
	CALL	_cosh
	POP	BC
	POP	BC
	LD	(_cplx_w),HL
	LD	(_cplx_w+2),DE
	; cos(im)
	LD	HL,(_cplx_z+4)
	LD	DE,(_cplx_z+6)
	PUSH	DE
	PUSH	HL
	CALL	_cos
	POP	BC
	POP	BC
	; Real = cosh(re) * cos(im)
	LD	(__tmp32),HL
	LD	(__tmp32+2),DE
	LD	HL,(_cplx_w)
	LD	DE,(_cplx_w+2)
	CALL	__fmul
	LD	(_cplx_res),HL
	LD	(_cplx_res+2),DE
	; sinh(re)
	LD	HL,(_cplx_z)
	LD	DE,(_cplx_z+2)
	PUSH	DE
	PUSH	HL
	CALL	_sinh
	POP	BC
	POP	BC
	LD	(_cplx_w),HL
	LD	(_cplx_w+2),DE
	; sin(im)
	LD	HL,(_cplx_z+4)
	LD	DE,(_cplx_z+6)
	PUSH	DE
	PUSH	HL
	CALL	_sin
	POP	BC
	POP	BC
	; Imag = sinh(re) * sin(im)
	LD	(__tmp32),HL
	LD	(__tmp32+2),DE
	LD	HL,(_cplx_w)
	LD	DE,(_cplx_w+2)
	CALL	__fmul
	LD	(_cplx_res+4),HL
	LD	(_cplx_res+6),DE
	LD	HL,_cplx_res
	POP	IX
	RET

; ctanh: tanh(z) = sinh(z) / cosh(z)
_ctanh:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	LD	L,(IX+4)
	LD	H,(IX+5)
	; sinh(z)
	PUSH	HL
	CALL	_csinh
	POP	BC
	LD	DE,__cplx_l
	LD	BC,8
	LDIR
	; cosh(z)
	LD	L,(IX+4)
	LD	H,(IX+5)
	PUSH	HL
	CALL	_ccosh
	POP	BC
	LD	DE,__cplx_r
	LD	BC,8
	LDIR
	CALL	__cdiv
	LD	DE,_cplx_res
	LD	BC,8
	LDIR
	LD	HL,_cplx_res
	POP	IX
	RET

; Inverse trig/hyperbolic - simplified placeholders that return input
_casin:
_cacos:
_catan:
_casinh:
_cacosh:
_catanh:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	LD	L,(IX+4)
	LD	H,(IX+5)
	LD	DE,_cplx_res
	LD	BC,8
	LDIR
	LD	HL,_cplx_res
	POP	IX
	RET

; Complex multiply: __cplx_l * __cplx_r -> __cplx_result
; Stub implementation - returns __cplx_l
__cmul:
	LD	HL,__cplx_l
	LD	DE,__cplx_result
	LD	BC,8
	LDIR
	RET

; Complex divide: __cplx_l / __cplx_r -> __cplx_result
; Stub implementation - returns __cplx_l
__cdiv:
	LD	HL,__cplx_l
	LD	DE,__cplx_result
	LD	BC,8
	LDIR
	RET

	DSEG

; Complex number work areas
_cplx_z:	DS	8	; Input complex
_cplx_w:	DS	8	; Second input / work area
_cplx_res:	DS	8	; Result storage


; ============================================================
; lc_cos.mac
; ============================================================
	CSEG
; lc_cos.mac - cos, cosf, cosl


	EXTRN	__fadd
	EXTRN	__fmul
	EXTRN	__fdiv
	EXTRN	__itof
	EXTRN	__tmp32

	CSEG

; ============================================================
; cos(x) - Cosine using Taylor series
; cos(x) = 1 - x^2/2! + x^4/4! - x^6/6! + ...
; ============================================================
	PUBLIC	_cos
	PUBLIC	_cosf
	PUBLIC	_cosl
_cos:
_cosf:
_cosl:
	PUSH	IX
	PUSH	BC
	LD	IX,0
	ADD	IX,SP

	CALL	_math_getarg	; x in DEHL

	; Work with |x|
	LD	A,D
	AND	7FH
	LD	D,A

	LD	(_cos_x),HL
	LD	(_cos_x+2),DE

	; Start with sum = 1.0 (3F800000)
	LD	HL,0
	LD	DE,3F80H
	LD	(_cos_sum),HL
	LD	(_cos_sum+2),DE

	; term = 1.0
	LD	(_cos_term),HL
	LD	(_cos_term+2),DE

	; Compute x^2
	LD	HL,(_cos_x)
	LD	DE,(_cos_x+2)
	LD	(__tmp32),HL
	LD	(__tmp32+2),DE
	CALL	__fmul
	LD	(_cos_x2),HL
	LD	(_cos_x2+2),DE

	; Taylor series: 4 terms
	LD	B,4
	LD	C,1		; n starts at 1

_cos_loop:
	PUSH	BC

	; term *= x^2
	LD	HL,(_cos_term)
	LD	DE,(_cos_term+2)
	LD	A,(_cos_x2)
	LD	(__tmp32),A
	LD	A,(_cos_x2+1)
	LD	(__tmp32+1),A
	LD	A,(_cos_x2+2)
	LD	(__tmp32+2),A
	LD	A,(_cos_x2+3)
	LD	(__tmp32+3),A
	CALL	__fmul
	LD	(_cos_term),HL
	LD	(_cos_term+2),DE

	; Divide by (2n-1)*(2n)
	POP	BC
	LD	A,C
	ADD	A,A		; 2n
	DEC	A		; 2n-1
	LD	L,A
	LD	H,0
	LD	E,H
	LD	D,H		; DEHL = (2n-1) as 32-bit int
	PUSH	BC		; Save BC across __itof
	CALL	__itof
	LD	(_cos_n),HL
	LD	(_cos_n+2),DE
	POP	BC
	LD	A,C
	ADD	A,A		; 2n
	INC	C		; Advance n for next iteration
	PUSH	BC		; Save updated B and C
	LD	L,A
	LD	H,0
	LD	E,H
	LD	D,H		; DEHL = 2n as 32-bit int
	CALL	__itof
	; Multiply
	LD	A,(_cos_n)
	LD	(__tmp32),A
	LD	A,(_cos_n+1)
	LD	(__tmp32+1),A
	LD	A,(_cos_n+2)
	LD	(__tmp32+2),A
	LD	A,(_cos_n+3)
	LD	(__tmp32+3),A
	CALL	__fmul

	; Divide term
	LD	(__tmp32),HL
	LD	(__tmp32+2),DE
	LD	HL,(_cos_term)
	LD	DE,(_cos_term+2)
	EX	DE,HL
	LD	A,D
	LD	D,E
	LD	E,A
	LD	A,H
	LD	H,L
	LD	L,A
	EX	DE,HL
	CALL	__fdiv

	; Negate
	LD	A,D
	XOR	80H
	LD	D,A
	LD	(_cos_term),HL
	LD	(_cos_term+2),DE

	; Add to sum
	LD	A,(_cos_sum)
	LD	(__tmp32),A
	LD	A,(_cos_sum+1)
	LD	(__tmp32+1),A
	LD	A,(_cos_sum+2)
	LD	(__tmp32+2),A
	LD	A,(_cos_sum+3)
	LD	(__tmp32+3),A
	CALL	__fadd
	LD	(_cos_sum),HL
	LD	(_cos_sum+2),DE

	POP	BC
	DJNZ	_cos_loop

	LD	HL,(_cos_sum)
	LD	DE,(_cos_sum+2)

	POP	BC
	POP	IX
	RET

	DSEG

_cos_x:		DS	4
_cos_x2:	DS	4
_cos_sum:	DS	4
_cos_term:	DS	4
_cos_n:		DS	4


; ============================================================
; lc_cosh.mac
; ============================================================
	CSEG
; lc_cosh.mac - cosh, coshf (depends on exp)


	EXTRN	__fadd
	EXTRN	__tmp32

	CSEG

; ============================================================
; cosh(x) = (e^x + e^-x) / 2
; ============================================================
	PUBLIC	_cosh
	PUBLIC	_coshf
_cosh:
_coshf:
	PUSH	IX
	PUSH	BC
	LD	IX,0
	ADD	IX,SP

	CALL	_math_getarg
	LD	(_cosh_x),HL
	LD	(_cosh_x+2),DE

	; e^x
	PUSH	DE
	PUSH	HL
	CALL	_expf
	POP	BC
	POP	BC
	LD	(_cosh_ep),HL
	LD	(_cosh_ep+2),DE

	; e^-x
	LD	HL,(_cosh_x)
	LD	DE,(_cosh_x+2)
	LD	A,D
	XOR	80H
	LD	D,A
	PUSH	DE
	PUSH	HL
	CALL	_expf
	POP	BC
	POP	BC

	; e^x + e^-x
	LD	(__tmp32),HL
	LD	(__tmp32+2),DE
	LD	HL,(_cosh_ep)
	LD	DE,(_cosh_ep+2)
	CALL	__fadd

	; Divide by 2: decrement IEEE 754 exponent by 1
	OR	A		; Clear carry
	LD	A,E
	SUB	80H
	LD	E,A
	LD	A,D
	SBC	A,0
	LD	D,A

	POP	BC
	POP	IX
	RET

	DSEG

_cosh_x:	DS	4
_cosh_ep:	DS	4


; ============================================================
; lc_ctype.mac
; ============================================================
	CSEG
; lc_ctype.mac - character classification functions


	CSEG

; ============================================================
; Character classification functions
; These are also available as macros in ctype.h but provided
; as functions for use with function pointers
; ============================================================

; int isdigit(int c)
	PUBLIC	_isdigit
_isdigit:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	LD	A,(IX+4)
	CP	'0'
	JR	C,_isdigit_no
	CP	'9'+1
	JR	NC,_isdigit_no
	LD	HL,1
	POP	IX
	RET
_isdigit_no:
	LD	HL,0
	POP	IX
	RET

; int isalpha(int c)
	PUBLIC	_isalpha
_isalpha:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	LD	A,(IX+4)
	; Check uppercase
	CP	'A'
	JR	C,_isalpha_lower
	CP	'Z'+1
	JR	C,_isalpha_yes
_isalpha_lower:
	; Check lowercase
	CP	'a'
	JR	C,_isalpha_no
	CP	'z'+1
	JR	NC,_isalpha_no
_isalpha_yes:
	LD	HL,1
	POP	IX
	RET
_isalpha_no:
	LD	HL,0
	POP	IX
	RET

; int isalnum(int c)
	PUBLIC	_isalnum
_isalnum:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	LD	A,(IX+4)
	; Check digit
	CP	'0'
	JR	C,_isalnum_alpha
	CP	'9'+1
	JR	C,_isalnum_yes
_isalnum_alpha:
	; Check uppercase
	CP	'A'
	JR	C,_isalnum_lower
	CP	'Z'+1
	JR	C,_isalnum_yes
_isalnum_lower:
	CP	'a'
	JR	C,_isalnum_no
	CP	'z'+1
	JR	NC,_isalnum_no
_isalnum_yes:
	LD	HL,1
	POP	IX
	RET
_isalnum_no:
	LD	HL,0
	POP	IX
	RET

; int isspace(int c)
	PUBLIC	_isspace
_isspace:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	LD	A,(IX+4)
	CP	' '
	JR	Z,_isspace_yes
	CP	09H		; TAB
	JR	Z,_isspace_yes
	CP	0AH		; LF
	JR	Z,_isspace_yes
	CP	0BH		; VT
	JR	Z,_isspace_yes
	CP	0CH		; FF
	JR	Z,_isspace_yes
	CP	0DH		; CR
	JR	Z,_isspace_yes
	LD	HL,0
	POP	IX
	RET
_isspace_yes:
	LD	HL,1
	POP	IX
	RET

; int isupper(int c)
	PUBLIC	_isupper
_isupper:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	LD	A,(IX+4)
	CP	'A'
	JR	C,_isupper_no
	CP	'Z'+1
	JR	NC,_isupper_no
	LD	HL,1
	POP	IX
	RET
_isupper_no:
	LD	HL,0
	POP	IX
	RET

; int islower(int c)
	PUBLIC	_islower
_islower:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	LD	A,(IX+4)
	CP	'a'
	JR	C,_islower_no
	CP	'z'+1
	JR	NC,_islower_no
	LD	HL,1
	POP	IX
	RET
_islower_no:
	LD	HL,0
	POP	IX
	RET

; int toupper(int c)
	PUBLIC	_toupper
_toupper:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	LD	A,(IX+4)
	CP	'a'
	JR	C,_toupper_ret
	CP	'z'+1
	JR	NC,_toupper_ret
	SUB	'a'-'A'		; Convert to uppercase
_toupper_ret:
	LD	L,A
	LD	H,0
	POP	IX
	RET

; int tolower(int c)
	PUBLIC	_tolower
_tolower:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	LD	A,(IX+4)
	CP	'A'
	JR	C,_tolower_ret
	CP	'Z'+1
	JR	NC,_tolower_ret
	ADD	A,'a'-'A'	; Convert to lowercase
_tolower_ret:
	LD	L,A
	LD	H,0
	POP	IX
	RET

; int isprint(int c)
	PUBLIC	_isprint
_isprint:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	LD	A,(IX+4)
	CP	' '
	JR	C,_isprint_no
	CP	7FH		; DEL
	JR	NC,_isprint_no
	LD	HL,1
	POP	IX
	RET
_isprint_no:
	LD	HL,0
	POP	IX
	RET

; int isxdigit(int c)
	PUBLIC	_isxdigit
_isxdigit:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	LD	A,(IX+4)
	; Check digit
	CP	'0'
	JR	C,_isxdigit_hex
	CP	'9'+1
	JR	C,_isxdigit_yes
_isxdigit_hex:
	; Check A-F
	CP	'A'
	JR	C,_isxdigit_lower
	CP	'F'+1
	JR	C,_isxdigit_yes
_isxdigit_lower:
	; Check a-f
	CP	'a'
	JR	C,_isxdigit_no
	CP	'f'+1
	JR	NC,_isxdigit_no
_isxdigit_yes:
	LD	HL,1
	POP	IX
	RET
_isxdigit_no:
	LD	HL,0
	POP	IX
	RET


; ============================================================
; lc_data.mac
; ============================================================
	CSEG
; lc_data.mac - global data

	DSEG

; Standard I/O streams
	PUBLIC	_stdin_data
_stdin_data:	DB	0,0,0FFH,0
	PUBLIC	_stdout_data
_stdout_data:	DB	1,0,0FFH,0
	PUBLIC	_stderr_data
_stderr_data:	DB	2,0,0FFH,0

	PUBLIC	_stdin
_stdin:	DW	_stdin_data
	PUBLIC	_stdout
_stdout:	DW	_stdout_data
	PUBLIC	_stderr
_stderr:	DW	_stderr_data

	PUBLIC	_errno
_errno:	DW	0


; ============================================================
; lc_exp.mac
; ============================================================
	CSEG
; lc_exp.mac - exp, expf, expl
; Range reduction: exp(x) = exp(r) * 2^k where k = trunc(x/ln2), r = x - k*ln2


	EXTRN	__fadd
	EXTRN	__fsub
	EXTRN	__fmul
	EXTRN	__fdiv
	EXTRN	__ftoi
	EXTRN	__itof
	EXTRN	__tmp32

	CSEG

; ============================================================
; exp(x) - Exponential with range reduction
; ============================================================
	PUBLIC	_exp
	PUBLIC	_expf
	PUBLIC	_expl
_exp:
_expf:
_expl:
	PUSH	IX
	PUSH	BC
	LD	IX,0
	ADD	IX,SP

	; Read float arg directly: IX+6..IX+9
	LD	L,(IX+6)
	LD	H,(IX+7)
	LD	E,(IX+8)
	LD	D,(IX+9)

	LD	(_exp_x),HL
	LD	(_exp_x+2),DE

	; --- Range reduction: k = trunc(x / ln2), r = x - k*ln2 ---
	; Multiply x by 1/ln2 = 1.442695 = 3FB8AA3BH
	LD	A,3BH
	LD	(__tmp32),A
	LD	A,0AAH
	LD	(__tmp32+1),A
	LD	A,0B8H
	LD	(__tmp32+2),A
	LD	A,3FH
	LD	(__tmp32+3),A
	CALL	__fmul		; DEHL = x / ln2

	; k = trunc(x/ln2) -> integer
	CALL	__ftoi		; DEHL = k as int
	LD	A,L
	LD	(_exp_k),A	; Save k (low byte, signed)

	; Convert k back to float
	CALL	__itof

	; r = x - k * ln2
	; First compute k * ln2
	LD	A,18H
	LD	(__tmp32),A
	LD	A,72H
	LD	(__tmp32+1),A
	LD	A,31H
	LD	(__tmp32+2),A
	LD	A,3FH
	LD	(__tmp32+3),A
	CALL	__fmul		; DEHL = k * ln2

	; r = x - k*ln2
	LD	(__tmp32),HL
	LD	(__tmp32+2),DE
	LD	HL,(_exp_x)
	LD	DE,(_exp_x+2)
	CALL	__fsub		; DEHL = x - k*ln2 = r

	; Save r as the new x for Taylor series
	LD	(_exp_r),HL
	LD	(_exp_r+2),DE

	; --- Taylor series: exp(r) = 1 + r + r^2/2! + ... ---
	; Start with sum = 1.0, term = 1.0
	LD	HL,0
	LD	DE,3F80H
	LD	(_exp_sum),HL
	LD	(_exp_sum+2),DE
	LD	(_exp_term),HL
	LD	(_exp_term+2),DE

	; 10 iterations for precision (plenty for |r| < ln2)
	LD	B,10
	LD	C,1

_exp_loop:
	PUSH	BC

	; term *= r
	LD	HL,(_exp_term)
	LD	DE,(_exp_term+2)
	LD	A,(_exp_r)
	LD	(__tmp32),A
	LD	A,(_exp_r+1)
	LD	(__tmp32+1),A
	LD	A,(_exp_r+2)
	LD	(__tmp32+2),A
	LD	A,(_exp_r+3)
	LD	(__tmp32+3),A
	CALL	__fmul
	LD	(_exp_term),HL
	LD	(_exp_term+2),DE

	; Divide by n
	POP	BC
	LD	L,C
	INC	C		; Advance C for next iteration
	PUSH	BC		; Save updated B and C
	LD	H,0
	LD	E,H
	LD	D,H		; DEHL = n as 32-bit int
	CALL	__itof
	LD	(__tmp32),HL
	LD	(__tmp32+2),DE
	LD	HL,(_exp_term)
	LD	DE,(_exp_term+2)
	CALL	__fdiv
	LD	(_exp_term),HL
	LD	(_exp_term+2),DE

	; Add to sum
	LD	A,(_exp_sum)
	LD	(__tmp32),A
	LD	A,(_exp_sum+1)
	LD	(__tmp32+1),A
	LD	A,(_exp_sum+2)
	LD	(__tmp32+2),A
	LD	A,(_exp_sum+3)
	LD	(__tmp32+3),A
	CALL	__fadd
	LD	(_exp_sum),HL
	LD	(_exp_sum+2),DE

	POP	BC
	DJNZ	_exp_loop

	; --- Multiply by 2^k: add k to IEEE 754 exponent ---
	LD	HL,(_exp_sum)
	LD	DE,(_exp_sum+2)

	; Extract biased exponent
	LD	A,D		; D = SEEEEEEE
	AND	7FH
	ADD	A,A		; EEEEEEE0
	LD	B,A
	LD	A,E		; EMMMMMMM
	RLCA
	AND	1
	OR	B		; A = full biased exponent

	; Add k
	LD	B,A
	LD	A,(_exp_k)
	ADD	A,B		; New biased exponent

	; Reconstruct float
	LD	C,A		; Save new exponent
	SRL	A		; exp >> 1
	LD	B,A
	LD	A,D
	AND	80H		; Keep sign
	OR	B
	LD	D,A
	LD	A,C
	AND	1		; exp[0]
	RRCA			; Rotate to bit 7
	LD	B,A
	LD	A,E
	AND	7FH		; Keep mantissa
	OR	B
	LD	E,A

	POP	BC
	POP	IX
	RET

	DSEG

_exp_x:		DS	4
_exp_r:		DS	4
_exp_sum:	DS	4
_exp_term:	DS	4
_exp_k:		DS	1


; ============================================================
; lc_exp2.mac
; ============================================================
	CSEG
; lc_exp2.mac - exp2, exp2f
; exp2(x) = 2^x = exp(x * ln(2))
; ln(2) = 0.693147... = 3F317218H


	EXTRN	__fmul
	EXTRN	__tmp32

	CSEG

	PUBLIC	_exp2
	PUBLIC	_exp2f
_exp2:
_exp2f:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP

	; Load x
	LD	L,(IX+4)
	LD	H,(IX+5)
	LD	E,(IX+6)
	LD	D,(IX+7)

	; x * ln(2)
	LD	(__tmp32),HL
	LD	(__tmp32+2),DE
	LD	HL,7218H	; ln(2) = 3F317218H
	LD	DE,3F31H
	CALL	__fmul

	; exp(x * ln(2))
	PUSH	DE
	PUSH	HL
	CALL	_expf
	POP	BC
	POP	BC

	POP	IX
	RET


; ============================================================
; lc_expm1.mac
; ============================================================
	CSEG
; lc_expm1.mac - expm1, expm1f
; expm1(x) = exp(x) - 1


	EXTRN	__fsub
	EXTRN	__tmp32

	CSEG

	PUBLIC	_expm1
	PUBLIC	_expm1f
_expm1:
_expm1f:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP

	; exp(x)
	LD	L,(IX+4)
	LD	H,(IX+5)
	LD	E,(IX+6)
	LD	D,(IX+7)
	PUSH	DE
	PUSH	HL
	CALL	_expf
	POP	BC
	POP	BC

	; Save exp(x) result
	LD	(_expm1_t),HL
	LD	(_expm1_t+2),DE

	; exp(x) - 1.0: DEHL=exp(x), __tmp32=1.0
	LD	HL,0
	LD	DE,3F80H
	LD	(__tmp32),HL
	LD	(__tmp32+2),DE
	LD	HL,(_expm1_t)
	LD	DE,(_expm1_t+2)
	CALL	__fsub

	POP	IX
	RET

	DSEG

_expm1_t:	DS	4


; ============================================================
; lc_fabs.mac
; ============================================================
	CSEG
; lc_fabs.mac - fabs, fabsf, fabsl, copysign, copysignf


	CSEG

; ============================================================
; fabs(x) - return absolute value
; For 32-bit float, clear sign bit (bit 31)
; ============================================================
	PUBLIC	_fabs
	PUBLIC	_fabsf
	PUBLIC	_fabsl
_fabs:
_fabsf:
_fabsl:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	LD	L,(IX+4)
	LD	H,(IX+5)
	LD	E,(IX+6)
	LD	A,(IX+7)
	AND	7FH		; Clear sign bit
	LD	D,A
	POP	IX
	RET

; ============================================================
; copysign(x, y) - return x with sign of y
; ============================================================
	PUBLIC	_copysign
	PUBLIC	_copysignf
_copysign:
_copysignf:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	LD	L,(IX+4)
	LD	H,(IX+5)
	LD	E,(IX+6)
	LD	A,(IX+7)
	AND	7FH		; Clear x sign
	LD	B,A
	LD	A,(IX+11)	; y high byte
	AND	80H		; Get y sign
	OR	B		; Combine
	LD	D,A
	POP	IX
	RET


; ============================================================
; lc_fdim.mac
; ============================================================
	CSEG
; lc_fdim.mac - fdim, fdimf
; fdim(x, y) = max(x - y, 0)


	EXTRN	__fcmp
	EXTRN	__fsub
	EXTRN	__tmp32

	CSEG

	PUBLIC	_fdim
	PUBLIC	_fdimf
_fdim:
_fdimf:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP

	; Load x into DEHL
	LD	L,(IX+4)
	LD	H,(IX+5)
	LD	E,(IX+6)
	LD	D,(IX+7)

	; Load y into __tmp32
	LD	A,(IX+8)
	LD	(__tmp32),A
	LD	A,(IX+9)
	LD	(__tmp32+1),A
	LD	A,(IX+10)
	LD	(__tmp32+2),A
	LD	A,(IX+11)
	LD	(__tmp32+3),A

	; Compare x with y
	CALL	__fcmp
	JR	Z,_fdim_zero	; x == y
	JR	C,_fdim_zero	; x < y

	; x > y: return x - y
	; Reload x and y (fcmp may have clobbered)
	LD	L,(IX+4)
	LD	H,(IX+5)
	LD	E,(IX+6)
	LD	D,(IX+7)
	LD	A,(IX+8)
	LD	(__tmp32),A
	LD	A,(IX+9)
	LD	(__tmp32+1),A
	LD	A,(IX+10)
	LD	(__tmp32+2),A
	LD	A,(IX+11)
	LD	(__tmp32+3),A
	CALL	__fsub
	POP	IX
	RET

_fdim_zero:
	; Return 0.0
	LD	HL,0
	LD	DE,0
	POP	IX
	RET


; ============================================================
; lc_file.mac
; ============================================================
	CSEG
; lc_file.mac - file I/O functions



	EXTRN	__div16
	EXTRN	__mul16

	CSEG

; ============================================================
; CP/M File I/O Implementation
; Real file operations using BDOS FCB calls
; ============================================================

BDOS_OPEN	EQU	15	; Open file
BDOS_CLOSE	EQU	16	; Close file
BDOS_DELETE	EQU	19	; Delete file
BDOS_RENAME	EQU	23	; Rename file
BDOS_READ	EQU	20	; Read sequential
BDOS_WRITE	EQU	21	; Write sequential
BDOS_MAKE	EQU	22	; Make (create) file
BDOS_SETDMA	EQU	26	; Set DMA address
BDOS_RREAD	EQU	33	; Read random
BDOS_RWRITE	EQU	34	; Write random
BDOS_FSIZE	EQU	35	; Compute file size
BDOS_SETREC	EQU	36	; Set random record

; FILE structure offsets (170 bytes total)
FILE_FD		EQU	0	; Slot number (0=stdin,1=stdout,2=stderr,3+=files)
FILE_FLAGS	EQU	1	; bit0=open,bit1=EOF,bit2=error,bit3=write,bit4=read
FILE_UNGET	EQU	2	; Ungetc char (0xFF=none)
FILE_BUFPOS	EQU	3	; Current position in buffer
FILE_BUFCNT	EQU	4	; Valid bytes in buffer (for read)
FILE_RESERVED	EQU	5	; Reserved
FILE_FCB	EQU	6	; FCB starts here (36 bytes)
FILE_BUFFER	EQU	42	; Buffer starts here (128 bytes)
FILE_SIZE	EQU	170	; Total FILE structure size

; Flag bits
FLAG_OPEN	EQU	01H
FLAG_EOF	EQU	02H
FLAG_ERROR	EQU	04H
FLAG_WRITE	EQU	08H
FLAG_READ	EQU	10H

; Standard stream file descriptors
FD_STDIN	EQU	0
FD_STDOUT	EQU	1
FD_STDERR	EQU	2

; Number of file slots (besides stdin/stdout/stderr)
MAX_FILES	EQU	4

; ============================================================
; FILE *fopen(const char *pathname, const char *mode)
; Open a file for reading or writing
; ============================================================
	PUBLIC	_fopen
_fopen:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	PUSH	BC
	PUSH	DE

	; Find free file slot
	LD	HL,_file_slots
	LD	B,MAX_FILES
_fopen_find:
	PUSH	HL
	INC	HL		; Point to flags
	LD	A,(HL)
	AND	FLAG_OPEN
	POP	HL
	JR	Z,_fopen_found
	LD	DE,FILE_SIZE
	ADD	HL,DE
	DJNZ	_fopen_find
	; No free slot
	LD	HL,0
	JP	_fopen_ret

_fopen_found:
	; HL = FILE structure, save it
	PUSH	HL

	; Parse mode string
	LD	L,(IX+6)
	LD	H,(IX+7)	; HL = mode
	LD	A,(HL)
	LD	B,0		; B = mode flags
	CP	'r'
	JR	Z,_fopen_read
	CP	'w'
	JR	Z,_fopen_write
	CP	'a'
	JR	Z,_fopen_append
	; Invalid mode
	POP	HL
	LD	HL,0
	JP	_fopen_ret

_fopen_read:
	LD	B,FLAG_READ
	JR	_fopen_setup

_fopen_write:
	LD	B,FLAG_WRITE
	JR	_fopen_setup

_fopen_append:
	LD	B,FLAG_WRITE	; Append = write mode
	; (simplified: append not fully supported)

_fopen_setup:
	; B = mode flags, stack has FILE*
	POP	HL		; HL = FILE*
	PUSH	HL
	PUSH	BC		; Save mode

	; Initialize FILE structure
	LD	A,3		; fd = 3+ for files
	LD	(HL),A
	INC	HL
	XOR	A
	LD	(HL),A		; flags = 0 (will set later)
	INC	HL
	LD	A,0FFH
	LD	(HL),A		; unget = none
	INC	HL
	XOR	A
	LD	(HL),A		; bufpos = 0
	INC	HL
	LD	(HL),A		; bufcnt = 0
	INC	HL
	LD	(HL),A		; reserved = 0
	INC	HL		; HL now at FCB

	; Clear FCB (36 bytes)
	PUSH	HL
	LD	B,36
_fopen_clr:
	LD	(HL),A
	INC	HL
	DJNZ	_fopen_clr
	POP	HL		; HL = FCB start

	; Parse pathname into FCB
	; HL = FCB, pathname at IX+4
	PUSH	HL
	LD	E,(IX+4)
	LD	D,(IX+5)	; DE = pathname
	CALL	_parse_fcb
	POP	HL		; HL = FCB

	; Get FILE* back
	POP	BC		; B = mode flags
	POP	DE		; DE = FILE*
	PUSH	DE
	PUSH	BC

	; Set DMA to FILE's buffer
	PUSH	HL
	LD	HL,FILE_BUFFER-FILE_FCB
	ADD	HL,DE
	EX	DE,HL		; DE = buffer address
	LD	C,BDOS_SETDMA
	CALL	BDOS
	POP	DE		; DE = FCB

	; Open or create based on mode
	POP	BC		; B = mode flags
	POP	HL		; HL = FILE*
	PUSH	HL
	PUSH	BC

	LD	A,B
	AND	FLAG_WRITE
	JR	Z,_fopen_doopen

	; Write mode - delete existing, create new
	PUSH	DE
	LD	C,BDOS_DELETE
	CALL	BDOS
	POP	DE
	LD	C,BDOS_MAKE
	CALL	BDOS
	JR	_fopen_check

_fopen_doopen:
	; Read mode - open existing
	LD	C,BDOS_OPEN
	CALL	BDOS

_fopen_check:
	; A = 0xFF on error
	CP	0FFH
	JR	NZ,_fopen_ok

	; Open failed
	POP	BC
	POP	HL
	LD	HL,0
	JP	_fopen_ret

_fopen_ok:
	; Set flags and return FILE*
	POP	BC		; B = mode flags
	POP	HL		; HL = FILE*
	PUSH	HL
	INC	HL		; Point to flags
	LD	A,B
	OR	FLAG_OPEN
	LD	(HL),A
	POP	HL		; Return FILE*
	JR	_fopen_ret

_fopen_ret:
	POP	DE
	POP	BC
	POP	IX
	RET

; ============================================================
; Internal: Parse pathname into FCB
; DE = pathname, HL = FCB
; ============================================================
_parse_fcb:
	PUSH	BC
	PUSH	HL

	; Check for drive letter
	LD	A,(DE)
	INC	DE
	LD	B,A
	LD	A,(DE)
	CP	':'
	JR	NZ,_parse_nodrive
	; Has drive letter
	LD	A,B
	AND	0DFH		; Uppercase
	SUB	'A'-1		; A=1, B=2, etc.
	LD	(HL),A
	INC	DE		; Skip colon
	JR	_parse_name

_parse_nodrive:
	DEC	DE		; Back up
	XOR	A		; Default drive
	LD	(HL),A

_parse_name:
	INC	HL		; Point to filename
	LD	B,8		; 8 chars max
_parse_name_loop:
	LD	A,(DE)
	OR	A
	JR	Z,_parse_pad_name
	CP	'.'
	JR	Z,_parse_ext
	; Store uppercase (only for a-z, leave digits etc. alone)
	CP	'a'
	JR	C,_parse_name_store
	CP	'z'+1
	JR	NC,_parse_name_store
	AND	0DFH
_parse_name_store:
	LD	(HL),A
	INC	HL
	INC	DE
	DJNZ	_parse_name_loop
	; Skip to dot or end
_parse_skip:
	LD	A,(DE)
	OR	A
	JR	Z,_parse_pad_name
	CP	'.'
	JR	Z,_parse_ext
	INC	DE
	JR	_parse_skip

_parse_pad_name:
	; Pad remaining name with spaces
	LD	A,' '
_parse_pad_n:
	LD	A,B
	OR	A
	JR	Z,_parse_ext_start
	LD	A,' '
	LD	(HL),A
	INC	HL
	DEC	B
	JR	_parse_pad_n

_parse_ext:
	INC	DE		; Skip dot
	; Pad any remaining name chars
	JR	_parse_pad_name

_parse_ext_start:
	; Now at extension position (FCB+9)
	LD	B,3		; 3 chars max
_parse_ext_loop:
	LD	A,(DE)
	OR	A
	JR	Z,_parse_pad_ext
	; Uppercase only a-z
	CP	'a'
	JR	C,_parse_ext_store
	CP	'z'+1
	JR	NC,_parse_ext_store
	AND	0DFH
_parse_ext_store:
	LD	(HL),A
	INC	HL
	INC	DE
	DJNZ	_parse_ext_loop
	JR	_parse_done

_parse_pad_ext:
	LD	A,B
	OR	A
	JR	Z,_parse_done
	LD	A,' '
	LD	(HL),A
	INC	HL
	DEC	B
	JR	_parse_pad_ext

_parse_done:
	POP	HL
	POP	BC
	RET

; ============================================================
; int fclose(FILE *stream)
; Close a file
; ============================================================
	PUBLIC	_fclose
_fclose:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	PUSH	BC
	PUSH	DE

	LD	L,(IX+4)
	LD	H,(IX+5)	; HL = stream

	; Check for NULL or console streams
	LD	A,H
	OR	L
	JR	Z,_fclose_ok
	LD	A,(HL)
	CP	3
	JR	C,_fclose_ok	; stdin/stdout/stderr

	; Check if open
	INC	HL
	LD	A,(HL)
	AND	FLAG_OPEN
	JR	Z,_fclose_ok

	; If write mode, flush buffer
	LD	A,(HL)
	AND	FLAG_WRITE
	JR	Z,_fclose_doclose

	; Flush write buffer
	DEC	HL
	PUSH	HL
	CALL	_fflush_internal
	POP	HL
	INC	HL

_fclose_doclose:
	DEC	HL		; Back to FILE start
	PUSH	HL

	; Set DMA and close
	LD	DE,FILE_FCB
	ADD	HL,DE
	EX	DE,HL		; DE = FCB

	LD	C,BDOS_CLOSE
	CALL	BDOS

	; Clear flags
	POP	HL
	INC	HL		; flags
	LD	(HL),0

_fclose_ok:
	LD	HL,0
	POP	DE
	POP	BC
	POP	IX
	RET

; ============================================================
; int fgetc(FILE *stream)
; Get character from stream
; ============================================================
	PUBLIC	_fgetc
_fgetc:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	PUSH	BC
	PUSH	DE

	LD	L,(IX+4)
	LD	H,(IX+5)	; HL = stream

	; Check for NULL
	LD	A,H
	OR	L
	JP	Z,_fgetc_eof

	; Check if stdin
	LD	A,(HL)
	OR	A
	JR	NZ,_fgetc_file

	; stdin - read from console
	LD	C,CONIN
	CALL	BDOS
	LD	L,A
	LD	H,0
	JP	_fgetc_ret

_fgetc_file:
	; Check for ungetc char first
	PUSH	HL
	INC	HL
	INC	HL		; unget
	LD	A,(HL)
	CP	0FFH
	JR	Z,_fgetc_nobuf
	; Return unget char
	LD	B,A
	LD	A,0FFH
	LD	(HL),A		; Clear unget
	POP	HL
	LD	L,B
	LD	H,0
	JP	_fgetc_ret

_fgetc_nobuf:
	POP	HL

	; Check EOF flag
	PUSH	HL
	INC	HL		; flags
	LD	A,(HL)
	AND	FLAG_EOF
	JR	NZ,_fgetc_iseof

	; Check if buffer has data
	INC	HL		; unget
	INC	HL		; bufpos
	LD	B,(HL)
	INC	HL		; bufcnt
	LD	A,(HL)
	CP	B		; bufcnt > bufpos?
	JR	Z,_fgetc_refill
	JR	C,_fgetc_refill

	; Get byte from buffer
	POP	HL
	PUSH	HL
	LD	DE,FILE_BUFFER
	ADD	HL,DE		; HL = buffer start
	LD	E,B
	LD	D,0
	ADD	HL,DE		; HL = buffer[bufpos]
	LD	A,(HL)
	; Check for Ctrl-Z (CP/M EOF marker)
	CP	1AH
	JR	Z,_fgetc_seteof
	LD	E,A		; Save char

	; Increment bufpos
	POP	HL
	PUSH	HL
	LD	BC,FILE_BUFPOS
	ADD	HL,BC
	INC	(HL)

	; Skip CR characters for Unix text compatibility
	LD	A,E
	CP	0DH
	JP	Z,_fgetc_nobuf	; Skip CR, get next char

	POP	HL
	LD	L,E
	LD	H,0
	JP	_fgetc_ret

_fgetc_refill:
	; Need to read more data
	POP	HL
	PUSH	HL

	; Set DMA to buffer
	LD	DE,FILE_BUFFER
	ADD	HL,DE
	EX	DE,HL
	LD	C,BDOS_SETDMA
	CALL	BDOS

	; Read record
	POP	HL
	PUSH	HL
	LD	DE,FILE_FCB
	ADD	HL,DE
	EX	DE,HL
	LD	C,BDOS_READ
	CALL	BDOS

	; A = 0 success, non-zero = EOF/error
	OR	A
	JR	NZ,_fgetc_seteof

	; Reset buffer position, set count
	POP	HL
	PUSH	HL
	LD	BC,FILE_BUFPOS
	ADD	HL,BC
	LD	(HL),0		; bufpos = 0
	INC	HL
	LD	(HL),128	; bufcnt = 128

	; Get first byte
	POP	HL
	PUSH	HL
	LD	DE,FILE_BUFFER
	ADD	HL,DE
	LD	A,(HL)
	; Check for Ctrl-Z (CP/M EOF marker)
	CP	1AH
	JR	Z,_fgetc_seteof
	LD	E,A

	; Increment bufpos
	POP	HL
	PUSH	HL
	LD	BC,FILE_BUFPOS
	ADD	HL,BC
	INC	(HL)

	; Skip CR characters for Unix text compatibility
	LD	A,E
	CP	0DH
	JP	Z,_fgetc_nobuf	; Skip CR, get next char

	POP	HL
	LD	L,E
	LD	H,0
	JP	_fgetc_ret

_fgetc_seteof:
	POP	HL
	PUSH	HL
	INC	HL		; flags
	LD	A,(HL)
	OR	FLAG_EOF
	LD	(HL),A
_fgetc_iseof:
	POP	HL
_fgetc_eof:
	LD	HL,-1
_fgetc_ret:
	POP	DE
	POP	BC
	POP	IX
	RET

; ============================================================
; int fputc(int c, FILE *stream)
; Put character to stream
; ============================================================
	PUBLIC	_fputc
_fputc:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	PUSH	BC
	PUSH	DE

	LD	L,(IX+6)
	LD	H,(IX+7)	; HL = stream

	; Check for NULL
	LD	A,H
	OR	L
	JP	Z,_fputc_err

	; Check if stdout/stderr
	LD	A,(HL)
	CP	3
	JR	NC,_fputc_file

	; Console output
	LD	E,(IX+4)
	LD	C,CONOUT
	CALL	BDOS
	LD	L,(IX+4)
	LD	H,0
	JP	_fputc_ret

_fputc_file:
	; Check if buffer full
	PUSH	HL
	LD	BC,FILE_BUFPOS
	ADD	HL,BC
	LD	A,(HL)
	CP	128
	JR	C,_fputc_store

	; Buffer full - flush it
	POP	HL
	PUSH	HL
	CALL	_fflush_internal
	; Check for error
	LD	A,H
	OR	L
	JR	NZ,_fputc_flerr
	POP	HL
	PUSH	HL
	LD	BC,FILE_BUFPOS
	ADD	HL,BC

_fputc_store:
	; Store byte in buffer
	LD	A,(HL)		; A = bufpos
	POP	HL
	PUSH	HL
	LD	DE,FILE_BUFFER
	ADD	HL,DE
	LD	E,A
	LD	D,0
	ADD	HL,DE		; HL = buffer[bufpos]
	LD	A,(IX+4)
	LD	(HL),A		; Store the byte

	; Increment bufpos
	POP	HL
	PUSH	HL
	LD	DE,FILE_BUFPOS
	ADD	HL,DE
	INC	(HL)		; bufpos++

	POP	HL
	LD	L,(IX+4)
	LD	H,0
	JP	_fputc_ret

_fputc_flerr:
	POP	HL
_fputc_err:
	LD	HL,-1
_fputc_ret:
	POP	DE
	POP	BC
	POP	IX
	RET

; ============================================================
; Internal: Flush write buffer
; HL = FILE*
; Returns HL=0 success, HL=-1 error
; ============================================================
_fflush_internal:
	PUSH	BC
	PUSH	DE
	PUSH	HL

	; Check bufpos
	LD	BC,FILE_BUFPOS
	ADD	HL,BC
	LD	A,(HL)
	OR	A
	JR	Z,_fflush_ok	; Nothing to flush

	; Pad rest of buffer with Ctrl-Z (CP/M EOF)
	LD	B,A		; B = bytes written
	POP	HL
	PUSH	HL
	LD	DE,FILE_BUFFER
	ADD	HL,DE
	LD	E,B
	LD	D,0
	ADD	HL,DE		; HL = buffer[bufpos]
	LD	A,128
	SUB	B
	LD	B,A		; B = bytes to pad
	JR	Z,_fflush_write
	LD	A,1AH		; Ctrl-Z
_fflush_pad:
	LD	(HL),A
	INC	HL
	DJNZ	_fflush_pad

_fflush_write:
	; Set DMA
	POP	HL
	PUSH	HL
	LD	DE,FILE_BUFFER
	ADD	HL,DE
	EX	DE,HL
	LD	C,BDOS_SETDMA
	CALL	BDOS

	; Write record
	POP	HL
	PUSH	HL
	LD	DE,FILE_FCB
	ADD	HL,DE
	EX	DE,HL
	LD	C,BDOS_WRITE
	CALL	BDOS

	OR	A
	JR	NZ,_fflush_err

	; Reset bufpos
	POP	HL
	PUSH	HL
	LD	BC,FILE_BUFPOS
	ADD	HL,BC
	LD	(HL),0

_fflush_ok:
	POP	HL
	LD	HL,0
	POP	DE
	POP	BC
	RET

_fflush_err:
	POP	HL
	PUSH	HL
	INC	HL		; flags
	LD	A,(HL)
	OR	FLAG_ERROR
	LD	(HL),A
	POP	HL
	LD	HL,-1
	POP	DE
	POP	BC
	RET

; ============================================================
; char *fgets(char *s, int size, FILE *stream)
; Read line from stream
; ============================================================
	PUBLIC	_fgets
_fgets:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	PUSH	BC
	PUSH	DE

	LD	L,(IX+8)
	LD	H,(IX+9)	; stream
	LD	A,H
	OR	L
	JR	Z,_fgets_null

	LD	E,(IX+4)	; buffer
	LD	D,(IX+5)
	LD	C,(IX+6)	; size
	LD	B,(IX+7)
	PUSH	DE		; Save for return

	DEC	BC		; Leave room for null
	LD	A,B
	OR	C
	JR	Z,_fgets_term

_fgets_loop:
	PUSH	BC
	PUSH	DE
	PUSH	HL		; Save stream
	PUSH	HL		; Pass stream as arg
	CALL	_fgetc
	POP	BC		; Discard arg
	; HL = fgetc return value, save it
	LD	A,H		; Check high byte first
	LD	B,L		; B = character (save before POP)
	POP	HL		; Restore stream to HL
	OR	A
	JR	NZ,_fgets_eof	; EOF if H != 0 (return was 0xFFxx)
	LD	A,B		; A = character
	POP	DE		; Restore dest pointer
	POP	BC		; Restore count

	LD	(DE),A
	INC	DE
	DEC	BC

	CP	0AH		; LF?
	JR	Z,_fgets_term
	CP	0DH		; CR?
	JR	Z,_fgets_term

	LD	A,B
	OR	C
	JR	NZ,_fgets_loop

_fgets_term:
	XOR	A
	LD	(DE),A
	POP	HL		; Return buffer
	POP	DE
	POP	BC
	POP	IX
	RET

_fgets_eof:
	; Stack has: [BC_count][DE_dest]
	; HL = stream (just restored)
	POP	DE		; Restore dest pointer
	POP	BC		; Restore count
	; Check if we read anything
	LD	A,(IX+4)
	CP	E
	JR	NZ,_fgets_term	; Got some data
	LD	A,(IX+5)
	CP	D
	JR	NZ,_fgets_term
	; No data read - return NULL
	; Pop saved buffer before going to _fgets_null
	POP	DE
_fgets_null:
	LD	HL,0
	POP	DE
	POP	BC
	POP	IX
	RET

; ============================================================
; int fputs(const char *s, FILE *stream)
; Write string to stream
; ============================================================
	PUBLIC	_fputs
_fputs:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	PUSH	BC
	PUSH	DE

	LD	L,(IX+6)
	LD	H,(IX+7)	; stream
	LD	A,H
	OR	L
	JR	Z,_fputs_err

	LD	E,(IX+4)	; string
	LD	D,(IX+5)

_fputs_loop:
	LD	A,(DE)
	OR	A
	JR	Z,_fputs_ok

	PUSH	DE
	PUSH	HL
	; Push args for fputc(char, stream)
	PUSH	HL		; stream
	LD	L,A
	LD	H,0
	PUSH	HL		; char
	CALL	_fputc
	POP	BC
	POP	BC
	POP	HL
	POP	DE

	; Check for error
	LD	A,H
	INC	A
	JR	Z,_fputs_err	; HL was -1

	INC	DE
	JR	_fputs_loop

_fputs_ok:
	LD	HL,0
	POP	DE
	POP	BC
	POP	IX
	RET

_fputs_err:
	LD	HL,-1
	POP	DE
	POP	BC
	POP	IX
	RET

; ============================================================
; size_t fread(void *ptr, size_t size, size_t nmemb, FILE *stream)
; Read data from stream
; ============================================================
	PUBLIC	_fread
_fread:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	PUSH	BC
	PUSH	DE

	; Calculate total bytes = size * nmemb
	LD	L,(IX+6)
	LD	H,(IX+7)	; size
	LD	E,(IX+8)
	LD	D,(IX+9)	; nmemb
	CALL	__mul16		; HL = total bytes
	LD	B,H
	LD	C,L		; BC = bytes to read

	; If zero, return 0
	LD	A,B
	OR	C
	JR	Z,_fread_done

	; Save dest pointer
	LD	L,(IX+4)
	LD	H,(IX+5)	; HL = dest ptr
	LD	(_fread_ptr),HL

	; Initialize read count
	LD	HL,0
	LD	(_fread_cnt),HL

_fread_loop:
	; Call fgetc(stream)
	LD	L,(IX+10)
	LD	H,(IX+11)	; stream
	PUSH	BC		; Save remaining count
	PUSH	HL
	CALL	_fgetc
	POP	DE		; Clean up arg

	; Check for EOF (returns -1 = 0xFFFF)
	LD	A,H
	AND	L
	INC	A		; If HL=0xFFFF, A becomes 0
	JR	Z,_fread_eof

	; Store byte
	LD	A,L
	LD	HL,(_fread_ptr)
	LD	(HL),A
	INC	HL
	LD	(_fread_ptr),HL

	; Increment count
	LD	HL,(_fread_cnt)
	INC	HL
	LD	(_fread_cnt),HL

	; Decrement BC and continue
	POP	BC		; Restore remaining count
	DEC	BC
	LD	A,B
	OR	C
	JR	NZ,_fread_loop
	JR	_fread_done

_fread_eof:
	POP	BC		; Clean up saved count

_fread_done:
	; Return items read (cnt / size)
	; __div16 does HL = DE / HL, so DE = cnt, HL = size
	LD	E,(IX+6)
	LD	D,(IX+7)	; DE = size (temporarily)
	LD	A,D
	OR	E
	JR	Z,_fread_ret
	LD	HL,(_fread_cnt)	; HL = cnt
	EX	DE,HL		; Now DE = cnt, HL = size
	CALL	__div16		; HL = cnt / size

_fread_ret:
	POP	DE
	POP	BC
	POP	IX
	RET

; ============================================================
; size_t fwrite(const void *ptr, size_t size, size_t nmemb, FILE *stream)
; Write data to stream
; ============================================================
	PUBLIC	_fwrite
	EXTRN	__div16
_fwrite:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	PUSH	BC
	PUSH	DE

	; Simple implementation - write byte by byte
	LD	L,(IX+6)
	LD	H,(IX+7)	; size
	LD	E,(IX+8)
	LD	D,(IX+9)	; nmemb
	CALL	__mul16		; HL = total bytes
	LD	B,H
	LD	C,L		; BC = bytes to write

	LD	A,B
	OR	C
	JR	Z,_fwrite_done

	LD	L,(IX+4)
	LD	H,(IX+5)	; HL = ptr (source)
	LD	(_fwrite_ptr),HL
	LD	HL,0
	LD	(_fwrite_cnt),HL

_fwrite_loop:
	LD	A,B
	OR	C
	JR	Z,_fwrite_done

	; Get byte from source
	LD	HL,(_fwrite_ptr)
	LD	A,(HL)
	INC	HL
	LD	(_fwrite_ptr),HL

	; Write to stream
	PUSH	BC
	LD	L,(IX+10)
	LD	H,(IX+11)	; stream
	PUSH	HL
	LD	L,A
	LD	H,0
	PUSH	HL
	CALL	_fputc
	POP	HL
	POP	HL
	POP	BC

	; Check error
	LD	A,H
	INC	A
	JR	Z,_fwrite_done	; Error

	LD	HL,(_fwrite_cnt)
	INC	HL
	LD	(_fwrite_cnt),HL
	DEC	BC
	JR	_fwrite_loop

_fwrite_done:
	; Return items written (cnt / size)
	; __div16 does HL = DE / HL, so DE = cnt, HL = size
	LD	E,(IX+6)
	LD	D,(IX+7)	; DE = size (temporarily)
	LD	A,D
	OR	E
	JR	Z,_fwrite_ret
	LD	HL,(_fwrite_cnt)	; HL = cnt
	EX	DE,HL		; Now DE = cnt, HL = size
	CALL	__div16		; HL = cnt / size
_fwrite_ret:
	POP	DE
	POP	BC
	POP	IX
	RET

; ============================================================
; int feof(FILE *stream)
; Check EOF flag
; ============================================================
	PUBLIC	_feof
_feof:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	LD	L,(IX+4)
	LD	H,(IX+5)
	LD	A,H
	OR	L
	JR	Z,_feof_yes
	INC	HL		; flags
	LD	A,(HL)
	AND	FLAG_EOF
	LD	L,A
	LD	H,0
	POP	IX
	RET
_feof_yes:
	LD	HL,1
	POP	IX
	RET

; ============================================================
; int ferror(FILE *stream)
; Check error flag
; ============================================================
	PUBLIC	_ferror
_ferror:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	LD	L,(IX+4)
	LD	H,(IX+5)
	LD	A,H
	OR	L
	JR	Z,_ferror_yes
	INC	HL		; flags
	LD	A,(HL)
	AND	FLAG_ERROR
	JR	Z,_ferror_no
	LD	HL,1
	POP	IX
	RET
_ferror_no:
	LD	HL,0
	POP	IX
	RET
_ferror_yes:
	LD	HL,1
	POP	IX
	RET

; ============================================================
; void clearerr(FILE *stream)
; Clear error and EOF flags
; ============================================================
	PUBLIC	_clearerr
_clearerr:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	LD	L,(IX+4)
	LD	H,(IX+5)
	LD	A,H
	OR	L
	JR	Z,_clearerr_ret
	INC	HL		; flags
	LD	A,(HL)
	AND	0FFH - FLAG_EOF - FLAG_ERROR
	LD	(HL),A
_clearerr_ret:
	POP	IX
	RET

; ============================================================
; int ungetc(int c, FILE *stream)
; Push character back to stream
; ============================================================
	PUBLIC	_ungetc
_ungetc:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	LD	L,(IX+6)
	LD	H,(IX+7)	; stream
	LD	A,H
	OR	L
	JR	Z,_ungetc_err
	INC	HL
	INC	HL		; unget
	LD	A,(IX+4)
	LD	(HL),A
	LD	L,A
	LD	H,0
	POP	IX
	RET
_ungetc_err:
	LD	HL,-1
	POP	IX
	RET

; ============================================================
; int fflush(FILE *stream)
; Flush stream buffers
; ============================================================
	PUBLIC	_fflush
_fflush:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	PUSH	BC
	PUSH	DE

	LD	L,(IX+4)
	LD	H,(IX+5)
	LD	A,H
	OR	L
	JR	Z,_fflush_done_pub

	; Check if file (not console)
	LD	A,(HL)
	CP	3
	JR	C,_fflush_done_pub

	; Check write mode
	INC	HL
	LD	A,(HL)
	AND	FLAG_WRITE
	DEC	HL
	JR	Z,_fflush_done_pub

	CALL	_fflush_internal
	POP	DE
	POP	BC
	POP	IX
	RET

_fflush_done_pub:
	LD	HL,0
	POP	DE
	POP	BC
	POP	IX
	RET

; ============================================================
; int fseek(FILE *stream, long offset, int whence)
; Seek to position in file (simplified - sector-based)
; ============================================================
	PUBLIC	_fseek
_fseek:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	PUSH	BC
	PUSH	DE

	LD	L,(IX+4)
	LD	H,(IX+5)	; stream
	LD	A,H
	OR	L
	JR	Z,_fseek_err

	; Check if file
	LD	A,(HL)
	CP	3
	JR	C,_fseek_err

	; Flush buffer first if write mode
	PUSH	HL
	INC	HL
	LD	A,(HL)
	AND	FLAG_WRITE
	JR	Z,_fseek_noflush
	DEC	HL
	CALL	_fflush_internal
	JR	_fseek_doset
_fseek_noflush:
	DEC	HL
_fseek_doset:
	POP	HL
	PUSH	HL

	; Get offset (lower 16 bits only for simplicity)
	LD	E,(IX+6)
	LD	D,(IX+7)	; offset low word

	; Check whence
	LD	A,(IX+10)
	OR	A
	JR	NZ,_fseek_err_pop	; Only SEEK_SET supported

	; Convert byte offset to record number (divide by 128)
	; Shift DE right 7 times
	SRL	D
	RR	E
	SRL	D
	RR	E
	SRL	D
	RR	E
	SRL	D
	RR	E
	SRL	D
	RR	E
	SRL	D
	RR	E
	SRL	D
	RR	E		; DE = record number

	; Set random record in FCB
	POP	HL
	PUSH	HL
	LD	BC,FILE_FCB+33	; r0, r1 in FCB
	ADD	HL,BC
	LD	(HL),E		; r0
	INC	HL
	LD	(HL),D		; r1
	INC	HL
	LD	(HL),0		; r2

	; Clear buffer
	POP	HL
	PUSH	HL
	LD	BC,FILE_BUFPOS
	ADD	HL,BC
	LD	(HL),0		; bufpos
	INC	HL
	LD	(HL),0		; bufcnt

	; Clear EOF flag
	POP	HL
	PUSH	HL
	INC	HL
	LD	A,(HL)
	AND	0FFH - FLAG_EOF
	LD	(HL),A

	POP	HL
	LD	HL,0
	POP	DE
	POP	BC
	POP	IX
	RET

_fseek_err_pop:
	POP	HL
_fseek_err:
	LD	HL,-1
	POP	DE
	POP	BC
	POP	IX
	RET

; ============================================================
; long ftell(FILE *stream)
; Return current position (simplified)
; ============================================================
	PUBLIC	_ftell
_ftell:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP

	LD	L,(IX+4)
	LD	H,(IX+5)
	LD	A,H
	OR	L
	JR	Z,_ftell_err

	LD	A,(HL)
	CP	3
	JR	C,_ftell_err

	; Get record number from FCB
	LD	DE,FILE_FCB+33
	ADD	HL,DE
	LD	E,(HL)		; r0
	INC	HL
	LD	D,(HL)		; r1

	; Convert to byte offset (multiply by 128)
	; Shift DE left 7 times, result in DEHL
	LD	H,D
	LD	L,E
	LD	DE,0

	SLA	L
	RL	H
	RL	E
	RL	D		; x2
	SLA	L
	RL	H
	RL	E
	RL	D		; x4
	SLA	L
	RL	H
	RL	E
	RL	D		; x8
	SLA	L
	RL	H
	RL	E
	RL	D		; x16
	SLA	L
	RL	H
	RL	E
	RL	D		; x32
	SLA	L
	RL	H
	RL	E
	RL	D		; x64
	SLA	L
	RL	H
	RL	E
	RL	D		; x128

	; Add buffer position
	; (simplified - not adding bufpos)
	POP	IX
	RET

_ftell_err:
	LD	HL,-1
	LD	DE,-1
	POP	IX
	RET

; ============================================================
; void rewind(FILE *stream)
; Rewind to beginning of file
; ============================================================
	PUBLIC	_rewind
_rewind:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	PUSH	BC
	PUSH	DE

	; Call fseek(stream, 0L, SEEK_SET)
	LD	L,(IX+4)
	LD	H,(IX+5)
	PUSH	HL
	LD	HL,0
	PUSH	HL		; whence = SEEK_SET
	PUSH	HL		; offset high = 0
	PUSH	HL		; offset low = 0
	LD	L,(IX+4)
	LD	H,(IX+5)
	PUSH	HL		; stream
	CALL	_fseek
	POP	HL
	POP	HL
	POP	HL
	POP	HL
	POP	HL

	POP	DE
	POP	BC
	POP	IX
	RET

; ============================================================
; int remove(const char *pathname)
; Delete a file
; Returns 0 on success, -1 on error
; ============================================================
	PUBLIC	_remove
_remove:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	PUSH	BC
	PUSH	DE

	; Parse pathname into temporary FCB
	LD	E,(IX+4)
	LD	D,(IX+5)	; DE = pathname
	LD	HL,_tmp_fcb
	CALL	_parse_fcb

	; Delete the file
	LD	DE,_tmp_fcb
	LD	C,BDOS_DELETE
	CALL	BDOS

	; A = 0xFF on error
	CP	0FFH
	JR	Z,_remove_err
	LD	HL,0
	JR	_remove_ret
_remove_err:
	LD	HL,-1
_remove_ret:
	POP	DE
	POP	BC
	POP	IX
	RET

; ============================================================
; int rename(const char *oldpath, const char *newpath)
; Rename a file
; Returns 0 on success, -1 on error
; ============================================================
	PUBLIC	_rename
_rename:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	PUSH	BC
	PUSH	DE

	; Parse old pathname into FCB (first 16 bytes)
	LD	E,(IX+4)
	LD	D,(IX+5)	; DE = oldpath
	LD	HL,_tmp_fcb
	CALL	_parse_fcb

	; Parse new pathname into FCB+16 (destination)
	LD	E,(IX+6)
	LD	D,(IX+7)	; DE = newpath
	LD	HL,_tmp_fcb+16
	CALL	_parse_fcb

	; CP/M rename uses DE pointing to FCB with old name in first 16 bytes
	; and new name in second 16 bytes
	LD	DE,_tmp_fcb
	LD	C,BDOS_RENAME
	CALL	BDOS

	; A = 0xFF on error
	CP	0FFH
	JR	Z,_rename_err
	LD	HL,0
	JR	_rename_ret
_rename_err:
	LD	HL,-1
_rename_ret:
	POP	DE
	POP	BC
	POP	IX
	RET

; ============================================================
; FILE *tmpfile(void)
; Create and open a temporary file for writing
; File is automatically deleted when closed (by using $$$ extension)
; ============================================================
	PUBLIC	_tmpfile
_tmpfile:
	PUSH	IX
	PUSH	BC
	PUSH	DE

	; Generate unique temp name
	LD	HL,_tmpfile_name
	CALL	_gen_tmpnam

	; Open with "w+" mode (create new)
	LD	HL,_tmpfile_name
	PUSH	HL
	LD	HL,_tmpfile_mode
	PUSH	HL
	CALL	_fopen
	POP	BC
	POP	BC

	; Mark this file for delete on close (use $$$ extension)
	; Actually, CP/M doesn't have auto-delete, so we rely on unique names

	POP	DE
	POP	BC
	POP	IX
	RET

_tmpfile_mode:
	DB	'w',0

; ============================================================
; char *tmpnam(char *s)
; Generate a unique temporary file name
; If s is NULL, returns pointer to internal static buffer
; ============================================================
	PUBLIC	_tmpnam
_tmpnam:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	PUSH	BC
	PUSH	DE

	; Get buffer pointer
	LD	L,(IX+4)
	LD	H,(IX+5)
	LD	A,H
	OR	L
	JR	NZ,_tmpnam_usebuf
	; Use internal buffer
	LD	HL,_tmpnam_buf
_tmpnam_usebuf:
	PUSH	HL		; Save destination
	CALL	_gen_tmpnam
	POP	HL		; Return destination

	POP	DE
	POP	BC
	POP	IX
	RET

; Internal: Generate temp name into HL
_gen_tmpnam:
	PUSH	BC
	PUSH	DE
	PUSH	HL

	; Format: TMP00000.$$$
	LD	(HL),'T'
	INC	HL
	LD	(HL),'M'
	INC	HL
	LD	(HL),'P'
	INC	HL

	; Get counter and convert to 5 digits
	LD	DE,(_tmpnam_cnt)
	INC	DE
	LD	(_tmpnam_cnt),DE

	; Convert DE to 5 decimal digits
	LD	BC,10000
	CALL	_div16
	ADD	A,'0'
	LD	(HL),A
	INC	HL
	; Remainder in DE
	LD	BC,1000
	CALL	_div16
	ADD	A,'0'
	LD	(HL),A
	INC	HL
	LD	BC,100
	CALL	_div16
	ADD	A,'0'
	LD	(HL),A
	INC	HL
	LD	BC,10
	CALL	_div16
	ADD	A,'0'
	LD	(HL),A
	INC	HL
	LD	A,E
	ADD	A,'0'
	LD	(HL),A
	INC	HL

	; Add .$$$ extension
	LD	(HL),'.'
	INC	HL
	LD	(HL),'$'
	INC	HL
	LD	(HL),'$'
	INC	HL
	LD	(HL),'$'
	INC	HL
	LD	(HL),0

	POP	HL
	POP	DE
	POP	BC
	RET

; Internal: Divide DE by BC, quotient in A, remainder in DE
_div16:
	XOR	A
_div16_loop:
	LD	H,D
	LD	L,E
	OR	A
	SBC	HL,BC
	JR	C,_div16_done
	EX	DE,HL
	INC	A
	JR	_div16_loop
_div16_done:
	RET

_tmpnam_cnt:
	DW	0
_tmpnam_buf:
	DS	13		; TMP00000.$$$ + null
_tmpfile_name:
	DS	13

; ============================================================
; FILE *freopen(const char *pathname, const char *mode, FILE *stream)
; Reopen stream with new file
; ============================================================
	PUBLIC	_freopen
_freopen:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	PUSH	BC
	PUSH	DE

	; Close current stream
	LD	L,(IX+8)
	LD	H,(IX+9)
	PUSH	HL
	CALL	_fclose
	POP	BC

	; Now reopen with new file
	; Can't use the same FILE slot reliably, so just call fopen
	LD	L,(IX+4)
	LD	H,(IX+5)	; pathname
	PUSH	HL
	LD	L,(IX+6)
	LD	H,(IX+7)	; mode
	PUSH	HL
	CALL	_fopen
	POP	BC
	POP	BC

	; HL = new FILE* or NULL
	POP	DE
	POP	BC
	POP	IX
	RET

; ============================================================
; int getc(FILE *stream)
; Get character from stream (equivalent to fgetc)
; ============================================================
	PUBLIC	_getc
_getc:
	JP	_fgetc		; Just tail-call fgetc

; ============================================================
; int putc(int c, FILE *stream)
; Put character to stream (equivalent to fputc)
; ============================================================
	PUBLIC	_putc
_putc:
	JP	_fputc		; Just tail-call fputc

; ============================================================
; int fgetpos(FILE *stream, fpos_t *pos)
; Get current file position
; Returns 0 on success, non-zero on error
; ============================================================
	PUBLIC	_fgetpos
_fgetpos:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	PUSH	BC
	PUSH	DE

	; Call ftell to get position
	LD	L,(IX+4)
	LD	H,(IX+5)	; stream
	PUSH	HL
	CALL	_ftell
	POP	BC
	; DEHL = position (long)

	; Check for error (returns -1 as 0xFFFFFFFF)
	LD	A,D
	AND	E
	AND	H
	AND	L
	INC	A
	JR	Z,_fgetpos_err

	; Store position at *pos
	LD	C,(IX+6)
	LD	B,(IX+7)	; BC = pos pointer
	LD	A,L
	LD	(BC),A
	INC	BC
	LD	A,H
	LD	(BC),A
	INC	BC
	LD	A,E
	LD	(BC),A
	INC	BC
	LD	A,D
	LD	(BC),A

	LD	HL,0		; Return success
	JR	_fgetpos_ret

_fgetpos_err:
	LD	HL,-1
_fgetpos_ret:
	POP	DE
	POP	BC
	POP	IX
	RET

; ============================================================
; int fsetpos(FILE *stream, const fpos_t *pos)
; Set file position
; Returns 0 on success, non-zero on error
; ============================================================
	PUBLIC	_fsetpos
_fsetpos:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	PUSH	BC
	PUSH	DE

	; Load position from *pos
	LD	L,(IX+6)
	LD	H,(IX+7)	; HL = pos pointer
	LD	E,(HL)
	INC	HL
	LD	D,(HL)
	INC	HL
	LD	C,(HL)
	INC	HL
	LD	B,(HL)		; BCDE = position
	PUSH	BC		; High word
	PUSH	DE		; Low word

	; Call fseek(stream, pos, SEEK_SET)
	LD	HL,0
	PUSH	HL		; whence = SEEK_SET
	LD	L,(IX+4)
	LD	H,(IX+5)
	PUSH	HL		; stream
	; Stack: stream, whence(0), pos_low, pos_high
	; fseek expects: stream, offset_low, offset_high, whence
	; Need to rearrange...

	; Actually let's redo this properly
	POP	HL		; stream
	POP	BC		; whence
	POP	DE		; pos low
	POP	BC		; pos high
	; Now push in correct order for fseek(stream, offset, whence)
	LD	A,0
	PUSH	AF		; whence = SEEK_SET (use AF as 16-bit 0)
	INC	SP		; Adjust for 1-byte push
	DEC	SP
	LD	HL,0
	PUSH	HL		; whence = 0
	PUSH	BC		; offset high
	PUSH	DE		; offset low
	LD	L,(IX+4)
	LD	H,(IX+5)
	PUSH	HL		; stream
	CALL	_fseek
	; Clean up stack (5 words = 10 bytes)
	LD	HL,10
	ADD	HL,SP
	LD	SP,HL

	; fseek returns 0 on success, -1 on error
	; HL already has return value

	POP	DE
	POP	BC
	POP	IX
	RET

; ============================================================
; void setbuf(FILE *stream, char *buf)
; Set stream buffer (no-op on CP/M - fixed buffers)
; ============================================================
	PUBLIC	_setbuf
_setbuf:
	; No-op - CP/M uses fixed 128-byte buffers
	RET

; ============================================================
; int setvbuf(FILE *stream, char *buf, int mode, size_t size)
; Set stream buffering (limited support on CP/M)
; ============================================================
	PUBLIC	_setvbuf
_setvbuf:
	; No-op - CP/M uses fixed 128-byte buffers
	; Always return 0 (success) for compatibility
	LD	HL,0
	RET

; ============================================================
; void perror(const char *s)
; Print error message to stderr
; ============================================================
	PUBLIC	_perror
_perror:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	PUSH	BC
	PUSH	DE

	; Print user string if provided
	LD	L,(IX+4)
	LD	H,(IX+5)
	LD	A,H
	OR	L
	JR	Z,_perror_errmsg
	LD	A,(HL)
	OR	A
	JR	Z,_perror_errmsg

	; Print user string
_perror_uloop:
	LD	A,(HL)
	OR	A
	JR	Z,_perror_colon
	LD	E,A
	PUSH	HL
	LD	C,CONOUT
	CALL	BDOS
	POP	HL
	INC	HL
	JR	_perror_uloop

_perror_colon:
	; Print ": "
	LD	E,':'
	LD	C,CONOUT
	CALL	BDOS
	LD	E,' '
	LD	C,CONOUT
	CALL	BDOS

_perror_errmsg:
	; Print generic error message (CP/M doesn't have errno)
	LD	HL,_perror_msg
_perror_loop:
	LD	A,(HL)
	OR	A
	JR	Z,_perror_nl
	LD	E,A
	PUSH	HL
	LD	C,CONOUT
	CALL	BDOS
	POP	HL
	INC	HL
	JR	_perror_loop

_perror_nl:
	; Print newline
	LD	E,13
	LD	C,CONOUT
	CALL	BDOS
	LD	E,10
	LD	C,CONOUT
	CALL	BDOS

	POP	DE
	POP	BC
	POP	IX
	RET

_perror_msg:
	DB	'Error',0

; Temporary FCB for remove/rename operations
_tmp_fcb:
	DS	36


	DSEG

; File slot storage
_file_slots:	DS	680	; 4 FILE structures * 170 bytes each
_fread_ptr:	DS	2	; fread dest pointer temp
_fread_cnt:	DS	2	; fread byte counter temp
_fwrite_ptr:	DS	2	; fwrite source pointer temp
_fwrite_cnt:	DS	2	; fwrite byte counter temp


; ============================================================
; lc_floor.mac
; ============================================================
	CSEG
; lc_floor.mac - floor, ceil, trunc, round and f/l variants


	EXTRN	__fadd
	EXTRN	__fsub
	EXTRN	__ftoi
	EXTRN	__itof
	EXTRN	__tmp32

	CSEG

; ============================================================
; floor(x) - round toward negative infinity
; ============================================================
	PUBLIC	_floor
	PUBLIC	_floorf
	PUBLIC	_floorl
_floor:
_floorf:
_floorl:
	PUSH	IX
	PUSH	BC
	LD	IX,0
	ADD	IX,SP

	CALL	_math_getarg
	LD	(_floor_x),HL
	LD	(_floor_x+2),DE

	; Save sign
	LD	A,D
	AND	80H
	LD	(_floor_sign),A

	; trunc(x)
	CALL	__ftoi
	CALL	__itof
	LD	(_floor_t),HL
	LD	(_floor_t+2),DE

	; If positive, done
	LD	A,(_floor_sign)
	OR	A
	JR	Z,_floor_ret

	; Negative: check if x == trunc(x)
	LD	(__tmp32),HL
	LD	(__tmp32+2),DE
	LD	HL,(_floor_x)
	LD	DE,(_floor_x+2)
	CALL	__fsub		; x - trunc(x)

	; If fractional part is 0, done
	LD	A,D
	AND	7FH
	OR	E
	OR	H
	OR	L
	JR	Z,_floor_ret

	; Subtract 1.0 from trunc(x)
	LD	HL,0
	LD	DE,3F80H	; 1.0
	LD	(__tmp32),HL
	LD	(__tmp32+2),DE
	LD	HL,(_floor_t)
	LD	DE,(_floor_t+2)
	CALL	__fsub		; trunc(x) - 1.0

	JR	_floor_done

_floor_ret:
	LD	HL,(_floor_t)
	LD	DE,(_floor_t+2)

_floor_done:
	POP	BC
	POP	IX
	RET

; ============================================================
; ceil(x) = -floor(-x)
; ============================================================
	PUBLIC	_ceil
	PUBLIC	_ceilf
	PUBLIC	_ceill
_ceil:
_ceilf:
_ceill:
	PUSH	IX
	PUSH	BC
	LD	IX,0
	ADD	IX,SP

	CALL	_math_getarg

	; Negate
	LD	A,D
	XOR	80H
	LD	D,A

	; floor(-x)
	PUSH	DE
	PUSH	HL
	CALL	_floorf
	POP	BC
	POP	BC

	; Negate result
	LD	A,D
	XOR	80H
	LD	D,A

	POP	BC
	POP	IX
	RET

; ============================================================
; trunc(x) - round toward zero
; ============================================================
	PUBLIC	_trunc
	PUBLIC	_truncf
	PUBLIC	_truncl
_trunc:
_truncf:
_truncl:
	PUSH	IX
	PUSH	BC
	LD	IX,0
	ADD	IX,SP

	CALL	_math_getarg
	CALL	__ftoi
	CALL	__itof

	POP	BC
	POP	IX
	RET

; ============================================================
; round(x) - round to nearest, ties away from zero
; ============================================================
	PUBLIC	_round
	PUBLIC	_roundf
	PUBLIC	_roundl
_round:
_roundf:
_roundl:
	PUSH	IX
	PUSH	BC
	LD	IX,0
	ADD	IX,SP

	CALL	_math_getarg

	; Add 0.5 (or -0.5 if negative)
	LD	A,D
	AND	80H
	LD	B,A		; Save sign

	; 0.5 = 3F000000
	LD	A,0
	LD	(__tmp32),A
	LD	(__tmp32+1),A
	LD	A,0
	LD	(__tmp32+2),A
	LD	A,3FH
	OR	B		; Apply sign
	LD	(__tmp32+3),A
	CALL	__fadd

	; Truncate
	CALL	__ftoi
	CALL	__itof

	POP	BC
	POP	IX
	RET

	DSEG

_floor_x:	DS	4
_floor_t:	DS	4
_floor_sign:	DS	1
_ceil_x:	DS	4


; ============================================================
; lc_fma.mac
; ============================================================
	CSEG
; lc_fma.mac - fma, fmaf
; fma(x, y, z) = x * y + z


	EXTRN	__fmul
	EXTRN	__fadd
	EXTRN	__tmp32

	CSEG

	PUBLIC	_fma
	PUBLIC	_fmaf
_fma:
_fmaf:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP

	; Load x into DEHL
	LD	L,(IX+4)
	LD	H,(IX+5)
	LD	E,(IX+6)
	LD	D,(IX+7)

	; y into __tmp32
	LD	A,(IX+8)
	LD	(__tmp32),A
	LD	A,(IX+9)
	LD	(__tmp32+1),A
	LD	A,(IX+10)
	LD	(__tmp32+2),A
	LD	A,(IX+11)
	LD	(__tmp32+3),A

	; x * y
	CALL	__fmul

	; z into __tmp32
	LD	A,(IX+12)
	LD	(__tmp32),A
	LD	A,(IX+13)
	LD	(__tmp32+1),A
	LD	A,(IX+14)
	LD	(__tmp32+2),A
	LD	A,(IX+15)
	LD	(__tmp32+3),A

	; x*y + z
	CALL	__fadd

	POP	IX
	RET


; ============================================================
; lc_fmax.mac
; ============================================================
	CSEG
; lc_fmax.mac - fmax, fmaxf, fmin, fminf


	EXTRN	__fcmp
	EXTRN	__tmp32

	CSEG

; ============================================================
; fmax(x, y) - return larger of x, y
; ============================================================
	PUBLIC	_fmax
	PUBLIC	_fmaxf
_fmax:
_fmaxf:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP

	; Load x into DEHL
	LD	L,(IX+4)
	LD	H,(IX+5)
	LD	E,(IX+6)
	LD	D,(IX+7)

	; Load y into __tmp32
	LD	A,(IX+8)
	LD	(__tmp32),A
	LD	A,(IX+9)
	LD	(__tmp32+1),A
	LD	A,(IX+10)
	LD	(__tmp32+2),A
	LD	A,(IX+11)
	LD	(__tmp32+3),A

	CALL	__fcmp
	JR	NC,_fmax_ret	; x >= y, keep x in DEHL

	; x < y, return y
	LD	L,(IX+8)
	LD	H,(IX+9)
	LD	E,(IX+10)
	LD	D,(IX+11)

_fmax_ret:
	POP	IX
	RET

; ============================================================
; fmin(x, y) - return smaller of x, y
; ============================================================
	PUBLIC	_fmin
	PUBLIC	_fminf
_fmin:
_fminf:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP

	; Load x into DEHL
	LD	L,(IX+4)
	LD	H,(IX+5)
	LD	E,(IX+6)
	LD	D,(IX+7)

	; Load y into __tmp32
	LD	A,(IX+8)
	LD	(__tmp32),A
	LD	A,(IX+9)
	LD	(__tmp32+1),A
	LD	A,(IX+10)
	LD	(__tmp32+2),A
	LD	A,(IX+11)
	LD	(__tmp32+3),A

	CALL	__fcmp
	JR	Z,_fmin_ret	; x == y, return x
	JR	C,_fmin_ret	; x < y, return x

	; x > y, return y
	LD	L,(IX+8)
	LD	H,(IX+9)
	LD	E,(IX+10)
	LD	D,(IX+11)

_fmin_ret:
	POP	IX
	RET


; ============================================================
; lc_fmod.mac
; ============================================================
	CSEG
; lc_fmod.mac - fmod, fmodf, fmodl, remainder, remainderf


	EXTRN	__fadd
	EXTRN	__fsub
	EXTRN	__fmul
	EXTRN	__fdiv
	EXTRN	__ftoi
	EXTRN	__itof
	EXTRN	__tmp32

	CSEG

; ============================================================
; fmod(x, y) - floating-point remainder
; fmod(x, y) = x - trunc(x/y) * y
; ============================================================
	PUBLIC	_fmod
	PUBLIC	_fmodf
	PUBLIC	_fmodl
_fmod:
_fmodf:
_fmodl:
	PUSH	IX
	PUSH	BC
	LD	IX,0
	ADD	IX,SP

	CALL	_math_getarg	; x
	LD	(_fmod_x),HL
	LD	(_fmod_x+2),DE

	CALL	_math_getarg2	; y
	LD	HL,(__tmp32)
	LD	DE,(__tmp32+2)
	LD	(_fmod_y),HL
	LD	(_fmod_y+2),DE

	; x / y
	LD	(__tmp32),HL
	LD	(__tmp32+2),DE
	LD	HL,(_fmod_x)
	LD	DE,(_fmod_x+2)
	CALL	__fdiv

	; trunc(x/y)
	CALL	__ftoi
	CALL	__itof

	; * y
	LD	A,(_fmod_y)
	LD	(__tmp32),A
	LD	A,(_fmod_y+1)
	LD	(__tmp32+1),A
	LD	A,(_fmod_y+2)
	LD	(__tmp32+2),A
	LD	A,(_fmod_y+3)
	LD	(__tmp32+3),A
	CALL	__fmul

	; x - trunc(x/y)*y
	LD	(__tmp32),HL
	LD	(__tmp32+2),DE
	LD	HL,(_fmod_x)
	LD	DE,(_fmod_x+2)
	CALL	__fsub

	POP	BC
	POP	IX
	RET

; ============================================================
; remainder - same as fmod for now
; ============================================================
	PUBLIC	_remainder
	PUBLIC	_remainderf
_remainder:
_remainderf:
	JP	_fmod

	DSEG

_fmod_x:	DS	4
_fmod_y:	DS	4


; ============================================================
; lc_fpclassify.mac
; ============================================================
	CSEG
; lc_fpclassify.mac - fpclassify, isfinite, isinf, isnan, isnormal, signbit
; IEEE 754 classification functions
;
; FP_NAN       0
; FP_INFINITE  1
; FP_ZERO      2
; FP_SUBNORMAL 3
; FP_NORMAL    4


	CSEG

; ============================================================
; fpclassify(x) - classify floating-point value
; ============================================================
	PUBLIC	_fpclassify
_fpclassify:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP

	; Extract exponent
	LD	A,(IX+7)	; D byte (SEEEEEEE)
	AND	7FH		; Strip sign (0EEEEEEE)
	ADD	A,A		; Shift left (EEEEEEE0)
	LD	B,A
	LD	A,(IX+6)	; E byte (EMMMMMMM)
	RLCA			; Rotate - exp low bit into bit 0
	AND	1		; Isolate exp low bit
	OR	B		; A = 8-bit biased exponent

	; exp == 0?
	OR	A
	JR	Z,_fpc_expz

	; exp == 255?
	CP	255
	JR	Z,_fpc_exp255

	; Normal (exp 1..254)
	LD	HL,4		; FP_NORMAL
	POP	IX
	RET

_fpc_expz:
	; Check mantissa
	LD	A,(IX+6)
	AND	7FH
	OR	(IX+5)
	OR	(IX+4)
	JR	NZ,_fpc_sub
	; Zero
	LD	HL,2		; FP_ZERO
	POP	IX
	RET

_fpc_sub:
	LD	HL,3		; FP_SUBNORMAL
	POP	IX
	RET

_fpc_exp255:
	; Check mantissa for NaN vs Inf
	LD	A,(IX+6)
	AND	7FH
	OR	(IX+5)
	OR	(IX+4)
	JR	NZ,_fpc_nan
	; Infinity
	LD	HL,1		; FP_INFINITE
	POP	IX
	RET

_fpc_nan:
	LD	HL,0		; FP_NAN
	POP	IX
	RET

; ============================================================
; isfinite(x) - return nonzero if finite (not inf or nan)
; ============================================================
	PUBLIC	_isfinite
_isfinite:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP

	LD	A,(IX+7)	; D byte (SEEEEEEE)
	AND	7FH		; Strip sign (0EEEEEEE)
	ADD	A,A		; Shift left (EEEEEEE0)
	LD	B,A
	LD	A,(IX+6)	; E byte (EMMMMMMM)
	RLCA			; Rotate - exp low bit into bit 0
	AND	1		; Isolate exp low bit
	OR	B		; A = 8-bit biased exponent
	CP	255
	JR	Z,_ret_zero	; inf or nan
	LD	HL,1
	POP	IX
	RET

; ============================================================
; isinf(x) - return nonzero if infinity
; ============================================================
	PUBLIC	_isinf
_isinf:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP

	LD	A,(IX+7)	; D byte (SEEEEEEE)
	AND	7FH		; Strip sign (0EEEEEEE)
	ADD	A,A		; Shift left (EEEEEEE0)
	LD	B,A
	LD	A,(IX+6)	; E byte (EMMMMMMM)
	RLCA			; Rotate - exp low bit into bit 0
	AND	1		; Isolate exp low bit
	OR	B		; A = 8-bit biased exponent
	CP	255
	JR	NZ,_ret_zero	; exp != 255, not inf
	; Check mantissa == 0
	LD	A,(IX+6)
	AND	7FH
	OR	(IX+5)
	OR	(IX+4)
	JR	NZ,_ret_zero	; NaN, not inf
	LD	HL,1
	POP	IX
	RET

; ============================================================
; isnan(x) - return nonzero if NaN
; ============================================================
	PUBLIC	_isnan
_isnan:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP

	LD	A,(IX+7)	; D byte (SEEEEEEE)
	AND	7FH		; Strip sign (0EEEEEEE)
	ADD	A,A		; Shift left (EEEEEEE0)
	LD	B,A
	LD	A,(IX+6)	; E byte (EMMMMMMM)
	RLCA			; Rotate - exp low bit into bit 0
	AND	1		; Isolate exp low bit
	OR	B		; A = 8-bit biased exponent
	CP	255
	JR	NZ,_ret_zero	; exp != 255, not nan
	; Check mantissa != 0
	LD	A,(IX+6)
	AND	7FH
	OR	(IX+5)
	OR	(IX+4)
	JR	Z,_ret_zero	; mantissa 0 = inf, not nan
	LD	HL,1
	POP	IX
	RET

; ============================================================
; isnormal(x) - return nonzero if normal
; ============================================================
	PUBLIC	_isnormal
_isnormal:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP

	LD	A,(IX+7)	; D byte (SEEEEEEE)
	AND	7FH		; Strip sign (0EEEEEEE)
	ADD	A,A		; Shift left (EEEEEEE0)
	LD	B,A
	LD	A,(IX+6)	; E byte (EMMMMMMM)
	RLCA			; Rotate - exp low bit into bit 0
	AND	1		; Isolate exp low bit
	OR	B		; A = 8-bit biased exponent
	OR	A
	JR	Z,_ret_zero	; exp 0 = zero or subnormal
	CP	255
	JR	Z,_ret_zero	; exp 255 = inf or nan
	LD	HL,1
	POP	IX
	RET

; Shared return-zero
_ret_zero:
	LD	HL,0
	POP	IX
	RET

; ============================================================
; signbit(x) - return nonzero if sign bit is set
; ============================================================
	PUBLIC	_signbit
_signbit:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP

	LD	A,(IX+7)	; D byte, sign in bit 7
	RLCA			; Sign into bit 0
	AND	1
	LD	L,A
	LD	H,0
	POP	IX
	RET


; ============================================================
; lc_fprintf.mac
; ============================================================
	CSEG
; lc_fprintf.mac - fprintf, vfprintf, vprintf, vsprintf



	CSEG

; ============================================================
; int fprintf(FILE *stream, const char *fmt, ...)
; Print formatted output to a file stream
; Supports %d, %s, %c, %x, %%
; ============================================================
	PUBLIC	_fprintf
_fprintf:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	PUSH	BC
	PUSH	DE

	; stream at IX+4, fmt at IX+6, first vararg at IX+8
	LD	E,(IX+4)
	LD	D,(IX+5)
	LD	(_fprintf_stream),DE	; Save stream
	LD	L,(IX+6)
	LD	H,(IX+7)	; HL = format string pointer
	LD	C,8		; C = offset to next argument

_fprintf_loop:
	LD	A,(HL)
	OR	A
	JP	Z,_fprintf_done

	CP	'%'
	JR	Z,_fprintf_format

	; Regular character - output via fputc
	PUSH	HL
	PUSH	BC
	LD	DE,(_fprintf_stream)
	PUSH	DE		; stream arg
	LD	E,A
	LD	D,0
	PUSH	DE		; char arg
	CALL	_fputc
	POP	DE
	POP	DE
	POP	BC
	POP	HL
	INC	HL
	JR	_fprintf_loop

_fprintf_format:
	INC	HL
	LD	A,(HL)
	OR	A
	JP	Z,_fprintf_done

	CP	'%'
	JR	Z,_fprintf_pct

_fprintf_fmt2:
	; Skip flags: -, +, space, #, 0
	CP	'-'
	JR	Z,_fprintf_fskip
	CP	'+'
	JR	Z,_fprintf_fskip
	CP	' '
	JR	Z,_fprintf_fskip
	CP	'#'
	JR	Z,_fprintf_fskip
	CP	'0'
	JR	Z,_fprintf_fskip
	; Skip field width digits
	CP	'1'
	JR	C,_fprintf_nodig
	CP	'9'+1
	JR	C,_fprintf_fskip
_fprintf_nodig:
	; Skip precision
	CP	'.'
	JR	Z,_fprintf_fskip
	; Skip length modifiers: h, l, z
	CP	'h'
	JR	Z,_fprintf_fskip
	CP	'l'
	JR	Z,_fprintf_fskip
	CP	'z'
	JR	Z,_fprintf_fskip
	; Now check format specifiers
	CP	's'
	JR	Z,_fprintf_str

	CP	'd'
	JR	Z,_fprintf_dec

	CP	'i'
	JR	Z,_fprintf_dec

	CP	'c'
	JR	Z,_fprintf_chr

	CP	'x'
	JR	Z,_fprintf_hex

	CP	'X'
	JR	Z,_fprintf_hex

	CP	'u'
	JR	Z,_fprintf_dec	; %u same as %d for now

	; Unknown format - skip
	INC	HL
	JP	_fprintf_loop

_fprintf_fskip:
	INC	HL
	LD	A,(HL)
	OR	A
	JP	Z,_fprintf_done
	JR	_fprintf_fmt2

_fprintf_pct:
	; Output literal %
	PUSH	HL
	PUSH	BC
	LD	DE,(_fprintf_stream)
	PUSH	DE
	LD	DE,'%'
	PUSH	DE
	CALL	_fputc
	POP	DE
	POP	DE
	POP	BC
	POP	HL
	INC	HL
	JP	_fprintf_loop

_fprintf_chr:
	; Output character argument
	PUSH	HL
	LD	H,0
	LD	L,C
	PUSH	BC
	PUSH	IX
	POP	DE
	ADD	HL,DE
	LD	E,(HL)		; E = char
	LD	D,0
	LD	BC,(_fprintf_stream)
	PUSH	BC		; stream
	PUSH	DE		; char
	CALL	_fputc
	POP	DE
	POP	DE
	POP	BC
	INC	C
	INC	C
	POP	HL
	INC	HL
	JP	_fprintf_loop

_fprintf_str:
	; Output string argument
	PUSH	HL
	LD	H,0
	LD	L,C
	PUSH	BC
	PUSH	IX
	POP	DE
	ADD	HL,DE
	LD	E,(HL)
	INC	HL
	LD	D,(HL)		; DE = string pointer
_fprintf_str_lp:
	LD	A,(DE)
	OR	A
	JR	Z,_fprintf_str_end
	PUSH	DE
	LD	BC,(_fprintf_stream)
	PUSH	BC
	LD	E,A
	LD	D,0
	PUSH	DE
	CALL	_fputc
	POP	DE
	POP	DE
	POP	DE
	INC	DE
	JR	_fprintf_str_lp
_fprintf_str_end:
	POP	BC
	INC	C
	INC	C
	POP	HL
	INC	HL
	JP	_fprintf_loop

_fprintf_dec:
	; Output decimal number
	PUSH	HL
	LD	H,0
	LD	L,C
	PUSH	BC
	PUSH	IX
	POP	DE
	ADD	HL,DE
	LD	E,(HL)
	INC	HL
	LD	D,(HL)
	EX	DE,HL		; HL = value
	CALL	_fprintf_prt_dec
	POP	BC
	INC	C
	INC	C
	POP	HL
	INC	HL
	JP	_fprintf_loop

_fprintf_hex:
	; Output hex number
	PUSH	HL
	LD	H,0
	LD	L,C
	PUSH	BC
	PUSH	IX
	POP	DE
	ADD	HL,DE
	LD	E,(HL)
	INC	HL
	LD	D,(HL)
	EX	DE,HL		; HL = value
	CALL	_fprintf_prt_hex
	POP	BC
	INC	C
	INC	C
	POP	HL
	INC	HL
	JP	_fprintf_loop

_fprintf_done:
	LD	HL,0		; Return 0
	POP	DE
	POP	BC
	POP	IX
	RET

; fprintf helper: print HL as decimal to stream
	PUBLIC	_fprintf_prt_dec
_fprintf_prt_dec:
	PUSH	BC
	PUSH	DE
	; Check for negative
	BIT	7,H
	JR	Z,_fprintf_dec_pos
	; Negative - print minus sign
	PUSH	HL
	LD	DE,(_fprintf_stream)
	PUSH	DE
	LD	DE,'-'
	PUSH	DE
	CALL	_fputc
	POP	DE
	POP	DE
	POP	HL
	; Negate HL
	LD	A,L
	CPL
	LD	L,A
	LD	A,H
	CPL
	LD	H,A
	INC	HL
_fprintf_dec_pos:
	; Convert to decimal digits on stack
	LD	DE,10
	LD	B,0		; Digit counter
_fprintf_dec_lp:
	CALL	_prt_div16	; HL = HL / 10, DE = remainder
	PUSH	DE		; Push digit
	INC	B
	LD	A,H
	OR	L
	JR	NZ,_fprintf_dec_lp
	; Pop and print digits
_fprintf_dec_pr:
	POP	DE		; Get digit
	LD	A,E
	ADD	A,'0'
	PUSH	BC
	LD	DE,(_fprintf_stream)
	PUSH	DE
	LD	E,A
	LD	D,0
	PUSH	DE
	CALL	_fputc
	POP	DE
	POP	DE
	POP	BC
	DJNZ	_fprintf_dec_pr
	POP	DE
	POP	BC
	RET

; fprintf helper: print HL as hex to stream
	PUBLIC	_fprintf_prt_hex
_fprintf_prt_hex:
	PUSH	BC
	PUSH	DE
	LD	B,4		; 4 hex digits
	LD	C,H		; Save high byte
_fprintf_hex_lp:
	; Rotate left 4 bits
	ADD	HL,HL
	RL	C
	ADD	HL,HL
	RL	C
	ADD	HL,HL
	RL	C
	ADD	HL,HL
	RL	C
	; Get top nibble
	LD	A,C
	AND	0FH
	ADD	A,'0'
	CP	'9'+1
	JR	C,_fprintf_hex_dig
	ADD	A,7		; A-F
_fprintf_hex_dig:
	PUSH	HL
	PUSH	BC
	LD	DE,(_fprintf_stream)
	PUSH	DE
	LD	E,A
	LD	D,0
	PUSH	DE
	CALL	_fputc
	POP	DE
	POP	DE
	POP	BC
	POP	HL
	DJNZ	_fprintf_hex_lp
	POP	DE
	POP	BC
	RET

; ============================================================
; int vprintf(const char *fmt, va_list ap)
; ============================================================
	PUBLIC	_vprintf
_vprintf:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	; fmt at IX+4, ap at IX+6
	LD	L,(IX+4)
	LD	H,(IX+5)	; HL = format string
	LD	E,(IX+6)
	LD	D,(IX+7)	; DE = va_list (pointer to args)
	LD	(_vprintf_ap),DE
	LD	BC,0		; Character count

_vprintf_loop:
	LD	A,(HL)
	OR	A
	JP	Z,_vprintf_done

	CP	'%'
	JP	Z,_vprintf_fmt

	; Regular char - output
	PUSH	HL
	PUSH	BC
	LD	E,A
	LD	C,2
	CALL	5
	POP	BC
	POP	HL
	INC	BC
	INC	HL
	JP	_vprintf_loop

_vprintf_fmt:
	INC	HL
	LD	A,(HL)
	OR	A
	JP	Z,_vprintf_done

	CP	'%'
	JR	NZ,_vprintf_fmt2
	; Literal %
	PUSH	HL
	PUSH	BC
	LD	E,'%'
	LD	C,2
	CALL	5
	POP	BC
	POP	HL
	INC	BC
	INC	HL
	JP	_vprintf_loop

_vprintf_fmt2:
	; Skip flags: -, +, space, #, 0
	CP	'-'
	JR	Z,_vprintf_skip
	CP	'+'
	JR	Z,_vprintf_skip
	CP	' '
	JR	Z,_vprintf_skip
	CP	'#'
	JR	Z,_vprintf_skip
	CP	'0'
	JR	Z,_vprintf_skip
	; Skip field width digits
	CP	'1'
	JR	C,_vprintf_nodig
	CP	'9'+1
	JR	C,_vprintf_skip
_vprintf_nodig:
	; Skip precision
	CP	'.'
	JR	Z,_vprintf_skip
	; Skip length modifiers: h, z (l handled separately for long)
	CP	'h'
	JR	Z,_vprintf_skip
	CP	'z'
	JR	Z,_vprintf_skip
	; Now check format specifiers
	CP	's'
	JP	Z,_vprintf_str
	CP	'd'
	JP	Z,_vprintf_dec
	CP	'i'
	JP	Z,_vprintf_dec
	CP	'c'
	JP	Z,_vprintf_chr
	CP	'x'
	JP	Z,_vprintf_hex
	CP	'X'
	JP	Z,_vprintf_hex
	CP	'u'
	JP	Z,_vprintf_uns
	CP	'l'
	JP	Z,_vprintf_long
	; Unknown - skip
	INC	HL
	JP	_vprintf_loop
_vprintf_skip:
	INC	HL
	LD	A,(HL)
	OR	A
	JP	Z,_vprintf_done
	JP	_vprintf_fmt2

_vprintf_str:
	; Print string
	PUSH	HL
	PUSH	BC
	LD	HL,(_vprintf_ap)
	LD	E,(HL)
	INC	HL
	LD	D,(HL)
	INC	HL
	LD	(_vprintf_ap),HL
	EX	DE,HL		; HL = string
_vprintf_str_lp:
	LD	A,(HL)
	OR	A
	JR	Z,_vprintf_str_dn
	LD	E,A
	PUSH	HL
	LD	C,2
	CALL	5
	POP	HL
	INC	HL
	JR	_vprintf_str_lp
_vprintf_str_dn:
	POP	BC
	POP	HL
	INC	HL
	JP	_vprintf_loop

_vprintf_dec:
	; Print signed int
	PUSH	HL
	PUSH	BC
	LD	HL,(_vprintf_ap)
	LD	E,(HL)
	INC	HL
	LD	D,(HL)
	INC	HL
	LD	(_vprintf_ap),HL
	EX	DE,HL
	CALL	_prt_dec
	POP	BC
	POP	HL
	INC	HL
	JP	_vprintf_loop

_vprintf_chr:
	; Print character
	PUSH	HL
	PUSH	BC
	LD	HL,(_vprintf_ap)
	LD	E,(HL)
	INC	HL
	INC	HL
	LD	(_vprintf_ap),HL
	LD	C,2
	CALL	5
	POP	BC
	POP	HL
	INC	HL
	JP	_vprintf_loop

_vprintf_hex:
	; Print hex
	PUSH	HL
	PUSH	BC
	LD	HL,(_vprintf_ap)
	LD	E,(HL)
	INC	HL
	LD	D,(HL)
	INC	HL
	LD	(_vprintf_ap),HL
	EX	DE,HL
	CALL	_prt_hex
	POP	BC
	POP	HL
	INC	HL
	JP	_vprintf_loop

_vprintf_uns:
	; Same as dec for now
	JP	_vprintf_dec

_vprintf_long:
	; Handle 'l' modifier
	INC	HL
	LD	A,(HL)
	CP	'd'
	JP	Z,_vprintf_ld
	CP	'x'
	JP	Z,_vprintf_lx
	JP	_vprintf_loop

_vprintf_ld:
	; Print long decimal
	PUSH	HL
	PUSH	BC
	LD	HL,(_vprintf_ap)
	LD	E,(HL)
	INC	HL
	LD	D,(HL)
	INC	HL
	LD	C,(HL)
	INC	HL
	LD	B,(HL)
	INC	HL
	LD	(_vprintf_ap),HL
	; DEHL = low, BC = high (need to swap)
	PUSH	BC
	EX	DE,HL
	POP	DE		; Now DEHL is 32-bit value
	CALL	_prt_dec32
	POP	BC
	POP	HL
	INC	HL
	JP	_vprintf_loop

_vprintf_lx:
	; Print long hex
	PUSH	HL
	PUSH	BC
	LD	HL,(_vprintf_ap)
	LD	E,(HL)
	INC	HL
	LD	D,(HL)
	INC	HL
	LD	C,(HL)
	INC	HL
	LD	B,(HL)
	INC	HL
	LD	(_vprintf_ap),HL
	; Print BC (high), then DE (low)
	PUSH	DE
	LD	H,B
	LD	L,C
	CALL	_prt_hex
	POP	HL
	CALL	_prt_hex
	POP	BC
	POP	HL
	INC	HL
	JP	_vprintf_loop

_vprintf_done:
	LD	H,B
	LD	L,C		; Return count
	POP	IX
	RET

; ============================================================
; int vfprintf(FILE *stream, const char *fmt, va_list ap)
; ============================================================
	PUBLIC	_vfprintf
_vfprintf:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	; stream at IX+4, fmt at IX+6, ap at IX+8
	LD	L,(IX+4)
	LD	H,(IX+5)
	LD	(_fprintf_stream),HL
	LD	L,(IX+6)
	LD	H,(IX+7)	; HL = format
	LD	E,(IX+8)
	LD	D,(IX+9)	; DE = va_list
	LD	(_vprintf_ap),DE
	LD	BC,0		; Count

_vfprintf_loop:
	LD	A,(HL)
	OR	A
	JP	Z,_vfprintf_done
	CP	'%'
	JP	Z,_vfprintf_fmt
	; Regular char
	PUSH	HL
	PUSH	BC
	LD	DE,(_fprintf_stream)
	PUSH	DE
	LD	E,A
	LD	D,0
	PUSH	DE
	CALL	_fputc
	POP	DE
	POP	DE
	POP	BC
	POP	HL
	INC	BC
	INC	HL
	JP	_vfprintf_loop

_vfprintf_fmt:
	INC	HL
	LD	A,(HL)
	OR	A
	JP	Z,_vfprintf_done
	CP	'%'
	JR	NZ,_vfprintf_fmt2
	PUSH	HL
	PUSH	BC
	LD	DE,(_fprintf_stream)
	PUSH	DE
	LD	DE,'%'
	PUSH	DE
	CALL	_fputc
	POP	DE
	POP	DE
	POP	BC
	POP	HL
	INC	BC
	INC	HL
	JP	_vfprintf_loop

_vfprintf_fmt2:
	; Skip flags: -, +, space, #, 0
	CP	'-'
	JR	Z,_vfprintf_skip
	CP	'+'
	JR	Z,_vfprintf_skip
	CP	' '
	JR	Z,_vfprintf_skip
	CP	'#'
	JR	Z,_vfprintf_skip
	CP	'0'
	JR	Z,_vfprintf_skip
	; Skip field width digits
	CP	'1'
	JR	C,_vfprintf_nodig
	CP	'9'+1
	JR	C,_vfprintf_skip
_vfprintf_nodig:
	; Skip precision
	CP	'.'
	JR	Z,_vfprintf_skip
	; Skip length modifiers: l, h, z
	CP	'l'
	JR	Z,_vfprintf_skip
	CP	'h'
	JR	Z,_vfprintf_skip
	CP	'z'
	JR	Z,_vfprintf_skip
	; Now check format specifiers
	CP	's'
	JP	Z,_vfprintf_str
	CP	'd'
	JP	Z,_vfprintf_dec
	CP	'i'
	JP	Z,_vfprintf_dec
	CP	'u'
	JP	Z,_vfprintf_dec
	CP	'x'
	JP	Z,_vfprintf_hex
	CP	'X'
	JP	Z,_vfprintf_hex
	CP	'c'
	JP	Z,_vfprintf_chr
	; Unknown specifier - skip it
	INC	HL
	JP	_vfprintf_loop
_vfprintf_skip:
	INC	HL
	LD	A,(HL)
	OR	A
	JP	Z,_vfprintf_done
	JP	_vfprintf_fmt2

_vfprintf_str:
	PUSH	HL
	PUSH	BC
	LD	HL,(_vprintf_ap)
	LD	E,(HL)
	INC	HL
	LD	D,(HL)
	INC	HL
	LD	(_vprintf_ap),HL
	EX	DE,HL
_vfprintf_str_lp:
	LD	A,(HL)
	OR	A
	JR	Z,_vfprintf_str_dn
	PUSH	HL
	LD	DE,(_fprintf_stream)
	PUSH	DE
	LD	E,A
	LD	D,0
	PUSH	DE
	CALL	_fputc
	POP	DE
	POP	DE
	POP	HL
	INC	HL
	JR	_vfprintf_str_lp
_vfprintf_str_dn:
	POP	BC
	POP	HL
	INC	HL
	JP	_vfprintf_loop

_vfprintf_dec:
	PUSH	HL
	PUSH	BC
	LD	HL,(_vprintf_ap)
	LD	E,(HL)
	INC	HL
	LD	D,(HL)
	INC	HL
	LD	(_vprintf_ap),HL
	EX	DE,HL
	CALL	_fprintf_prt_dec
	POP	BC
	POP	HL
	INC	HL
	JP	_vfprintf_loop

_vfprintf_chr:
	PUSH	HL
	PUSH	BC
	LD	HL,(_vprintf_ap)
	LD	E,(HL)
	INC	HL
	INC	HL
	LD	(_vprintf_ap),HL
	LD	DE,(_fprintf_stream)
	PUSH	DE
	LD	D,0
	PUSH	DE
	CALL	_fputc
	POP	DE
	POP	DE
	POP	BC
	POP	HL
	INC	HL
	JP	_vfprintf_loop

_vfprintf_hex:
	PUSH	HL
	PUSH	BC
	LD	HL,(_vprintf_ap)
	LD	E,(HL)
	INC	HL
	LD	D,(HL)
	INC	HL
	LD	(_vprintf_ap),HL
	EX	DE,HL
	CALL	_fprintf_prt_hex
	POP	BC
	POP	HL
	INC	HL
	JP	_vfprintf_loop

_vfprintf_done:
	LD	H,B
	LD	L,C
	POP	IX
	RET

; ============================================================
; int vsprintf(char *str, const char *fmt, va_list ap)
; ============================================================
	PUBLIC	_vsprintf
_vsprintf:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	; str at IX+4, fmt at IX+6, ap at IX+8
	LD	L,(IX+4)
	LD	H,(IX+5)
	LD	(_sprintf_out),HL
	LD	L,(IX+6)
	LD	H,(IX+7)	; HL = format
	LD	E,(IX+8)
	LD	D,(IX+9)	; DE = va_list
	LD	(_vprintf_ap),DE
	LD	BC,0		; Count
	LD	(_sprintf_cnt),BC

_vsprintf_loop:
	LD	A,(HL)
	OR	A
	JP	Z,_vsprintf_done
	CP	'%'
	JP	Z,_vsprintf_fmt
	; Regular char
	CALL	_sprintf_putc
	INC	HL
	JP	_vsprintf_loop

_vsprintf_fmt:
	INC	HL
	LD	A,(HL)
	OR	A
	JP	Z,_vsprintf_done
	CP	'%'
	JR	NZ,_vsprintf_fmt2
	LD	A,'%'
	CALL	_sprintf_putc
	INC	HL
	JP	_vsprintf_loop

_vsprintf_fmt2:
	; Skip flags: -, +, space, #, 0
	CP	'-'
	JR	Z,_vsprintf_skip
	CP	'+'
	JR	Z,_vsprintf_skip
	CP	' '
	JR	Z,_vsprintf_skip
	CP	'#'
	JR	Z,_vsprintf_skip
	CP	'0'
	JR	Z,_vsprintf_skip
	; Skip field width digits
	CP	'1'
	JR	C,_vsprintf_nodig
	CP	'9'+1
	JR	C,_vsprintf_skip
_vsprintf_nodig:
	; Skip precision
	CP	'.'
	JR	Z,_vsprintf_skip
	; Skip length modifiers: l, h, z
	CP	'l'
	JR	Z,_vsprintf_skip
	CP	'h'
	JR	Z,_vsprintf_skip
	CP	'z'
	JR	Z,_vsprintf_skip
	; Now check format specifiers
	CP	's'
	JP	Z,_vsprintf_str
	CP	'd'
	JP	Z,_vsprintf_dec
	CP	'i'
	JP	Z,_vsprintf_dec
	CP	'u'
	JP	Z,_vsprintf_dec
	CP	'x'
	JP	Z,_vsprintf_hex
	CP	'X'
	JP	Z,_vsprintf_hex
	CP	'c'
	JP	Z,_vsprintf_chr
	; Unknown specifier - skip it
	INC	HL
	JP	_vsprintf_loop
_vsprintf_skip:
	INC	HL
	LD	A,(HL)
	OR	A
	JP	Z,_vsprintf_done
	JP	_vsprintf_fmt2

_vsprintf_str:
	PUSH	HL
	LD	HL,(_vprintf_ap)
	LD	E,(HL)
	INC	HL
	LD	D,(HL)
	INC	HL
	LD	(_vprintf_ap),HL
	EX	DE,HL
_vsprintf_str_lp:
	LD	A,(HL)
	OR	A
	JR	Z,_vsprintf_str_dn
	CALL	_sprintf_putc
	INC	HL
	JR	_vsprintf_str_lp
_vsprintf_str_dn:
	POP	HL
	INC	HL
	JP	_vsprintf_loop

_vsprintf_dec:
	PUSH	HL
	LD	HL,(_vprintf_ap)
	LD	E,(HL)
	INC	HL
	LD	D,(HL)
	INC	HL
	LD	(_vprintf_ap),HL
	EX	DE,HL
	CALL	_sprintf_prt_dec
	POP	HL
	INC	HL
	JP	_vsprintf_loop

_vsprintf_chr:
	PUSH	HL
	LD	HL,(_vprintf_ap)
	LD	A,(HL)
	INC	HL
	INC	HL
	LD	(_vprintf_ap),HL
	CALL	_sprintf_putc
	POP	HL
	INC	HL
	JP	_vsprintf_loop

_vsprintf_hex:
	PUSH	HL
	LD	HL,(_vprintf_ap)
	LD	E,(HL)
	INC	HL
	LD	D,(HL)
	INC	HL
	LD	(_vprintf_ap),HL
	EX	DE,HL
	CALL	_sprintf_prt_hex
	POP	HL
	INC	HL
	JP	_vsprintf_loop

_vsprintf_done:
	; Null terminate
	XOR	A
	CALL	_sprintf_putc
	; Return count
	LD	HL,(_sprintf_cnt)
	DEC	HL		; Don't count null
	POP	IX
	RET

	DSEG

; fprintf/vfprintf working storage
	PUBLIC	_fprintf_stream
_fprintf_stream: DS	2

; vprintf/vfprintf/vsprintf shared working storage
	PUBLIC	_vprintf_ap
_vprintf_ap:	DS	2


; ============================================================
; lc_frexp.mac
; ============================================================
	CSEG
; lc_frexp.mac - frexp, frexpf, ldexp, ldexpf


	EXTRN	__tmp32

	CSEG

; ============================================================
; frexp(x, int *exp) - extract mantissa and exponent
; Returns mantissa in [0.5, 1), stores exponent
; ============================================================
	PUBLIC	_frexp
	PUBLIC	_frexpf
_frexp:
_frexpf:
	PUSH	IX
	PUSH	BC
	LD	IX,0
	ADD	IX,SP

	; Read float arg: IX+6..IX+9
	LD	L,(IX+6)
	LD	H,(IX+7)
	LD	E,(IX+8)
	LD	D,(IX+9)

	; Extract 8-bit biased exponent
	LD	A,D		; D = SEEEEEEE
	AND	7FH		; A = 0EEEEEEE
	ADD	A,A		; A = EEEEEEE0
	LD	B,A
	LD	A,E		; E = EMMMMMMM
	RLCA			; A = MMMMMMME
	AND	1		; A = 0000000E
	OR	B		; A = EEEEEEEE (full exponent)

	; Unbias: exp = biased - 126
	SUB	126
	LD	B,A

	; Store exponent to int* (at IX+10..IX+11)
	LD	A,(IX+10)
	LD	C,A
	LD	A,(IX+11)
	PUSH	HL
	LD	H,A
	LD	L,C
	LD	(HL),B
	INC	HL
	LD	A,B
	RLA			; Sign extend
	SBC	A,A
	LD	(HL),A
	POP	HL

	; Set exponent to 126 (biased) -> mantissa in [0.5, 1)
	; exp 126 = 01111110: D = S|3FH, E bit 7 = 0
	LD	A,D
	AND	80H		; Keep sign
	OR	3FH		; exp[7:1] for exponent 126
	LD	D,A
	LD	A,E
	AND	7FH		; Clear exp bit 0 (E0=0 for 126)
	LD	E,A

	POP	BC
	POP	IX
	RET

; ============================================================
; ldexp(x, n) - multiply x by 2^n
; ============================================================
	PUBLIC	_ldexp
	PUBLIC	_ldexpf
_ldexp:
_ldexpf:
	PUSH	IX
	PUSH	BC
	LD	IX,0
	ADD	IX,SP

	; Read float arg: IX+6..IX+9
	LD	L,(IX+6)
	LD	H,(IX+7)
	LD	E,(IX+8)
	LD	D,(IX+9)

	; Get int exponent n (at IX+10)
	LD	B,(IX+10)

	; Extract 8-bit biased exponent
	LD	A,D		; D = SEEEEEEE
	AND	7FH		; Strip sign
	ADD	A,A		; EEEEEEE0
	LD	C,A
	LD	A,E		; EMMMMMMM
	RLCA			; MMMMMMME
	AND	1
	OR	C		; Full 8-bit exponent

	; Add n
	ADD	A,B		; New biased exponent

	; Reconstruct: D = S | exp[7:1], E = exp[0] | mantissa[6:0]
	LD	C,A		; Save new exponent
	SRL	A		; A = exp >> 1 = 0_exp[7:1]
	LD	B,A
	LD	A,D
	AND	80H		; Keep sign
	OR	B
	LD	D,A
	LD	A,C		; New exponent
	AND	1		; exp[0]
	RRCA			; Rotate to bit 7
	LD	B,A
	LD	A,E
	AND	7FH		; Keep mantissa bits
	OR	B		; Set exp[0]
	LD	E,A

	POP	BC
	POP	IX
	RET


; ============================================================
; lc_getchar.mac
; ============================================================
	CSEG
; lc_getchar.mac - getchar


	CSEG

; ============================================================
; int getchar(void)
; Read a character from console
; Returns: character read, or EOF (-1) on error
; ============================================================
	PUBLIC	_getchar
_getchar:
	LD	C,CONIN
	CALL	BDOS
	LD	L,A
	LD	H,0
	RET



; ============================================================
; lc_gets.mac
; ============================================================
	CSEG
; lc_gets.mac - gets


	CSEG

; ============================================================
; char *gets(char *s)
; Read line from stdin into buffer (DANGEROUS - no size limit)
; Returns s, or NULL on EOF/error
; ============================================================
	PUBLIC	_gets
_gets:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	PUSH	BC
	PUSH	DE

	LD	E,(IX+4)	; DE = buffer pointer
	LD	D,(IX+5)
	PUSH	DE		; Save for return

_gets_loop:
	LD	C,CONIN
	CALL	BDOS		; A = char
	CP	0DH		; CR?
	JR	Z,_gets_done
	CP	0AH		; LF?
	JR	Z,_gets_done
	LD	(DE),A
	INC	DE
	JR	_gets_loop

_gets_done:
	XOR	A
	LD	(DE),A		; Null terminate
	POP	HL		; Return original pointer
	POP	DE
	POP	BC
	POP	IX
	RET


; ============================================================
; lc_hypot.mac
; ============================================================
	CSEG
; lc_hypot.mac - hypot, hypotf (depends on sqrt)


	EXTRN	__fadd
	EXTRN	__fmul
	EXTRN	__tmp32

	CSEG

; ============================================================
; hypot(x, y) = sqrt(x^2 + y^2)
; ============================================================
	PUBLIC	_hypot
	PUBLIC	_hypotf
_hypot:
_hypotf:
	PUSH	IX
	PUSH	BC
	LD	IX,0
	ADD	IX,SP

	CALL	_math_getarg	; x
	LD	(__tmp32),HL
	LD	(__tmp32+2),DE
	CALL	__fmul		; x^2
	LD	(_hypot_x2),HL
	LD	(_hypot_x2+2),DE

	CALL	_math_getarg2	; y
	LD	HL,(__tmp32)
	LD	DE,(__tmp32+2)
	LD	(__tmp32),HL
	LD	(__tmp32+2),DE
	CALL	__fmul		; y^2

	; x^2 + y^2
	LD	A,(_hypot_x2)
	LD	(__tmp32),A
	LD	A,(_hypot_x2+1)
	LD	(__tmp32+1),A
	LD	A,(_hypot_x2+2)
	LD	(__tmp32+2),A
	LD	A,(_hypot_x2+3)
	LD	(__tmp32+3),A
	CALL	__fadd

	; sqrt
	PUSH	DE
	PUSH	HL
	CALL	_sqrtf
	POP	BC
	POP	BC

	POP	BC
	POP	IX
	RET

	DSEG

_hypot_x2:	DS	4


; ============================================================
; lc_locale.mac
; ============================================================
	CSEG
; lc_locale.mac - locale functions


	CSEG

; ============================================================
; Locale support (minimal "C" locale only)
; ============================================================

; char *setlocale(int category, const char *locale)
; Only supports "C" and "" (null string = default = "C")
; Returns "C" on success, NULL on failure
	PUBLIC	_setlocale
_setlocale:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	; category at IX+4, locale at IX+6
	LD	L,(IX+6)
	LD	H,(IX+7)	; HL = locale string
	; NULL means query current locale (return "C")
	LD	A,H
	OR	L
	JR	Z,_setlocale_ok
	; "" means use default (return "C")
	LD	A,(HL)
	OR	A
	JR	Z,_setlocale_ok
	; Check for "C"
	CP	'C'
	JR	NZ,_setlocale_check_posix
	INC	HL
	LD	A,(HL)
	OR	A
	JR	Z,_setlocale_ok
	JR	_setlocale_fail
_setlocale_check_posix:
	; Check for "POSIX"
	LD	DE,_locale_posix
	LD	B,5
_setlocale_cmp:
	LD	A,(DE)
	CP	(HL)
	JR	NZ,_setlocale_fail
	INC	HL
	INC	DE
	DJNZ	_setlocale_cmp
	LD	A,(HL)
	OR	A
	JR	NZ,_setlocale_fail
_setlocale_ok:
	LD	HL,_locale_c_str
	POP	IX
	RET
_setlocale_fail:
	LD	HL,0		; Return NULL
	POP	IX
	RET

; struct lconv *localeconv(void)
; Returns pointer to static lconv structure
	PUBLIC	_localeconv
_localeconv:
	LD	HL,_lconv_data
	RET

	DSEG

; Locale data
_locale_c_str:	DB	'C',0
_locale_posix:	DB	'POSIX',0
_locale_dot:	DB	'.',0
_locale_empty:	DB	0

; struct lconv data for "C" locale
_lconv_data:
	DW	_locale_dot	; decimal_point
	DW	_locale_empty	; thousands_sep
	DW	_locale_empty	; grouping
	DW	_locale_empty	; int_curr_symbol
	DW	_locale_empty	; currency_symbol
	DW	_locale_empty	; mon_decimal_point
	DW	_locale_empty	; mon_thousands_sep
	DW	_locale_empty	; mon_grouping
	DW	_locale_empty	; positive_sign
	DW	_locale_empty	; negative_sign
	DB	127		; int_frac_digits (CHAR_MAX)
	DB	127		; frac_digits
	DB	127		; p_cs_precedes
	DB	127		; p_sep_by_space
	DB	127		; n_cs_precedes
	DB	127		; n_sep_by_space
	DB	127		; p_sign_posn
	DB	127		; n_sign_posn


; ============================================================
; lc_log.mac
; ============================================================
	CSEG
; lc_log.mac - log, logf, logl
; Range reduction: log(x) = e*ln(2) + log(m) where x = m * 2^e, m in [1,2)


	EXTRN	__fadd
	EXTRN	__fsub
	EXTRN	__fmul
	EXTRN	__fdiv
	EXTRN	__itof
	EXTRN	__tmp32

	CSEG

; ============================================================
; log(x) - Natural logarithm with range reduction
; ============================================================
	PUBLIC	_log
	PUBLIC	_logf
	PUBLIC	_logl
_log:
_logf:
_logl:
	PUSH	IX
	PUSH	BC
	LD	IX,0
	ADD	IX,SP

	CALL	_math_getarg

	; Check for x <= 0
	LD	A,D
	AND	7FH
	OR	E
	OR	H
	OR	L
	JR	Z,_log_err
	BIT	7,D
	JR	NZ,_log_err

	LD	(_log_x),HL
	LD	(_log_x+2),DE

	; Extract 8-bit biased exponent
	LD	A,D		; D = SEEEEEEE
	AND	7FH		; Strip sign
	ADD	A,A		; EEEEEEE0
	LD	B,A
	LD	A,E		; EMMMMMMM
	RLCA
	AND	1
	OR	B		; A = full biased exponent

	; e = biased - 127
	SUB	127
	LD	(_log_e),A

	; Set mantissa exponent to 127 -> m in [1, 2)
	; exp 127 = 01111111: D = 0|0111111 = 3FH, E bit7 = 1
	LD	A,(_log_x+3)
	AND	80H		; Keep sign (0 for positive)
	OR	3FH		; exp[7:1]
	LD	D,A
	LD	A,(_log_x+2)
	OR	80H		; exp[0] = 1
	LD	E,A
	LD	HL,(_log_x)

	; DEHL = m in [1, 2)
	LD	(_log_m),HL
	LD	(_log_m+2),DE

	; Compute (m-1)
	LD	HL,0
	LD	DE,3F80H	; 1.0
	LD	(__tmp32),HL
	LD	(__tmp32+2),DE
	LD	HL,(_log_m)
	LD	DE,(_log_m+2)
	CALL	__fsub		; m-1
	LD	(_log_num),HL
	LD	(_log_num+2),DE

	; Compute (m+1)
	LD	HL,0
	LD	DE,3F80H
	LD	(__tmp32),HL
	LD	(__tmp32+2),DE
	LD	HL,(_log_m)
	LD	DE,(_log_m+2)
	CALL	__fadd		; m+1
	LD	(_log_den),HL
	LD	(_log_den+2),DE

	; y = (m-1)/(m+1)
	LD	(__tmp32),HL
	LD	(__tmp32+2),DE
	LD	HL,(_log_num)
	LD	DE,(_log_num+2)
	CALL	__fdiv
	LD	(_log_y),HL
	LD	(_log_y+2),DE

	; y^2
	LD	(__tmp32),HL
	LD	(__tmp32+2),DE
	CALL	__fmul
	LD	(_log_y2),HL
	LD	(_log_y2+2),DE

	; atanh series: y + y^3/3 + y^5/5 + ...
	; sum = y, term = y
	LD	HL,(_log_y)
	LD	DE,(_log_y+2)
	LD	(_log_sum),HL
	LD	(_log_sum+2),DE
	LD	(_log_term),HL
	LD	(_log_term+2),DE

	LD	B,5
	LD	C,3

_log_loop:
	PUSH	BC

	; term *= y^2
	LD	HL,(_log_term)
	LD	DE,(_log_term+2)
	LD	A,(_log_y2)
	LD	(__tmp32),A
	LD	A,(_log_y2+1)
	LD	(__tmp32+1),A
	LD	A,(_log_y2+2)
	LD	(__tmp32+2),A
	LD	A,(_log_y2+3)
	LD	(__tmp32+3),A
	CALL	__fmul
	LD	(_log_term),HL
	LD	(_log_term+2),DE

	; Divide by n (odd number)
	POP	BC
	LD	L,C
	INC	C
	INC	C		; Next odd
	PUSH	BC		; Save updated B and C
	LD	H,0
	LD	E,H
	LD	D,H		; DEHL = n as 32-bit int
	CALL	__itof
	LD	(__tmp32),HL
	LD	(__tmp32+2),DE
	LD	HL,(_log_term)
	LD	DE,(_log_term+2)
	CALL	__fdiv

	; Add to sum
	LD	A,(_log_sum)
	LD	(__tmp32),A
	LD	A,(_log_sum+1)
	LD	(__tmp32+1),A
	LD	A,(_log_sum+2)
	LD	(__tmp32+2),A
	LD	A,(_log_sum+3)
	LD	(__tmp32+3),A
	CALL	__fadd
	LD	(_log_sum),HL
	LD	(_log_sum+2),DE

	POP	BC
	DJNZ	_log_loop

	; log(m) = 2 * sum
	LD	HL,(_log_sum)
	LD	DE,(_log_sum+2)
	LD	(__tmp32),HL
	LD	(__tmp32+2),DE
	CALL	__fadd		; 2*sum
	LD	(_log_sum),HL
	LD	(_log_sum+2),DE

	; Add e * ln(2)
	; Convert e (signed byte) to float
	LD	A,(_log_e)
	LD	L,A
	RLA			; Sign extend to 16-bit
	SBC	A,A
	LD	H,A
	LD	E,A
	LD	D,A		; DEHL = e as signed 32-bit
	CALL	__itof

	; Multiply by ln(2) = 0.693147 = 3F317218H
	LD	A,18H
	LD	(__tmp32),A
	LD	A,72H
	LD	(__tmp32+1),A
	LD	A,31H
	LD	(__tmp32+2),A
	LD	A,3FH
	LD	(__tmp32+3),A
	CALL	__fmul		; e * ln(2)

	; Add log(m)
	LD	A,(_log_sum)
	LD	(__tmp32),A
	LD	A,(_log_sum+1)
	LD	(__tmp32+1),A
	LD	A,(_log_sum+2)
	LD	(__tmp32+2),A
	LD	A,(_log_sum+3)
	LD	(__tmp32+3),A
	CALL	__fadd		; e*ln(2) + log(m)

	JR	_log_done

_log_err:
	; Return negative infinity
	LD	HL,0
	LD	DE,0FF80H	; -inf

_log_done:
	POP	BC
	POP	IX
	RET

	DSEG

_log_x:		DS	4
_log_m:		DS	4
_log_num:	DS	4
_log_den:	DS	4
_log_y:		DS	4
_log_y2:	DS	4
_log_sum:	DS	4
_log_term:	DS	4
_log_e:		DS	1


; ============================================================
; lc_log10.mac
; ============================================================
	CSEG
; lc_log10.mac - log10, log10f, log10l (depends on log)


	EXTRN	__fdiv
	EXTRN	__tmp32

	CSEG

; ============================================================
; log10(x) = log(x) / log(10)
; log(10) = 2.302585...
; ============================================================
	PUBLIC	_log10
	PUBLIC	_log10f
	PUBLIC	_log10l
_log10:
_log10f:
_log10l:
	PUSH	IX
	PUSH	BC
	LD	IX,0
	ADD	IX,SP

	CALL	_math_getarg
	PUSH	DE
	PUSH	HL
	CALL	_logf
	POP	BC
	POP	BC

	; Divide by log(10) = 2.302585 (40135D8E)
	LD	A,8EH
	LD	(__tmp32),A
	LD	A,5DH
	LD	(__tmp32+1),A
	LD	A,13H
	LD	(__tmp32+2),A
	LD	A,40H
	LD	(__tmp32+3),A
	CALL	__fdiv

	POP	BC
	POP	IX
	RET


; ============================================================
; lc_log1p.mac
; ============================================================
	CSEG
; lc_log1p.mac - log1p, log1pf
; log1p(x) = log(1 + x)


	EXTRN	__fadd
	EXTRN	__tmp32

	CSEG

	PUBLIC	_log1p
	PUBLIC	_log1pf
_log1p:
_log1pf:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP

	; 1.0 + x: put x in __tmp32, 1.0 in DEHL
	LD	A,(IX+4)
	LD	(__tmp32),A
	LD	A,(IX+5)
	LD	(__tmp32+1),A
	LD	A,(IX+6)
	LD	(__tmp32+2),A
	LD	A,(IX+7)
	LD	(__tmp32+3),A
	LD	HL,0
	LD	DE,3F80H	; 1.0
	CALL	__fadd		; 1.0 + x

	; log(1 + x)
	PUSH	DE
	PUSH	HL
	CALL	_logf
	POP	BC
	POP	BC

	POP	IX
	RET


; ============================================================
; lc_log2.mac
; ============================================================
	CSEG
; lc_log2.mac - log2, log2f (depends on log)


	EXTRN	__fdiv
	EXTRN	__tmp32

	CSEG

; ============================================================
; log2(x) = log(x) / log(2)
; log(2) = 0.693147...
; ============================================================
	PUBLIC	_log2
	PUBLIC	_log2f
_log2:
_log2f:
	PUSH	IX
	PUSH	BC
	LD	IX,0
	ADD	IX,SP

	CALL	_math_getarg
	PUSH	DE
	PUSH	HL
	CALL	_logf
	POP	BC
	POP	BC

	; Divide by log(2) = 0.693147 (3F317218)
	LD	A,18H
	LD	(__tmp32),A
	LD	A,72H
	LD	(__tmp32+1),A
	LD	A,31H
	LD	(__tmp32+2),A
	LD	A,3FH
	LD	(__tmp32+3),A
	CALL	__fdiv

	POP	BC
	POP	IX
	RET


; ============================================================
; lc_logb.mac
; ============================================================
	CSEG
; lc_logb.mac - logb, logbf, ilogb, ilogbf
; Extract exponent from IEEE 754 float


	EXTRN	__itof

	CSEG

; ============================================================
; ilogb(x) - return exponent as int
; Returns: HL = unbiased exponent
; ============================================================
	PUBLIC	_ilogb
	PUBLIC	_ilogbf
_ilogb:
_ilogbf:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP

	; Extract 8-bit exponent from IEEE 754
	; D has SEEEEEEE, E has EMMMMMM
	LD	A,(IX+7)	; D byte (SEEEEEEE)
	AND	7FH		; Strip sign (0EEEEEEE)
	ADD	A,A		; Shift left (EEEEEEE0)
	LD	B,A
	LD	A,(IX+6)	; E byte (EMMMMMMM)
	RLCA			; Rotate - exp low bit into bit 0
	AND	1		; Isolate exp low bit
	OR	B		; A = full 8-bit biased exponent

	; Check zero (exp=0)
	OR	A
	JR	Z,_ilogb_zero

	; Check inf/nan (exp=255)
	CP	255
	JR	Z,_ilogb_inf

	; Normal: exp - 127
	SUB	127
	LD	L,A
	RLA			; Sign extend
	SBC	A,A
	LD	H,A
	POP	IX
	RET

_ilogb_zero:
	; Check mantissa for subnormal
	LD	A,(IX+6)
	AND	7FH
	OR	(IX+5)
	OR	(IX+4)
	JR	NZ,_ilogb_sub
	; True zero: return INT_MIN
	LD	HL,8000H
	POP	IX
	RET

_ilogb_sub:
	; Subnormal: return -126
	LD	HL,0FF82H
	POP	IX
	RET

_ilogb_inf:
	; Return INT_MAX
	LD	HL,7FFFH
	POP	IX
	RET

; ============================================================
; logb(x) - return exponent as float
; ============================================================
	PUBLIC	_logb
	PUBLIC	_logbf
_logb:
_logbf:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP

	; Extract exponent
	LD	A,(IX+7)	; D byte (SEEEEEEE)
	AND	7FH		; Strip sign (0EEEEEEE)
	ADD	A,A		; Shift left (EEEEEEE0)
	LD	B,A
	LD	A,(IX+6)	; E byte (EMMMMMMM)
	RLCA			; Rotate - exp low bit into bit 0
	AND	1		; Isolate exp low bit
	OR	B		; A = biased exponent

	; Check zero
	OR	A
	JR	Z,_logb_zero

	; Check inf/nan
	CP	255
	JR	Z,_logb_inf

	; Normal: convert (exp - 127) to float
	SUB	127
	LD	L,A
	RLA
	SBC	A,A		; Sign extend
	LD	H,A
	LD	D,A
	LD	E,A		; DEHL = 32-bit signed
	CALL	__itof
	POP	IX
	RET

_logb_zero:
	; Check subnormal
	LD	A,(IX+6)
	AND	7FH
	OR	(IX+5)
	OR	(IX+4)
	JR	NZ,_logb_sub
	; True zero: return -inf
	LD	HL,0
	LD	DE,0FF80H
	POP	IX
	RET

_logb_sub:
	; Subnormal: return -126 as float
	LD	HL,0FF82H	; -126 as 16-bit
	LD	DE,0FFFFH	; Sign extend to 32-bit
	CALL	__itof
	POP	IX
	RET

_logb_inf:
	; Return +inf
	LD	HL,0
	LD	DE,7F80H
	POP	IX
	RET


; ============================================================
; lc_malloc.mac
; ============================================================
	CSEG
; lc_malloc.mac - dynamic memory allocation


	CSEG

; ============================================================
	PUBLIC	_malloc
_malloc:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP

	; Get size
	LD	C,(IX+4)
	LD	B,(IX+5)

	; Get current heap pointer
	LD	HL,(_heap_ptr)

	; If heap_ptr is 0, initialize it
	LD	A,H
	OR	L
	JR	NZ,_malloc_have_heap
	; Initialize heap to start after our data
	LD	HL,_heap_start
	LD	(_heap_ptr),HL

_malloc_have_heap:
	; HL = current heap pointer (return value)
	PUSH	HL		; Save return address

	; Advance heap pointer by size
	ADD	HL,BC
	; Check if we would exceed stack (rough check)
	; SP is approximate limit
	PUSH	HL
	EX	DE,HL
	LD	HL,0
	ADD	HL,SP
	; DE = new heap ptr, HL = SP
	; If new_ptr >= SP - 256, fail (leave some stack margin)
	LD	BC,256
	OR	A
	SBC	HL,BC		; HL = SP - 256
	EX	DE,HL		; DE = SP - 256, HL = new heap ptr
	OR	A
	SBC	HL,DE		; If new_heap > limit, carry clear and result positive
	POP	HL		; HL = new heap ptr
	JR	NC,_malloc_oom

	; Store new heap pointer
	LD	(_heap_ptr),HL

	; Return saved pointer
	POP	HL
	POP	IX
	RET

_malloc_oom:
	; Out of memory - return NULL
	POP	HL		; Discard saved pointer
	LD	HL,0
	POP	IX
	RET

; ============================================================
; void *calloc(size_t nmemb, size_t size)
; Allocate zeroed memory
; Arguments: nmemb at IX+4, size at IX+6
; Returns: pointer to zeroed memory, or NULL
; ============================================================
	PUBLIC	_calloc
_calloc:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP

	; Calculate total size = nmemb * size
	LD	L,(IX+4)	; HL = nmemb
	LD	H,(IX+5)
	LD	E,(IX+6)	; DE = size
	LD	D,(IX+7)

	; 16-bit multiply: HL = HL * DE
	PUSH	BC
	LD	B,H
	LD	C,L		; BC = nmemb
	LD	HL,0
_calloc_mult:
	LD	A,B
	OR	C
	JR	Z,_calloc_mult_done
	ADD	HL,DE
	DEC	BC
	JR	_calloc_mult
_calloc_mult_done:
	; HL = total size
	POP	BC

	; Call malloc with size in HL
	PUSH	HL		; Push size as argument
	CALL	_malloc
	POP	DE		; Pop size into DE (we need it for clearing)

	; Check if malloc returned NULL
	LD	A,H
	OR	L
	JR	Z,_calloc_ret	; Return NULL

	; Zero the memory: HL = ptr, DE = size
	PUSH	HL		; Save return value
	EX	DE,HL		; HL = size, DE = ptr

	; Zero BC bytes at (DE)
	LD	B,H
	LD	C,L		; BC = size
	EX	DE,HL		; HL = ptr

_calloc_zero:
	LD	A,B
	OR	C
	JR	Z,_calloc_zero_done
	LD	(HL),0
	INC	HL
	DEC	BC
	JR	_calloc_zero

_calloc_zero_done:
	POP	HL		; Restore return value

_calloc_ret:
	POP	IX
	RET

; ============================================================
; void free(void *ptr)
; Free memory - no-op in bump allocator
; ============================================================
	PUBLIC	_free
_free:
	RET			; No-op: bump allocator never frees

; ============================================================
; void *realloc(void *ptr, size_t size)
; Resize allocated memory
; Simple implementation: always allocates new block and copies
; ============================================================
	PUBLIC	_realloc
_realloc:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	PUSH	BC
	PUSH	DE

	LD	L,(IX+4)	; HL = ptr
	LD	H,(IX+5)
	LD	C,(IX+6)	; BC = size
	LD	B,(IX+7)

	; If ptr is NULL, just malloc
	LD	A,H
	OR	L
	JR	NZ,_realloc_check_size
	; malloc(size)
	PUSH	BC
	CALL	_malloc
	POP	DE
	JR	_realloc_done

_realloc_check_size:
	; If size is 0, free and return NULL
	LD	A,B
	OR	C
	JR	NZ,_realloc_do
	; size is 0, return NULL
	LD	HL,0
	JR	_realloc_done

_realloc_do:
	; Save old pointer
	PUSH	HL

	; Allocate new block
	PUSH	BC
	CALL	_malloc
	POP	DE		; DE = size (for copy)
	LD	B,D
	LD	C,E		; BC = size

	; Check if malloc failed
	LD	A,H
	OR	L
	JR	Z,_realloc_fail

	; Copy old data to new block
	; HL = new ptr, need old ptr
	EX	DE,HL		; DE = new ptr
	POP	HL		; HL = old ptr

	; Copy BC bytes from HL to DE
	; But BC might be larger than old allocation!
	; Since we don't track sizes, copy the minimum
	; For safety, just copy size bytes (user's responsibility)
	PUSH	DE		; Save new ptr to return
	LDIR			; Copy BC bytes from HL to DE
	POP	HL		; HL = new ptr
	JR	_realloc_done

_realloc_fail:
	POP	DE		; Discard old ptr
	; HL is already 0

_realloc_done:
	POP	DE
	POP	BC
	POP	IX
	RET

; ============================================================


	DSEG
_heap_ptr:	DW	0
_heap_start:	DW	0


; ============================================================
; lc_math_helper.mac
; ============================================================
	CSEG
; lc_math_helper.mac - shared math helper functions


	EXTRN	__tmp32

	CSEG

; ============================================================
; Helper: Load float argument from stack into DEHL
; Call with IX pointing to stack frame
; ============================================================
	PUBLIC	_math_getarg
_math_getarg:
	; Stack: +0,+1=BC, +2,+3=IX, +4,+5=retaddr, +6..+9=arg
	LD	L,(IX+6)
	LD	H,(IX+7)
	LD	E,(IX+8)
	LD	D,(IX+9)
	RET

; ============================================================
; Helper: Load second float argument into __tmp32
; ============================================================
	PUBLIC	_math_getarg2
_math_getarg2:
	LD	A,(IX+10)
	LD	(__tmp32),A
	LD	A,(IX+11)
	LD	(__tmp32+1),A
	LD	A,(IX+12)
	LD	(__tmp32+2),A
	LD	A,(IX+13)
	LD	(__tmp32+3),A
	RET


; ============================================================
; lc_mem.mac
; ============================================================
	CSEG
; lc_mem.mac - memory functions


	CSEG

; ============================================================
; void *memcpy(void *dest, const void *src, size_t n)
; Copy n bytes from src to dest
; Returns: dest
; ============================================================
	PUBLIC	_memcpy
_memcpy:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	PUSH	BC

	LD	E,(IX+4)	; DE = dest
	LD	D,(IX+5)
	LD	L,(IX+6)	; HL = src
	LD	H,(IX+7)
	LD	C,(IX+8)	; BC = n
	LD	B,(IX+9)

	LD	A,B		; Check if n == 0
	OR	C
	JR	Z,_memcpy_done

	LDIR			; Block copy

_memcpy_done:
	LD	L,(IX+4)	; Return dest
	LD	H,(IX+5)
	POP	BC
	POP	IX
	RET

; ============================================================
; void *memset(void *s, int c, size_t n)
; Fill n bytes of s with c
; Returns: s
; ============================================================
	PUBLIC	_memset
_memset:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	PUSH	BC

	LD	L,(IX+4)	; HL = dest
	LD	H,(IX+5)
	LD	A,(IX+6)	; A = fill byte
	LD	C,(IX+8)	; BC = n
	LD	B,(IX+9)

	PUSH	HL		; Save dest for return

	PUSH	AF		; Save fill byte
	LD	A,B		; Check if n == 0
	OR	C
	JR	Z,_memset_done_pop

	POP	AF		; Restore fill byte
	LD	(HL),A		; Store first byte
	LD	D,H		; DE = HL + 1
	LD	E,L
	INC	DE
	DEC	BC		; n - 1
	LD	A,B
	OR	C
	JR	Z,_memset_done
	LDIR			; Copy first byte to rest
	JR	_memset_done

_memset_done_pop:
	POP	AF		; Discard saved fill byte

_memset_done:
	POP	HL		; Return dest
	POP	BC
	POP	IX
	RET

; ============================================================
; int memcmp(const void *s1, const void *s2, size_t n)
; Compare n bytes of s1 and s2
; Returns: <0 if s1<s2, 0 if s1==s2, >0 if s1>s2
; ============================================================
	PUBLIC	_memcmp
_memcmp:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	PUSH	BC

	LD	E,(IX+4)	; DE = s1
	LD	D,(IX+5)
	LD	L,(IX+6)	; HL = s2
	LD	H,(IX+7)
	LD	C,(IX+8)	; BC = n
	LD	B,(IX+9)

_memcmp_loop:
	LD	A,B
	OR	C
	JR	Z,_memcmp_equal	; n == 0, equal

	LD	A,(DE)
	PUSH	HL
	LD	H,(HL)
	SUB	H
	POP	HL
	JR	NZ,_memcmp_diff

	DEC	BC
	INC	DE
	INC	HL
	JR	_memcmp_loop

_memcmp_equal:
	LD	HL,0
	POP	BC
	POP	IX
	RET

_memcmp_diff:
	LD	L,A
	RLA
	SBC	A,A
	LD	H,A
	POP	BC
	POP	IX
	RET

; ============================================================
; void *malloc(size_t size)
; Allocate memory from heap
; Simple bump allocator - memory is never freed
; Argument: size on stack at IX+4
; Returns: pointer to allocated memory, or NULL (0) if failed

; ============================================================
; void *memmove(void *dest, const void *src, size_t n)
; Copy n bytes, handles overlapping regions
; Returns: dest
; ============================================================
	PUBLIC	_memmove
_memmove:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	PUSH	BC

	LD	E,(IX+4)	; DE = dest
	LD	D,(IX+5)
	LD	L,(IX+6)	; HL = src
	LD	H,(IX+7)
	LD	C,(IX+8)	; BC = n
	LD	B,(IX+9)

	; Check if n == 0
	LD	A,B
	OR	C
	JR	Z,_memmove_done

	; Check if we need to copy backwards
	; If dest > src and dest < src + n, copy backwards
	PUSH	HL
	OR	A
	SBC	HL,DE		; HL = src - dest
	POP	HL
	JR	NC,_memmove_fwd	; src >= dest, copy forward

	; dest > src, check if overlapping
	PUSH	HL
	ADD	HL,BC		; HL = src + n
	OR	A
	SBC	HL,DE		; If src + n > dest, overlapping
	POP	HL
	JR	C,_memmove_fwd	; No overlap, forward is fine
	JR	Z,_memmove_fwd

	; Copy backwards
	; Move pointers to end
	ADD	HL,BC
	DEC	HL		; HL = src + n - 1
	EX	DE,HL
	ADD	HL,BC
	DEC	HL		; HL = dest + n - 1
	EX	DE,HL		; HL = src end, DE = dest end

_memmove_bwd:
	LD	A,B
	OR	C
	JR	Z,_memmove_done
	LD	A,(HL)
	LD	(DE),A
	DEC	HL
	DEC	DE
	DEC	BC
	JR	_memmove_bwd

_memmove_fwd:
	; Copy forward using LDIR
	LDIR

_memmove_done:
	LD	L,(IX+4)	; Return dest
	LD	H,(IX+5)
	POP	BC
	POP	IX
	RET

; ============================================================
; void *memchr(const void *s, int c, size_t n)
; Find first occurrence of c in first n bytes of s
; Returns: pointer to byte, or NULL if not found
; ============================================================
	PUBLIC	_memchr
_memchr:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	PUSH	BC

	LD	L,(IX+4)	; HL = s
	LD	H,(IX+5)
	LD	E,(IX+6)	; E = char to find
	LD	C,(IX+8)	; BC = n
	LD	B,(IX+9)

_memchr_loop:
	LD	A,B
	OR	C
	JR	Z,_memchr_notfound

	LD	A,(HL)
	CP	E
	JR	Z,_memchr_found

	INC	HL
	DEC	BC
	JR	_memchr_loop

_memchr_found:
	POP	BC
	POP	IX
	RET			; HL already points to match

_memchr_notfound:
	LD	HL,0
	POP	BC
	POP	IX
	RET

; ============================================================
; int sprintf(char *str, const char *fmt, ...)
; Format string into buffer
; Supports %d, %s, %c, %x, %%
; Returns: number of characters written (excluding null)


; ============================================================
; lc_misc.mac
; ============================================================
	CSEG
; lc_misc.mac - getenv, system


	CSEG

; ============================================================
; char *getenv(const char *name)
; Get environment variable (stub - returns NULL on CP/M)
; ============================================================
	PUBLIC	_getenv
_getenv:
	LD	HL,0		; Always return NULL
	RET

; ============================================================
; int system(const char *command)
; Execute shell command (stub - returns -1 on CP/M)
; ============================================================
	PUBLIC	_system
_system:
	LD	HL,-1		; Return -1 (failure)
	RET

; ============================================================


; ============================================================
; lc_modf.mac
; ============================================================
	CSEG
; lc_modf.mac - modf, modff


	EXTRN	__fsub
	EXTRN	__ftoi
	EXTRN	__itof
	EXTRN	__tmp32

	CSEG

; ============================================================
; modf(x, double *iptr) - split into integer and fractional parts
; ============================================================
	PUBLIC	_modf
	PUBLIC	_modff
_modf:
_modff:
	PUSH	IX
	PUSH	BC
	LD	IX,0
	ADD	IX,SP

	CALL	_math_getarg
	LD	(_modf_x),HL
	LD	(_modf_x+2),DE

	; Get integer part
	CALL	__ftoi
	CALL	__itof
	LD	(_modf_i),HL
	LD	(_modf_i+2),DE

	; Store to *iptr
	LD	A,(IX+10)
	LD	C,A
	LD	A,(IX+11)
	LD	B,A
	LD	A,L
	LD	(BC),A
	INC	BC
	LD	A,H
	LD	(BC),A
	INC	BC
	LD	A,E
	LD	(BC),A
	INC	BC
	LD	A,D
	LD	(BC),A

	; Return fractional part: x - int
	LD	(__tmp32),HL
	LD	(__tmp32+2),DE
	LD	HL,(_modf_x)
	LD	DE,(_modf_x+2)
	CALL	__fsub

	POP	BC
	POP	IX
	RET

	DSEG

_modf_x:	DS	4
_modf_i:	DS	4


; ============================================================
; lc_nan.mac
; ============================================================
	CSEG
; lc_nan.mac - nan, nanf
; Return quiet NaN (7FC00000H)


	CSEG

	PUBLIC	_nan
	PUBLIC	_nanf
_nan:
_nanf:
	LD	HL,0
	LD	DE,7FC0H	; Quiet NaN
	RET


; ============================================================
; lc_nextafter.mac
; ============================================================
	CSEG
; lc_nextafter.mac - nextafter, nextafterf
; Return next representable float from x toward y


	EXTRN	__fcmp
	EXTRN	__tmp32

	CSEG

	PUBLIC	_nextafter
	PUBLIC	_nextafterf
_nextafter:
_nextafterf:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP

	; Load x into DEHL
	LD	L,(IX+4)
	LD	H,(IX+5)
	LD	E,(IX+6)
	LD	D,(IX+7)

	; Check x == 0
	LD	A,D
	AND	7FH
	OR	E
	OR	H
	OR	L
	JR	Z,_na_xzero

	; Load y into __tmp32
	LD	A,(IX+8)
	LD	(__tmp32),A
	LD	A,(IX+9)
	LD	(__tmp32+1),A
	LD	A,(IX+10)
	LD	(__tmp32+2),A
	LD	A,(IX+11)
	LD	(__tmp32+3),A

	; Reload x (clobbered by __tmp32 stores)
	LD	L,(IX+4)
	LD	H,(IX+5)
	LD	E,(IX+6)
	LD	D,(IX+7)

	; Compare x with y
	CALL	__fcmp
	JR	Z,_na_eq

	; Save C flag: 1 if x < y
	LD	A,0
	RLA			; A = carry
	LD	B,A		; B = (x < y) ? 1 : 0

	; Get sign of x
	LD	A,(IX+7)
	RLCA			; Sign into C and bit 0
	AND	1		; A = sign (0=pos, 1=neg)

	; XOR: different → increment, same → decrement
	XOR	B

	; Reload x
	LD	L,(IX+4)
	LD	H,(IX+5)
	LD	E,(IX+6)
	LD	D,(IX+7)

	JR	NZ,_na_inc

	; Decrement 32-bit DEHL
	LD	A,L
	SUB	1
	LD	L,A
	LD	A,H
	SBC	A,0
	LD	H,A
	LD	A,E
	SBC	A,0
	LD	E,A
	LD	A,D
	SBC	A,0
	LD	D,A
	JR	_na_done

_na_inc:
	; Increment 32-bit DEHL
	LD	A,L
	ADD	A,1
	LD	L,A
	LD	A,H
	ADC	A,0
	LD	H,A
	LD	A,E
	ADC	A,0
	LD	E,A
	LD	A,D
	ADC	A,0
	LD	D,A
	JR	_na_done

_na_xzero:
	; x is zero, return smallest subnormal toward y
	LD	L,1
	LD	H,0
	LD	E,0
	LD	A,(IX+11)	; Sign of y
	AND	80H
	LD	D,A
	JR	_na_done

_na_eq:
	; x == y, return y
	LD	L,(IX+8)
	LD	H,(IX+9)
	LD	E,(IX+10)
	LD	D,(IX+11)

_na_done:
	POP	IX
	RET


; ============================================================
; lc_pow.mac
; ============================================================
	CSEG
; lc_pow.mac - pow, powf, powl (depends on log, exp)


	EXTRN	__fmul
	EXTRN	__tmp32

	CSEG

; ============================================================
; pow(x, y) = exp(y * log(x))
; ============================================================
	PUBLIC	_pow
	PUBLIC	_powf
	PUBLIC	_powl
_pow:
_powf:
_powl:
	PUSH	IX
	PUSH	BC
	LD	IX,0
	ADD	IX,SP

	; Get x
	CALL	_math_getarg
	LD	(_pow_x),HL
	LD	(_pow_x+2),DE

	; Get y
	CALL	_math_getarg2
	LD	HL,(__tmp32)
	LD	DE,(__tmp32+2)
	LD	(_pow_y),HL
	LD	(_pow_y+2),DE

	; Compute log(x)
	LD	HL,(_pow_x)
	LD	DE,(_pow_x+2)
	PUSH	DE
	PUSH	HL
	CALL	_logf
	POP	BC
	POP	BC

	; Multiply by y
	LD	A,(_pow_y)
	LD	(__tmp32),A
	LD	A,(_pow_y+1)
	LD	(__tmp32+1),A
	LD	A,(_pow_y+2)
	LD	(__tmp32+2),A
	LD	A,(_pow_y+3)
	LD	(__tmp32+3),A
	CALL	__fmul

	; Compute exp(y*log(x))
	PUSH	DE
	PUSH	HL
	CALL	_expf
	POP	BC
	POP	BC

	POP	BC
	POP	IX
	RET

	DSEG

_pow_x:		DS	4
_pow_y:		DS	4


; ============================================================
; lc_printf_all.mac
; ============================================================
	CSEG
; lc_printf_all.mac - default printf format table (all handlers)
; This module provides the full __printf_format_table when no
; #pragma printf is specified. It references all format handlers
; so the linker pulls them all in.




	CSEG

	PUBLIC	__printf_format_table
__printf_format_table:
	DB	'd'
	DW	__printf_handle_d
	DB	'i'
	DW	__printf_handle_d	; %i same as %d
	DB	'u'
	DW	__printf_handle_u
	DB	'o'
	DW	__printf_handle_o
	DB	'x'
	DW	__printf_handle_x
	DB	'X'
	DW	__printf_handle_xu
	DB	's'
	DW	__printf_handle_s
	DB	'c'
	DW	__printf_handle_c
	DB	'p'
	DW	__printf_handle_p
	DB	'l'
	DW	__printf_handle_l
	DB	'f'
	DW	__printf_handle_f
	DB	0		; sentinel

	PUBLIC	__printf_long_table
__printf_long_table:
	DB	'd'
	DW	__printf_handle_ld
	DB	'i'
	DW	__printf_handle_ld	; %li same as %ld
	DB	'u'
	DW	__printf_handle_lu
	DB	'o'
	DW	__printf_handle_lo
	DB	'x'
	DW	__printf_handle_lx
	DB	'f'
	DW	__printf_handle_f	; %lf same as %f
	DB	'l'
	DW	__printf_ll_entry
	DB	0		; sentinel

	PUBLIC	__printf_ll_table
__printf_ll_table:
	DB	'd'
	DW	__printf_handle_lld
	DB	'i'
	DW	__printf_handle_lld
	DB	'u'
	DW	__printf_handle_llu
	DB	'x'
	DW	__printf_handle_llx
	DB	0		; sentinel

; The 'll' dispatch entry point - search __printf_ll_table
; This is needed because 'l' handler in lc_printf_l.mac
; references __printf_ll_table directly
__printf_ll_entry:
	; Not used directly - the 'l' handler handles 'll' internally
	RET


; ============================================================
; lc_printf_c.mac
; ============================================================
	CSEG
; lc_printf_c.mac - printf %c handler



	CSEG

	PUBLIC	__printf_handle_c
__printf_handle_c:
	PUSH	HL
	LD	H,0
	LD	L,C
	PUSH	BC
	PUSH	IX
	POP	DE
	ADD	HL,DE
	LD	E,(HL)
	LD	C,CONOUT
	CALL	BDOS
	POP	BC
	INC	C
	INC	C
	POP	HL
	JP	_printf_loop


; ============================================================
; lc_printf_core.mac
; ============================================================
	CSEG
; lc_printf_core.mac - printf core dispatcher
; Table-driven printf: searches __printf_format_table for format handlers
;
; Handler calling convention:
;   Entry: HL = format string ptr (past the specifier char)
;          C  = arg offset byte (relative to IX frame)
;          IX = caller's frame pointer
;   State: _printf_width, _printf_zero, _printf_prec, _printf_hasprec,
;          _printf_upper available via EXTRN
;   Exit:  JP _printf_loop with HL = next format position, C = updated arg offset
;
; The format table is an array of (DB char, DW handler_addr) entries
; terminated by DB 0. It is defined by the codegen (in the user's .mac file)
; when compiling main(), or defaults to a full table.




	CSEG

	PUBLIC	_printf
	PUBLIC	_printf_loop
	PUBLIC	_printf_done
	PUBLIC	_printf_format
	PUBLIC	_printf_prt_hex
	PUBLIC	_printf_nib2a
	PUBLIC	_printf_width
	PUBLIC	_printf_zero
	PUBLIC	_printf_upper
	PUBLIC	_printf_prec
	PUBLIC	_printf_hasprec
	PUBLIC	_printf_neg
	PUBLIC	_printf_hexbuf
	PUBLIC	_printf_decbuf
	PUBLIC	_printf_dptr
	PUBLIC	_printf_dstart
	PUBLIC	_printf_dcnt
	PUBLIC	_printf_ll_w0
	PUBLIC	_printf_ll_w1
	PUBLIC	_printf_ll_w2
	PUBLIC	_printf_ll_w3
	PUBLIC	_prt_float_prec
	PUBLIC	_prt_float
	PUBLIC	__ftmp

_printf:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	PUSH	BC
	PUSH	DE

	; fmt is at IX+4, first vararg at IX+6
	LD	L,(IX+4)
	LD	H,(IX+5)	; HL = format string pointer
	LD	C,6		; C = offset to next argument

_printf_loop:
	LD	A,(HL)
	OR	A
	JR	Z,_printf_done

	CP	'%'
	JR	Z,_printf_format

	; Regular character - output it
	LD	E,A
	PUSH	HL
	PUSH	BC
	LD	C,CONOUT
	CALL	BDOS
	POP	BC
	POP	HL
	INC	HL
	JR	_printf_loop

_printf_format:
	INC	HL
	; Initialize format state
	XOR	A
	LD	(_printf_width),A
	LD	(_printf_zero),A
	LD	(_printf_upper),A
	LD	(_printf_prec),A
	LD	(_printf_hasprec),A
	LD	A,(HL)
	OR	A
	JP	Z,_printf_done

	CP	'%'
	JR	Z,_printf_pct

_printf_fmt2:
	; Check for '0' flag (only when not in precision and width is 0)
	CP	'0'
	JR	NZ,_printf_not0
	PUSH	AF
	LD	A,(_printf_hasprec)
	OR	A
	JR	NZ,_printf_0dig
	LD	A,(_printf_width)
	OR	A
	JR	NZ,_printf_0dig
	; Set zero-padding flag
	LD	A,1
	LD	(_printf_zero),A
	POP	AF
	JR	_printf_skip
_printf_0dig:
	POP	AF
	JR	_printf_isdig

_printf_not0:
	; Check for precision start
	CP	'.'
	JR	NZ,_printf_notdot
	PUSH	AF
	LD	A,1
	LD	(_printf_hasprec),A
	POP	AF
	JR	_printf_skip

_printf_notdot:
	; Skip other flags: -, +, space, #
	CP	'-'
	JR	Z,_printf_skip
	CP	'+'
	JR	Z,_printf_skip
	CP	' '
	JR	Z,_printf_skip
	CP	'#'
	JR	Z,_printf_skip
	; Check for digits (1-9)
	CP	'1'
	JR	C,_printf_nodig
	CP	'9'+1
	JR	C,_printf_isdig
_printf_nodig:
	; Skip length modifiers: h, z, L
	CP	'h'
	JR	Z,_printf_skip
	CP	'z'
	JR	Z,_printf_skip
	CP	'L'
	JR	Z,_printf_skip

	; === DISPATCH: search __printf_format_table ===
	PUSH	HL		; Save format string position
	PUSH	BC		; Save arg offset
	LD	B,A		; B = format char to find
	LD	HL,__printf_format_table
_printf_search:
	LD	A,(HL)
	OR	A
	JR	Z,_printf_unknown	; End of table, char not found
	CP	B
	JR	Z,_printf_found
	INC	HL		; Skip handler address
	INC	HL
	INC	HL		; Next entry
	JR	_printf_search

_printf_found:
	INC	HL
	LD	E,(HL)
	INC	HL
	LD	D,(HL)		; DE = handler address
	POP	BC		; Restore arg offset
	POP	HL		; Restore format string ptr
	INC	HL		; Past the specifier char
	PUSH	DE
	RET			; Tail-call handler (JP DE)

_printf_unknown:
	; Unknown format char - skip it
	POP	BC
	POP	HL
	INC	HL
	JP	_printf_loop

_printf_isdig:
	; Parse digit into width or precision
	SUB	'0'
	PUSH	BC
	LD	B,A		; B = new digit
	LD	A,(_printf_hasprec)
	OR	A
	JR	NZ,_printf_precdig
	; Width digit
	LD	A,(_printf_width)
	LD	C,A
	ADD	A,A		; *2
	ADD	A,A		; *4
	ADD	A,C		; *5
	ADD	A,A		; *10
	ADD	A,B		; + digit
	LD	(_printf_width),A
	POP	BC
	JR	_printf_skip
_printf_precdig:
	; Precision digit
	LD	A,(_printf_prec)
	LD	C,A
	ADD	A,A
	ADD	A,A
	ADD	A,C
	ADD	A,A
	ADD	A,B
	LD	(_printf_prec),A
	POP	BC
	; Fall through to _printf_skip

_printf_skip:
	INC	HL
	LD	A,(HL)
	OR	A
	JP	Z,_printf_done
	JR	_printf_fmt2

_printf_pct:
	; Output literal %
	LD	E,'%'
	PUSH	HL
	PUSH	BC
	LD	C,CONOUT
	CALL	BDOS
	POP	BC
	POP	HL
	INC	HL
	JR	_printf_loop

_printf_done:
	LD	HL,0		; Return 0
	POP	DE
	POP	BC
	POP	IX
	RET

; ============================================================
; Printf hex with width/zero-padding/uppercase support
; Input: HL = value to print
; ============================================================
_printf_prt_hex:
	PUSH	BC
	; Convert 4 hex nibbles to ASCII in buffer
	LD	DE,_printf_hexbuf
	LD	A,H
	RRCA
	RRCA
	RRCA
	RRCA
	AND	0FH
	CALL	_printf_nib2a
	LD	A,H
	AND	0FH
	CALL	_printf_nib2a
	LD	A,L
	RRCA
	RRCA
	RRCA
	RRCA
	AND	0FH
	CALL	_printf_nib2a
	LD	A,L
	AND	0FH
	CALL	_printf_nib2a
	; Buffer has 4 ASCII hex chars
	; Find first significant digit (skip leading '0' but keep last)
	LD	HL,_printf_hexbuf
	LD	B,4
_printf_hx_lz:
	LD	A,B
	CP	1
	JR	Z,_printf_hx_pad
	LD	A,(HL)
	CP	'0'
	JR	NZ,_printf_hx_pad
	INC	HL
	DEC	B
	JR	_printf_hx_lz
_printf_hx_pad:
	; B = significant digits, HL = pointer to first
	LD	A,(_printf_width)
	OR	A
	JR	Z,_printf_hx_out
	SUB	B
	JR	Z,_printf_hx_out
	JR	C,_printf_hx_out
	PUSH	HL
	PUSH	BC
	LD	B,A
	LD	A,(_printf_zero)
	OR	A
	LD	A,' '
	JR	Z,_printf_hx_plp
	LD	A,'0'
_printf_hx_plp:
	LD	E,A
	PUSH	AF
	PUSH	BC
	LD	C,CONOUT
	CALL	BDOS
	POP	BC
	POP	AF
	DJNZ	_printf_hx_plp
	POP	BC
	POP	HL
_printf_hx_out:
	LD	A,(HL)
	LD	E,A
	PUSH	BC
	PUSH	HL
	LD	C,CONOUT
	CALL	BDOS
	POP	HL
	POP	BC
	INC	HL
	DJNZ	_printf_hx_out
	POP	BC
	RET

; Convert nibble (0-15) in A to ASCII hex char, store at (DE), advance DE
_printf_nib2a:
	ADD	A,'0'
	CP	'9'+1
	JR	C,_printf_nib_ok
	PUSH	BC
	LD	B,A
	LD	A,(_printf_upper)
	OR	A
	LD	A,B
	POP	BC
	JR	Z,_printf_nib_lo
	ADD	A,7
	JR	_printf_nib_ok
_printf_nib_lo:
	ADD	A,39
_printf_nib_ok:
	LD	(DE),A
	INC	DE
	RET

; ============================================================
; Internal: print float from __ftmp (IEEE 754 single precision)
; This is included in core since it's complex and shares state
; ============================================================
	EXTRN	__fmul
	EXTRN	__fsub
	EXTRN	__ftoi
	EXTRN	__itof
	EXTRN	__fadd
	EXTRN	__tmp32

_prt_float:
	PUSH	BC
	PUSH	DE
	PUSH	IX

	; Load float from __ftmp into HLDE
	LD	DE,(__ftmp)
	LD	HL,(__ftmp+2)

	; Check for zero
	LD	A,H
	AND	7FH
	OR	L
	OR	D
	OR	E
	JP	Z,_prt_float_zero

	; Check sign bit
	BIT	7,H
	JR	Z,_prt_float_pos

	; Print minus sign
	PUSH	HL
	PUSH	DE
	LD	E,'-'
	LD	C,CONOUT
	CALL	BDOS
	POP	DE
	POP	HL
	RES	7,H

_prt_float_pos:
	EX	DE,HL
	LD	(__fwork),HL
	LD	(__fwork+2),DE

	; Pre-round
	PUSH	DE
	PUSH	HL
	LD	DE,3F00H
	LD	HL,0
	LD	A,(_prt_float_prec)
	OR	A
	JR	Z,_prt_round_add
	LD	B,A
_prt_round_lp:
	LD	(__tmp32),HL
	LD	(__tmp32+2),DE
	LD	DE,3DCCH
	LD	HL,0CCCDH
	CALL	__fmul
	DJNZ	_prt_round_lp
_prt_round_add:
	LD	(__tmp32),HL
	LD	(__tmp32+2),DE
	LD	HL,(__fwork)
	LD	DE,(__fwork+2)
	CALL	__fadd
	LD	(__fwork),HL
	LD	(__fwork+2),DE
	POP	HL
	POP	DE

	; Reload rounded value
	LD	HL,(__fwork)
	LD	DE,(__fwork+2)
	EX	DE,HL

	; Extract exponent
	LD	A,H
	ADD	A,A
	LD	B,A
	LD	A,L
	RLCA
	LD	A,B
	ADC	A,0
	LD	B,A

	CP	255
	JP	Z,_prt_float_inf

	OR	A
	JP	Z,_prt_float_zero

	; Extract mantissa
	LD	A,L
	AND	7FH
	OR	80H
	LD	L,A

	LD	A,B
	SUB	127

	LD	(__fman),DE
	LD	A,L
	LD	(__fman+2),A

	LD	A,B
	SUB	127
	LD	B,A

	BIT	7,B
	JP	NZ,_prt_float_small

	LD	A,B
	CP	24
	JP	NC,_prt_float_large

	LD	A,23
	SUB	B
	LD	B,A

	LD	A,(__fman+2)
	LD	H,A
	LD	A,(__fman+1)
	LD	L,A
	LD	A,(__fman)
	LD	E,A

	PUSH	HL
	PUSH	DE

	LD	A,B
	OR	A
	JR	Z,_prt_float_noshr
_prt_float_shrloop:
	SRL	H
	RR	L
	RR	E
	DEC	A
	JR	NZ,_prt_float_shrloop
_prt_float_noshr:
	LD	A,H
	OR	A
	JR	NZ,_prt_float_use_hl
	LD	H,L
	LD	L,E
_prt_float_use_hl:
	PUSH	HL
	CALL	_prt_dec
	LD	E,'.'
	LD	C,CONOUT
	CALL	BDOS
	POP	HL

	POP	DE
	POP	DE

	LD	DE,0
	CALL	__itof
	LD	(__tmp32),HL
	LD	(__tmp32+2),DE
	LD	HL,(__fwork)
	LD	DE,(__fwork+2)
	CALL	__fsub
	LD	(__fwork),HL
	LD	(__fwork+2),DE

	LD	A,(_prt_float_prec)
	LD	B,A
	OR	A
	JP	Z,_prt_float_done
_prt_float_frac:
	PUSH	BC
	LD	HL,(__fwork)
	LD	DE,(__fwork+2)
	LD	(__tmp32),HL
	LD	(__tmp32+2),DE
	LD	DE,4120H
	LD	HL,0
	CALL	__fmul
	LD	(__fwork),HL
	LD	(__fwork+2),DE
	CALL	__ftoi
	LD	A,L
	PUSH	AF
	ADD	A,'0'
	LD	E,A
	LD	C,CONOUT
	CALL	BDOS
	POP	AF
	LD	L,A
	LD	H,0
	LD	DE,0
	CALL	__itof
	LD	(__tmp32),HL
	LD	(__tmp32+2),DE
	LD	HL,(__fwork)
	LD	DE,(__fwork+2)
	CALL	__fsub
	LD	(__fwork),HL
	LD	(__fwork+2),DE
	POP	BC
	DJNZ	_prt_float_frac
	JP	_prt_float_done

_prt_float_small:
	PUSH	BC
	LD	E,'0'
	LD	C,CONOUT
	CALL	BDOS
	LD	E,'.'
	LD	C,CONOUT
	CALL	BDOS
	POP	BC
	LD	A,B
	ADD	A,127
	LD	B,A
	LD	A,B
	SRL	A
	LD	D,A
	LD	A,B
	AND	1
	RLCA
	RLCA
	RLCA
	RLCA
	RLCA
	RLCA
	RLCA
	LD	C,A
	LD	A,(__fman+2)
	AND	7FH
	OR	C
	LD	E,A
	LD	A,(__fman+1)
	LD	H,A
	LD	A,(__fman)
	LD	L,A
	LD	(__fwork),HL
	LD	(__fwork+2),DE
	LD	A,(_prt_float_prec)
	LD	B,A
	OR	A
	JP	Z,_prt_float_done
_prt_float_sm_lp:
	PUSH	BC
	LD	HL,(__fwork)
	LD	DE,(__fwork+2)
	LD	(__tmp32),HL
	LD	(__tmp32+2),DE
	LD	DE,4120H
	LD	HL,0
	CALL	__fmul
	LD	(__fwork),HL
	LD	(__fwork+2),DE
	CALL	__ftoi
	LD	A,L
	PUSH	AF
	ADD	A,'0'
	LD	E,A
	LD	C,CONOUT
	CALL	BDOS
	POP	AF
	LD	L,A
	LD	H,0
	LD	DE,0
	CALL	__itof
	LD	(__tmp32),HL
	LD	(__tmp32+2),DE
	LD	HL,(__fwork)
	LD	DE,(__fwork+2)
	CALL	__fsub
	LD	(__fwork),HL
	LD	(__fwork+2),DE
	POP	BC
	DJNZ	_prt_float_sm_lp
	JP	_prt_float_done

_prt_float_large:
	LD	A,(__fman+2)
	LD	H,A
	LD	A,(__fman+1)
	LD	L,A
	LD	A,B
	SUB	23
	LD	B,A
	OR	A
	JR	Z,_prt_float_lg2
_prt_float_shlloop:
	SLA	L
	RL	H
	DJNZ	_prt_float_shlloop
_prt_float_lg2:
	CALL	_prt_dec
	LD	E,'.'
	LD	C,CONOUT
	CALL	BDOS
	LD	A,(_prt_float_prec)
	LD	B,A
	OR	A
	JR	Z,_prt_float_done
_prt_float_lg3:
	PUSH	BC
	LD	E,'0'
	LD	C,CONOUT
	CALL	BDOS
	POP	BC
	DJNZ	_prt_float_lg3
	JR	_prt_float_done

_prt_float_zero:
	LD	E,'0'
	LD	C,CONOUT
	CALL	BDOS
	LD	E,'.'
	LD	C,CONOUT
	CALL	BDOS
	LD	A,(_prt_float_prec)
	LD	B,A
	OR	A
	JR	Z,_prt_float_done
_prt_float_z2:
	PUSH	BC
	LD	E,'0'
	LD	C,CONOUT
	CALL	BDOS
	POP	BC
	DJNZ	_prt_float_z2
	JR	_prt_float_done

_prt_float_inf:
	LD	E,'i'
	LD	C,CONOUT
	CALL	BDOS
	LD	E,'n'
	LD	C,CONOUT
	CALL	BDOS
	LD	E,'f'
	LD	C,CONOUT
	CALL	BDOS

_prt_float_done:
	POP	IX
	POP	DE
	POP	BC
	RET

; ============================================================
; Internal: print HL as decimal (no padding, simple)
; ============================================================
	PUBLIC	_prt_dec
_prt_dec:
	PUSH	BC
	PUSH	DE
	LD	DE,10
	LD	B,0
_prt_dec_loop:
	CALL	_prt_div16
	PUSH	DE
	INC	B
	LD	A,H
	OR	L
	JR	NZ,_prt_dec_loop
_prt_dec_out:
	POP	DE
	LD	A,E
	ADD	A,'0'
	LD	E,A
	PUSH	BC
	LD	C,CONOUT
	CALL	BDOS
	POP	BC
	DJNZ	_prt_dec_out
	POP	DE
	POP	BC
	RET

; ============================================================
; Internal: HL = HL / 10, DE = HL % 10
; ============================================================
	PUBLIC	_prt_div16
_prt_div16:
	PUSH	BC
	LD	BC,0
	LD	DE,0
_prt_div16_lp:
	LD	A,H
	OR	A
	JR	NZ,_prt_div16_sub
	LD	A,L
	CP	10
	JR	C,_prt_div16_dn
_prt_div16_sub:
	LD	A,L
	SUB	10
	LD	L,A
	LD	A,H
	SBC	A,0
	LD	H,A
	INC	BC
	JR	_prt_div16_lp
_prt_div16_dn:
	LD	E,L
	LD	D,0
	LD	H,B
	LD	L,C
	POP	BC
	RET

	DSEG

_printf_hexbuf:	DS	4
_printf_decbuf:	DS	6
_printf_neg:	DB	0
_printf_dptr:	DS	2
_printf_dstart:	DS	2
_printf_dcnt:	DB	0
_printf_width:	DB	0
_printf_zero:	DB	0
_printf_upper:	DB	0
_printf_prec:	DB	0
_printf_hasprec:	DB	0
_printf_ll_w0:	DS	2
_printf_ll_w1:	DS	2
_printf_ll_w2:	DS	2
_printf_ll_w3:	DS	2
_prt_float_prec:	DB	6
__ftmp:		DS	4
__fman:		DS	4
__fwork:	DS	4


; ============================================================
; lc_printf_d.mac
; ============================================================
	CSEG
; lc_printf_d.mac - printf %d/%i handler



	CSEG

	PUBLIC	__printf_handle_d
__printf_handle_d:
	; Entry: HL = format ptr (past 'd'), C = arg offset, IX = frame
	; Output signed decimal with width/zero-padding
	PUSH	HL
	LD	H,0
	LD	L,C
	PUSH	BC
	PUSH	IX
	POP	DE
	ADD	HL,DE		; HL = IX + offset
	LD	E,(HL)
	INC	HL
	LD	D,(HL)		; DE = value
	EX	DE,HL		; HL = value

	; Check for negative
	XOR	A
	LD	(_printf_neg),A
	BIT	7,H
	JR	Z,_phd_pos

	; Negative - set flag and negate
	LD	A,1
	LD	(_printf_neg),A
	PUSH	DE
	EX	DE,HL
	LD	HL,0
	OR	A
	SBC	HL,DE
	POP	DE

_phd_pos:
	; Convert HL to decimal digits in _printf_decbuf
	PUSH	IX
	PUSH	BC
	LD	DE,10
	LD	B,0
	LD	(_printf_dptr),IX
	LD	IX,_printf_decbuf+5
_phd_cvt:
	CALL	_prt_div16
	LD	A,E
	ADD	A,'0'
	DEC	IX
	LD	(IX+0),A
	INC	B
	LD	DE,10
	LD	A,H
	OR	L
	JR	NZ,_phd_cvt
	LD	(_printf_dstart),IX
	LD	A,B
	LD	(_printf_dcnt),A
	LD	IX,(_printf_dptr)
	POP	BC

	; Handle width padding
	LD	A,(_printf_neg)
	LD	D,A
	LD	A,(_printf_dcnt)
	ADD	A,D
	LD	E,A
	LD	A,(_printf_width)
	OR	A
	JR	Z,_phd_nopad
	SUB	E
	JR	Z,_phd_nopad
	JR	C,_phd_nopad
	PUSH	BC
	LD	B,A
	LD	A,(_printf_zero)
	OR	A
	JR	NZ,_phd_zpad
	; Space padding
_phd_spad:
	PUSH	BC
	PUSH	DE
	LD	E,' '
	LD	C,CONOUT
	CALL	BDOS
	POP	DE
	POP	BC
	DJNZ	_phd_spad
	POP	BC
	JR	_phd_nopad
_phd_zpad:
	LD	A,D
	OR	A
	JR	Z,_phd_zpd2
	PUSH	BC
	PUSH	DE
	LD	E,'-'
	LD	C,CONOUT
	CALL	BDOS
	POP	DE
	POP	BC
	XOR	A
	LD	D,A
_phd_zpd2:
	PUSH	BC
	PUSH	DE
	LD	E,'0'
	LD	C,CONOUT
	CALL	BDOS
	POP	DE
	POP	BC
	DJNZ	_phd_zpd2
	POP	BC
_phd_nopad:
	; Output minus sign if not already output
	LD	A,D
	OR	A
	JR	Z,_phd_digs
	PUSH	BC
	LD	E,'-'
	LD	C,CONOUT
	CALL	BDOS
	POP	BC
_phd_digs:
	LD	HL,(_printf_dstart)
	LD	A,(_printf_dcnt)
	LD	B,A
_phd_dlp:
	LD	E,(HL)
	PUSH	BC
	PUSH	HL
	LD	C,CONOUT
	CALL	BDOS
	POP	HL
	POP	BC
	INC	HL
	DJNZ	_phd_dlp
	POP	IX
	POP	BC
	INC	C
	INC	C
	POP	HL
	JP	_printf_loop


; ============================================================
; lc_printf_f.mac
; ============================================================
	CSEG
; lc_printf_f.mac - printf %f handler (float)


	CSEG

	PUBLIC	__printf_handle_f
__printf_handle_f:
	; Float is 32 bits (4 bytes) on stack
	PUSH	HL
	LD	H,0
	LD	L,C
	PUSH	BC
	PUSH	IX
	POP	DE
	ADD	HL,DE
	; Load 32-bit float from (HL) into __ftmp
	LD	E,(HL)
	INC	HL
	LD	D,(HL)
	INC	HL
	LD	(__ftmp),DE
	LD	E,(HL)
	INC	HL
	LD	D,(HL)
	LD	(__ftmp+2),DE
	; Set precision
	LD	A,(_printf_hasprec)
	OR	A
	JR	Z,_phf_defprec
	LD	A,(_printf_prec)
	LD	(_prt_float_prec),A
	JR	_phf_go
_phf_defprec:
	LD	A,6
	LD	(_prt_float_prec),A
_phf_go:
	CALL	_prt_float
	POP	BC
	LD	A,C
	ADD	A,4
	LD	C,A
	POP	HL
	JP	_printf_loop


; ============================================================
; lc_printf_l.mac
; ============================================================
	CSEG
; lc_printf_l.mac - printf 'l' length prefix handler
; Dispatches to __printf_long_table, or 'll' to __printf_ll_table


	CSEG

	PUBLIC	__printf_handle_l
__printf_handle_l:
	; HL points past the 'l' in format string
	; Read next char
	LD	A,(HL)
	INC	HL

	CP	'l'
	JR	Z,_phl_ll

	; Search __printf_long_table for this char
	PUSH	HL
	PUSH	BC
	LD	B,A		; B = format char
	LD	HL,__printf_long_table
_phl_search:
	LD	A,(HL)
	OR	A
	JR	Z,_phl_unknown
	CP	B
	JR	Z,_phl_found
	INC	HL
	INC	HL
	INC	HL
	JR	_phl_search

_phl_found:
	INC	HL
	LD	E,(HL)
	INC	HL
	LD	D,(HL)		; DE = handler address
	POP	BC
	POP	HL
	PUSH	DE
	RET			; Tail-call handler

_phl_unknown:
	POP	BC
	POP	HL
	JP	_printf_loop

_phl_ll:
	; 'll' prefix - search __printf_ll_table
	LD	A,(HL)
	INC	HL
	PUSH	HL
	PUSH	BC
	LD	B,A
	LD	HL,__printf_ll_table
_phl_ll_search:
	LD	A,(HL)
	OR	A
	JR	Z,_phl_ll_unknown
	CP	B
	JR	Z,_phl_ll_found
	INC	HL
	INC	HL
	INC	HL
	JR	_phl_ll_search

_phl_ll_found:
	INC	HL
	LD	E,(HL)
	INC	HL
	LD	D,(HL)
	POP	BC
	POP	HL
	PUSH	DE
	RET

_phl_ll_unknown:
	POP	BC
	POP	HL
	JP	_printf_loop


; ============================================================
; lc_printf_ld.mac
; ============================================================
	CSEG
; lc_printf_ld.mac - printf %ld handler (signed long decimal)



	CSEG

	PUBLIC	__printf_handle_ld
__printf_handle_ld:
	PUSH	HL
	LD	H,0
	LD	L,C
	PUSH	BC
	PUSH	IX
	POP	DE
	ADD	HL,DE		; HL = IX + offset
	; Get 32-bit value
	LD	E,(HL)
	INC	HL
	LD	D,(HL)		; DE = low word
	INC	HL
	LD	A,(HL)
	INC	HL
	LD	H,(HL)
	LD	L,A		; HL = high word
	EX	DE,HL		; DEHL = 32-bit value

	; Check for negative
	BIT	7,D
	JR	Z,_phld_pos

	; Negative - output minus and negate
	PUSH	HL
	PUSH	DE
	LD	E,'-'
	LD	C,CONOUT
	CALL	BDOS
	POP	DE
	POP	HL
	; Negate DEHL
	PUSH	BC
	LD	BC,0
	LD	A,C
	SUB	L
	LD	L,A
	LD	A,C
	SBC	A,H
	LD	H,A
	LD	A,C
	SBC	A,E
	LD	E,A
	LD	A,C
	SBC	A,D
	LD	D,A
	POP	BC

_phld_pos:
	CALL	_prt_dec32
	POP	BC
	LD	A,C
	ADD	A,4		; Long is 4 bytes
	LD	C,A
	POP	HL
	JP	_printf_loop


; ============================================================
; lc_printf_lld.mac
; ============================================================
	CSEG
; lc_printf_lld.mac - printf %lld handler (signed long long decimal)



	CSEG

	PUBLIC	__printf_handle_lld
__printf_handle_lld:
	PUSH	HL
	LD	H,0
	LD	L,C
	PUSH	BC
	PUSH	IX
	POP	DE
	ADD	HL,DE		; HL = IX + offset
	; Read 8 bytes (64 bits) into _prt64_val
	LD	E,(HL)
	INC	HL
	LD	D,(HL)
	INC	HL
	LD	(_prt64_val),DE
	LD	E,(HL)
	INC	HL
	LD	D,(HL)
	INC	HL
	LD	(_prt64_val+2),DE
	LD	E,(HL)
	INC	HL
	LD	D,(HL)
	INC	HL
	LD	(_prt64_val+4),DE
	LD	E,(HL)
	INC	HL
	LD	D,(HL)
	LD	(_prt64_val+6),DE

	; Check sign (bit 7 of highest byte)
	LD	A,D
	AND	80H
	JR	Z,_phlld_pos

	; Negative - print minus sign
	PUSH	BC
	LD	E,'-'
	LD	C,CONOUT
	CALL	BDOS
	POP	BC

	; Negate 64-bit value (0 - _prt64_val)
	XOR	A		; Clear carry
	LD	HL,0
	LD	DE,(_prt64_val)
	SBC	HL,DE
	LD	(_prt64_val),HL
	LD	HL,0
	LD	DE,(_prt64_val+2)
	SBC	HL,DE
	LD	(_prt64_val+2),HL
	LD	HL,0
	LD	DE,(_prt64_val+4)
	SBC	HL,DE
	LD	(_prt64_val+4),HL
	LD	HL,0
	LD	DE,(_prt64_val+6)
	SBC	HL,DE
	LD	(_prt64_val+6),HL

_phlld_pos:
	CALL	_prt_dec64
	POP	BC
	LD	A,C
	ADD	A,8		; Long long is 8 bytes
	LD	C,A
	POP	HL
	JP	_printf_loop


; ============================================================
; lc_printf_llu.mac
; ============================================================
	CSEG
; lc_printf_llu.mac - printf %llu handler (unsigned long long decimal)


	CSEG

	PUBLIC	__printf_handle_llu
__printf_handle_llu:
	PUSH	HL
	LD	H,0
	LD	L,C
	PUSH	BC
	PUSH	IX
	POP	DE
	ADD	HL,DE		; HL = IX + offset
	; Read 8 bytes (64 bits) into _prt64_val
	LD	E,(HL)
	INC	HL
	LD	D,(HL)
	INC	HL
	LD	(_prt64_val),DE
	LD	E,(HL)
	INC	HL
	LD	D,(HL)
	INC	HL
	LD	(_prt64_val+2),DE
	LD	E,(HL)
	INC	HL
	LD	D,(HL)
	INC	HL
	LD	(_prt64_val+4),DE
	LD	E,(HL)
	INC	HL
	LD	D,(HL)
	LD	(_prt64_val+6),DE

	CALL	_prt_dec64
	POP	BC
	LD	A,C
	ADD	A,8		; Long long is 8 bytes
	LD	C,A
	POP	HL
	JP	_printf_loop


; ============================================================
; lc_printf_llx.mac
; ============================================================
	CSEG
; lc_printf_llx.mac - printf %llx handler (long long hex)



	CSEG

	PUBLIC	__printf_handle_llx
__printf_handle_llx:
	PUSH	HL
	LD	H,0
	LD	L,C
	PUSH	BC
	PUSH	IX
	POP	DE
	ADD	HL,DE
	; Read 8 bytes (64 bits)
	LD	E,(HL)
	INC	HL
	LD	D,(HL)
	INC	HL
	LD	(_printf_ll_w0),DE
	LD	E,(HL)
	INC	HL
	LD	D,(HL)
	INC	HL
	LD	(_printf_ll_w1),DE
	LD	E,(HL)
	INC	HL
	LD	D,(HL)
	INC	HL
	LD	(_printf_ll_w2),DE
	LD	E,(HL)
	INC	HL
	LD	D,(HL)
	LD	(_printf_ll_w3),DE
	; Print from highest word to lowest, skip leading zeros
	LD	HL,(_printf_ll_w3)
	LD	A,H
	OR	L
	JR	Z,_phllx_w2
	CALL	_prt_hex
	LD	HL,(_printf_ll_w2)
	CALL	_prt_hex4
	LD	HL,(_printf_ll_w1)
	CALL	_prt_hex4
	LD	HL,(_printf_ll_w0)
	CALL	_prt_hex4
	JR	_phllx_done
_phllx_w2:
	LD	HL,(_printf_ll_w2)
	LD	A,H
	OR	L
	JR	Z,_phllx_w1
	CALL	_prt_hex
	LD	HL,(_printf_ll_w1)
	CALL	_prt_hex4
	LD	HL,(_printf_ll_w0)
	CALL	_prt_hex4
	JR	_phllx_done
_phllx_w1:
	LD	HL,(_printf_ll_w1)
	LD	A,H
	OR	L
	JR	Z,_phllx_w0
	CALL	_prt_hex
	LD	HL,(_printf_ll_w0)
	CALL	_prt_hex4
	JR	_phllx_done
_phllx_w0:
	LD	HL,(_printf_ll_w0)
	CALL	_prt_hex
_phllx_done:
	POP	BC
	LD	A,C
	ADD	A,8
	LD	C,A
	POP	HL
	JP	_printf_loop


; ============================================================
; lc_printf_lo.mac
; ============================================================
	CSEG
; lc_printf_lo.mac - printf %lo handler (unsigned long octal)



	CSEG

	PUBLIC	__printf_handle_lo
__printf_handle_lo:
	PUSH	HL
	LD	H,0
	LD	L,C
	PUSH	BC
	PUSH	IX
	POP	DE
	ADD	HL,DE
	LD	E,(HL)
	INC	HL
	LD	D,(HL)
	INC	HL
	LD	A,(HL)
	INC	HL
	LD	H,(HL)
	LD	L,A
	EX	DE,HL		; DEHL = value
	; Store DEHL to work area
	LD	(_plo_val),HL
	LD	(_plo_val+2),DE
	PUSH	IX
	LD	B,0		; digit counter
_plo_cvt:
	LD	A,(_plo_val)
	AND	07h		; remainder = value & 7
	ADD	A,'0'
	PUSH	AF
	INC	B
	; Shift 32-bit _plo_val right by 3 (divide by 8)
	; Byte order: _plo_val+0 (low) .. _plo_val+3 (high)
	; Do 3 single-bit right shifts
	LD	A,(_plo_val+3)
	SRL	A
	LD	(_plo_val+3),A
	LD	A,(_plo_val+2)
	RRA
	LD	(_plo_val+2),A
	LD	A,(_plo_val+1)
	RRA
	LD	(_plo_val+1),A
	LD	A,(_plo_val)
	RRA
	LD	(_plo_val),A
	; Second shift
	LD	A,(_plo_val+3)
	SRL	A
	LD	(_plo_val+3),A
	LD	A,(_plo_val+2)
	RRA
	LD	(_plo_val+2),A
	LD	A,(_plo_val+1)
	RRA
	LD	(_plo_val+1),A
	LD	A,(_plo_val)
	RRA
	LD	(_plo_val),A
	; Third shift
	LD	A,(_plo_val+3)
	SRL	A
	LD	(_plo_val+3),A
	LD	A,(_plo_val+2)
	RRA
	LD	(_plo_val+2),A
	LD	A,(_plo_val+1)
	RRA
	LD	(_plo_val+1),A
	LD	A,(_plo_val)
	RRA
	LD	(_plo_val),A
	; Check if quotient is zero
	LD	HL,(_plo_val)
	LD	A,H
	OR	L
	JR	NZ,_plo_cvt
	LD	HL,(_plo_val+2)
	LD	A,H
	OR	L
	JR	NZ,_plo_cvt
	; Pop and print digits
_plo_out:
	POP	AF
	LD	E,A
	PUSH	BC
	LD	C,CONOUT
	CALL	BDOS
	POP	BC
	DJNZ	_plo_out
	POP	IX
	POP	BC
	LD	A,C
	ADD	A,4
	LD	C,A
	POP	HL
	JP	_printf_loop

	DSEG
_plo_val:	DS	4


; ============================================================
; lc_printf_lu.mac
; ============================================================
	CSEG
; lc_printf_lu.mac - printf %lu handler (unsigned long decimal)


	CSEG

	PUBLIC	__printf_handle_lu
__printf_handle_lu:
	PUSH	HL
	LD	H,0
	LD	L,C
	PUSH	BC
	PUSH	IX
	POP	DE
	ADD	HL,DE
	LD	E,(HL)
	INC	HL
	LD	D,(HL)
	INC	HL
	LD	A,(HL)
	INC	HL
	LD	H,(HL)
	LD	L,A
	EX	DE,HL		; DEHL = value
	CALL	_prt_dec32
	POP	BC
	LD	A,C
	ADD	A,4
	LD	C,A
	POP	HL
	JP	_printf_loop


; ============================================================
; lc_printf_lx.mac
; ============================================================
	CSEG
; lc_printf_lx.mac - printf %lx and %lX handlers (long hex)



	CSEG

	PUBLIC	__printf_handle_lx
	PUBLIC	__printf_handle_lxu

; %lX / %X-under-int32: set uppercase flag, fall through to %lx path
__printf_handle_lxu:
	PUSH	AF
	LD	A,1
	LD	(_printf_upper),A
	POP	AF
	; fall through

__printf_handle_lx:
	PUSH	HL
	LD	H,0
	LD	L,C
	PUSH	BC
	PUSH	IX
	POP	DE
	ADD	HL,DE
	LD	E,(HL)
	INC	HL
	LD	D,(HL)
	INC	HL
	LD	A,(HL)
	INC	HL
	LD	H,(HL)
	LD	L,A
	EX	DE,HL		; DEHL = value (DE=high, HL=low)
	; Print DE then HL as hex (skip leading zeros in DE)
	PUSH	HL
	EX	DE,HL
	CALL	_prt_hex
	POP	HL
	CALL	_prt_hex4
	POP	BC
	LD	A,C
	ADD	A,4
	LD	C,A
	POP	HL
	JP	_printf_loop


; ============================================================
; lc_printf_o.mac
; ============================================================
	CSEG
; lc_printf_o.mac - printf %o handler (unsigned int octal)



	CSEG

	PUBLIC	__printf_handle_o
__printf_handle_o:
	PUSH	HL
	LD	H,0
	LD	L,C
	PUSH	BC
	PUSH	IX
	POP	DE
	ADD	HL,DE
	LD	E,(HL)
	INC	HL
	LD	D,(HL)
	EX	DE,HL		; HL = value
	PUSH	IX
	PUSH	BC
	LD	B,0
	LD	IX,_printf_decbuf+5
_pho_cvt:
	LD	A,L
	AND	07h		; remainder = value & 7
	ADD	A,'0'
	DEC	IX
	LD	(IX+0),A
	INC	B
	; Shift HL right by 3 (divide by 8)
	SRL	H
	RR	L
	SRL	H
	RR	L
	SRL	H
	RR	L
	LD	A,H
	OR	L
	JR	NZ,_pho_cvt
	LD	(_printf_dstart),IX
	LD	A,B
	LD	(_printf_dcnt),A
	POP	BC
	; Width padding
	LD	A,(_printf_width)
	OR	A
	JR	Z,_pho_nopad
	LD	B,A
	LD	A,(_printf_dcnt)
	LD	C,A
	LD	A,B
	SUB	C
	JR	Z,_pho_nopad
	JR	C,_pho_nopad
	PUSH	BC
	LD	B,A
	LD	A,(_printf_zero)
	OR	A
	LD	A,' '
	JR	Z,_pho_plp
	LD	A,'0'
_pho_plp:
	LD	E,A
	PUSH	AF
	PUSH	BC
	LD	C,CONOUT
	CALL	BDOS
	POP	BC
	POP	AF
	DJNZ	_pho_plp
	POP	BC
_pho_nopad:
	LD	HL,(_printf_dstart)
	LD	A,(_printf_dcnt)
	LD	B,A
_pho_digs:
	LD	E,(HL)
	PUSH	BC
	PUSH	HL
	LD	C,CONOUT
	CALL	BDOS
	POP	HL
	POP	BC
	INC	HL
	DJNZ	_pho_digs
	POP	IX
	POP	BC
	INC	C
	INC	C
	POP	HL
	JP	_printf_loop


; ============================================================
; lc_printf_s.mac
; ============================================================
	CSEG
; lc_printf_s.mac - printf %s handler



	CSEG

	PUBLIC	__printf_handle_s
__printf_handle_s:
	PUSH	HL
	LD	H,0
	LD	L,C
	PUSH	BC
	PUSH	IX
	POP	DE
	ADD	HL,DE
	LD	E,(HL)
	INC	HL
	LD	D,(HL)		; DE = string pointer

	; Load precision limit into B (0 = unlimited)
	LD	A,(_printf_hasprec)
	OR	A
	JR	Z,_phs_nop
	LD	A,(_printf_prec)
	LD	B,A
	JR	_phs_loop
_phs_nop:
	LD	B,0

_phs_loop:
	LD	A,(_printf_hasprec)
	OR	A
	JR	Z,_phs_nolim
	LD	A,B
	OR	A
	JR	Z,_phs_done
	DEC	B
_phs_nolim:
	LD	A,(DE)
	OR	A
	JR	Z,_phs_done
	PUSH	DE
	PUSH	BC
	LD	E,A
	LD	C,CONOUT
	CALL	BDOS
	POP	BC
	POP	DE
	INC	DE
	JR	_phs_loop

_phs_done:
	POP	BC
	INC	C
	INC	C
	POP	HL
	JP	_printf_loop


; ============================================================
; lc_printf_u.mac
; ============================================================
	CSEG
; lc_printf_u.mac - printf %u handler



	CSEG

	PUBLIC	__printf_handle_u
__printf_handle_u:
	PUSH	HL
	LD	H,0
	LD	L,C
	PUSH	BC
	PUSH	IX
	POP	DE
	ADD	HL,DE
	LD	E,(HL)
	INC	HL
	LD	D,(HL)
	EX	DE,HL		; HL = value
	PUSH	IX
	PUSH	BC
	LD	DE,10
	LD	B,0
	LD	IX,_printf_decbuf+5
_phu_cvt:
	CALL	_prt_div16
	LD	A,E
	ADD	A,'0'
	DEC	IX
	LD	(IX+0),A
	INC	B
	LD	DE,10
	LD	A,H
	OR	L
	JR	NZ,_phu_cvt
	LD	(_printf_dstart),IX
	LD	A,B
	LD	(_printf_dcnt),A
	POP	BC
	; Width padding
	LD	A,(_printf_width)
	OR	A
	JR	Z,_phu_nopad
	LD	B,A
	LD	A,(_printf_dcnt)
	LD	C,A
	LD	A,B
	SUB	C
	JR	Z,_phu_nopad
	JR	C,_phu_nopad
	PUSH	BC
	LD	B,A
	LD	A,(_printf_zero)
	OR	A
	LD	A,' '
	JR	Z,_phu_plp
	LD	A,'0'
_phu_plp:
	LD	E,A
	PUSH	AF
	PUSH	BC
	LD	C,CONOUT
	CALL	BDOS
	POP	BC
	POP	AF
	DJNZ	_phu_plp
	POP	BC
_phu_nopad:
	LD	HL,(_printf_dstart)
	LD	A,(_printf_dcnt)
	LD	B,A
_phu_digs:
	LD	E,(HL)
	PUSH	BC
	PUSH	HL
	LD	C,CONOUT
	CALL	BDOS
	POP	HL
	POP	BC
	INC	HL
	DJNZ	_phu_digs
	POP	IX
	POP	BC
	INC	C
	INC	C
	POP	HL
	JP	_printf_loop


; ============================================================
; lc_printf_x.mac
; ============================================================
	CSEG
; lc_printf_x.mac - printf %x, %X, %p handlers



	CSEG

	PUBLIC	__printf_handle_x
	PUBLIC	__printf_handle_xu
	PUBLIC	__printf_handle_p

__printf_handle_xu:
	; %X handler - set uppercase flag and fall through
	PUSH	AF
	LD	A,1
	LD	(_printf_upper),A
	POP	AF
	JR	__printf_handle_x

__printf_handle_p:
	; Pointer - same as %x

__printf_handle_x:
	PUSH	HL
	LD	H,0
	LD	L,C
	PUSH	BC
	PUSH	IX
	POP	DE
	ADD	HL,DE
	LD	E,(HL)
	INC	HL
	LD	D,(HL)
	EX	DE,HL
	CALL	_printf_prt_hex
	POP	BC
	INC	C
	INC	C
	POP	HL
	JP	_printf_loop


; ============================================================
; lc_prt_dec32.mac
; ============================================================
	CSEG
; lc_prt_dec32.mac - print DEHL as 32-bit decimal


	CSEG

	PUBLIC	_prt_dec32
_prt_dec32:
	PUSH	BC
	PUSH	IX

	; Store value in work area
	LD	(_prt32_val),HL
	LD	(_prt32_val+2),DE

	LD	B,0		; Digit counter

_prt32_loop:
	CALL	_div32_10
	PUSH	AF		; Save digit (remainder)
	INC	B

	; Check if quotient is zero
	LD	HL,(_prt32_val)
	LD	A,H
	OR	L
	JR	NZ,_prt32_loop
	LD	HL,(_prt32_val+2)
	LD	A,H
	OR	L
	JR	NZ,_prt32_loop

	; Pop and print digits
_prt32_out:
	POP	AF
	ADD	A,'0'
	LD	E,A
	PUSH	BC
	LD	C,CONOUT
	CALL	BDOS
	POP	BC
	DJNZ	_prt32_out

	POP	IX
	POP	BC
	RET

; Internal: divide _prt32_val by 10
; Returns remainder in A, quotient stored back in _prt32_val
	PUBLIC	_div32_10
_div32_10:
	PUSH	BC
	PUSH	DE
	PUSH	HL

	LD	DE,0		; DE = running remainder
	LD	B,32

_div32_10_loop:
	EX	DE,HL
	ADD	HL,HL
	EX	DE,HL

	LD	HL,(_prt32_val)
	ADD	HL,HL
	LD	(_prt32_val),HL
	LD	HL,(_prt32_val+2)
	ADC	HL,HL
	LD	(_prt32_val+2),HL
	JR	NC,_div32_10_nc1
	INC	DE
_div32_10_nc1:

	LD	A,D
	OR	A
	JR	NZ,_div32_10_sub
	LD	A,E
	CP	10
	JR	C,_div32_10_nosub

_div32_10_sub:
	LD	A,E
	SUB	10
	LD	E,A
	LD	A,D
	SBC	A,0
	LD	D,A

	LD	HL,(_prt32_val)
	INC	HL
	LD	(_prt32_val),HL

_div32_10_nosub:
	DJNZ	_div32_10_loop

	LD	A,E

	POP	HL
	POP	DE
	POP	BC
	RET

	DSEG
	PUBLIC	_prt32_val
_prt32_val:	DS	4


; ============================================================
; lc_prt_dec64.mac
; ============================================================
	CSEG
; lc_prt_dec64.mac - print 64-bit value as unsigned decimal


	CSEG

	PUBLIC	_prt_dec64
; Input: 8-byte value already stored in _prt64_val
_prt_dec64:
	PUSH	BC
	PUSH	IX

	LD	B,0		; Digit counter

_prt64_loop:
	CALL	_div64_10
	PUSH	AF		; Save digit (remainder)
	INC	B

	; Check if quotient is zero (all 8 bytes)
	LD	HL,(_prt64_val)
	LD	A,H
	OR	L
	JR	NZ,_prt64_loop
	LD	HL,(_prt64_val+2)
	LD	A,H
	OR	L
	JR	NZ,_prt64_loop
	LD	HL,(_prt64_val+4)
	LD	A,H
	OR	L
	JR	NZ,_prt64_loop
	LD	HL,(_prt64_val+6)
	LD	A,H
	OR	L
	JR	NZ,_prt64_loop

	; Pop and print digits
_prt64_out:
	POP	AF
	ADD	A,'0'
	LD	E,A
	PUSH	BC
	LD	C,CONOUT
	CALL	BDOS
	POP	BC
	DJNZ	_prt64_out

	POP	IX
	POP	BC
	RET

; Internal: divide _prt64_val (8 bytes) by 10
; Returns remainder in A, quotient stored back in _prt64_val
_div64_10:
	PUSH	BC
	PUSH	DE
	PUSH	HL

	LD	DE,0		; DE = running remainder
	LD	B,64

_div64_10_loop:
	; Shift remainder left by 1
	EX	DE,HL
	ADD	HL,HL
	EX	DE,HL

	; Shift _prt64_val left by 1 (64 bits, MSB first carries into DE)
	LD	HL,(_prt64_val)
	ADD	HL,HL
	LD	(_prt64_val),HL
	LD	HL,(_prt64_val+2)
	ADC	HL,HL
	LD	(_prt64_val+2),HL
	LD	HL,(_prt64_val+4)
	ADC	HL,HL
	LD	(_prt64_val+4),HL
	LD	HL,(_prt64_val+6)
	ADC	HL,HL
	LD	(_prt64_val+6),HL
	JR	NC,_div64_10_nc
	INC	DE
_div64_10_nc:

	; Check if DE >= 10
	LD	A,D
	OR	A
	JR	NZ,_div64_10_sub
	LD	A,E
	CP	10
	JR	C,_div64_10_nosub

_div64_10_sub:
	LD	A,E
	SUB	10
	LD	E,A
	LD	A,D
	SBC	A,0
	LD	D,A

	; Set bit 0 of quotient (lowest byte of _prt64_val)
	LD	HL,(_prt64_val)
	INC	HL
	LD	(_prt64_val),HL

_div64_10_nosub:
	DJNZ	_div64_10_loop

	LD	A,E		; Remainder

	POP	HL
	POP	DE
	POP	BC
	RET

	PUBLIC	_prt64_val
	DSEG
_prt64_val:	DS	8


; ============================================================
; lc_prt_hex.mac
; ============================================================
	CSEG
; lc_prt_hex.mac - hex printing helpers
;
; _prt_hex and _prt_hex4 honor the _printf_upper flag: when nonzero,
; hex digits A-F are uppercase; otherwise lowercase.  The flag is
; defined in lc_printf_core.mac and set by %X / %lX / %llX handlers.



	CSEG

; Convert nibble 0-15 in A to ASCII hex, honoring _printf_upper.
; Preserves BC; clobbers flags.
_prt_hex_nib:
	ADD	A,'0'
	CP	'9'+1
	RET	C		; 0-9: done
	PUSH	HL
	LD	H,A		; stash A
	LD	A,(_printf_upper)
	OR	A
	LD	A,H
	POP	HL
	JR	Z,_prt_hex_nib_lo
	ADD	A,7		; 'A'..'F'
	RET
_prt_hex_nib_lo:
	ADD	A,39		; 'a'..'f'
	RET

; Print HL as hex (no leading zeros)
	PUBLIC	_prt_hex
_prt_hex:
	PUSH	BC
	LD	B,0		; B=1 means we've printed a non-zero digit
	LD	A,H
	RRCA
	RRCA
	RRCA
	RRCA
	AND	0FH
	CALL	_prt_hexd
	LD	A,H
	AND	0FH
	CALL	_prt_hexd
	LD	A,L
	RRCA
	RRCA
	RRCA
	RRCA
	AND	0FH
	CALL	_prt_hexd
	LD	A,L
	AND	0FH
	OR	A
	JR	NZ,_prt_hexf
	PUSH	AF
	LD	A,B
	OR	A
	POP	AF
	JR	NZ,_prt_hexf
	LD	A,'0'
	LD	E,A
	LD	C,CONOUT
	CALL	BDOS
	POP	BC
	RET
_prt_hexf:
	LD	B,1
	CALL	_prt_hex_nib
	LD	E,A
	LD	C,CONOUT
	CALL	BDOS
	POP	BC
	RET

_prt_hexd:
	OR	A
	JR	NZ,_prt_hexd1
	LD	A,B
	OR	A
	RET	Z
	XOR	A
_prt_hexd1:
	LD	B,1
	CALL	_prt_hex_nib
	LD	E,A
	PUSH	BC
	LD	C,CONOUT
	CALL	BDOS
	POP	BC
	RET

; Print HL as 4-digit hex (always all 4 digits, with leading zeros)
	PUBLIC	_prt_hex4
_prt_hex4:
	PUSH	BC
	LD	A,H
	CALL	_prt_hex4_byte
	LD	A,L
	CALL	_prt_hex4_byte
	POP	BC
	RET
_prt_hex4_byte:
	PUSH	AF
	RRCA
	RRCA
	RRCA
	RRCA
	CALL	_prt_hex4_nib
	POP	AF
_prt_hex4_nib:
	AND	0FH
	CALL	_prt_hex_nib
	LD	E,A
	LD	C,CONOUT
	CALL	BDOS
	RET


; ============================================================
; lc_putchar.mac
; ============================================================
	CSEG
; lc_putchar.mac - putchar


	CSEG

; ============================================================
; int putchar(int c)
; Output a character to console
; Argument: character on stack at IX+4
; Returns: the character written, or EOF (-1) on error
; ============================================================
	PUBLIC	_putchar
_putchar:
	; Minimal implementation - doesn't touch IX
	; Stack at entry: [ret_addr][arg]
	POP	HL		; Get return address
	POP	DE		; Get argument (char in E)
	PUSH	DE		; Restore arg for caller cleanup
	PUSH	HL		; Restore return address

	LD	C,CONOUT
	CALL	BDOS

	; Return value - get arg again
	LD	HL,2
	ADD	HL,SP		; Points to arg (after ret addr)
	LD	L,(HL)
	LD	H,0
	RET


; ============================================================
; lc_puts.mac
; ============================================================
	CSEG
; lc_puts.mac - puts, cputs


	CSEG

; ============================================================
; int puts(const char *s)
; Output a string followed by newline
; Argument: pointer to string on stack at IX+4
; Returns: non-negative on success, EOF (-1) on error
; ============================================================
	PUBLIC	_puts
_puts:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	PUSH	BC

	; Get string pointer
	LD	L,(IX+4)
	LD	H,(IX+5)

_puts_loop:
	LD	A,(HL)
	OR	A
	JR	Z,_puts_newline	; End of string

	LD	E,A		; Character in E
	LD	C,CONOUT
	PUSH	HL
	CALL	BDOS
	POP	HL
	INC	HL
	JR	_puts_loop

_puts_newline:
	; Output newline (CR LF)
	LD	E,0DH		; CR
	LD	C,CONOUT
	CALL	BDOS
	LD	E,0AH		; LF
	LD	C,CONOUT
	CALL	BDOS

	; Return 0 (success)
	LD	HL,0

	POP	BC
	POP	IX
	RET

; ============================================================
; void cputs(const char *s)
; Output a string (no newline, for internal use)
; ============================================================
	PUBLIC	_cputs
_cputs:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	PUSH	BC

	; Get string pointer
	LD	L,(IX+4)
	LD	H,(IX+5)

_cputs_loop:
	LD	A,(HL)
	OR	A
	JR	Z,_cputs_done

	LD	E,A
	LD	C,CONOUT
	PUSH	HL
	CALL	BDOS
	POP	HL
	INC	HL
	JR	_cputs_loop

_cputs_done:
	POP	BC
	POP	IX
	RET


; ============================================================
; lc_qsort.mac
; ============================================================
	CSEG
; lc_qsort.mac - qsort, bsearch



	EXTRN	__callhl
	EXTRN	__mul16

	CSEG

; ============================================================
; void qsort(void *base, size_t nmemb, size_t size,
;            int (*compar)(const void *, const void *))
; Sort array using selection sort (simpler for Z80)
; Stack: base(IX+4), nmemb(IX+6), size(IX+8), compar(IX+10)
; ============================================================
	PUBLIC	_qsort
_qsort:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	PUSH	BC
	PUSH	DE

	; Check if nmemb <= 1, nothing to sort
	LD	L,(IX+6)
	LD	H,(IX+7)
	LD	A,H
	OR	A
	JR	NZ,_qsort_start
	LD	A,L
	CP	2
	JP	C,_qsort_done	; nmemb < 2

_qsort_start:
	; Outer loop: i = 0 to nmemb-2
	LD	HL,0
	LD	(_qsort_i),HL

_qsort_outer:
	; Check if i >= nmemb - 1
	LD	HL,(_qsort_i)
	INC	HL		; i + 1
	LD	E,(IX+6)	; nmemb (low word only, assume < 65536)
	LD	D,(IX+7)
	OR	A
	SBC	HL,DE
	JP	NC,_qsort_done	; i + 1 >= nmemb, done

	; min_idx = i
	LD	HL,(_qsort_i)
	LD	(_qsort_min),HL

	; Inner loop: j = i + 1 to nmemb - 1
	LD	HL,(_qsort_i)
	INC	HL
	LD	(_qsort_j),HL

_qsort_inner:
	; Check if j >= nmemb
	LD	HL,(_qsort_j)
	LD	E,(IX+6)
	LD	D,(IX+7)
	OR	A
	SBC	HL,DE
	JP	NC,_qsort_swap	; j >= nmemb, do swap

	; Compare base[j] with base[min_idx]
	; Calculate address of base[j]
	LD	HL,(_qsort_j)
	CALL	_qsort_addr	; HL = base + j*size
	PUSH	HL		; First arg to compare

	; Calculate address of base[min_idx]
	LD	HL,(_qsort_min)
	CALL	_qsort_addr	; HL = base + min_idx*size
	PUSH	HL		; Second arg

	; Call compare function
	LD	L,(IX+10)
	LD	H,(IX+11)
	CALL	__callhl
	POP	DE		; Clean up args
	POP	DE

	; If result < 0, update min_idx
	BIT	7,H
	JR	Z,_qsort_inner_next
	; arr[j] < arr[min_idx], update min_idx
	LD	HL,(_qsort_j)
	LD	(_qsort_min),HL

_qsort_inner_next:
	LD	HL,(_qsort_j)
	INC	HL
	LD	(_qsort_j),HL
	JR	_qsort_inner

_qsort_swap:
	; Swap base[i] with base[min_idx] if min_idx != i
	LD	HL,(_qsort_i)
	LD	DE,(_qsort_min)
	OR	A
	SBC	HL,DE
	JR	Z,_qsort_outer_next	; Same, no swap needed

	; Get addresses
	LD	HL,(_qsort_i)
	CALL	_qsort_addr
	LD	(_qsort_ptr1),HL

	LD	HL,(_qsort_min)
	CALL	_qsort_addr
	LD	(_qsort_ptr2),HL

	; Swap size bytes
	LD	L,(IX+8)
	LD	H,(IX+9)	; HL = size
	LD	B,H
	LD	C,L		; BC = size counter

_qsort_swap_loop:
	LD	A,B
	OR	C
	JR	Z,_qsort_outer_next

	LD	HL,(_qsort_ptr1)
	LD	D,(HL)		; D = byte from ptr1
	LD	HL,(_qsort_ptr2)
	LD	E,(HL)		; E = byte from ptr2
	LD	(HL),D		; Store D at ptr2
	LD	HL,(_qsort_ptr1)
	LD	(HL),E		; Store E at ptr1

	; Advance pointers
	LD	HL,(_qsort_ptr1)
	INC	HL
	LD	(_qsort_ptr1),HL
	LD	HL,(_qsort_ptr2)
	INC	HL
	LD	(_qsort_ptr2),HL

	DEC	BC
	JR	_qsort_swap_loop

_qsort_outer_next:
	LD	HL,(_qsort_i)
	INC	HL
	LD	(_qsort_i),HL
	JP	_qsort_outer

_qsort_done:
	POP	DE
	POP	BC
	POP	IX
	RET

; Internal: calculate base + index*size
; Input: HL = index
; Output: HL = address
; Uses: size from IX+8
_qsort_addr:
	PUSH	DE
	PUSH	BC
	; Multiply HL by size
	LD	E,(IX+8)
	LD	D,(IX+9)	; DE = size
	CALL	__mul16		; HL = index * size
	; Add base
	LD	E,(IX+4)
	LD	D,(IX+5)
	ADD	HL,DE
	POP	BC
	POP	DE
	RET

; ============================================================
; void *bsearch(const void *key, const void *base, size_t nmemb,
;               size_t size, int (*compar)(const void *, const void *))
; Binary search in sorted array
; Stack: key(IX+4), base(IX+6), nmemb(IX+8), size(IX+10), compar(IX+12)
; Returns: pointer to found element, or NULL
; ============================================================
	PUBLIC	_bsearch
_bsearch:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	PUSH	BC
	PUSH	DE

	; low = 0
	LD	HL,0
	LD	(_bsearch_low),HL

	; high = nmemb
	LD	L,(IX+8)
	LD	H,(IX+9)
	LD	(_bsearch_high),HL

_bsearch_loop:
	; Check if low >= high
	LD	HL,(_bsearch_low)
	LD	DE,(_bsearch_high)
	OR	A
	SBC	HL,DE
	JP	NC,_bsearch_notfound	; low >= high

	; mid = (low + high) / 2
	LD	HL,(_bsearch_low)
	LD	DE,(_bsearch_high)
	ADD	HL,DE
	SRL	H
	RR	L		; HL = (low + high) / 2
	LD	(_bsearch_mid),HL

	; Calculate address of base[mid]
	LD	E,(IX+10)
	LD	D,(IX+11)	; DE = size
	CALL	__mul16		; HL = mid * size
	LD	E,(IX+6)
	LD	D,(IX+7)
	ADD	HL,DE		; HL = base + mid*size
	PUSH	HL		; Save mid address

	; Call compare(key, &base[mid])
	PUSH	HL		; Second arg: &base[mid]
	LD	L,(IX+4)
	LD	H,(IX+5)
	PUSH	HL		; First arg: key
	LD	L,(IX+12)
	LD	H,(IX+13)
	CALL	__callhl
	POP	DE		; Clean up first arg
	POP	DE		; Clean up second arg

	POP	DE		; Restore mid address into DE

	; Check result
	LD	A,H
	OR	L
	JR	Z,_bsearch_found	; cmp == 0, found!

	BIT	7,H
	JR	NZ,_bsearch_left	; cmp < 0, search left

	; cmp > 0, search right: low = mid + 1
	LD	HL,(_bsearch_mid)
	INC	HL
	LD	(_bsearch_low),HL
	JR	_bsearch_loop

_bsearch_left:
	; cmp < 0, search left: high = mid
	LD	HL,(_bsearch_mid)
	LD	(_bsearch_high),HL
	JR	_bsearch_loop

_bsearch_found:
	; Return mid address (saved in DE)
	EX	DE,HL
	JR	_bsearch_ret

_bsearch_notfound:
	LD	HL,0		; Return NULL

_bsearch_ret:
	POP	DE
	POP	BC
	POP	IX
	RET


	DSEG
; qsort working storage
_qsort_i:	DS	2
_qsort_j:	DS	2
_qsort_min:	DS	2
_qsort_ptr1:	DS	2
_qsort_ptr2:	DS	2
; bsearch working storage
_bsearch_low:	DS	2
_bsearch_high:	DS	2
_bsearch_mid:	DS	2


; ============================================================
; lc_scalbn.mac
; ============================================================
	CSEG
; lc_scalbn.mac - scalbn, scalbnf, scalbln, scalblnf
; scalbn(x, n) = x * 2^n (same as ldexp)



	CSEG

	PUBLIC	_scalbn
	PUBLIC	_scalbnf
	PUBLIC	_scalbln
	PUBLIC	_scalblnf
_scalbn:
_scalbnf:
_scalbln:
_scalblnf:
	JP	_ldexpf


; ============================================================
; lc_scanf.mac
; ============================================================
	CSEG
; lc_scanf.mac - scanf family




	CSEG

; ============================================================
; scanf family - formatted input
; int scanf(const char *fmt, ...)
; int sscanf(const char *str, const char *fmt, ...)
; int fscanf(FILE *stream, const char *fmt, ...)
; ============================================================

	PUBLIC	_scanf
_scanf:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	; fmt at IX+4, args start at IX+6
	LD	L,(IX+4)
	LD	H,(IX+5)	; HL = format string
	LD	C,6		; C = offset to next argument
	XOR	A
	LD	(_scanf_count),A ; matched count
	LD	(_scanf_mode),A  ; mode=0: stdin

_scanf_loop:
	LD	A,(HL)
	OR	A
	JP	Z,_scanf_done

	CP	'%'
	JP	Z,_scanf_format

	CP	' '
	JP	Z,_scanf_white
	CP	9		; tab
	JP	Z,_scanf_white
	CP	10		; newline
	JP	Z,_scanf_white
	CP	13		; CR
	JP	Z,_scanf_white

	; Literal match required
	PUSH	HL
	PUSH	BC
	CALL	_scanf_getc
	POP	BC
	POP	HL
	CP	(HL)
	JP	NZ,_scanf_done	; Mismatch
	INC	HL
	JP	_scanf_loop

_scanf_white:
	; Skip whitespace in format and input
	INC	HL
	PUSH	HL
	PUSH	BC
_scanf_skip_ws:
	CALL	_scanf_getc
	CP	' '
	JR	Z,_scanf_skip_ws
	CP	9
	JR	Z,_scanf_skip_ws
	CP	10
	JR	Z,_scanf_skip_ws
	CP	13
	JR	Z,_scanf_skip_ws
	; Unget non-whitespace char
	CALL	_scanf_ungetc
	POP	BC
	POP	HL
	JP	_scanf_loop

_scanf_format:
	INC	HL
	LD	A,(HL)
	OR	A
	JP	Z,_scanf_done

	CP	'%'
	JP	Z,_scanf_pct

	CP	'd'
	JP	Z,_scanf_int
	CP	'i'
	JP	Z,_scanf_int

	CP	's'
	JP	Z,_scanf_str

	CP	'c'
	JP	Z,_scanf_chr

	CP	'u'
	JP	Z,_scanf_uint

	CP	'x'
	JP	Z,_scanf_hex

	CP	'l'
	JP	Z,_scanf_long

	CP	'*'
	JP	Z,_scanf_star

	; Unknown - skip
	INC	HL
	JP	_scanf_loop

_scanf_pct:
	; Match literal %
	PUSH	HL
	PUSH	BC
	CALL	_scanf_getc
	POP	BC
	POP	HL
	CP	'%'
	JP	NZ,_scanf_done
	INC	HL
	JP	_scanf_loop

_scanf_star:
	; Suppressed assignment - read but don't store
	INC	HL
	LD	A,(HL)
	CP	'd'
	JP	Z,_scanf_star_int
	CP	's'
	JP	Z,_scanf_star_str
	; Default: skip one int
_scanf_star_int:
	PUSH	HL
	PUSH	BC
	CALL	_scanf_skip_ws
	CALL	_scanf_read_int
	POP	BC
	POP	HL
	INC	HL
	JP	_scanf_loop
_scanf_star_str:
	PUSH	HL
	PUSH	BC
	CALL	_scanf_skip_ws
_scanf_star_str_loop:
	CALL	_scanf_getc
	CP	' '
	JR	Z,_scanf_star_str_done
	CP	9
	JR	Z,_scanf_star_str_done
	CP	10
	JR	Z,_scanf_star_str_done
	CP	13
	JR	Z,_scanf_star_str_done
	OR	A
	JR	NZ,_scanf_star_str_loop
_scanf_star_str_done:
	CALL	_scanf_ungetc
	POP	BC
	POP	HL
	INC	HL
	JP	_scanf_loop

_scanf_int:
	; Read signed integer
	PUSH	HL
	PUSH	BC
	CALL	_scanf_skip_ws
	CALL	_scanf_read_int	; Result in HL
	PUSH	HL
	; Get destination pointer
	LD	H,0
	LD	L,C
	PUSH	IX
	POP	DE
	ADD	HL,DE
	LD	E,(HL)
	INC	HL
	LD	D,(HL)		; DE = destination pointer
	POP	HL		; HL = value
	EX	DE,HL		; HL = dest, DE = value
	LD	(HL),E
	INC	HL
	LD	(HL),D
	; Increment count
	LD	A,(_scanf_count)
	INC	A
	LD	(_scanf_count),A
	POP	BC
	INC	C
	INC	C
	POP	HL
	INC	HL
	JP	_scanf_loop

_scanf_uint:
	; Read unsigned integer (same as int for now)
	JP	_scanf_int

_scanf_hex:
	; Read hex integer
	PUSH	HL
	PUSH	BC
	CALL	_scanf_skip_ws
	CALL	_scanf_read_hex	; Result in HL
	PUSH	HL
	; Get destination pointer
	LD	H,0
	LD	L,C
	PUSH	IX
	POP	DE
	ADD	HL,DE
	LD	E,(HL)
	INC	HL
	LD	D,(HL)
	POP	HL
	EX	DE,HL
	LD	(HL),E
	INC	HL
	LD	(HL),D
	LD	A,(_scanf_count)
	INC	A
	LD	(_scanf_count),A
	POP	BC
	INC	C
	INC	C
	POP	HL
	INC	HL
	JP	_scanf_loop

_scanf_str:
	; Read string (non-whitespace)
	PUSH	HL
	PUSH	BC
	CALL	_scanf_skip_ws
	; Get destination pointer
	LD	H,0
	LD	L,C
	PUSH	IX
	POP	DE
	ADD	HL,DE
	LD	E,(HL)
	INC	HL
	LD	D,(HL)		; DE = destination pointer
	EX	DE,HL		; HL = dest
_scanf_str_loop:
	PUSH	HL
	CALL	_scanf_getc
	POP	HL
	CP	' '
	JR	Z,_scanf_str_end
	CP	9
	JR	Z,_scanf_str_end
	CP	10
	JR	Z,_scanf_str_end
	CP	13
	JR	Z,_scanf_str_end
	CP	0FFH
	JR	Z,_scanf_str_end
	OR	A
	JR	Z,_scanf_str_end
	LD	(HL),A
	INC	HL
	JR	_scanf_str_loop
_scanf_str_end:
	LD	(HL),0		; Null terminate
	CALL	_scanf_ungetc
	LD	A,(_scanf_count)
	INC	A
	LD	(_scanf_count),A
	POP	BC
	INC	C
	INC	C
	POP	HL
	INC	HL
	JP	_scanf_loop

_scanf_chr:
	; Read single character
	PUSH	HL
	PUSH	BC
	CALL	_scanf_getc
	PUSH	AF
	; Get destination pointer
	LD	H,0
	LD	L,C
	PUSH	IX
	POP	DE
	ADD	HL,DE
	LD	E,(HL)
	INC	HL
	LD	D,(HL)
	EX	DE,HL
	POP	AF
	LD	(HL),A
	LD	A,(_scanf_count)
	INC	A
	LD	(_scanf_count),A
	POP	BC
	INC	C
	INC	C
	POP	HL
	INC	HL
	JP	_scanf_loop

_scanf_long:
	; Handle 'l' modifier
	INC	HL
	LD	A,(HL)
	CP	'd'
	JP	Z,_scanf_ld
	CP	'i'
	JP	Z,_scanf_ld	; %li → signed long (no base-prefix detection)
	CP	'u'
	JP	Z,_scanf_ld	; %lu → same reader as %ld (no sign distinction)
	CP	'x'
	JP	Z,_scanf_lx
	; Unknown - skip
	JP	_scanf_loop

_scanf_ld:
	; Read long signed integer
	PUSH	HL
	PUSH	BC
	CALL	_scanf_skip_ws
	CALL	_scanf_read_long	; Result in DEHL
	PUSH	DE
	PUSH	HL
	; Get destination pointer
	LD	H,0
	LD	L,C
	PUSH	IX
	POP	DE
	ADD	HL,DE
	LD	E,(HL)
	INC	HL
	LD	D,(HL)
	EX	DE,HL		; HL = dest
	POP	DE		; DE = low word
	LD	(HL),E
	INC	HL
	LD	(HL),D
	INC	HL
	POP	DE		; DE = high word
	LD	(HL),E
	INC	HL
	LD	(HL),D
	LD	A,(_scanf_count)
	INC	A
	LD	(_scanf_count),A
	POP	BC
	INC	C
	INC	C
	POP	HL
	INC	HL
	JP	_scanf_loop

_scanf_lx:
	; Read long hex
	PUSH	HL
	PUSH	BC
	CALL	_scanf_skip_ws
	CALL	_scanf_read_long_hex
	PUSH	DE
	PUSH	HL
	LD	H,0
	LD	L,C
	PUSH	IX
	POP	DE
	ADD	HL,DE
	LD	E,(HL)
	INC	HL
	LD	D,(HL)
	EX	DE,HL
	POP	DE
	LD	(HL),E
	INC	HL
	LD	(HL),D
	INC	HL
	POP	DE
	LD	(HL),E
	INC	HL
	LD	(HL),D
	LD	A,(_scanf_count)
	INC	A
	LD	(_scanf_count),A
	POP	BC
	INC	C
	INC	C
	POP	HL
	INC	HL
	JP	_scanf_loop

_scanf_done:
	LD	A,(_scanf_count)
	LD	L,A
	LD	H,0
	POP	IX
	RET

; Internal: get a character based on mode
_scanf_getc:
	LD	A,(_scanf_mode)
	OR	A
	JR	NZ,_scanf_getc_str
	; Mode 0: stdin
	LD	C,1		; CONIN
	CALL	5
	RET
_scanf_getc_str:
	CP	1
	JR	NZ,_scanf_getc_file
	; Mode 1: string
	LD	HL,(_scanf_src)
	LD	A,(HL)
	OR	A
	JR	Z,_scanf_getc_eof
	INC	HL
	LD	(_scanf_src),HL
	RET
_scanf_getc_file:
	; Mode 2: file
	LD	HL,(_scanf_fp)
	PUSH	HL
	CALL	_fgetc
	POP	BC
	RET
_scanf_getc_eof:
	LD	A,0FFH
	RET

; Internal: unget character
_scanf_ungetc:
	LD	(_scanf_ungot),A
	RET

; Internal: read signed integer into HL
_scanf_read_int:
	LD	HL,0
	LD	D,0		; D = sign (0=positive, 1=negative)
	; Check for sign
	CALL	_scanf_getc
	CP	'-'
	JR	NZ,_scanf_ri_notneg
	LD	D,1
	JR	_scanf_ri_loop
_scanf_ri_notneg:
	CP	'+'
	JR	Z,_scanf_ri_loop
	; Not a sign - first digit
	JR	_scanf_ri_digit

_scanf_ri_loop:
	CALL	_scanf_getc
_scanf_ri_digit:
	CP	'0'
	JR	C,_scanf_ri_done
	CP	'9'+1
	JR	NC,_scanf_ri_done
	; Digit - accumulate
	SUB	'0'
	PUSH	DE
	LD	E,A
	; HL = HL * 10 + digit
	ADD	HL,HL		; *2
	LD	B,H
	LD	C,L
	ADD	HL,HL		; *4
	ADD	HL,HL		; *8
	ADD	HL,BC		; *10
	LD	D,0
	ADD	HL,DE
	POP	DE
	JR	_scanf_ri_loop

_scanf_ri_done:
	; Unget the non-digit
	CALL	_scanf_ungetc
	; Apply sign
	LD	A,D
	OR	A
	RET	Z
	; Negate HL
	XOR	A
	LD	D,A
	LD	E,A
	EX	DE,HL
	SBC	HL,DE
	RET

; Internal: read hex integer into HL
_scanf_read_hex:
	LD	HL,0
	; Skip optional 0x prefix
	CALL	_scanf_getc
	CP	'0'
	JR	NZ,_scanf_rh_digit
	CALL	_scanf_getc
	CP	'x'
	JR	Z,_scanf_rh_loop
	CP	'X'
	JR	Z,_scanf_rh_loop
	; Not 0x - process as digit
	CALL	_scanf_ungetc
	LD	A,'0'
	JR	_scanf_rh_digit

_scanf_rh_loop:
	CALL	_scanf_getc
_scanf_rh_digit:
	CP	'0'
	JR	C,_scanf_rh_done
	CP	'9'+1
	JR	C,_scanf_rh_09
	CP	'A'
	JR	C,_scanf_rh_done
	CP	'F'+1
	JR	C,_scanf_rh_AF
	CP	'a'
	JR	C,_scanf_rh_done
	CP	'f'+1
	JR	NC,_scanf_rh_done
	; a-f
	SUB	'a'-10
	JR	_scanf_rh_acc
_scanf_rh_AF:
	SUB	'A'-10
	JR	_scanf_rh_acc
_scanf_rh_09:
	SUB	'0'
_scanf_rh_acc:
	; HL = HL * 16 + digit
	ADD	HL,HL
	ADD	HL,HL
	ADD	HL,HL
	ADD	HL,HL
	OR	L
	LD	L,A
	JR	_scanf_rh_loop
_scanf_rh_done:
	CALL	_scanf_ungetc
	RET

; Internal: read long integer into DEHL
_scanf_read_long:
	LD	HL,0
	LD	DE,0
	LD	B,0		; sign
	CALL	_scanf_getc
	CP	'-'
	JR	NZ,_scanf_rl_notneg
	LD	B,1
	JR	_scanf_rl_loop
_scanf_rl_notneg:
	CP	'+'
	JR	Z,_scanf_rl_loop
	JR	_scanf_rl_digit

_scanf_rl_loop:
	CALL	_scanf_getc
_scanf_rl_digit:
	CP	'0'
	JP	C,_scanf_rl_done
	CP	'9'+1
	JP	NC,_scanf_rl_done
	SUB	'0'
	PUSH	BC
	LD	C,A
	; DEHL = DEHL * 10 + digit
	; First *10 = *8 + *2
	PUSH	DE
	PUSH	HL		; Save original
	SLA	L
	RL	H
	RL	E
	RL	D		; *2
	PUSH	DE
	PUSH	HL		; Save *2
	SLA	L
	RL	H
	RL	E
	RL	D		; *4
	SLA	L
	RL	H
	RL	E
	RL	D		; *8
	; Add *2
	POP	BC		; BC = *2 low
	ADD	HL,BC
	EX	(SP),HL		; Stack *8+*2 low, get *2 high
	EX	DE,HL
	POP	BC		; BC = *8+*2 low
	ADC	HL,DE		; HL = *10 high
	EX	DE,HL		; DE = *10 high
	LD	H,B
	LD	L,C		; HL = *10 low
	POP	BC		; Discard saved original high
	POP	BC		; Discard saved original low
	; Add digit
	LD	B,0
	ADD	HL,BC
	JR	NC,_scanf_rl_noc
	INC	DE
_scanf_rl_noc:
	POP	BC		; Restore sign
	JP	_scanf_rl_loop

_scanf_rl_done:
	CALL	_scanf_ungetc
	LD	A,B
	OR	A
	RET	Z
	; Negate DEHL
	PUSH	BC
	LD	A,L
	CPL
	LD	L,A
	LD	A,H
	CPL
	LD	H,A
	LD	A,E
	CPL
	LD	E,A
	LD	A,D
	CPL
	LD	D,A
	LD	BC,1
	ADD	HL,BC
	JR	NC,_scanf_rl_neg_done
	INC	DE
_scanf_rl_neg_done:
	POP	BC
	RET

; Internal: read long hex into DEHL
_scanf_read_long_hex:
	LD	HL,0
	LD	DE,0
	; Skip optional 0x
	CALL	_scanf_getc
	CP	'0'
	JR	NZ,_scanf_rlh_digit
	CALL	_scanf_getc
	CP	'x'
	JR	Z,_scanf_rlh_loop
	CP	'X'
	JR	Z,_scanf_rlh_loop
	CALL	_scanf_ungetc
	LD	A,'0'
	JR	_scanf_rlh_digit

_scanf_rlh_loop:
	CALL	_scanf_getc
_scanf_rlh_digit:
	CP	'0'
	JR	C,_scanf_rlh_done
	CP	'9'+1
	JR	C,_scanf_rlh_09
	CP	'A'
	JR	C,_scanf_rlh_done
	CP	'F'+1
	JR	C,_scanf_rlh_AF
	CP	'a'
	JR	C,_scanf_rlh_done
	CP	'f'+1
	JR	NC,_scanf_rlh_done
	SUB	'a'-10
	JR	_scanf_rlh_acc
_scanf_rlh_AF:
	SUB	'A'-10
	JR	_scanf_rlh_acc
_scanf_rlh_09:
	SUB	'0'
_scanf_rlh_acc:
	; DEHL = DEHL * 16 + digit
	SLA	L
	RL	H
	RL	E
	RL	D
	SLA	L
	RL	H
	RL	E
	RL	D
	SLA	L
	RL	H
	RL	E
	RL	D
	SLA	L
	RL	H
	RL	E
	RL	D
	OR	L
	LD	L,A
	JR	_scanf_rlh_loop
_scanf_rlh_done:
	CALL	_scanf_ungetc
	RET

; ============================================================
; sscanf - read from string
; ============================================================
	PUBLIC	_sscanf
_sscanf:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	; str at IX+4, fmt at IX+6, args at IX+8
	LD	L,(IX+4)
	LD	H,(IX+5)
	LD	(_scanf_src),HL
	LD	A,1
	LD	(_scanf_mode),A
	; Setup format and args offset
	LD	L,(IX+6)
	LD	H,(IX+7)	; HL = format
	LD	C,8		; args start at IX+8
	XOR	A
	LD	(_scanf_count),A
	JP	_scanf_loop

; ============================================================
; fscanf - read from file
; ============================================================
	PUBLIC	_fscanf
_fscanf:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	; stream at IX+4, fmt at IX+6, args at IX+8
	LD	L,(IX+4)
	LD	H,(IX+5)
	LD	(_scanf_fp),HL
	LD	A,2
	LD	(_scanf_mode),A
	LD	L,(IX+6)
	LD	H,(IX+7)
	LD	C,8
	XOR	A
	LD	(_scanf_count),A
	JP	_scanf_loop

	DSEG

; scanf work areas
_scanf_count:	DS	1	; Number of matched items
_scanf_mode:	DS	1	; 0=stdin, 1=string, 2=file
_scanf_src:	DS	2	; String source pointer
_scanf_fp:	DS	2	; File pointer
_scanf_ungot:	DS	1	; Ungetc'd character
_scanf_buf:	DS	32	; Working buffer


; ============================================================
; lc_signal.mac
; ============================================================
	CSEG
; lc_signal.mac - signal handling


	CSEG

; ============================================================
; Signal handling for CP/M
; Software signal system - no hardware signals but full API support
; ============================================================

; Signal handler table - 7 entries (signals 0-6), each a 2-byte function pointer
; Initialized to SIG_DFL (0) = default handling
_sig_handlers:
	DW	0		; Signal 0 (unused)
	DW	0		; SIGABRT (1)
	DW	0		; SIGFPE (2)
	DW	0		; SIGILL (3)
	DW	0		; SIGINT (4)
	DW	0		; SIGSEGV (5)
	DW	0		; SIGTERM (6)

; sig_handler_t signal(int sig, sig_handler_t handler)
; Sets signal handler, returns previous handler
; Returns SIG_ERR (-1) for invalid signal numbers
	PUBLIC	_signal
_signal:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	; Get signal number
	LD	L,(IX+4)
	LD	H,(IX+5)
	; Validate signal (must be 1-6)
	LD	A,L
	OR	H		; H must be 0
	JR	NZ,_sig_err
	LD	A,L
	OR	A
	JR	Z,_sig_err	; 0 is invalid
	CP	7
	JR	NC,_sig_err	; >= 7 is invalid
	; Calculate table offset: sig * 2
	ADD	A,A		; A = sig * 2
	LD	E,A
	LD	D,0
	LD	HL,_sig_handlers
	ADD	HL,DE		; HL = &_sig_handlers[sig]
	; Save old handler to return
	LD	E,(HL)
	INC	HL
	LD	D,(HL)
	DEC	HL		; HL back to start
	; Store new handler
	LD	A,(IX+6)
	LD	(HL),A
	INC	HL
	LD	A,(IX+7)
	LD	(HL),A
	; Return old handler in HL
	EX	DE,HL
	POP	IX
	RET
_sig_err:
	; Return SIG_ERR (-1)
	LD	HL,-1
	POP	IX
	RET

; int raise(int sig)
; Raises a signal - calls the registered handler
; Returns 0 on success, -1 on error
	PUBLIC	_raise
_raise:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	; Get signal number
	LD	L,(IX+4)
	LD	H,(IX+5)
	; Validate signal (must be 1-6)
	LD	A,L
	OR	H
	JR	NZ,_raise_err
	LD	A,L
	OR	A
	JR	Z,_raise_err
	CP	7
	JR	NC,_raise_err
	; Save signal number
	PUSH	AF
	; Get handler: _sig_handlers[sig]
	ADD	A,A		; A = sig * 2
	LD	E,A
	LD	D,0
	LD	HL,_sig_handlers
	ADD	HL,DE
	LD	E,(HL)
	INC	HL
	LD	D,(HL)		; DE = handler
	; Check handler type
	LD	A,D
	OR	E
	JR	Z,_raise_dfl	; SIG_DFL (0) - default handling
	LD	A,D
	AND	E
	INC	A
	JR	Z,_raise_ign	; SIG_IGN (-1 = 0xFFFF) - ignore (but that's SIG_ERR)
	; Check if SIG_IGN (1)
	LD	A,D
	OR	A
	JR	NZ,_raise_call
	LD	A,E
	CP	1
	JR	Z,_raise_ign	; SIG_IGN (1) - ignore
	; Fall through to call handler
_raise_call:
	; Reset to SIG_DFL before calling (ANSI behavior)
	POP	AF		; Get signal number back
	PUSH	AF
	ADD	A,A
	LD	C,A
	LD	B,0
	LD	HL,_sig_handlers
	ADD	HL,BC
	XOR	A
	LD	(HL),A
	INC	HL
	LD	(HL),A		; Reset to SIG_DFL
	; Call handler with signal number as argument
	POP	AF		; Signal number
	PUSH	AF
	LD	L,A
	LD	H,0
	PUSH	HL		; Push signal argument
	; Call handler (DE has address)
	PUSH	DE
	POP	HL		; HL = handler address
	CALL	_raise_callhl
	POP	BC		; Clean up argument
	POP	AF		; Clean up saved signal
	; Return success
	LD	HL,0
	POP	IX
	RET
_raise_callhl:
	JP	(HL)		; Call handler

_raise_dfl:
	; Default handling - depends on signal type
	POP	AF		; Get signal number
	CP	1		; SIGABRT?
	JR	Z,_raise_abort
	CP	2		; SIGFPE?
	JR	Z,_raise_abort
	CP	3		; SIGILL?
	JR	Z,_raise_abort
	CP	5		; SIGSEGV?
	JR	Z,_raise_abort
	CP	6		; SIGTERM?
	JR	Z,_raise_abort
	; SIGINT (4) - default is ignore in CP/M context
	LD	HL,0
	POP	IX
	RET
_raise_abort:
	; Abort - warm boot CP/M
	LD	C,0		; BDOS function 0 - warm boot
	CALL	5
	; Should not return, but just in case
	LD	HL,0
	POP	IX
	RET

_raise_ign:
	; Signal ignored - just return success
	POP	AF		; Clean up saved signal
	LD	HL,0
	POP	IX
	RET

_raise_err:
	; Invalid signal number
	LD	HL,-1
	POP	IX
	RET

; ============================================================
; Math functions - IEEE 754 single precision implementations
; Using Taylor series, Newton-Raphson, and polynomial approximations


	DSEG
_signal_table:	DS	14


; ============================================================
; lc_sin.mac
; ============================================================
	CSEG
; lc_sin.mac - sin, sinf, sinl


	EXTRN	__fadd
	EXTRN	__fmul
	EXTRN	__fdiv
	EXTRN	__itof
	EXTRN	__tmp32

	CSEG

; ============================================================
; sin(x) - Sine using Taylor series
; sin(x) = x - x^3/3! + x^5/5! - x^7/7! + ...
; ============================================================
	PUBLIC	_sin
	PUBLIC	_sinf
	PUBLIC	_sinl
_sin:
_sinf:
_sinl:
	PUSH	IX
	PUSH	BC
	LD	IX,0
	ADD	IX,SP

	CALL	_math_getarg	; x in DEHL

	; Save sign and work with |x|
	LD	A,D
	AND	80H
	LD	(_sin_sign),A
	LD	A,D
	AND	7FH
	LD	D,A

	; Reduce x to [-pi, pi] range (simplified: assume small x)
	LD	(_sin_x),HL
	LD	(_sin_x+2),DE

	; Start with sum = x
	LD	(_sin_sum),HL
	LD	(_sin_sum+2),DE

	; term = x
	LD	(_sin_term),HL
	LD	(_sin_term+2),DE

	; Compute x^2 for subsequent terms
	LD	A,L
	LD	(__tmp32),A
	LD	A,H
	LD	(__tmp32+1),A
	LD	A,E
	LD	(__tmp32+2),A
	LD	A,D
	LD	(__tmp32+3),A
	CALL	__fmul		; DEHL = x^2
	LD	(_sin_x2),HL
	LD	(_sin_x2+2),DE

	; Taylor series: 4 terms should be enough for single precision
	; term *= -x^2 / (n*(n+1))
	LD	A,2
	LD	(_sin_iter),A	; n starts at 2
	LD	B,4		; loop count

_sin_loop:
	PUSH	BC		; Save loop counter only

	; term *= x^2
	LD	HL,(_sin_term)
	LD	DE,(_sin_term+2)
	LD	A,(_sin_x2)
	LD	(__tmp32),A
	LD	A,(_sin_x2+1)
	LD	(__tmp32+1),A
	LD	A,(_sin_x2+2)
	LD	(__tmp32+2),A
	LD	A,(_sin_x2+3)
	LD	(__tmp32+3),A
	CALL	__fmul
	LD	(_sin_term),HL
	LD	(_sin_term+2),DE

	; Divide by n*(n+1)
	LD	A,(_sin_iter)	; Get n
	LD	L,A
	LD	H,0
	LD	D,0
	LD	E,0		; DEHL = n as 32-bit integer
	CALL	__itof		; Convert n to float
	LD	(_sin_n),HL
	LD	(_sin_n+2),DE
	LD	A,(_sin_iter)
	INC	A		; n+1
	LD	L,A
	LD	H,0
	LD	D,0
	LD	E,0		; DEHL = n+1 as 32-bit
	CALL	__itof		; Convert n+1 to float
	; Multiply n * (n+1)
	LD	A,(_sin_n)
	LD	(__tmp32),A
	LD	A,(_sin_n+1)
	LD	(__tmp32+1),A
	LD	A,(_sin_n+2)
	LD	(__tmp32+2),A
	LD	A,(_sin_n+3)
	LD	(__tmp32+3),A
	CALL	__fmul		; n*(n+1) in DEHL

	; Advance n by 2 for next iteration
	LD	A,(_sin_iter)
	ADD	A,2
	LD	(_sin_iter),A

	; Divide term by n*(n+1)
	; __fdiv expects: DEHL = dividend, __tmp32 = divisor
	; We have n*(n+1) in DEHL, need term / n*(n+1)
	LD	(__tmp32),HL	; Store n*(n+1) as divisor
	LD	(__tmp32+2),DE
	LD	HL,(_sin_term)	; Load term as dividend
	LD	DE,(_sin_term+2)
	CALL	__fdiv		; DEHL = term / n*(n+1)

	; Negate term (alternate signs)
	LD	A,D
	XOR	80H
	LD	D,A
	LD	(_sin_term),HL
	LD	(_sin_term+2),DE

	; Add to sum
	LD	A,(_sin_sum)
	LD	(__tmp32),A
	LD	A,(_sin_sum+1)
	LD	(__tmp32+1),A
	LD	A,(_sin_sum+2)
	LD	(__tmp32+2),A
	LD	A,(_sin_sum+3)
	LD	(__tmp32+3),A
	CALL	__fadd
	LD	(_sin_sum),HL
	LD	(_sin_sum+2),DE

	POP	BC		; Restore loop counter
	DJNZ	_sin_loop

	; Apply original sign
	LD	HL,(_sin_sum)
	LD	DE,(_sin_sum+2)
	LD	A,(_sin_sign)
	OR	D
	LD	D,A

	POP	BC
	POP	IX
	RET

	DSEG

_sin_sign:	DS	1
_sin_x:		DS	4
_sin_x2:	DS	4
_sin_sum:	DS	4
_sin_term:	DS	4
_sin_n:		DS	4
_sin_iter:	DS	1


; ============================================================
; lc_sinh.mac
; ============================================================
	CSEG
; lc_sinh.mac - sinh, sinhf (depends on exp)


	EXTRN	__fadd
	EXTRN	__fsub
	EXTRN	__tmp32

	CSEG

; ============================================================
; sinh(x) = (e^x - e^-x) / 2
; ============================================================
	PUBLIC	_sinh
	PUBLIC	_sinhf
_sinh:
_sinhf:
	PUSH	IX
	PUSH	BC
	LD	IX,0
	ADD	IX,SP

	CALL	_math_getarg
	LD	(_sinh_x),HL
	LD	(_sinh_x+2),DE

	; e^x
	PUSH	DE
	PUSH	HL
	CALL	_expf
	POP	BC
	POP	BC
	LD	(_sinh_ep),HL
	LD	(_sinh_ep+2),DE

	; e^-x
	LD	HL,(_sinh_x)
	LD	DE,(_sinh_x+2)
	LD	A,D
	XOR	80H
	LD	D,A
	PUSH	DE
	PUSH	HL
	CALL	_expf
	POP	BC
	POP	BC

	; e^x - e^-x
	LD	(__tmp32),HL
	LD	(__tmp32+2),DE
	LD	HL,(_sinh_ep)
	LD	DE,(_sinh_ep+2)
	CALL	__fsub

	; Divide by 2: decrement IEEE 754 exponent by 1
	OR	A		; Clear carry
	LD	A,E
	SUB	80H
	LD	E,A
	LD	A,D
	SBC	A,0
	LD	D,A

	POP	BC
	POP	IX
	RET

	DSEG

_sinh_x:	DS	4
_sinh_ep:	DS	4


; ============================================================
; lc_snprintf.mac
; ============================================================
	CSEG
; lc_snprintf.mac - snprintf




	CSEG

; ============================================================
; int snprintf(char *str, size_t size, const char *fmt, ...)
; Format string into buffer with size limit
; Supports %d, %s, %c, %x, %u, %p, %%
; Returns: number of chars that would have been written (excl. null)
; Stack: str(IX+4), size(IX+6), fmt(IX+8), args start at IX+10
; ============================================================
	PUBLIC	_snprintf
_snprintf:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	PUSH	BC
	PUSH	DE

	; str is at IX+4, size at IX+6, fmt at IX+8, first vararg at IX+10
	LD	E,(IX+4)
	LD	D,(IX+5)	; DE = output buffer pointer
	LD	(_snprintf_out),DE
	LD	E,(IX+6)
	LD	D,(IX+7)	; DE = size
	LD	(_snprintf_max),DE
	LD	L,(IX+8)
	LD	H,(IX+9)	; HL = format string pointer
	LD	C,10		; C = offset to next argument

	; Character counter and remaining counter
	LD	DE,0
	LD	(_snprintf_cnt),DE

_snprintf_loop:
	LD	A,(HL)
	OR	A
	JP	Z,_snprintf_done

	CP	'%'
	JR	Z,_snprintf_format

	; Regular character - output it
	CALL	_snprintf_putc
	INC	HL
	JR	_snprintf_loop

_snprintf_format:
	; Reset per-conversion flags so they don't leak between %-specifiers.
	XOR	A
	LD	(_snprintf_plus),A
	LD	(_snprintf_space),A
	LD	(_snprintf_width),A
	LD	(_snprintf_zero),A
	INC	HL
	LD	A,(HL)
	OR	A
	JP	Z,_snprintf_done

	CP	'%'
	JR	Z,_snprintf_pct

_snprintf_fmt2:
	; Flags: '-', '+', ' ', '#', '0'.  Capture the ones we use, skip
	; (but don't error on) the rest.
	CP	'+'
	JR	Z,_snprintf_set_plus
	CP	' '
	JR	Z,_snprintf_set_space
	CP	'-'
	JR	Z,_snprintf_fskip
	CP	'#'
	JR	Z,_snprintf_fskip
	CP	'0'
	JR	Z,_snprintf_set_zero
	; Field width: capture digit into _snprintf_width.
	; (zero-padding flag '0' was handled above; here '0' inside width
	; just multiplies width by 10, i.e. width = width*10 + (A - '0').)
	CP	'1'
	JR	C,_snprintf_nodig
	CP	'9'+1
	JR	C,_snprintf_set_widthdig
_snprintf_nodig:
	; Skip precision
	CP	'.'
	JR	Z,_snprintf_fskip
	; Skip length modifiers: h, l, z
	CP	'h'
	JR	Z,_snprintf_fskip
	CP	'l'
	JR	Z,_snprintf_fskip
	CP	'z'
	JR	Z,_snprintf_fskip
	; Now check format specifiers
	CP	's'
	JR	Z,_snprintf_str

	CP	'd'
	JR	Z,_snprintf_dec

	CP	'i'
	JR	Z,_snprintf_dec

	CP	'c'
	JR	Z,_snprintf_chr

	CP	'x'
	JR	Z,_snprintf_hex_lc

	CP	'X'
	JR	Z,_snprintf_hex_uc

	CP	'u'
	JR	Z,_snprintf_uns

	CP	'p'
	JR	Z,_snprintf_hex_lc	; %p same as %x

	; Unknown format - skip
	INC	HL
	JP	_snprintf_loop

_snprintf_set_plus:
	LD	A,1
	LD	(_snprintf_plus),A
	JR	_snprintf_fskip
_snprintf_set_space:
	LD	A,1
	LD	(_snprintf_space),A
	JR	_snprintf_fskip
_snprintf_set_zero:
	; '0' before any width digit = zero-pad flag; '0' after digits
	; just keeps multiplying width by 10.
	LD	A,(_snprintf_width)
	OR	A
	JR	NZ,_snprintf_widthdig_zero
	LD	A,1
	LD	(_snprintf_zero),A
	JR	_snprintf_fskip
_snprintf_widthdig_zero:
	; width = width * 10 (digit is 0)
	LD	A,(_snprintf_width)
	LD	D,A
	ADD	A,A		; *2
	ADD	A,A		; *4
	ADD	A,D		; *5
	ADD	A,A		; *10
	LD	(_snprintf_width),A
	JR	_snprintf_fskip
_snprintf_set_widthdig:
	; width = width * 10 + (A - '0')
	SUB	'0'
	LD	D,A
	LD	A,(_snprintf_width)
	LD	E,A
	ADD	A,A		; *2
	ADD	A,A		; *4
	ADD	A,E		; *5
	ADD	A,A		; *10
	ADD	A,D
	LD	(_snprintf_width),A
	JR	_snprintf_fskip
_snprintf_fskip:
	INC	HL
	LD	A,(HL)
	OR	A
	JP	Z,_snprintf_done
	JR	_snprintf_fmt2

_snprintf_pct:
	LD	A,'%'
	CALL	_snprintf_putc
	INC	HL
	JP	_snprintf_loop

_snprintf_chr:
	PUSH	HL
	LD	H,0
	LD	L,C
	PUSH	BC
	PUSH	IX
	POP	DE
	ADD	HL,DE
	LD	A,(HL)
	CALL	_snprintf_putc
	POP	BC
	INC	C
	INC	C
	POP	HL
	INC	HL
	JP	_snprintf_loop

_snprintf_str:
	PUSH	HL
	LD	H,0
	LD	L,C
	PUSH	BC
	PUSH	IX
	POP	DE
	ADD	HL,DE
	LD	E,(HL)
	INC	HL
	LD	D,(HL)		; DE = string pointer

_snprintf_str_loop:
	LD	A,(DE)
	OR	A
	JR	Z,_snprintf_str_done
	CALL	_snprintf_putc
	INC	DE
	JR	_snprintf_str_loop

_snprintf_str_done:
	POP	BC
	INC	C
	INC	C
	POP	HL
	INC	HL
	JP	_snprintf_loop

_snprintf_dec:
	PUSH	HL
	LD	H,0
	LD	L,C
	PUSH	BC
	PUSH	IX
	POP	DE
	ADD	HL,DE
	LD	E,(HL)
	INC	HL
	LD	D,(HL)
	EX	DE,HL		; HL = value

	; Determine sign char (D = char, 0 = none)
	LD	D,0
	BIT	7,H
	JR	Z,_snprintf_dec_pos
	LD	D,'-'
	; Negate
	PUSH	DE
	EX	DE,HL
	LD	HL,0
	OR	A
	SBC	HL,DE
	POP	DE
	JR	_snprintf_dec_have_sign
_snprintf_dec_pos:
	LD	A,(_snprintf_plus)
	OR	A
	JR	Z,_snprintf_dec_chk_space2
	LD	D,'+'
	JR	_snprintf_dec_have_sign
_snprintf_dec_chk_space2:
	LD	A,(_snprintf_space)
	OR	A
	JR	Z,_snprintf_dec_have_sign
	LD	D,' '
_snprintf_dec_have_sign:
	; HL = positive value, D = sign char (or 0)
	; Count digits of HL (B = digit count, minimum 1).
	PUSH	HL
	PUSH	DE		; save sign in D
	LD	B,1
_snprintf_dec_count:
	LD	DE,10
	CALL	_sprintf_div16	; HL = HL/10, DE = remainder
	LD	A,H
	OR	L
	JR	Z,_snprintf_dec_count_done
	INC	B
	JR	_snprintf_dec_count
_snprintf_dec_count_done:
	POP	DE		; restore sign
	POP	HL		; restore value
	; Emit padding: pad = width - digit_count - (sign != 0)
	LD	A,(_snprintf_width)
	OR	A
	JR	Z,_snprintf_dec_skip_pad
	; A = width.  Subtract digit count (B) and sign (1 if D!=0).
	SUB	B
	JR	Z,_snprintf_dec_skip_pad
	JR	C,_snprintf_dec_skip_pad
	LD	E,A		; E = remaining padding budget
	LD	A,D
	OR	A
	JR	Z,_snprintf_dec_pad_loop1
	; sign present: subtract 1 more
	DEC	E
	JR	Z,_snprintf_dec_skip_pad
	JR	C,_snprintf_dec_skip_pad
_snprintf_dec_pad_loop1:
	; Decide pad char: '0' if zero-flag and no negative-sign-already-printed
	LD	A,(_snprintf_zero)
	OR	A
	JR	NZ,_snprintf_dec_zpad
	; Space-pad: emit sign AFTER padding
	PUSH	DE		; preserve sign in D, count in E
_snprintf_dec_spad_loop:
	PUSH	DE
	LD	A,' '
	CALL	_snprintf_putc
	POP	DE
	DEC	E
	JR	NZ,_snprintf_dec_spad_loop
	POP	DE
	JR	_snprintf_dec_emit_sign
_snprintf_dec_zpad:
	; Zero-pad: emit sign BEFORE padding
	LD	A,D
	OR	A
	JR	Z,_snprintf_dec_zpad_loop
	PUSH	DE
	LD	A,D
	CALL	_snprintf_putc
	POP	DE
	LD	D,0		; clear so emit_sign doesn't re-emit
_snprintf_dec_zpad_loop:
	PUSH	DE
	LD	A,'0'
	CALL	_snprintf_putc
	POP	DE
	DEC	E
	JR	NZ,_snprintf_dec_zpad_loop
_snprintf_dec_skip_pad:
_snprintf_dec_emit_sign:
	LD	A,D
	OR	A
	JR	Z,_snprintf_dec_emit
	PUSH	HL
	CALL	_snprintf_putc
	POP	HL
_snprintf_dec_emit:
	CALL	_snprintf_prt_dec
	POP	BC
	INC	C
	INC	C
	POP	HL
	INC	HL
	JP	_snprintf_loop

_snprintf_uns:
	PUSH	HL
	LD	H,0
	LD	L,C
	PUSH	BC
	PUSH	IX
	POP	DE
	ADD	HL,DE
	LD	E,(HL)
	INC	HL
	LD	D,(HL)
	EX	DE,HL
	CALL	_snprintf_prt_dec
	POP	BC
	INC	C
	INC	C
	POP	HL
	INC	HL
	JP	_snprintf_loop

_snprintf_hex_lc:
	XOR	A
	LD	(_snprintf_upper),A
	JR	_snprintf_hex
_snprintf_hex_uc:
	LD	A,1
	LD	(_snprintf_upper),A
_snprintf_hex:
	PUSH	HL
	LD	H,0
	LD	L,C
	PUSH	BC
	PUSH	IX
	POP	DE
	ADD	HL,DE
	LD	E,(HL)
	INC	HL
	LD	D,(HL)
	EX	DE,HL
	CALL	_snprintf_prt_hex
	POP	BC
	INC	C
	INC	C
	POP	HL
	INC	HL
	JP	_snprintf_loop

_snprintf_done:
	; Null terminate (if room)
	LD	HL,(_snprintf_max)
	LD	A,H
	OR	L
	JR	Z,_snprintf_ret	; size was 0, don't write null
	LD	HL,(_snprintf_out)
	LD	(HL),0

_snprintf_ret:
	; Return count (what would have been written)
	LD	HL,(_snprintf_cnt)
	POP	DE
	POP	BC
	POP	IX
	RET

; Internal: put character to buffer if room
_snprintf_putc:
	PUSH	HL
	PUSH	DE

	; Always increment count
	LD	HL,(_snprintf_cnt)
	INC	HL
	LD	(_snprintf_cnt),HL

	; Check if we have room (need 1 for char + 1 for null)
	LD	HL,(_snprintf_max)
	LD	DE,2
	OR	A
	SBC	HL,DE
	JR	C,_snprintf_putc_skip	; No room

	; Write character
	LD	HL,(_snprintf_out)
	LD	(HL),A
	INC	HL
	LD	(_snprintf_out),HL

	; Decrement remaining size
	LD	HL,(_snprintf_max)
	DEC	HL
	LD	(_snprintf_max),HL

_snprintf_putc_skip:
	POP	DE
	POP	HL
	RET

; Internal: print HL as decimal to buffer
_snprintf_prt_dec:
	PUSH	BC
	PUSH	DE
	LD	DE,10
	LD	B,0
_snprintf_dec_loop:
	CALL	_sprintf_div16	; Reuse sprintf's div16
	PUSH	DE
	INC	B
	LD	A,H
	OR	L
	JR	NZ,_snprintf_dec_loop
_snprintf_dec_out:
	POP	DE
	LD	A,E
	ADD	A,'0'
	CALL	_snprintf_putc
	DJNZ	_snprintf_dec_out
	POP	DE
	POP	BC
	RET

; Internal: print HL as 4-digit hex to buffer
_snprintf_prt_hex:
	PUSH	BC
	LD	A,H
	CALL	_snprintf_hex2
	LD	A,L
	CALL	_snprintf_hex2
	POP	BC
	RET

_snprintf_hex2:
	PUSH	AF
	RRCA
	RRCA
	RRCA
	RRCA
	CALL	_snprintf_hex1
	POP	AF
_snprintf_hex1:
	AND	0FH
	ADD	A,'0'
	CP	'9'+1
	JR	C,_snprintf_hex_out
	; Letter A-F: pick case from _snprintf_upper flag.
	; Note: um80 does case-insensitive char literals, so 'a' == 'A'.
	; Use explicit numeric constants to get the right offsets.
	PUSH	AF
	LD	A,(_snprintf_upper)
	OR	A
	JR	NZ,_snprintf_hex_uc1
	POP	AF
	ADD	A,39		; 'a'-'9'-1 = 97-57-1 = 39 (lowercase a-f)
	JR	_snprintf_hex_out
_snprintf_hex_uc1:
	POP	AF
	ADD	A,7		; 'A'-'9'-1 = 65-57-1 = 7 (uppercase A-F)
_snprintf_hex_out:
	JP	_snprintf_putc

	DSEG

; snprintf working storage
_snprintf_out:	DS	2	; Current output pointer
_snprintf_max:	DS	2	; Remaining space in buffer
_snprintf_cnt:	DS	2	; Total character count
_snprintf_upper: DS	1	; Hex case: 0 = lowercase, 1 = uppercase
_snprintf_plus:	DS	1	; '+' flag: prepend + on non-negative %d
_snprintf_space: DS	1	; ' ' flag: prepend ' ' on non-negative %d
_snprintf_width: DS	1	; field width (0 = no width)
_snprintf_zero:	DS	1	; '0' flag: zero-pad %d to width


; ============================================================
; lc_sprintf.mac
; ============================================================
	CSEG
; lc_sprintf.mac - sprintf




	CSEG

; ============================================================
; int sprintf(char *str, const char *fmt, ...)
; Format string into buffer
; Supports %d, %s, %c, %x, %%
; Returns: number of characters written (excluding null)
; ============================================================
	PUBLIC	_sprintf
	PUBLIC	_sprintf_out
	PUBLIC	_sprintf_cnt
	PUBLIC	_sprintf_putc
	PUBLIC	_sprintf_prt_dec
	PUBLIC	_sprintf_prt_hex
	PUBLIC	_sprintf_div16
_sprintf:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	PUSH	BC
	PUSH	DE

	; str is at IX+4, fmt at IX+6, first vararg at IX+8
	LD	E,(IX+4)
	LD	D,(IX+5)	; DE = output buffer pointer
	LD	(_sprintf_out),DE
	LD	L,(IX+6)
	LD	H,(IX+7)	; HL = format string pointer
	LD	C,8		; C = offset to next argument

	; Character counter
	LD	DE,0
	LD	(_sprintf_cnt),DE

_sprintf_loop:
	LD	A,(HL)
	OR	A
	JP	Z,_sprintf_done

	CP	'%'
	JR	Z,_sprintf_format

	; Regular character - output it
	CALL	_sprintf_putc
	INC	HL
	JR	_sprintf_loop

_sprintf_format:
	; Reset all per-conversion flags so they don't leak between
	; %-specifiers within the same format string.
	XOR	A
	LD	(_sprintf_width),A
	LD	(_sprintf_zero),A
	LD	(_sprintf_plus),A
	LD	(_sprintf_space),A
	LD	(_sprintf_left),A
	LD	(_sprintf_prec),A
	LD	(_sprintf_hasprec),A
	LD	(_sprintf_long),A
	INC	HL
	LD	A,(HL)
	OR	A
	JP	Z,_sprintf_done

	CP	'%'
	JR	Z,_sprintf_pct

_sprintf_fmt2:
	; Check for zero-padding flag (only at start)
	CP	'0'
	JR	NZ,_sprintf_chk_dig
	; Check if we haven't started parsing width yet
	LD	A,(_sprintf_width)
	OR	A
	JR	NZ,_sprintf_is_digit	; Already have width, this is a digit
	; This is the zero-padding flag
	LD	A,1
	LD	(_sprintf_zero),A
	INC	HL
	LD	A,(HL)
	OR	A
	JP	Z,_sprintf_done
	JR	_sprintf_fmt2

_sprintf_chk_dig:
	; Check for digit (1-9 first, then 0-9)
	CP	'1'
	JR	C,_sprintf_nodig
	CP	'9'+1
	JR	NC,_sprintf_nodig
_sprintf_is_digit:
	; Parse width digit: width = width * 10 + digit
	SUB	'0'
	PUSH	BC
	LD	B,A		; B = new digit
	LD	A,(_sprintf_width)
	; A = A * 10
	LD	C,A
	ADD	A,A		; A * 2
	ADD	A,A		; A * 4
	ADD	A,C		; A * 5
	ADD	A,A		; A * 10
	ADD	A,B		; A * 10 + digit
	LD	(_sprintf_width),A
	POP	BC
	INC	HL
	LD	A,(HL)
	OR	A
	JP	Z,_sprintf_done
	; Continue parsing - might be another digit
	CP	'0'
	JR	C,_sprintf_nodig
	CP	'9'+1
	JR	C,_sprintf_is_digit

_sprintf_nodig:
	; Capture '+', ' ', '-' flags; skip '#' (alternate form not yet).
	CP	'+'
	JR	Z,_sprintf_set_plus
	CP	' '
	JR	Z,_sprintf_set_space
	CP	'-'
	JR	Z,_sprintf_set_left
	CP	'#'
	JR	Z,_sprintf_fskip
	; Capture precision (".N"), skipping the '.' itself.
	CP	'.'
	JR	Z,_sprintf_set_hasprec
	; Length modifier 'l' marks the next conversion as long (32-bit).
	; 'h' and 'z' are accepted but treated as int (16-bit on Z80, or
	; 32-bit if --int=32 — same as plain).
	CP	'l'
	JR	Z,_sprintf_set_long
	CP	'h'
	JR	Z,_sprintf_fskip
	CP	'z'
	JR	Z,_sprintf_fskip
	; Now check format specifiers
	CP	's'
	JR	Z,_sprintf_str

	CP	'd'
	JR	Z,_sprintf_dec

	CP	'i'
	JR	Z,_sprintf_dec

	CP	'c'
	JR	Z,_sprintf_chr

	CP	'x'
	JR	Z,_sprintf_hex_lc

	CP	'X'
	JR	Z,_sprintf_hex_uc

	CP	'u'
	JR	Z,_sprintf_uns

	CP	'o'
	JR	Z,_sprintf_oct

	CP	'p'
	JR	Z,_sprintf_hex_lc	; %p is same as %x

	; Unknown format - skip
	INC	HL
	JP	_sprintf_loop

_sprintf_set_plus:
	LD	A,1
	LD	(_sprintf_plus),A
	JR	_sprintf_fskip
_sprintf_set_space:
	LD	A,1
	LD	(_sprintf_space),A
	JR	_sprintf_fskip
_sprintf_set_left:
	LD	A,1
	LD	(_sprintf_left),A
	JR	_sprintf_fskip
_sprintf_set_long:
	LD	A,1
	LD	(_sprintf_long),A
	JR	_sprintf_fskip
_sprintf_set_hasprec:
	; Mark that a precision was specified (so prec=0 is meaningful)
	; and parse the digits that follow into _sprintf_prec.
	LD	A,1
	LD	(_sprintf_hasprec),A
	INC	HL
	LD	A,(HL)
	OR	A
	JP	Z,_sprintf_done
_sprintf_set_precdig:
	CP	'0'
	JR	C,_sprintf_fmt2	; non-digit ends precision
	CP	'9'+1
	JR	NC,_sprintf_fmt2
	SUB	'0'
	LD	D,A
	LD	A,(_sprintf_prec)
	LD	E,A
	ADD	A,A		; *2
	ADD	A,A		; *4
	ADD	A,E		; *5
	ADD	A,A		; *10
	ADD	A,D
	LD	(_sprintf_prec),A
	INC	HL
	LD	A,(HL)
	OR	A
	JP	Z,_sprintf_done
	JR	_sprintf_set_precdig
	; fall through
_sprintf_fskip:
	INC	HL
	LD	A,(HL)
	OR	A
	JP	Z,_sprintf_done
	JR	_sprintf_fmt2

_sprintf_pct:
	; Output literal %
	LD	A,'%'
	CALL	_sprintf_putc
	INC	HL
	JP	_sprintf_loop

_sprintf_chr:
	; Output character
	PUSH	HL
	; Get argument
	LD	H,0
	LD	L,C
	PUSH	BC
	PUSH	IX
	POP	DE
	ADD	HL,DE		; HL = IX + offset
	LD	A,(HL)		; Get character
	CALL	_sprintf_putc
	POP	BC
	INC	C
	INC	C		; Advance to next arg
	POP	HL
	INC	HL
	JP	_sprintf_loop

_sprintf_str:
	; Output string with width / precision / left-justify.
	PUSH	HL
	LD	H,0
	LD	L,C
	PUSH	BC
	PUSH	IX
	POP	DE
	ADD	HL,DE		; HL = IX + offset
	LD	E,(HL)
	INC	HL
	LD	D,(HL)		; DE = string pointer

	; Count effective string length (capped by precision if any).
	; B = effective length (0..255).
	PUSH	DE
	LD	B,0
_sprintf_str_count:
	LD	A,(DE)
	OR	A
	JR	Z,_sprintf_str_count_done
	; If precision specified and we already emitted prec chars, stop.
	LD	A,(_sprintf_hasprec)
	OR	A
	JR	Z,_sprintf_str_count_continue
	LD	A,(_sprintf_prec)
	CP	B
	JR	Z,_sprintf_str_count_done
_sprintf_str_count_continue:
	INC	B
	INC	DE
	JR	NZ,_sprintf_str_count
_sprintf_str_count_done:
	POP	DE

	; Compute pad budget (width - effective length) into C.
	LD	C,0
	LD	A,(_sprintf_width)
	OR	A
	JR	Z,_sprintf_str_emit
	SUB	B
	JR	Z,_sprintf_str_emit
	JR	C,_sprintf_str_emit
	LD	C,A

	; Right-justify (default): emit padding first
	LD	A,(_sprintf_left)
	OR	A
	JR	NZ,_sprintf_str_emit
_sprintf_str_pad_left:
	PUSH	BC
	PUSH	DE
	LD	A,' '
	CALL	_sprintf_putc
	POP	DE
	POP	BC
	DEC	C
	JR	NZ,_sprintf_str_pad_left

_sprintf_str_emit:
	; Emit B bytes from DE
	LD	A,B
	OR	A
	JR	Z,_sprintf_str_after_emit
_sprintf_str_loop:
	PUSH	BC
	LD	A,(DE)
	CALL	_sprintf_putc
	POP	BC
	INC	DE
	DJNZ	_sprintf_str_loop

_sprintf_str_after_emit:
	; Left-justify trailing pad (if any).
	LD	A,C
	OR	A
	JR	Z,_sprintf_str_done
_sprintf_str_pad_right:
	PUSH	BC
	PUSH	DE
	LD	A,' '
	CALL	_sprintf_putc
	POP	DE
	POP	BC
	DEC	C
	JR	NZ,_sprintf_str_pad_right

_sprintf_str_done:
	POP	BC
	INC	C
	INC	C
	POP	HL
	INC	HL
	JP	_sprintf_loop

_sprintf_dec:
	; Output signed decimal with width / zero-pad / +/space flag support
	; If 'l' length modifier was seen, dispatch to the 32-bit path.
	LD	A,(_sprintf_long)
	OR	A
	JP	NZ,_sprintf_dec32

	PUSH	HL
	LD	H,0
	LD	L,C
	PUSH	BC
	PUSH	IX
	POP	DE
	ADD	HL,DE
	LD	E,(HL)
	INC	HL
	LD	D,(HL)		; DE = value
	EX	DE,HL		; HL = value

	; Determine sign char (D = char, 0 = none)
	LD	D,0
	BIT	7,H
	JR	Z,_sprintf_dec_npos
	LD	D,'-'
	; Negate
	PUSH	DE
	EX	DE,HL
	LD	HL,0
	OR	A
	SBC	HL,DE
	POP	DE
	JR	_sprintf_dec_have_sign
_sprintf_dec_npos:
	LD	A,(_sprintf_plus)
	OR	A
	JR	Z,_sprintf_dec_chk_space
	LD	D,'+'
	JR	_sprintf_dec_have_sign
_sprintf_dec_chk_space:
	LD	A,(_sprintf_space)
	OR	A
	JR	Z,_sprintf_dec_have_sign
	LD	D,' '
_sprintf_dec_have_sign:
	; HL = positive value, D = sign char (or 0).
	; Count digits of HL (B = digit count, minimum 1).
	PUSH	HL
	PUSH	DE
	LD	B,1
_sprintf_dec_count:
	LD	DE,10
	CALL	_sprintf_div16
	LD	A,H
	OR	L
	JR	Z,_sprintf_dec_count_done
	INC	B
	JR	_sprintf_dec_count
_sprintf_dec_count_done:
	POP	DE
	POP	HL
	; Compute total pad = width - digits - sign (clamped to 0).
	; Stash trailing pad in (_sprintf_trail).
	XOR	A
	LD	(_sprintf_trail),A
	LD	A,(_sprintf_width)
	OR	A
	JR	Z,_sprintf_dec_skip_pad
	SUB	B
	JR	Z,_sprintf_dec_skip_pad
	JR	C,_sprintf_dec_skip_pad
	LD	E,A
	LD	A,D
	OR	A
	JR	Z,_sprintf_dec_have_budget
	DEC	E
	JR	Z,_sprintf_dec_skip_pad
	JR	C,_sprintf_dec_skip_pad
_sprintf_dec_have_budget:
	; If left-justify: all pad is trailing, no leading pad.
	LD	A,(_sprintf_left)
	OR	A
	JR	Z,_sprintf_dec_pad_check
	LD	A,E
	LD	(_sprintf_trail),A
	JR	_sprintf_dec_skip_pad
_sprintf_dec_pad_check:
	; Right-justify: leading pad is space or zero per _sprintf_zero.
	LD	A,(_sprintf_zero)
	OR	A
	JR	NZ,_sprintf_dec_zpad
	; Space pad: emit sign AFTER padding
_sprintf_dec_spad_loop:
	PUSH	DE
	LD	A,' '
	CALL	_sprintf_putc
	POP	DE
	DEC	E
	JR	NZ,_sprintf_dec_spad_loop
	JR	_sprintf_dec_skip_pad
_sprintf_dec_zpad:
	; Zero pad: emit sign BEFORE padding
	LD	A,D
	OR	A
	JR	Z,_sprintf_dec_zpad_loop
	PUSH	DE
	LD	A,D
	CALL	_sprintf_putc
	POP	DE
	LD	D,0
_sprintf_dec_zpad_loop:
	PUSH	DE
	LD	A,'0'
	CALL	_sprintf_putc
	POP	DE
	DEC	E
	JR	NZ,_sprintf_dec_zpad_loop
_sprintf_dec_skip_pad:
	; Emit sign if not already
	LD	A,D
	OR	A
	JR	Z,_sprintf_dec_emit
	PUSH	HL
	CALL	_sprintf_putc
	POP	HL
_sprintf_dec_emit:
	; _sprintf_prt_dec re-applies width itself.  We've already handled
	; padding above, so zero the width so prt_dec just emits digits.
	XOR	A
	LD	(_sprintf_width),A
	CALL	_sprintf_prt_dec
	; Emit trailing pad (only set when left-justify is active)
	LD	A,(_sprintf_trail)
	OR	A
	JR	Z,_sprintf_dec_done
_sprintf_dec_trail_loop:
	PUSH	AF
	LD	A,' '
	CALL	_sprintf_putc
	POP	AF
	DEC	A
	JR	NZ,_sprintf_dec_trail_loop
_sprintf_dec_done:
	POP	BC
	INC	C
	INC	C
	POP	HL
	INC	HL
	JP	_sprintf_loop

_sprintf_uns:
	; Output unsigned decimal.  If 'l' length, dispatch to 32-bit path.
	LD	A,(_sprintf_long)
	OR	A
	JP	NZ,_sprintf_uns32
	PUSH	HL
	LD	H,0
	LD	L,C
	PUSH	BC
	PUSH	IX
	POP	DE
	ADD	HL,DE
	LD	E,(HL)
	INC	HL
	LD	D,(HL)
	EX	DE,HL		; HL = value
	CALL	_sprintf_prt_dec
	POP	BC
	INC	C
	INC	C
	POP	HL
	INC	HL
	JP	_sprintf_loop

_sprintf_uns32:
	; %lu — same as %ld but never emits a sign character.  We share
	; _sprintf_dec32's code by clearing the sign-detect bit: load
	; the value into _prt32_val, then jump straight into the digit
	; loop with sign char = 0 (or '+' / ' ' if those flags are set).
	PUSH	HL
	LD	H,0
	LD	L,C
	PUSH	BC
	PUSH	IX
	POP	DE
	ADD	HL,DE
	LD	E,(HL)
	INC	HL
	LD	D,(HL)
	LD	(_prt32_val),DE
	INC	HL
	LD	E,(HL)
	INC	HL
	LD	D,(HL)
	LD	(_prt32_val+2),DE
	; No sign for unsigned (but +/space flags still apply).
	LD	D,0
	LD	A,(_sprintf_plus)
	OR	A
	JR	Z,_sprintf_uns32_chk_space
	LD	D,'+'
	JR	_sprintf_uns32_join
_sprintf_uns32_chk_space:
	LD	A,(_sprintf_space)
	OR	A
	JR	Z,_sprintf_uns32_join
	LD	D,' '
_sprintf_uns32_join:
	JP	_sprintf_dec32_have_sign

_sprintf_oct:
	; Output unsigned octal.  'l' length → 32-bit path.
	LD	A,(_sprintf_long)
	OR	A
	JP	NZ,_sprintf_oct32
	PUSH	HL
	LD	H,0
	LD	L,C
	PUSH	BC
	PUSH	IX
	POP	DE
	ADD	HL,DE
	LD	E,(HL)
	INC	HL
	LD	D,(HL)
	EX	DE,HL		; HL = value
	CALL	_sprintf_prt_oct
	POP	BC
	INC	C
	INC	C
	POP	HL
	INC	HL
	JP	_sprintf_loop

_sprintf_oct32:
	; %lo — 32-bit unsigned octal, natural width (no padding yet).
	; Max 11 octal digits (0o37777777777 = 0xFFFFFFFF).
	PUSH	HL
	LD	H,0
	LD	L,C
	PUSH	BC
	PUSH	IX
	POP	DE
	ADD	HL,DE
	LD	E,(HL)
	INC	HL
	LD	D,(HL)
	LD	(_prt32_val),DE
	INC	HL
	LD	E,(HL)
	INC	HL
	LD	D,(HL)
	LD	(_prt32_val+2),DE

	; Divide by 8 repeatedly, pushing each remainder.  Stops when
	; value is 0 (B has the digit count; at least 1).
	LD	B,0
_sprintf_oct32_lp:
	; Low 3 bits of _prt32_val are the digit.
	LD	A,(_prt32_val)
	AND	7
	PUSH	AF
	INC	B
	; Shift right by 3: SRL _prt32_val+3, RR _prt32_val+2, RR +1, RR +0.
	; Three times.
	LD	A,3
_sprintf_oct32_shift:
	PUSH	AF
	LD	HL,_prt32_val+3
	SRL	(HL)
	DEC	HL
	RR	(HL)
	DEC	HL
	RR	(HL)
	DEC	HL
	RR	(HL)
	POP	AF
	DEC	A
	JR	NZ,_sprintf_oct32_shift
	; Done if value is 0
	LD	HL,(_prt32_val)
	LD	A,H
	OR	L
	JR	NZ,_sprintf_oct32_lp
	LD	HL,(_prt32_val+2)
	LD	A,H
	OR	L
	JR	NZ,_sprintf_oct32_lp

	; Emit B digits.
_sprintf_oct32_out:
	POP	AF
	ADD	A,'0'
	PUSH	BC
	CALL	_sprintf_putc
	POP	BC
	DJNZ	_sprintf_oct32_out

	POP	BC
	INC	C
	INC	C
	INC	C
	INC	C
	POP	HL
	INC	HL
	JP	_sprintf_loop

; %ld / %li handler — 32-bit signed decimal.
; Reuses width / zero-pad / sign / left-justify state set by the
; common parser.  Doesn't yet share the leading-pad code with the
; 16-bit path; precision and other niceties go through the same
; helpers.
_sprintf_dec32:
	PUSH	HL
	LD	H,0
	LD	L,C
	PUSH	BC
	PUSH	IX
	POP	DE
	ADD	HL,DE
	; Read 4-byte arg into _prt32_val
	LD	E,(HL)
	INC	HL
	LD	D,(HL)
	LD	(_prt32_val),DE	; low word
	INC	HL
	LD	E,(HL)
	INC	HL
	LD	D,(HL)
	LD	(_prt32_val+2),DE	; high word

	; Determine sign.  Bit 7 of high byte = sign.
	LD	A,(_prt32_val+3)
	LD	D,0
	BIT	7,A
	JR	Z,_sprintf_dec32_npos
	; Negate _prt32_val in place: 0 - val.  D gets clobbered, so set
	; the sign char in D *after* the negation completes.
	LD	HL,0
	LD	DE,(_prt32_val)
	OR	A
	SBC	HL,DE
	LD	(_prt32_val),HL
	LD	HL,0
	LD	DE,(_prt32_val+2)
	SBC	HL,DE
	LD	(_prt32_val+2),HL
	LD	D,'-'
	JR	_sprintf_dec32_have_sign
_sprintf_dec32_npos:
	LD	A,(_sprintf_plus)
	OR	A
	JR	Z,_sprintf_dec32_chk_space
	LD	D,'+'
	JR	_sprintf_dec32_have_sign
_sprintf_dec32_chk_space:
	LD	A,(_sprintf_space)
	OR	A
	JR	Z,_sprintf_dec32_have_sign
	LD	D,' '
_sprintf_dec32_have_sign:
	; Save sign char in a static so it survives the digit loop's
	; pushes (we'd lose it if it were on the stack underneath all
	; the AFs we're about to push).
	LD	A,D
	LD	(_sprintf_signch),A

	; Convert to decimal digits on stack via _div32_10.
	; Counts digits in B (start at 0).  _prt32_val gets consumed.
	LD	B,0
_sprintf_dec32_cvt:
	CALL	_div32_10
	PUSH	AF		; push remainder digit
	INC	B
	LD	HL,(_prt32_val)
	LD	A,H
	OR	L
	JR	NZ,_sprintf_dec32_cvt
	LD	HL,(_prt32_val+2)
	LD	A,H
	OR	L
	JR	NZ,_sprintf_dec32_cvt
	; Restore sign char from static into D.
	LD	A,(_sprintf_signch)
	LD	D,A
	; Stack now: B digits.  Compute pad and emit per flags.
	XOR	A
	LD	(_sprintf_trail),A
	LD	A,(_sprintf_width)
	OR	A
	JR	Z,_sprintf_dec32_skip_pad
	SUB	B
	JR	Z,_sprintf_dec32_skip_pad
	JR	C,_sprintf_dec32_skip_pad
	LD	E,A
	LD	A,D
	OR	A
	JR	Z,_sprintf_dec32_have_budget
	DEC	E
	JR	Z,_sprintf_dec32_skip_pad
	JR	C,_sprintf_dec32_skip_pad
_sprintf_dec32_have_budget:
	LD	A,(_sprintf_left)
	OR	A
	JR	Z,_sprintf_dec32_pad_check
	LD	A,E
	LD	(_sprintf_trail),A
	JR	_sprintf_dec32_skip_pad
_sprintf_dec32_pad_check:
	LD	A,(_sprintf_zero)
	OR	A
	JR	NZ,_sprintf_dec32_zpad
_sprintf_dec32_spad_loop:
	PUSH	BC
	PUSH	DE
	LD	A,' '
	CALL	_sprintf_putc
	POP	DE
	POP	BC
	DEC	E
	JR	NZ,_sprintf_dec32_spad_loop
	JR	_sprintf_dec32_skip_pad
_sprintf_dec32_zpad:
	LD	A,D
	OR	A
	JR	Z,_sprintf_dec32_zpad_loop
	PUSH	BC
	PUSH	DE
	LD	A,D
	CALL	_sprintf_putc
	POP	DE
	POP	BC
	LD	D,0
_sprintf_dec32_zpad_loop:
	PUSH	BC
	PUSH	DE
	LD	A,'0'
	CALL	_sprintf_putc
	POP	DE
	POP	BC
	DEC	E
	JR	NZ,_sprintf_dec32_zpad_loop
_sprintf_dec32_skip_pad:
	LD	A,D
	OR	A
	JR	Z,_sprintf_dec32_emit
	PUSH	BC
	CALL	_sprintf_putc
	POP	BC
_sprintf_dec32_emit:
	; Pop and print B digits.
_sprintf_dec32_out:
	POP	AF
	ADD	A,'0'
	PUSH	BC
	CALL	_sprintf_putc
	POP	BC
	DJNZ	_sprintf_dec32_out
	; Trailing pad
	LD	A,(_sprintf_trail)
	OR	A
	JR	Z,_sprintf_dec32_done
_sprintf_dec32_trail:
	PUSH	AF
	LD	A,' '
	CALL	_sprintf_putc
	POP	AF
	DEC	A
	JR	NZ,_sprintf_dec32_trail
_sprintf_dec32_done:
	POP	BC
	; Long arg consumes 4 stack bytes (advance C by 4).
	INC	C
	INC	C
	INC	C
	INC	C
	POP	HL
	INC	HL
	JP	_sprintf_loop

_sprintf_hex_lc:
	; Output hex (lowercase, %x)
	XOR	A
	LD	(_sprintf_upper),A
	JR	_sprintf_hex_common

_sprintf_hex_uc:
	; Output hex (uppercase, %X)
	LD	A,1
	LD	(_sprintf_upper),A
_sprintf_hex_common:
	; If 'l' length, dispatch to 32-bit hex (8 digits).
	LD	A,(_sprintf_long)
	OR	A
	JP	NZ,_sprintf_hex32
	PUSH	HL
	LD	H,0
	LD	L,C
	PUSH	BC
	PUSH	IX
	POP	DE
	ADD	HL,DE
	LD	E,(HL)
	INC	HL
	LD	D,(HL)
	EX	DE,HL
	CALL	_sprintf_prt_hex
	POP	BC
	INC	C
	INC	C
	POP	HL
	INC	HL
	JP	_sprintf_loop

_sprintf_hex32:
	; %lx / %lX — 32-bit hex with leading-zero suppression, width
	; padding, and left-justify.  The value is emitted into an
	; 8-char DSEG buffer first, then we skip leading zeros and
	; pad / emit.
	PUSH	HL
	LD	H,0
	LD	L,C
	PUSH	BC
	PUSH	IX
	POP	DE
	ADD	HL,DE
	; Read 4 bytes into _prt32_val.
	LD	E,(HL)
	INC	HL
	LD	D,(HL)
	LD	(_prt32_val),DE
	INC	HL
	LD	E,(HL)
	INC	HL
	LD	D,(HL)
	LD	(_prt32_val+2),DE

	; Fill _sprintf_hexbuf with 8 hex digits, high to low.
	LD	HL,_sprintf_hexbuf
	LD	A,(_prt32_val+3)
	CALL	_sprintf_hex_to_buf
	LD	A,(_prt32_val+2)
	CALL	_sprintf_hex_to_buf
	LD	A,(_prt32_val+1)
	CALL	_sprintf_hex_to_buf
	LD	A,(_prt32_val)
	CALL	_sprintf_hex_to_buf

	; Find first non-zero digit.  If all zero, keep the last digit.
	; We count "skipped leading zeros" in C (starts at 0), walking HL
	; through the buffer up to 7 times.  On exit B = natural digit
	; count = 8 - skipped.
	LD	HL,_sprintf_hexbuf
	LD	C,0		; skipped count
	LD	B,7		; max skip
_sprintf_hex32_strip:
	LD	A,(HL)
	CP	'0'
	JR	NZ,_sprintf_hex32_got
	INC	HL
	INC	C
	DJNZ	_sprintf_hex32_strip
_sprintf_hex32_got:
	LD	A,8
	SUB	C
	LD	B,A		; B = natural digit count

	; Compute pad budget and trailing pad, applying flags.
	XOR	A
	LD	(_sprintf_trail),A
	LD	A,(_sprintf_width)
	OR	A
	JR	Z,_sprintf_hex32_emit
	SUB	B
	JR	Z,_sprintf_hex32_emit
	JR	C,_sprintf_hex32_emit
	; A = pad count.  If left-justify, put it in _sprintf_trail.
	LD	E,A
	LD	A,(_sprintf_left)
	OR	A
	JR	Z,_sprintf_hex32_lead_pad
	LD	A,E
	LD	(_sprintf_trail),A
	JR	_sprintf_hex32_emit
_sprintf_hex32_lead_pad:
	; Right-justify: emit leading pad.  Char is ' ' or '0'.
	LD	A,(_sprintf_zero)
	OR	A
	LD	A,' '
	JR	Z,_sprintf_hex32_pad_lp
	LD	A,'0'
_sprintf_hex32_pad_lp:
	PUSH	BC
	PUSH	DE
	PUSH	HL
	PUSH	AF
	CALL	_sprintf_putc
	POP	AF
	POP	HL
	POP	DE
	POP	BC
	DEC	E
	JR	NZ,_sprintf_hex32_pad_lp

_sprintf_hex32_emit:
	; Emit B digits from HL
	LD	A,(HL)
	PUSH	BC
	PUSH	HL
	CALL	_sprintf_putc
	POP	HL
	POP	BC
	INC	HL
	DJNZ	_sprintf_hex32_emit

	; Trailing pad for left-justify.
	LD	A,(_sprintf_trail)
	OR	A
	JR	Z,_sprintf_hex32_done
_sprintf_hex32_trail:
	PUSH	AF
	LD	A,' '
	CALL	_sprintf_putc
	POP	AF
	DEC	A
	JR	NZ,_sprintf_hex32_trail

_sprintf_hex32_done:
	POP	BC
	; Long arg = 4 bytes.
	INC	C
	INC	C
	INC	C
	INC	C
	POP	HL
	INC	HL
	JP	_sprintf_loop

; Helper: split byte in A into two hex chars, write to (HL), HL+=2.
_sprintf_hex_to_buf:
	PUSH	AF
	RRCA
	RRCA
	RRCA
	RRCA
	CALL	_sprintf_hexbuf1
	POP	AF
	; fall through
_sprintf_hexbuf1:
	PUSH	AF
	AND	0FH
	ADD	A,'0'
	CP	'9'+1
	JR	C,_sprintf_hexbuf_store
	PUSH	AF
	LD	A,(_sprintf_upper)
	OR	A
	JR	NZ,_sprintf_hexbuf_uc
	POP	AF
	ADD	A,39		; lowercase a..f
	JR	_sprintf_hexbuf_store
_sprintf_hexbuf_uc:
	POP	AF
	ADD	A,7		; uppercase A..F
_sprintf_hexbuf_store:
	LD	(HL),A
	INC	HL
	POP	AF
	RET

_sprintf_done:
	; Null terminate
	LD	HL,(_sprintf_out)
	LD	(HL),0

	; Return count
	LD	HL,(_sprintf_cnt)
	POP	DE
	POP	BC
	POP	IX
	RET

; Internal: put character to buffer
_sprintf_putc:
	PUSH	HL
	LD	HL,(_sprintf_out)
	LD	(HL),A
	INC	HL
	LD	(_sprintf_out),HL
	LD	HL,(_sprintf_cnt)
	INC	HL
	LD	(_sprintf_cnt),HL
	POP	HL
	RET

; Internal: print HL as decimal to buffer with optional width padding
_sprintf_prt_dec:
	PUSH	BC
	PUSH	DE

	; Convert to decimal digits on stack
	LD	DE,10
	LD	B,0		; Digit counter

_sprintf_dec_loop:
	CALL	_sprintf_div16
	PUSH	DE		; Push digit
	INC	B
	LD	A,H
	OR	L
	JR	NZ,_sprintf_dec_loop

	; B = digit count, check if we need padding
	LD	A,(_sprintf_width)
	OR	A
	JR	Z,_sprintf_dec_out	; No width specified

	; Calculate padding needed: width - digit_count
	SUB	B		; A = width - digit_count
	JR	Z,_sprintf_dec_out	; No padding needed
	JR	C,_sprintf_dec_out	; Digit count > width, no padding

	; A = number of padding chars needed
	PUSH	BC		; Save digit count
	LD	B,A		; B = padding count
	LD	A,(_sprintf_zero)
	OR	A
	LD	A,' '		; Default pad with space
	JR	Z,_sprintf_pad_lp
	LD	A,'0'		; Pad with zero

_sprintf_pad_lp:
	CALL	_sprintf_putc
	DJNZ	_sprintf_pad_lp
	POP	BC		; Restore digit count

	; Pop and output digits
_sprintf_dec_out:
	POP	DE
	LD	A,E
	ADD	A,'0'
	CALL	_sprintf_putc
	DJNZ	_sprintf_dec_out

	POP	DE
	POP	BC
	RET

; Simple division: HL = HL / 10, DE = HL % 10
_sprintf_div16:
	PUSH	BC
	LD	BC,0		; Result

_sprintf_div_lp:
	LD	A,H
	OR	A
	JR	NZ,_sprintf_div_sub
	LD	A,L
	CP	10
	JR	C,_sprintf_div_dn

_sprintf_div_sub:
	LD	A,L
	SUB	10
	LD	L,A
	LD	A,H
	SBC	A,0
	LD	H,A
	INC	BC
	JR	_sprintf_div_lp

_sprintf_div_dn:
	LD	E,L
	LD	D,0
	LD	H,B
	LD	L,C
	POP	BC
	RET

; Internal: print HL as unsigned octal to buffer.  Up to 6 octal digits
; for a 16-bit value.  Counts and emits in reverse via the stack.
_sprintf_prt_oct:
	PUSH	BC
	PUSH	DE
	LD	B,0		; digit counter
_sprintf_oct_lp:
	LD	A,L
	AND	7
	PUSH	AF		; push digit (low 3 bits)
	INC	B
	; HL >>= 3
	SRL	H
	RR	L
	SRL	H
	RR	L
	SRL	H
	RR	L
	LD	A,H
	OR	L
	JR	NZ,_sprintf_oct_lp
_sprintf_oct_out:
	POP	AF
	ADD	A,'0'
	CALL	_sprintf_putc
	DJNZ	_sprintf_oct_out
	POP	DE
	POP	BC
	RET

; Internal: print HL as 4-digit hex to buffer
_sprintf_prt_hex:
	PUSH	BC
	LD	A,H
	CALL	_sprintf_hex2
	LD	A,L
	CALL	_sprintf_hex2
	POP	BC
	RET

_sprintf_hex2:
	PUSH	AF
	RRCA
	RRCA
	RRCA
	RRCA
	CALL	_sprintf_hex1
	POP	AF
_sprintf_hex1:
	AND	0FH
	ADD	A,'0'
	CP	'9'+1
	JR	C,_sprintf_hex_out
	; Letter A-F: pick case from _sprintf_upper flag.
	; Note: um80 does case-insensitive char literals, so 'a' == 'A'.
	; Use explicit numeric constants to get the right offsets.
	PUSH	AF
	LD	A,(_sprintf_upper)
	OR	A
	JR	NZ,_sprintf_hex_uc1
	POP	AF
	ADD	A,39		; 'a'-'9'-1 = 97-57-1 = 39 (lowercase a-f)
	JR	_sprintf_hex_out
_sprintf_hex_uc1:
	POP	AF
	ADD	A,7		; 'A'-'9'-1 = 65-57-1 = 7 (uppercase A-F)
_sprintf_hex_out:
	JP	_sprintf_putc


	DSEG
; sprintf working storage
_sprintf_out:	DS	2	; Current output pointer
_sprintf_cnt:	DS	2	; Character count
_sprintf_width:	DS	1	; Field width (0 = no width)
_sprintf_zero:	DS	1	; Zero-padding flag
_sprintf_upper:	DS	1	; Hex case: 0 = lowercase, 1 = uppercase
_sprintf_plus:	DS	1	; '+' flag for non-negative %d
_sprintf_space:	DS	1	; ' ' flag for non-negative %d
_sprintf_left:	DS	1	; '-' flag: left-justify
_sprintf_prec:	DS	1	; precision count (max 255)
_sprintf_hasprec: DS	1	; 1 if precision was specified
_sprintf_trail:	DS	1	; trailing-pad count (left-justify)
_sprintf_long:	DS	1	; 1 if 'l' length modifier was seen
_sprintf_signch: DS	1	; saved sign char during 32-bit dec emit
_sprintf_hexbuf: DS	8	; 8-digit hex scratch for %lx/%lX


; ============================================================
; lc_sqrt.mac
; ============================================================
	CSEG
; lc_sqrt.mac - sqrt, sqrtf, sqrtl


	EXTRN	__fadd
	EXTRN	__fdiv
	EXTRN	__tmp32

	CSEG

; ============================================================
; sqrt(x) - Square root using Newton-Raphson
; x_{n+1} = (x_n + S/x_n) / 2
; ============================================================
	PUBLIC	_sqrt
	PUBLIC	_sqrtf
	PUBLIC	_sqrtl
_sqrt:
_sqrtf:
_sqrtl:
	PUSH	IX
	PUSH	BC
	LD	IX,0
	ADD	IX,SP

	CALL	_math_getarg	; x in DEHL

	; Check for zero or negative
	LD	A,D
	AND	7FH
	OR	E
	OR	H
	OR	L
	JR	Z,_sqrt_zero
	BIT	7,D
	JR	NZ,_sqrt_neg	; Negative -> return 0

	; Save x
	LD	(_sqrt_x),HL
	LD	(_sqrt_x+2),DE

	; Initial guess: halve the biased exponent
	; new_exp = (exp - 127) / 2 + 127
	; Extract 8-bit exponent
	LD	A,D		; D = SEEEEEEE
	AND	7FH		; A = 0EEEEEEE (upper 7 exp bits)
	ADD	A,A		; A = EEEEEEE0
	LD	B,A
	LD	A,E		; E = EMMMMMMM
	RLCA			; bit 0 = exp low bit
	AND	1
	OR	B		; A = full 8-bit exponent

	; Halve the unbiased exponent
	SUB	127		; A = exp - 127 (signed)
	SRA	A		; A = (exp-127)/2 (arithmetic shift right)
	ADD	A,127		; A = new biased exponent

	; Reconstruct float with new exponent, mantissa=1.0
	; D = sign(0) | exp[7:1], E = exp[0] | 0000000
	LD	B,A		; Save exponent
	SRL	A		; A = exp >> 1 = exp[7:1]
	LD	D,A		; D = 0 exp[7:1]
	LD	A,B
	AND	1		; exp[0]
	RRCA			; Rotate to bit 7
	LD	E,A		; E = exp[0] 0000000
	LD	H,0
	LD	L,0
	LD	(_sqrt_guess),HL
	LD	(_sqrt_guess+2),DE

_sqrt_iterate:
	; Newton-Raphson: 8 iterations
	LD	B,8

_sqrt_loop:
	PUSH	BC

	; Compute x / guess
	LD	HL,(_sqrt_x)
	LD	DE,(_sqrt_x+2)
	LD	A,(_sqrt_guess)
	LD	(__tmp32),A
	LD	A,(_sqrt_guess+1)
	LD	(__tmp32+1),A
	LD	A,(_sqrt_guess+2)
	LD	(__tmp32+2),A
	LD	A,(_sqrt_guess+3)
	LD	(__tmp32+3),A
	CALL	__fdiv		; DEHL = x / guess

	; Add guess: DEHL = x/guess + guess
	LD	A,(_sqrt_guess)
	LD	(__tmp32),A
	LD	A,(_sqrt_guess+1)
	LD	(__tmp32+1),A
	LD	A,(_sqrt_guess+2)
	LD	(__tmp32+2),A
	LD	A,(_sqrt_guess+3)
	LD	(__tmp32+3),A
	CALL	__fadd		; DEHL = (x/guess + guess)

	; Divide by 2: decrement IEEE 754 exponent by 1
	; Subtract 0x00800000 from DEHL (exponent bit 0 is E bit 7)
	OR	A		; Clear carry
	LD	A,E
	SUB	80H
	LD	E,A
	LD	A,D
	SBC	A,0		; Borrow into upper exponent bits
	LD	D,A

	; Update guess
	LD	(_sqrt_guess),HL
	LD	(_sqrt_guess+2),DE

	POP	BC
	DJNZ	_sqrt_loop

	; Result in DEHL
	LD	HL,(_sqrt_guess)
	LD	DE,(_sqrt_guess+2)
	JR	_sqrt_done

_sqrt_zero:
_sqrt_neg:
	LD	HL,0
	LD	DE,0

_sqrt_done:
	POP	BC
	POP	IX
	RET

	DSEG

_sqrt_x:	DS	4
_sqrt_guess:	DS	4


; ============================================================
; lc_stdlib.mac
; ============================================================
	CSEG
; lc_stdlib.mac - standard library functions



	EXTRN	__mul16
	EXTRN	__sdiv16
	EXTRN	__smod16
	EXTRN	__sdiv32
	EXTRN	__smod32
	EXTRN	__tmp32

	CSEG

; ============================================================
; void exit(int status)
; Calls atexit handlers then terminates
; ============================================================
	PUBLIC	_exit
_exit:
	; Call atexit handlers in reverse order
	LD	A,(_atexit_cnt)
	OR	A
	JR	Z,_exit_done

_exit_loop:
	DEC	A
	LD	(_atexit_cnt),A
	; Get handler address: _atexit_tab + A*2
	LD	L,A
	LD	H,0
	ADD	HL,HL		; HL = A*2
	LD	DE,_atexit_tab
	ADD	HL,DE		; HL = address of handler pointer
	LD	E,(HL)
	INC	HL
	LD	D,(HL)		; DE = handler address
	; Call handler
	PUSH	AF
	LD	HL,_exit_loop_ret
	PUSH	HL		; Push return address
	PUSH	DE		; Push handler address
	RET			; "Call" the handler
_exit_loop_ret:
	POP	AF
	OR	A
	JR	NZ,_exit_loop

_exit_done:
	; Return to CP/M (warm boot)
	JP	0

; ============================================================
; void abort(void)
; Abnormal program termination
; ============================================================
	PUBLIC	_abort
_abort:
	; Print abort message
	LD	DE,_abort_msg
	LD	C,PRTSTR
	CALL	BDOS
	; Exit
	JP	0

; ============================================================
; int atexit(void (*func)(void))
; Register function to be called at exit
; Returns 0 on success, non-zero on failure
; ============================================================
	PUBLIC	_atexit
_atexit:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP

	; Check if we have room
	LD	A,(_atexit_cnt)
	CP	4		; Max 4 handlers
	JR	NC,_atexit_fail

	; Get handler address: _atexit_tab + cnt*2
	LD	L,A
	LD	H,0
	ADD	HL,HL
	LD	DE,_atexit_tab
	ADD	HL,DE		; HL = slot address

	; Store function pointer
	LD	E,(IX+4)
	LD	D,(IX+5)
	LD	(HL),E
	INC	HL
	LD	(HL),D

	; Increment count
	LD	A,(_atexit_cnt)
	INC	A
	LD	(_atexit_cnt),A

	; Return success
	LD	HL,0
	POP	IX
	RET

_atexit_fail:
	LD	HL,1
	POP	IX
	RET

; ============================================================
; int rand(void)
; Returns pseudo-random number 0 to RAND_MAX (32767)
; Uses 16-bit linear congruential generator
; seed = (seed * 25173 + 13849) & 0x7FFF
; ============================================================
	PUBLIC	_rand
	EXTRN	__mul16
_rand:
	LD	HL,(_rand_seed)
	LD	DE,25173
	CALL	__mul16		; HL = seed * 25173
	LD	DE,13849
	ADD	HL,DE		; HL = seed * 25173 + 13849
	LD	A,H
	AND	7FH		; Mask to 0-32767
	LD	H,A
	LD	(_rand_seed),HL
	RET

; ============================================================
; void srand(unsigned int seed)
; Initialize random seed
; ============================================================
	PUBLIC	_srand
_srand:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	LD	L,(IX+4)
	LD	H,(IX+5)
	LD	(_rand_seed),HL
	POP	IX
	RET

; ============================================================
; int abs(int n)
; Return absolute value
; ============================================================
	PUBLIC	_abs
_abs:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	LD	L,(IX+4)
	LD	H,(IX+5)
	BIT	7,H
	JR	Z,_abs_done
	; Negate
	LD	DE,0
	EX	DE,HL
	OR	A
	SBC	HL,DE
_abs_done:
	POP	IX
	RET

; ============================================================
; long labs(long n)
; Return absolute value of long
; Returns in DEHL
; ============================================================
	PUBLIC	_labs
_labs:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	LD	L,(IX+4)
	LD	H,(IX+5)
	LD	E,(IX+6)
	LD	D,(IX+7)	; DEHL = n
	BIT	7,D
	JR	Z,_labs_done
	; Negate DEHL
	PUSH	BC
	LD	BC,0
	LD	A,C
	SUB	L
	LD	L,A
	LD	A,C
	SBC	A,H
	LD	H,A
	LD	A,C
	SBC	A,E
	LD	E,A
	LD	A,C
	SBC	A,D
	LD	D,A
	POP	BC
_labs_done:
	POP	IX
	RET

; ============================================================
; div_t div(int numer, int denom)
; Compute quotient and remainder
; Returns: pointer to static div_t in HL
; (div_t.quot at _div_result, div_t.rem at _div_result+2)
; ============================================================
	PUBLIC	_div
	EXTRN	__sdiv16
	EXTRN	__smod16
_div:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	PUSH	BC

	LD	L,(IX+4)	; HL = numer
	LD	H,(IX+5)
	LD	E,(IX+6)	; DE = denom
	LD	D,(IX+7)

	; Compute quotient
	PUSH	HL
	PUSH	DE
	CALL	__sdiv16
	LD	(_div_result),HL
	POP	DE
	POP	HL

	; Compute remainder
	CALL	__smod16
	LD	(_div_result+2),HL

	LD	HL,_div_result
	POP	BC
	POP	IX
	RET

; ============================================================
; ldiv_t ldiv(long numer, long denom)
; Compute quotient and remainder for long
; Returns: pointer to static ldiv_t in HL
; (ldiv_t.quot at _ldiv_result, ldiv_t.rem at _ldiv_result+4)
; Runtime uses: DEHL / __tmp32 for 32-bit ops
; ============================================================
	PUBLIC	_ldiv
	EXTRN	__sdiv32
	EXTRN	__smod32
	EXTRN	__tmp32
_ldiv:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	PUSH	BC

	; Store denom in __tmp32
	LD	A,(IX+8)
	LD	(__tmp32),A
	LD	A,(IX+9)
	LD	(__tmp32+1),A
	LD	A,(IX+10)
	LD	(__tmp32+2),A
	LD	A,(IX+11)
	LD	(__tmp32+3),A

	; Load numer into DEHL
	LD	L,(IX+4)
	LD	H,(IX+5)
	LD	E,(IX+6)
	LD	D,(IX+7)

	; Save numer for mod computation
	PUSH	DE
	PUSH	HL

	; Compute quotient: DEHL / __tmp32
	CALL	__sdiv32
	LD	(_ldiv_result),HL
	LD	(_ldiv_result+2),DE

	; Restore numer
	POP	HL
	POP	DE

	; Compute remainder: DEHL % __tmp32 (denom still in __tmp32)
	CALL	__smod32
	LD	(_ldiv_result+4),HL
	LD	(_ldiv_result+6),DE

	LD	HL,_ldiv_result
	POP	BC
	POP	IX
	RET

	DSEG

; atexit handler table (max 4 handlers)
_atexit_cnt:	DB	0	; Number of registered handlers
_atexit_tab:	DS	8	; 4 function pointers (2 bytes each)

; abort message
_abort_msg:	DB	'Aborted',0DH,0AH,'$'

; div/ldiv result storage
_div_result:	DS	4	; div_t: quot (2), rem (2)
_ldiv_result:	DS	8	; ldiv_t: quot (4), rem (4)

; rand seed
_rand_seed:	DW	1	; Default seed = 1


; ============================================================
; lc_string.mac
; ============================================================
	CSEG
; lc_string.mac - string functions


	CSEG

; ============================================================
; size_t strlen(const char *s)
; ============================================================
	PUBLIC	_strlen
_strlen:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP

	LD	L,(IX+4)
	LD	H,(IX+5)	; HL = string pointer
	LD	BC,0		; Counter

_strlen_loop:
	LD	A,(HL)
	OR	A
	JR	Z,_strlen_done
	INC	HL
	INC	BC
	JR	_strlen_loop

_strlen_done:
	LD	H,B
	LD	L,C
	POP	IX
	RET


; ============================================================
; char *strcpy(char *dest, const char *src)
; Copy string from src to dest
; Returns: dest
; ============================================================
	PUBLIC	_strcpy
_strcpy:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP

	LD	E,(IX+4)	; DE = dest
	LD	D,(IX+5)
	LD	L,(IX+6)	; HL = src
	LD	H,(IX+7)

_strcpy_loop:
	LD	A,(HL)		; Get source char
	LD	(DE),A		; Store to dest
	OR	A
	JR	Z,_strcpy_done	; Done if null
	INC	HL
	INC	DE
	JR	_strcpy_loop

_strcpy_done:
	LD	L,(IX+4)	; Return dest
	LD	H,(IX+5)
	POP	IX
	RET

; ============================================================
; char *strncpy(char *dest, const char *src, size_t n)
; Copy at most n chars from src to dest
; Returns: dest
; ============================================================
	PUBLIC	_strncpy
_strncpy:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	PUSH	BC

	LD	E,(IX+4)	; DE = dest
	LD	D,(IX+5)
	LD	L,(IX+6)	; HL = src
	LD	H,(IX+7)
	LD	C,(IX+8)	; BC = n
	LD	B,(IX+9)

_strncpy_loop:
	LD	A,B		; Check if n == 0
	OR	C
	JR	Z,_strncpy_done

	LD	A,(HL)		; Get source char
	LD	(DE),A		; Store to dest
	DEC	BC
	OR	A
	JR	Z,_strncpy_pad	; Null found, pad with zeros
	INC	HL
	INC	DE
	JR	_strncpy_loop

_strncpy_pad:
	; Pad remaining with zeros
	LD	A,B
	OR	C
	JR	Z,_strncpy_done
	INC	DE
	XOR	A
	LD	(DE),A
	DEC	BC
	JR	_strncpy_pad

_strncpy_done:
	LD	L,(IX+4)	; Return dest
	LD	H,(IX+5)
	POP	BC
	POP	IX
	RET

; ============================================================
; int strcmp(const char *s1, const char *s2)
; Compare two strings
; Returns: <0 if s1<s2, 0 if s1==s2, >0 if s1>s2
; ============================================================
	PUBLIC	_strcmp
_strcmp:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP

	LD	E,(IX+4)	; DE = s1
	LD	D,(IX+5)
	LD	L,(IX+6)	; HL = s2
	LD	H,(IX+7)

_strcmp_loop:
	LD	A,(DE)		; Get s1 char
	LD	B,(HL)		; Get s2 char
	SUB	B		; Compare
	JR	NZ,_strcmp_diff	; Different

	LD	A,(DE)		; Check if null
	OR	A
	JR	Z,_strcmp_equal	; Both null, equal

	INC	DE
	INC	HL
	JR	_strcmp_loop

_strcmp_equal:
	LD	HL,0
	POP	IX
	RET

_strcmp_diff:
	; A contains s1[i] - s2[i]
	; Sign-extend to HL
	LD	L,A
	RLA			; Sign to carry
	SBC	A,A		; A = 0xFF if neg, 0 if pos
	LD	H,A
	POP	IX
	RET

; ============================================================
; int strncmp(const char *s1, const char *s2, size_t n)
; Compare at most n chars of two strings
; ============================================================
	PUBLIC	_strncmp
_strncmp:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	PUSH	BC

	LD	E,(IX+4)	; DE = s1
	LD	D,(IX+5)
	LD	L,(IX+6)	; HL = s2
	LD	H,(IX+7)
	LD	C,(IX+8)	; BC = n
	LD	B,(IX+9)

_strncmp_loop:
	LD	A,B		; Check if n == 0
	OR	C
	JR	Z,_strncmp_equal

	LD	A,(DE)		; Get s1 char
	PUSH	HL
	LD	H,(HL)		; H = s2 char
	SUB	H		; Compare
	POP	HL
	JR	NZ,_strncmp_diff

	LD	A,(DE)		; Check if null
	OR	A
	JR	Z,_strncmp_equal

	DEC	BC
	INC	DE
	INC	HL
	JR	_strncmp_loop

_strncmp_equal:
	LD	HL,0
	POP	BC
	POP	IX
	RET

_strncmp_diff:
	LD	L,A
	RLA
	SBC	A,A
	LD	H,A
	POP	BC
	POP	IX
	RET

; ============================================================
; char *strcat(char *dest, const char *src)
; Append src to dest
; Returns: dest
; ============================================================
	PUBLIC	_strcat
_strcat:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP

	LD	E,(IX+4)	; DE = dest
	LD	D,(IX+5)

	; Find end of dest
_strcat_find:
	LD	A,(DE)
	OR	A
	JR	Z,_strcat_copy
	INC	DE
	JR	_strcat_find

_strcat_copy:
	LD	L,(IX+6)	; HL = src
	LD	H,(IX+7)

_strcat_loop:
	LD	A,(HL)
	LD	(DE),A
	OR	A
	JR	Z,_strcat_done
	INC	HL
	INC	DE
	JR	_strcat_loop

_strcat_done:
	LD	L,(IX+4)	; Return dest
	LD	H,(IX+5)
	POP	IX
	RET

; ============================================================
; char *strchr(const char *s, int c)
; Find first occurrence of c in s
; Returns: pointer to char, or NULL if not found
; ============================================================
	PUBLIC	_strchr
_strchr:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP

	LD	L,(IX+4)	; HL = s
	LD	H,(IX+5)
	LD	C,(IX+6)	; C = char to find

_strchr_loop:
	LD	A,(HL)
	CP	C
	JR	Z,_strchr_found	; Found it
	OR	A
	JR	Z,_strchr_notfound	; End of string
	INC	HL
	JR	_strchr_loop

_strchr_found:
	POP	IX
	RET			; HL already points to char

_strchr_notfound:
	LD	HL,0		; Return NULL
	POP	IX
	RET

; ============================================================
; void *memcpy(void *dest, const void *src, size_t n)
; Copy n bytes from src to dest

; Additional string functions
; ============================================================
; char *strrchr(const char *s, int c)
; Find last occurrence of c in s
; Returns: pointer to char, or NULL if not found
; ============================================================
	PUBLIC	_strrchr
_strrchr:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP

	LD	L,(IX+4)	; HL = s
	LD	H,(IX+5)
	LD	C,(IX+6)	; C = char to find
	LD	DE,0		; DE = last match (NULL initially)

_strrchr_loop:
	LD	A,(HL)
	CP	C
	JR	NZ,_strrchr_nomatch
	LD	D,H		; Save this match
	LD	E,L
_strrchr_nomatch:
	OR	A		; Check for end of string
	JR	Z,_strrchr_done
	INC	HL
	JR	_strrchr_loop

_strrchr_done:
	EX	DE,HL		; HL = last match (or NULL)
	POP	IX
	RET

; ============================================================
; char *strstr(const char *haystack, const char *needle)
; Find first occurrence of needle in haystack
; Returns: pointer to start of match, or NULL if not found
; ============================================================
	PUBLIC	_strstr
_strstr:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	PUSH	BC

	LD	L,(IX+4)	; HL = haystack
	LD	H,(IX+5)
	LD	E,(IX+6)	; DE = needle
	LD	D,(IX+7)

	; Check if needle is empty
	LD	A,(DE)
	OR	A
	JR	Z,_strstr_found	; Empty needle matches at start

_strstr_outer:
	LD	A,(HL)
	OR	A
	JR	Z,_strstr_notfound	; End of haystack

	; Try to match needle at current position
	PUSH	HL		; Save haystack position
	PUSH	DE		; Save needle start

_strstr_inner:
	LD	A,(DE)
	OR	A
	JR	Z,_strstr_match	; End of needle = match!

	LD	B,(HL)		; B = haystack char
	CP	B
	JR	NZ,_strstr_nomatch

	INC	HL
	INC	DE
	JR	_strstr_inner

_strstr_nomatch:
	POP	DE		; Restore needle start
	POP	HL		; Restore haystack position
	INC	HL		; Try next position
	JR	_strstr_outer

_strstr_match:
	POP	DE		; Discard needle start
	POP	HL		; HL = start of match
_strstr_found:
	POP	BC
	POP	IX
	RET

_strstr_notfound:
	LD	HL,0
	POP	BC
	POP	IX
	RET

; ============================================================
; char *strdup(const char *s)
; Duplicate a string (allocate memory and copy)
; Returns: pointer to new string, or NULL if allocation fails
; ============================================================
	PUBLIC	_strdup
_strdup:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	PUSH	BC
	PUSH	DE

	; Get string pointer
	LD	L,(IX+4)
	LD	H,(IX+5)	; HL = s

	; Find length (including null terminator)
	PUSH	HL
	CALL	_strlen		; HL = length (not including null)
	INC	HL		; Add 1 for null terminator

	; Allocate memory
	PUSH	HL		; Push size argument
	CALL	_malloc		; HL = allocated pointer or NULL
	POP	DE		; Clean up argument

	; Check if malloc failed
	LD	A,H
	OR	L
	JR	Z,_strdup_done	; Return NULL

	; Copy string to new memory
	; HL = dest (from malloc)
	; Stack has source string address
	EX	DE,HL		; DE = dest
	POP	HL		; HL = source (was pushed earlier)
	PUSH	DE		; Save dest to return

	; Copy loop
_strdup_copy:
	LD	A,(HL)
	LD	(DE),A
	OR	A
	JR	Z,_strdup_copydone
	INC	HL
	INC	DE
	JR	_strdup_copy

_strdup_copydone:
	POP	HL		; HL = dest (return value)
	JR	_strdup_ret

_strdup_done:
	; NULL result - need to pop saved source
	POP	DE		; Discard saved source
	; HL is already 0

_strdup_ret:
	POP	DE
	POP	BC
	POP	IX
	RET

; ============================================================
; size_t strcspn(const char *s, const char *reject)
; Return length of initial segment of s not containing any chars from reject
; ============================================================
	PUBLIC	_strcspn
_strcspn:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	PUSH	BC
	PUSH	DE

	LD	L,(IX+4)	; HL = s
	LD	H,(IX+5)
	LD	E,(IX+6)	; DE = reject
	LD	D,(IX+7)
	LD	BC,0		; BC = count

_strcspn_loop:
	LD	A,(HL)
	OR	A
	JR	Z,_strcspn_done	; End of s

	; Check if A is in reject string
	PUSH	HL
	PUSH	DE
	POP	HL		; HL = reject
_strcspn_check:
	LD	D,(HL)
	LD	A,D
	OR	A
	JR	Z,_strcspn_ok	; End of reject, char not found
	POP	DE
	PUSH	DE
	LD	A,(DE)		; A = current char from s
	CP	D
	JR	Z,_strcspn_found	; Found in reject
	INC	HL
	JR	_strcspn_check

_strcspn_ok:
	; Char not in reject, continue
	POP	HL
	INC	HL
	INC	BC
	JR	_strcspn_loop

_strcspn_found:
	POP	HL		; Discard saved s pointer
_strcspn_done:
	LD	H,B
	LD	L,C		; HL = count
	POP	DE
	POP	BC
	POP	IX
	RET

; ============================================================
; size_t strspn(const char *s, const char *accept)
; Return length of initial segment of s containing only chars from accept
; ============================================================
	PUBLIC	_strspn
_strspn:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	PUSH	BC

	LD	L,(IX+4)	; HL = s
	LD	H,(IX+5)
	LD	BC,0		; BC = count

_strspn_loop:
	LD	A,(HL)
	OR	A
	JR	Z,_strspn_done	; End of s
	LD	E,A		; E = current char from s

	; Check if E is in accept string
	PUSH	HL		; Save s pointer
	LD	L,(IX+4+2)	; HL = accept (reload from stack frame)
	LD	H,(IX+5+2)
_strspn_check:
	LD	A,(HL)
	OR	A
	JR	Z,_strspn_notfound	; End of accept, char not found
	CP	E		; Compare accept char with s char
	JR	Z,_strspn_ok	; Found in accept
	INC	HL
	JR	_strspn_check

_strspn_ok:
	; Char in accept, continue
	POP	HL		; Restore s pointer
	INC	HL
	INC	BC
	JR	_strspn_loop

_strspn_notfound:
	POP	HL		; Discard saved s pointer
_strspn_done:
	LD	H,B
	LD	L,C		; HL = count
	POP	BC
	POP	IX
	RET

; ============================================================
; char *strtok(char *str, const char *delim)
; Tokenize a string. First call with str, subsequent with NULL.
; Uses _strtok_next for state, _strtok_tok for token start
; ============================================================
	PUBLIC	_strtok
_strtok:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	PUSH	BC
	PUSH	DE

	; Get str parameter or use saved position
	LD	L,(IX+4)
	LD	H,(IX+5)
	LD	A,H
	OR	L
	JR	NZ,_strtok_have_str
	LD	HL,(_strtok_next)
	LD	A,H
	OR	L
	JP	Z,_strtok_null		; No more tokens

_strtok_have_str:
	; HL = current position, skip leading delimiters
_strtok_skip:
	LD	A,(HL)
	OR	A
	JP	Z,_strtok_null		; End of string

	; Check if current char is a delimiter
	LD	B,A			; B = char to check
	LD	E,(IX+6)
	LD	D,(IX+7)		; DE = delim
_strtok_skip_loop:
	LD	A,(DE)
	OR	A
	JR	Z,_strtok_token_start	; Not a delimiter
	CP	B
	JR	Z,_strtok_skip_found
	INC	DE
	JR	_strtok_skip_loop
_strtok_skip_found:
	INC	HL
	JR	_strtok_skip

_strtok_token_start:
	; HL points to start of token, save it
	LD	(_strtok_tok),HL

	; Find end of token
_strtok_scan:
	LD	A,(HL)
	OR	A
	JR	Z,_strtok_end_of_str

	; Check if current char is a delimiter
	LD	B,A
	LD	E,(IX+6)
	LD	D,(IX+7)
_strtok_scan_loop:
	LD	A,(DE)
	OR	A
	JR	Z,_strtok_scan_next	; Not a delimiter
	CP	B
	JR	Z,_strtok_found_delim
	INC	DE
	JR	_strtok_scan_loop

_strtok_scan_next:
	INC	HL
	JR	_strtok_scan

_strtok_found_delim:
	; Null-terminate token
	LD	(HL),0
	INC	HL
	LD	(_strtok_next),HL
	JR	_strtok_return

_strtok_end_of_str:
	; No more tokens after this one
	LD	HL,0
	LD	(_strtok_next),HL

_strtok_return:
	LD	HL,(_strtok_tok)
	POP	DE
	POP	BC
	POP	IX
	RET

_strtok_null:
	LD	HL,0
	LD	(_strtok_next),HL
	POP	DE
	POP	BC
	POP	IX
	RET

; ============================================================
; char *strpbrk(const char *s, const char *accept)
; Find first occurrence of any char from accept in s
; Returns: pointer to char, or NULL if not found
; ============================================================
	PUBLIC	_strpbrk
_strpbrk:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	PUSH	BC
	PUSH	DE

	LD	L,(IX+4)	; HL = s
	LD	H,(IX+5)

_strpbrk_loop:
	LD	A,(HL)
	OR	A
	JR	Z,_strpbrk_notfound	; End of s

	; Check if char is in accept
	LD	B,A		; B = char to find
	LD	E,(IX+6)	; DE = accept
	LD	D,(IX+7)

_strpbrk_check:
	LD	A,(DE)
	OR	A
	JR	Z,_strpbrk_next	; End of accept, not found
	CP	B
	JR	Z,_strpbrk_found
	INC	DE
	JR	_strpbrk_check

_strpbrk_next:
	INC	HL
	JR	_strpbrk_loop

_strpbrk_found:
	; HL points to matching char
	POP	DE
	POP	BC
	POP	IX
	RET

_strpbrk_notfound:
	LD	HL,0
	POP	DE
	POP	BC
	POP	IX
	RET

; ============================================================
; char *strerror(int errnum)
; Return string describing error number
; ============================================================
	PUBLIC	_strerror
_strerror:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP

	LD	A,(IX+4)	; A = errnum (low byte)

	; Check common error codes
	OR	A
	JR	Z,_strerror_ok	; 0 = success
	CP	2		; ENOENT
	JR	Z,_strerror_noent
	CP	5		; EIO
	JR	Z,_strerror_io
	CP	12		; ENOMEM
	JR	Z,_strerror_nomem
	CP	13		; EACCES
	JR	Z,_strerror_acces
	CP	22		; EINVAL
	JR	Z,_strerror_inval
	CP	28		; ENOSPC
	JR	Z,_strerror_nospc
	CP	38		; ENOSYS
	JR	Z,_strerror_nosys
	; Default - unknown error
	LD	HL,_strerr_unknown
	JR	_strerror_ret

_strerror_ok:
	LD	HL,_strerr_ok
	JR	_strerror_ret
_strerror_noent:
	LD	HL,_strerr_noent
	JR	_strerror_ret
_strerror_io:
	LD	HL,_strerr_io
	JR	_strerror_ret
_strerror_nomem:
	LD	HL,_strerr_nomem
	JR	_strerror_ret
_strerror_acces:
	LD	HL,_strerr_acces
	JR	_strerror_ret
_strerror_inval:
	LD	HL,_strerr_inval
	JR	_strerror_ret
_strerror_nospc:
	LD	HL,_strerr_nospc
	JR	_strerror_ret
_strerror_nosys:
	LD	HL,_strerr_nosys

_strerror_ret:
	POP	IX
	RET

; ============================================================

; ============================================================
; char *strncat(char *dest, const char *src, size_t n)
; Append at most n chars from src to dest
; Returns: dest
; ============================================================
	PUBLIC	_strncat
_strncat:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	PUSH	BC

	LD	E,(IX+4)	; DE = dest
	LD	D,(IX+5)

	; Find end of dest
_strncat_find:
	LD	A,(DE)
	OR	A
	JR	Z,_strncat_copy
	INC	DE
	JR	_strncat_find

_strncat_copy:
	LD	L,(IX+6)	; HL = src
	LD	H,(IX+7)
	LD	C,(IX+8)	; BC = n
	LD	B,(IX+9)

_strncat_loop:
	LD	A,B		; Check if n == 0
	OR	C
	JR	Z,_strncat_done

	LD	A,(HL)
	OR	A
	JR	Z,_strncat_done	; End of src

	LD	(DE),A
	INC	HL
	INC	DE
	DEC	BC
	JR	_strncat_loop

_strncat_done:
	; Null terminate
	XOR	A
	LD	(DE),A

	LD	L,(IX+4)	; Return dest
	LD	H,(IX+5)
	POP	BC
	POP	IX
	RET

	DSEG

; strtok state
_strtok_next:	DS	2	; Next position in string
_strtok_tok:	DS	2	; Start of current token

; strerror messages
_strerr_ok:	DB	'Success',0
_strerr_noent:	DB	'No such file',0
_strerr_io:	DB	'I/O error',0
_strerr_nomem:	DB	'Out of memory',0
_strerr_acces:	DB	'Permission denied',0
_strerr_inval:	DB	'Invalid argument',0
_strerr_nospc:	DB	'No space left',0
_strerr_nosys:	DB	'Not implemented',0
_strerr_unknown: DB	'Unknown error',0


; ============================================================
; lc_tan.mac
; ============================================================
	CSEG
; lc_tan.mac - tan, tanf, tanl (depends on sin, cos)


	EXTRN	__fdiv
	EXTRN	__tmp32

	CSEG

; ============================================================
; tan(x) = sin(x) / cos(x)
; ============================================================
	PUBLIC	_tan
	PUBLIC	_tanf
	PUBLIC	_tanl
_tan:
_tanf:
_tanl:
	PUSH	IX
	PUSH	BC
	LD	IX,0
	ADD	IX,SP

	CALL	_math_getarg

	; Save x
	LD	(_tan_x),HL
	LD	(_tan_x+2),DE

	; Compute sin(x)
	PUSH	DE
	PUSH	HL
	CALL	_sinf
	POP	BC
	POP	BC
	LD	(_tan_sin),HL
	LD	(_tan_sin+2),DE

	; Compute cos(x) - push high word first, low word second
	LD	HL,(_tan_x+2)
	PUSH	HL
	LD	HL,(_tan_x)
	PUSH	HL
	CALL	_cosf
	POP	BC
	POP	BC

	; Divide sin/cos
	LD	(__tmp32),HL
	LD	(__tmp32+2),DE
	LD	HL,(_tan_sin)
	LD	DE,(_tan_sin+2)
	CALL	__fdiv

	POP	BC
	POP	IX
	RET

	DSEG

_tan_x:		DS	4
_tan_sin:	DS	4


; ============================================================
; lc_tanh.mac
; ============================================================
	CSEG
; lc_tanh.mac - tanh, tanhf (depends on sinh, cosh)


	EXTRN	__fdiv
	EXTRN	__tmp32

	CSEG

; ============================================================
; tanh(x) = sinh(x) / cosh(x)
; ============================================================
	PUBLIC	_tanh
	PUBLIC	_tanhf
_tanh:
_tanhf:
	PUSH	IX
	PUSH	BC
	LD	IX,0
	ADD	IX,SP

	CALL	_math_getarg
	LD	(_tanh_x),HL
	LD	(_tanh_x+2),DE

	; sinh(x)
	PUSH	DE
	PUSH	HL
	CALL	_sinhf
	POP	BC
	POP	BC
	LD	(_tanh_s),HL
	LD	(_tanh_s+2),DE

	; cosh(x) - push from saved memory
	LD	HL,(_tanh_x+2)
	PUSH	HL
	LD	HL,(_tanh_x)
	PUSH	HL
	CALL	_coshf
	POP	BC
	POP	BC

	; sinh/cosh
	LD	(__tmp32),HL
	LD	(__tmp32+2),DE
	LD	HL,(_tanh_s)
	LD	DE,(_tanh_s+2)
	CALL	__fdiv

	POP	BC
	POP	IX
	RET

	DSEG

_tanh_x:	DS	4
_tanh_s:	DS	4


; ============================================================
; lc_thread.mac
; ============================================================
	CSEG
; lc_thread.mac - threading support


; MP/M XDOS function numbers
MPM_DISPATCH	EQU	142	; Dispatch (yield)
MPM_DELAY	EQU	141	; Delay


	CSEG

; int __mpm_available(void)
; Check if MP/M is available (BDOS function 12 returns 0x31 or higher for MP/M)
	PUBLIC	___mpm_available
___mpm_available:
	PUSH	BC
	LD	C,12		; Get CP/M version
	CALL	5
	; H = 0 for CP/M, non-zero for MP/M
	LD	A,H
	OR	A
	JR	Z,_mpm_no
	; Check if H has MP/M flag
	LD	A,L
	CP	31H		; MP/M 1.x
	JR	NC,_mpm_yes
_mpm_no:
	LD	HL,0
	POP	BC
	RET
_mpm_yes:
	LD	HL,1
	POP	BC
	RET

; void __threads_use_mpm(int enable)
; Set thread mode
	PUBLIC	___threads_use_mpm
___threads_use_mpm:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	LD	A,(IX+4)
	LD	(_thread_mode),A
	POP	IX
	RET

; int thrd_create(thrd_t *thr, thrd_start_t func, void *arg)
; Create a new thread - only works under MP/M
; Under CP/M, returns thrd_error
	PUBLIC	_thrd_create
_thrd_create:
	; Under plain CP/M, we can't create threads
	; Return thrd_error (4)
	LD	HL,4		; thrd_error
	RET

; int thrd_equal(thrd_t lhs, thrd_t rhs)
; Compare two thread IDs
	PUBLIC	_thrd_equal
_thrd_equal:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	LD	A,(IX+4)	; lhs
	CP	(IX+6)		; rhs
	JR	Z,_thrd_eq_yes
	LD	HL,0
	POP	IX
	RET
_thrd_eq_yes:
	LD	HL,1
	POP	IX
	RET

; thrd_t thrd_current(void)
; Get current thread ID
	PUBLIC	_thrd_current
_thrd_current:
	LD	A,(_thread_current)
	LD	L,A
	LD	H,0
	RET

; int thrd_sleep(const struct timespec *duration, struct timespec *remaining)
; Sleep for specified duration
; Uses MPM_DELAY under MP/M, busy-wait under CP/M
	PUBLIC	_thrd_sleep
_thrd_sleep:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	PUSH	BC
	PUSH	DE

	; Get duration pointer
	LD	L,(IX+4)
	LD	H,(IX+5)
	; Load tv_sec (first 4 bytes)
	LD	E,(HL)
	INC	HL
	LD	D,(HL)
	INC	HL
	INC	HL
	INC	HL		; Skip to tv_nsec (ignored for simplicity)

	; Check thread mode
	LD	A,(_thread_mode)
	OR	A
	JR	Z,_thrd_sleep_busy

	; MP/M mode: use DELAY function
	; Convert seconds to 1/60th second ticks
	; DE = seconds, ticks = seconds * 60
	PUSH	DE
	POP	HL
	ADD	HL,HL		; *2
	LD	D,H
	LD	E,L
	ADD	HL,HL		; *4
	ADD	HL,HL		; *8
	ADD	HL,HL		; *16
	ADD	HL,HL		; *32
	ADD	HL,DE		; *32 + *2 = *34 (close to 60/2)
	ADD	HL,HL		; *68... this is approximate
	; Simpler: multiply by 64 (shift left 6 times)
	LD	L,(IX+4)
	LD	H,(IX+5)
	LD	E,(HL)
	INC	HL
	LD	D,(HL)
	SLA	E
	RL	D
	SLA	E
	RL	D
	SLA	E
	RL	D
	SLA	E
	RL	D
	SLA	E
	RL	D
	SLA	E
	RL	D		; DE = seconds * 64 (approx 60)

	LD	C,MPM_DELAY	; XDOS Delay
	CALL	5

	LD	HL,0		; Return 0 (success)
	JR	_thrd_sleep_ret

_thrd_sleep_busy:
	; CP/M mode: busy wait (very crude)
	; Just loop for a while
	LD	L,(IX+4)
	LD	H,(IX+5)
	LD	E,(HL)
	INC	HL
	LD	D,(HL)
	; DE = seconds, loop DE * 10000 times
_thrd_sleep_outer:
	LD	A,D
	OR	E
	JR	Z,_thrd_sleep_done
	LD	BC,10000
_thrd_sleep_inner:
	DEC	BC
	LD	A,B
	OR	C
	JR	NZ,_thrd_sleep_inner
	DEC	DE
	JR	_thrd_sleep_outer

_thrd_sleep_done:
	LD	HL,0

_thrd_sleep_ret:
	; Set remaining to 0 if pointer provided
	LD	L,(IX+6)
	LD	H,(IX+7)
	LD	A,H
	OR	L
	JR	Z,_thrd_sleep_noremain
	XOR	A
	LD	(HL),A
	INC	HL
	LD	(HL),A
	INC	HL
	LD	(HL),A
	INC	HL
	LD	(HL),A
	INC	HL
	LD	(HL),A
	INC	HL
	LD	(HL),A
	INC	HL
	LD	(HL),A
	INC	HL
	LD	(HL),A

_thrd_sleep_noremain:
	LD	HL,0
	POP	DE
	POP	BC
	POP	IX
	RET

; void thrd_yield(void)
; Yield execution to other threads
	PUBLIC	_thrd_yield
_thrd_yield:
	LD	A,(_thread_mode)
	OR	A
	RET	Z		; No-op under CP/M

	; MP/M: dispatch (yield CPU)
	PUSH	BC
	LD	C,MPM_DISPATCH
	CALL	5
	POP	BC
	RET

; void thrd_exit(int res)
; Exit current thread (exits program under CP/M)
	PUBLIC	_thrd_exit
_thrd_exit:
	; Under CP/M, just exit the program
	JP	_exit

; int thrd_detach(thrd_t thr)
; Detach a thread - returns thrd_error under CP/M
	PUBLIC	_thrd_detach
_thrd_detach:
	LD	HL,4		; thrd_error
	RET

; int thrd_join(thrd_t thr, int *res)
; Wait for thread to finish - returns thrd_error under CP/M
	PUBLIC	_thrd_join
_thrd_join:
	LD	HL,4		; thrd_error
	RET

; ============================================================
; Mutex functions - use DI/EI for synchronization
; ============================================================

; int mtx_init(mtx_t *mtx, int type)
; Initialize a mutex
	PUBLIC	_mtx_init
_mtx_init:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP

	LD	L,(IX+4)
	LD	H,(IX+5)	; HL = mtx
	; Clear the mutex structure
	XOR	A
	LD	(HL),A		; locked = 0
	INC	HL
	LD	A,(IX+6)	; type
	LD	(HL),A
	INC	HL
	XOR	A
	LD	(HL),A		; owner = 0
	INC	HL
	LD	(HL),A		; count = 0

	LD	HL,0		; thrd_success
	POP	IX
	RET

; int mtx_lock(mtx_t *mtx)
; Lock a mutex
	PUBLIC	_mtx_lock
_mtx_lock:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	PUSH	BC

	LD	L,(IX+4)
	LD	H,(IX+5)	; HL = mtx

_mtx_lock_retry:
	DI			; Disable interrupts
	LD	A,(HL)		; locked flag
	OR	A
	JR	Z,_mtx_lock_acq

	; Already locked - check if recursive
	INC	HL
	LD	A,(HL)		; type
	DEC	HL
	AND	1		; mtx_recursive
	JR	Z,_mtx_lock_wait

	; Check if we own it
	PUSH	HL
	INC	HL
	INC	HL
	LD	A,(_thread_current)
	CP	(HL)		; owner
	POP	HL
	JR	NZ,_mtx_lock_wait

	; We own it, increment count
	PUSH	HL
	INC	HL
	INC	HL
	INC	HL
	INC	(HL)		; count++
	POP	HL
	EI
	LD	HL,0		; thrd_success
	JR	_mtx_lock_ret

_mtx_lock_wait:
	EI			; Re-enable interrupts
	; Yield and retry
	PUSH	HL
	CALL	_thrd_yield
	POP	HL
	JR	_mtx_lock_retry

_mtx_lock_acq:
	; Acquire the lock
	LD	(HL),1		; locked = 1
	; Set owner
	PUSH	HL
	INC	HL
	INC	HL
	LD	A,(_thread_current)
	LD	(HL),A		; owner
	INC	HL
	LD	(HL),1		; count = 1
	POP	HL
	EI
	LD	HL,0		; thrd_success

_mtx_lock_ret:
	POP	BC
	POP	IX
	RET

; int mtx_trylock(mtx_t *mtx)
; Try to lock mutex without blocking
	PUBLIC	_mtx_trylock
_mtx_trylock:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP

	LD	L,(IX+4)
	LD	H,(IX+5)	; HL = mtx

	DI
	LD	A,(HL)
	OR	A
	JR	NZ,_mtx_try_busy

	; Lock it
	LD	(HL),1
	PUSH	HL
	INC	HL
	INC	HL
	LD	A,(_thread_current)
	LD	(HL),A
	INC	HL
	LD	(HL),1
	POP	HL
	EI
	LD	HL,0		; thrd_success
	POP	IX
	RET

_mtx_try_busy:
	; Check if recursive and we own it
	INC	HL
	LD	A,(HL)		; type
	AND	1
	JR	Z,_mtx_try_fail
	INC	HL
	LD	A,(_thread_current)
	CP	(HL)
	JR	NZ,_mtx_try_fail
	; We own it
	INC	HL
	INC	(HL)
	EI
	LD	HL,0
	POP	IX
	RET

_mtx_try_fail:
	EI
	LD	HL,3		; thrd_busy
	POP	IX
	RET

; int mtx_timedlock(mtx_t *mtx, const struct timespec *ts)
; Lock with timeout - simplified, just tries a few times then fails
	PUBLIC	_mtx_timedlock
_mtx_timedlock:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	PUSH	BC

	LD	B,100		; Try 100 times
_mtx_timed_loop:
	LD	L,(IX+4)
	LD	H,(IX+5)
	PUSH	HL
	CALL	_mtx_trylock
	POP	BC
	LD	A,H
	OR	L
	JR	Z,_mtx_timed_ok	; Got it
	DJNZ	_mtx_timed_loop

	; Timeout
	LD	HL,2		; thrd_timedout
	JR	_mtx_timed_ret

_mtx_timed_ok:
	LD	HL,0		; thrd_success

_mtx_timed_ret:
	POP	BC
	POP	IX
	RET

; int mtx_unlock(mtx_t *mtx)
; Unlock a mutex
	PUBLIC	_mtx_unlock
_mtx_unlock:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP

	LD	L,(IX+4)
	LD	H,(IX+5)	; HL = mtx

	DI
	; Check if recursive
	INC	HL
	LD	A,(HL)		; type
	AND	1
	JR	Z,_mtx_unlock_do

	; Recursive - decrement count
	INC	HL
	INC	HL
	DEC	(HL)		; count--
	JR	NZ,_mtx_unlock_recur
	; Count reached 0, release
	DEC	HL
	DEC	HL
	DEC	HL		; Back to start

_mtx_unlock_do:
	DEC	HL		; Back to locked flag
	XOR	A
	LD	(HL),A		; locked = 0

_mtx_unlock_recur:
	EI
	LD	HL,0		; thrd_success
	POP	IX
	RET

; void mtx_destroy(mtx_t *mtx)
; Destroy a mutex (no-op, just clear it)
	PUBLIC	_mtx_destroy
_mtx_destroy:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP

	LD	L,(IX+4)
	LD	H,(IX+5)
	XOR	A
	LD	B,12		; Size of mtx_t
_mtx_destroy_loop:
	LD	(HL),A
	INC	HL
	DJNZ	_mtx_destroy_loop

	POP	IX
	RET

; ============================================================
; Condition variable functions
; ============================================================

; int cnd_init(cnd_t *cond)
	PUBLIC	_cnd_init
_cnd_init:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP

	LD	L,(IX+4)
	LD	H,(IX+5)
	XOR	A
	LD	(HL),A		; waiters = 0
	INC	HL
	LD	(HL),A		; signaled = 0

	LD	HL,0		; thrd_success
	POP	IX
	RET

; int cnd_signal(cnd_t *cond)
	PUBLIC	_cnd_signal
_cnd_signal:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP

	LD	L,(IX+4)
	LD	H,(IX+5)
	INC	HL
	LD	(HL),1		; signaled = 1

	LD	HL,0
	POP	IX
	RET

; int cnd_broadcast(cnd_t *cond)
	PUBLIC	_cnd_broadcast
_cnd_broadcast:
	; Same as signal for our simple implementation
	JP	_cnd_signal

; int cnd_wait(cnd_t *cond, mtx_t *mtx)
	PUBLIC	_cnd_wait
_cnd_wait:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	PUSH	BC

	; Unlock mutex
	LD	L,(IX+6)
	LD	H,(IX+7)	; mtx
	PUSH	HL
	CALL	_mtx_unlock
	POP	BC

	; Wait for signal
	LD	L,(IX+4)
	LD	H,(IX+5)	; cond
	INC	HL		; Point to signaled

_cnd_wait_loop:
	DI
	LD	A,(HL)
	OR	A
	JR	NZ,_cnd_wait_done
	EI
	CALL	_thrd_yield
	JR	_cnd_wait_loop

_cnd_wait_done:
	XOR	A
	LD	(HL),A		; Clear signal
	EI

	; Re-lock mutex
	LD	L,(IX+6)
	LD	H,(IX+7)
	PUSH	HL
	CALL	_mtx_lock
	POP	BC

	LD	HL,0		; thrd_success
	POP	BC
	POP	IX
	RET

; int cnd_timedwait(cnd_t *cond, mtx_t *mtx, const struct timespec *ts)
	PUBLIC	_cnd_timedwait
_cnd_timedwait:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	PUSH	BC

	; Unlock mutex
	LD	L,(IX+6)
	LD	H,(IX+7)
	PUSH	HL
	CALL	_mtx_unlock
	POP	BC

	; Try a few times
	LD	B,100
	LD	L,(IX+4)
	LD	H,(IX+5)
	INC	HL

_cnd_timed_loop:
	DI
	LD	A,(HL)
	OR	A
	JR	NZ,_cnd_timed_done
	EI
	PUSH	HL
	PUSH	BC
	CALL	_thrd_yield
	POP	BC
	POP	HL
	DJNZ	_cnd_timed_loop

	; Timeout
	LD	L,(IX+6)
	LD	H,(IX+7)
	PUSH	HL
	CALL	_mtx_lock
	POP	BC
	LD	HL,2		; thrd_timedout
	JR	_cnd_timed_ret

_cnd_timed_done:
	XOR	A
	LD	(HL),A
	EI
	LD	L,(IX+6)
	LD	H,(IX+7)
	PUSH	HL
	CALL	_mtx_lock
	POP	BC
	LD	HL,0

_cnd_timed_ret:
	POP	BC
	POP	IX
	RET

; void cnd_destroy(cnd_t *cond)
	PUBLIC	_cnd_destroy
_cnd_destroy:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP

	LD	L,(IX+4)
	LD	H,(IX+5)
	XOR	A
	LD	(HL),A
	INC	HL
	LD	(HL),A

	POP	IX
	RET

; ============================================================
; Thread-specific storage functions
; ============================================================

; int tss_create(tss_t *key, tss_dtor_t dtor)
	PUBLIC	_tss_create
_tss_create:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP

	; Find free slot (value 0xFFFF means unused)
	LD	HL,_tss_slots
	LD	B,0		; Slot index
_tss_create_loop:
	LD	A,B
	CP	8		; 8 slots max
	JR	NC,_tss_create_fail

	LD	E,(HL)
	INC	HL
	LD	D,(HL)
	INC	HL
	LD	A,D
	AND	E
	INC	A
	JR	Z,_tss_create_found
	INC	B
	JR	_tss_create_loop

_tss_create_found:
	; Store NULL initially
	DEC	HL
	DEC	HL
	XOR	A
	LD	(HL),A
	INC	HL
	LD	(HL),A

	; Store destructor
	LD	HL,_tss_dtors
	LD	A,B
	ADD	A,A		; *2
	LD	E,A
	LD	D,0
	ADD	HL,DE
	LD	A,(IX+6)	; dtor low
	LD	(HL),A
	INC	HL
	LD	A,(IX+7)	; dtor high
	LD	(HL),A

	; Store key
	LD	L,(IX+4)
	LD	H,(IX+5)
	LD	(HL),B		; key = slot index

	LD	HL,0		; thrd_success
	POP	IX
	RET

_tss_create_fail:
	LD	HL,1		; thrd_nomem
	POP	IX
	RET

; void *tss_get(tss_t key)
	PUBLIC	_tss_get
_tss_get:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP

	LD	A,(IX+4)	; key
	CP	8
	JR	NC,_tss_get_null

	ADD	A,A		; *2
	LD	E,A
	LD	D,0
	LD	HL,_tss_slots
	ADD	HL,DE
	LD	E,(HL)
	INC	HL
	LD	D,(HL)
	EX	DE,HL
	POP	IX
	RET

_tss_get_null:
	LD	HL,0
	POP	IX
	RET

; int tss_set(tss_t key, void *val)
	PUBLIC	_tss_set
_tss_set:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP

	LD	A,(IX+4)	; key
	CP	8
	JR	NC,_tss_set_err

	ADD	A,A		; *2
	LD	E,A
	LD	D,0
	LD	HL,_tss_slots
	ADD	HL,DE
	LD	A,(IX+6)	; val low
	LD	(HL),A
	INC	HL
	LD	A,(IX+7)	; val high
	LD	(HL),A

	LD	HL,0		; thrd_success
	POP	IX
	RET

_tss_set_err:
	LD	HL,4		; thrd_error
	POP	IX
	RET

; void tss_delete(tss_t key)
	PUBLIC	_tss_delete
_tss_delete:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP

	LD	A,(IX+4)
	CP	8
	JR	NC,_tss_del_done

	ADD	A,A
	LD	E,A
	LD	D,0
	LD	HL,_tss_slots
	ADD	HL,DE
	LD	A,0FFH
	LD	(HL),A
	INC	HL
	LD	(HL),A		; Mark as unused

	; Clear destructor
	LD	HL,_tss_dtors
	ADD	HL,DE
	XOR	A
	LD	(HL),A
	INC	HL
	LD	(HL),A

_tss_del_done:
	POP	IX
	RET

; ============================================================
; call_once function
; ============================================================

; void call_once(once_flag *flag, void (*func)(void))
	PUBLIC	_call_once
_call_once:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	PUSH	BC

	LD	L,(IX+4)
	LD	H,(IX+5)	; flag
	DI
	LD	A,(HL)
	OR	A
	JR	NZ,_call_once_done

	; Mark as called
	LD	(HL),1
	EI

	; Call function
	LD	L,(IX+6)
	LD	H,(IX+7)
	CALL	_call_once_call
	JR	_call_once_ret

_call_once_done:
	EI
_call_once_ret:
	POP	BC
	POP	IX
	RET

_call_once_call:
	JP	(HL)

; ============================================================
; Atomic operations (stdatomic.h)
; All use DI/EI for atomicity on Z80
; ============================================================



	DSEG
_thread_mode:	DB	0
_thread_current:	DB	0
_tss_slots:	DS	16
_tss_dtors:	DS	16


; ============================================================
; lc_time.mac
; ============================================================
	CSEG
; lc_time.mac - time functions


	CSEG

; ============================================================
; time_t time(time_t *tloc)
; Return current time (stub - returns 0 on CP/M)
; ============================================================
	PUBLIC	_time
_time:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	; Return 0 in DEHL (32-bit)
	LD	HL,0
	LD	DE,0
	; If tloc != NULL, store result
	LD	A,(IX+4)
	OR	(IX+5)
	JR	Z,_time_ret
	; Store 0 at *tloc
	PUSH	HL
	LD	L,(IX+4)
	LD	H,(IX+5)
	LD	(HL),0
	INC	HL
	LD	(HL),0
	INC	HL
	LD	(HL),0
	INC	HL
	LD	(HL),0
	POP	HL
_time_ret:
	POP	IX
	RET

; ============================================================
; clock_t clock(void)
; Return CPU time used (stub - returns 0)
; ============================================================
	PUBLIC	_clock
_clock:
	LD	HL,0
	LD	DE,0
	RET

; ============================================================


; ============================================================
; lc_wchar.mac
; ============================================================
	CSEG
; lc_wchar.mac - multibyte/wide character functions


	CSEG

; ============================================================
; Multibyte/Wide Character Conversion Functions
; Minimal implementation for C locale (1:1 char mapping)
; ============================================================

; int mblen(const char *s, size_t n)
; Determine bytes in multibyte character
; C locale: always returns 1 for non-null char, 0 for null, -1 if s==NULL
	PUBLIC	_mblen
_mblen:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP

	LD	L,(IX+4)
	LD	H,(IX+5)	; HL = s
	LD	A,H
	OR	L
	JR	Z,_mblen_null	; s == NULL

	; Check if n >= 1
	LD	C,(IX+6)
	LD	B,(IX+7)	; BC = n
	LD	A,B
	OR	C
	JR	Z,_mblen_zero	; n == 0

	; Check character
	LD	A,(HL)
	OR	A
	JR	Z,_mblen_zero	; null character

	; Valid single-byte character
	LD	HL,1
	POP	IX
	RET

_mblen_null:
	; s == NULL: return 0 (stateless encoding)
	LD	HL,0
	POP	IX
	RET

_mblen_zero:
	LD	HL,0
	POP	IX
	RET

; int mbtowc(wchar_t *pwc, const char *s, size_t n)
; Convert multibyte to wide character
; C locale: just copy byte to wchar_t
	PUBLIC	_mbtowc
_mbtowc:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP

	LD	L,(IX+6)
	LD	H,(IX+7)	; HL = s
	LD	A,H
	OR	L
	JR	Z,_mbtowc_null	; s == NULL

	; Check n
	LD	C,(IX+8)
	LD	B,(IX+9)	; BC = n
	LD	A,B
	OR	C
	JR	Z,_mbtowc_err	; n == 0

	; Get character
	LD	A,(HL)
	OR	A
	JR	Z,_mbtowc_nul	; null character

	; Store in pwc if not NULL
	LD	C,A		; Save char
	LD	L,(IX+4)
	LD	H,(IX+5)	; HL = pwc
	LD	A,H
	OR	L
	JR	Z,_mbtowc_ret1
	; Store as wide char (16-bit)
	LD	(HL),C
	INC	HL
	XOR	A
	LD	(HL),A

_mbtowc_ret1:
	LD	HL,1
	POP	IX
	RET

_mbtowc_nul:
	; Store 0 in pwc if not NULL
	LD	L,(IX+4)
	LD	H,(IX+5)
	LD	A,H
	OR	L
	JR	Z,_mbtowc_ret0
	XOR	A
	LD	(HL),A
	INC	HL
	LD	(HL),A
_mbtowc_ret0:
	LD	HL,0
	POP	IX
	RET

_mbtowc_null:
	; s == NULL: return 0 (stateless)
	LD	HL,0
	POP	IX
	RET

_mbtowc_err:
	LD	HL,-1
	POP	IX
	RET

; int wctomb(char *s, wchar_t wc)
; Convert wide character to multibyte
; C locale: just copy low byte if <= 255
	PUBLIC	_wctomb
_wctomb:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP

	LD	L,(IX+4)
	LD	H,(IX+5)	; HL = s
	LD	A,H
	OR	L
	JR	Z,_wctomb_null	; s == NULL

	; Get wchar_t
	LD	C,(IX+6)	; Low byte of wc
	LD	A,(IX+7)	; High byte
	OR	A
	JR	NZ,_wctomb_err	; > 255: invalid for C locale

	; Store character
	LD	(HL),C
	LD	HL,1
	POP	IX
	RET

_wctomb_null:
	; s == NULL: return 0 (stateless)
	LD	HL,0
	POP	IX
	RET

_wctomb_err:
	LD	HL,-1
	POP	IX
	RET

; size_t mbstowcs(wchar_t *dest, const char *src, size_t n)
; Convert multibyte string to wide string
; C locale: copy bytes to wchar_t array
	PUBLIC	_mbstowcs
_mbstowcs:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	PUSH	BC

	LD	E,(IX+4)
	LD	D,(IX+5)	; DE = dest
	LD	L,(IX+6)
	LD	H,(IX+7)	; HL = src
	LD	C,(IX+8)
	LD	B,(IX+9)	; BC = n
	PUSH	BC		; Save n

	LD	BC,0		; Count = 0

_mbstowcs_loop:
	; Check if count < n
	POP	HL		; n
	PUSH	HL
	OR	A
	SBC	HL,BC
	JR	Z,_mbstowcs_done
	JR	C,_mbstowcs_done

	; Get source pointer back
	LD	L,(IX+6)
	LD	H,(IX+7)
	ADD	HL,BC		; HL = src + count
	LD	A,(HL)		; Get char

	; Check for null terminator
	OR	A
	JR	Z,_mbstowcs_term

	; Store in dest if not NULL
	LD	L,(IX+4)
	LD	H,(IX+5)	; HL = dest
	LD	E,A
	LD	A,H
	OR	L
	JR	Z,_mbstowcs_nodest
	; dest[count] = char
	PUSH	BC
	SLA	C
	RL	B		; BC * 2 for wchar_t offset
	ADD	HL,BC
	LD	(HL),E		; Low byte
	INC	HL
	XOR	A
	LD	(HL),A		; High byte = 0
	POP	BC

_mbstowcs_nodest:
	INC	BC		; count++
	JR	_mbstowcs_loop

_mbstowcs_term:
	; Null terminate dest if not NULL
	LD	L,(IX+4)
	LD	H,(IX+5)
	LD	A,H
	OR	L
	JR	Z,_mbstowcs_done
	PUSH	BC
	SLA	C
	RL	B
	ADD	HL,BC
	XOR	A
	LD	(HL),A
	INC	HL
	LD	(HL),A
	POP	BC

_mbstowcs_done:
	POP	HL		; Discard saved n
	LD	H,B
	LD	L,C		; Return count
	POP	BC
	POP	IX
	RET

; size_t wcstombs(char *dest, const wchar_t *src, size_t n)
; Convert wide string to multibyte string
; C locale: copy low bytes if <= 255
	PUBLIC	_wcstombs
_wcstombs:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	PUSH	BC

	LD	BC,0		; Count = 0

_wcstombs_loop:
	; Check if count < n
	LD	L,(IX+8)
	LD	H,(IX+9)	; HL = n
	OR	A
	SBC	HL,BC
	JR	Z,_wcstombs_done
	JR	C,_wcstombs_done

	; Get wchar at src[count]
	LD	L,(IX+6)
	LD	H,(IX+7)	; HL = src
	PUSH	BC
	SLA	C
	RL	B		; BC * 2 for wchar_t
	ADD	HL,BC
	POP	BC
	LD	E,(HL)		; Low byte
	INC	HL
	LD	A,(HL)		; High byte
	OR	A
	JR	NZ,_wcstombs_err	; > 255

	; Check for null terminator
	LD	A,E
	OR	A
	JR	Z,_wcstombs_term

	; Store in dest if not NULL
	LD	L,(IX+4)
	LD	H,(IX+5)
	LD	A,H
	OR	L
	JR	Z,_wcstombs_nodest
	ADD	HL,BC
	LD	(HL),E

_wcstombs_nodest:
	INC	BC
	JR	_wcstombs_loop

_wcstombs_term:
	; Null terminate
	LD	L,(IX+4)
	LD	H,(IX+5)
	LD	A,H
	OR	L
	JR	Z,_wcstombs_done
	ADD	HL,BC
	XOR	A
	LD	(HL),A

_wcstombs_done:
	LD	H,B
	LD	L,C
	POP	BC
	POP	IX
	RET

_wcstombs_err:
	LD	HL,-1
	POP	BC
	POP	IX
	RET

; ============================================================
; char *strrchr(const char *s, int c)
; Find last occurrence of c in s


	END
