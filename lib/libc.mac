_sin_iter:	DS	1
_cos_x:		DS	4
_cos_x2:	DS	4
_cos_sum:	DS	4
_cos_term:	DS	4
_cos_n:		DS	4
_tan_x:		DS	4
_tan_sin:	DS	4
_exp_x:		DS	4
_exp_sum:	DS	4
_exp_term:	DS	4
_exp_k:		DS	2
_exp_tmp:	DS	4
_log_x:		DS	4
