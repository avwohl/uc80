_floor_i:	DS	4
_ceil_x:	DS	4
_fmod_x:	DS	4
_fmod_y:	DS	4
_modf_x:	DS	4
_modf_i:	DS	4

; Complex number work areas
_cplx_z:	DS	8	; Input complex
_cplx_w:	DS	8	; Second input / work area
_cplx_res:	DS	8	; Result storage
__cplx_l:	DS	8	; Left operand for cmul/cdiv
__cplx_r:	DS	8	; Right operand for cmul/cdiv
__cplx_result:	DS	8	; Result from cmul/cdiv

; scanf work areas
_scanf_count:	DS	1	; Number of matched items
_scanf_mode:	DS	1	; 0=stdin, 1=string, 2=file
_scanf_src:	DS	2	; String source pointer
_scanf_fp:	DS	2	; File pointer
