; libc.mac - Minimal C Standard Library for CP/M
; uc80 C Compiler
;
; Implements basic I/O functions using CP/M BDOS calls

	.Z80

; CP/M BDOS function numbers
BDOS	EQU	5		; BDOS entry point
CONOUT	EQU	2		; Console output (char in E)
CONIN	EQU	1		; Console input (char returned in A)
PRTSTR	EQU	9		; Print string (address in DE, '$' terminated)

	CSEG

; ============================================================
; int putchar(int c)
; Output a character to console
; Argument: character on stack at IX+4
; Returns: the character written, or EOF (-1) on error
; ============================================================
	PUBLIC	_putchar
_putchar:
	; Minimal implementation - doesn't touch IX
	; Stack at entry: [ret_addr][arg]
	POP	HL		; Get return address
	POP	DE		; Get argument (char in E)
	PUSH	DE		; Restore arg for caller cleanup
	PUSH	HL		; Restore return address

	LD	C,CONOUT
	CALL	BDOS

	; Return value - get arg again
	LD	HL,2
	ADD	HL,SP		; Points to arg (after ret addr)
	LD	L,(HL)
	LD	H,0
	RET

; ============================================================
; int getchar(void)
; Read a character from console
; Returns: character read, or EOF (-1) on error
; ============================================================
	PUBLIC	_getchar
_getchar:
	LD	C,CONIN
	CALL	BDOS
	LD	L,A
	LD	H,0
	RET

; ============================================================
; int puts(const char *s)
; Output a string followed by newline
; Argument: pointer to string on stack at IX+4
; Returns: non-negative on success, EOF (-1) on error
; ============================================================
	PUBLIC	_puts
_puts:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	PUSH	BC

	; Get string pointer
	LD	L,(IX+4)
	LD	H,(IX+5)

_puts_loop:
	LD	A,(HL)
	OR	A
	JR	Z,_puts_newline	; End of string

	LD	E,A		; Character in E
	LD	C,CONOUT
	PUSH	HL
	CALL	BDOS
	POP	HL
	INC	HL
	JR	_puts_loop

_puts_newline:
	; Output newline (CR LF)
	LD	E,0DH		; CR
	LD	C,CONOUT
	CALL	BDOS
	LD	E,0AH		; LF
	LD	C,CONOUT
	CALL	BDOS

	; Return 0 (success)
	LD	HL,0

	POP	BC
	POP	IX
	RET

; ============================================================
; void cputs(const char *s)
; Output a string (no newline, for internal use)
; ============================================================
	PUBLIC	_cputs
_cputs:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	PUSH	BC

	; Get string pointer
	LD	L,(IX+4)
	LD	H,(IX+5)

_cputs_loop:
	LD	A,(HL)
	OR	A
	JR	Z,_cputs_done

	LD	E,A
	LD	C,CONOUT
	PUSH	HL
	CALL	BDOS
	POP	HL
	INC	HL
	JR	_cputs_loop

_cputs_done:
	POP	BC
	POP	IX
	RET

; ============================================================
; char *gets(char *s)
; Read line from stdin into buffer (DANGEROUS - no size limit)
; Returns s, or NULL on EOF/error
; ============================================================
	PUBLIC	_gets
_gets:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	PUSH	BC
	PUSH	DE

	LD	E,(IX+4)	; DE = buffer pointer
	LD	D,(IX+5)
	PUSH	DE		; Save for return

_gets_loop:
	LD	C,CONIN
	CALL	BDOS		; A = char
	CP	0DH		; CR?
	JR	Z,_gets_done
	CP	0AH		; LF?
	JR	Z,_gets_done
	LD	(DE),A
	INC	DE
	JR	_gets_loop

_gets_done:
	XOR	A
	LD	(DE),A		; Null terminate
	POP	HL		; Return original pointer
	POP	DE
	POP	BC
	POP	IX
	RET

; ============================================================
; CP/M File I/O Implementation
; Real file operations using BDOS FCB calls
; ============================================================

; CP/M BDOS function numbers
BDOS_OPEN	EQU	15	; Open file
BDOS_CLOSE	EQU	16	; Close file
BDOS_DELETE	EQU	19	; Delete file
BDOS_RENAME	EQU	23	; Rename file
BDOS_READ	EQU	20	; Read sequential
BDOS_WRITE	EQU	21	; Write sequential
BDOS_MAKE	EQU	22	; Make (create) file
BDOS_SETDMA	EQU	26	; Set DMA address
BDOS_RREAD	EQU	33	; Read random
BDOS_RWRITE	EQU	34	; Write random
BDOS_FSIZE	EQU	35	; Compute file size
BDOS_SETREC	EQU	36	; Set random record

; FILE structure offsets (170 bytes total)
FILE_FD		EQU	0	; Slot number (0=stdin,1=stdout,2=stderr,3+=files)
FILE_FLAGS	EQU	1	; bit0=open,bit1=EOF,bit2=error,bit3=write,bit4=read
FILE_UNGET	EQU	2	; Ungetc char (0xFF=none)
FILE_BUFPOS	EQU	3	; Current position in buffer
FILE_BUFCNT	EQU	4	; Valid bytes in buffer (for read)
FILE_RESERVED	EQU	5	; Reserved
FILE_FCB	EQU	6	; FCB starts here (36 bytes)
FILE_BUFFER	EQU	42	; Buffer starts here (128 bytes)
FILE_SIZE	EQU	170	; Total FILE structure size

; Flag bits
FLAG_OPEN	EQU	01H
FLAG_EOF	EQU	02H
FLAG_ERROR	EQU	04H
FLAG_WRITE	EQU	08H
FLAG_READ	EQU	10H

; Standard stream file descriptors
FD_STDIN	EQU	0
FD_STDOUT	EQU	1
FD_STDERR	EQU	2

; Number of file slots (besides stdin/stdout/stderr)
MAX_FILES	EQU	4

; ============================================================
; FILE *fopen(const char *pathname, const char *mode)
; Open a file for reading or writing
; ============================================================
	PUBLIC	_fopen
_fopen:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	PUSH	BC
	PUSH	DE

	; Find free file slot
	LD	HL,_file_slots
	LD	B,MAX_FILES
_fopen_find:
	PUSH	HL
	INC	HL		; Point to flags
	LD	A,(HL)
	AND	FLAG_OPEN
	POP	HL
	JR	Z,_fopen_found
	LD	DE,FILE_SIZE
	ADD	HL,DE
	DJNZ	_fopen_find
	; No free slot
	LD	HL,0
	JP	_fopen_ret

_fopen_found:
	; HL = FILE structure, save it
	PUSH	HL

	; Parse mode string
	LD	L,(IX+6)
	LD	H,(IX+7)	; HL = mode
	LD	A,(HL)
	LD	B,0		; B = mode flags
	CP	'r'
	JR	Z,_fopen_read
	CP	'w'
	JR	Z,_fopen_write
	CP	'a'
	JR	Z,_fopen_append
	; Invalid mode
	POP	HL
	LD	HL,0
	JP	_fopen_ret

_fopen_read:
	LD	B,FLAG_READ
	JR	_fopen_setup

_fopen_write:
	LD	B,FLAG_WRITE
	JR	_fopen_setup

_fopen_append:
	LD	B,FLAG_WRITE	; Append = write mode
	; (simplified: append not fully supported)

_fopen_setup:
	; B = mode flags, stack has FILE*
	POP	HL		; HL = FILE*
	PUSH	HL
	PUSH	BC		; Save mode

	; Initialize FILE structure
	LD	A,3		; fd = 3+ for files
	LD	(HL),A
	INC	HL
	XOR	A
	LD	(HL),A		; flags = 0 (will set later)
	INC	HL
	LD	A,0FFH
	LD	(HL),A		; unget = none
	INC	HL
	XOR	A
	LD	(HL),A		; bufpos = 0
	INC	HL
	LD	(HL),A		; bufcnt = 0
	INC	HL
	LD	(HL),A		; reserved = 0
	INC	HL		; HL now at FCB

	; Clear FCB (36 bytes)
	PUSH	HL
	LD	B,36
_fopen_clr:
	LD	(HL),A
	INC	HL
	DJNZ	_fopen_clr
	POP	HL		; HL = FCB start

	; Parse pathname into FCB
	; HL = FCB, pathname at IX+4
	PUSH	HL
	LD	E,(IX+4)
	LD	D,(IX+5)	; DE = pathname
	CALL	_parse_fcb
	POP	HL		; HL = FCB

	; Get FILE* back
	POP	BC		; B = mode flags
	POP	DE		; DE = FILE*
	PUSH	DE
	PUSH	BC

	; Set DMA to FILE's buffer
	PUSH	HL
	LD	HL,FILE_BUFFER-FILE_FCB
	ADD	HL,DE
	EX	DE,HL		; DE = buffer address
	LD	C,BDOS_SETDMA
	CALL	BDOS
	POP	DE		; DE = FCB

	; Open or create based on mode
	POP	BC		; B = mode flags
	POP	HL		; HL = FILE*
	PUSH	HL
	PUSH	BC

	LD	A,B
	AND	FLAG_WRITE
	JR	Z,_fopen_doopen

	; Write mode - delete existing, create new
	PUSH	DE
	LD	C,BDOS_DELETE
	CALL	BDOS
	POP	DE
	LD	C,BDOS_MAKE
	CALL	BDOS
	JR	_fopen_check

_fopen_doopen:
	; Read mode - open existing
	LD	C,BDOS_OPEN
	CALL	BDOS

_fopen_check:
	; A = 0xFF on error
	CP	0FFH
	JR	NZ,_fopen_ok

	; Open failed
	POP	BC
	POP	HL
	LD	HL,0
	JP	_fopen_ret

_fopen_ok:
	; Set flags and return FILE*
	POP	BC		; B = mode flags
	POP	HL		; HL = FILE*
	PUSH	HL
	INC	HL		; Point to flags
	LD	A,B
	OR	FLAG_OPEN
	LD	(HL),A
	POP	HL		; Return FILE*
	JR	_fopen_ret

_fopen_ret:
	POP	DE
	POP	BC
	POP	IX
	RET

; ============================================================
; Internal: Parse pathname into FCB
; DE = pathname, HL = FCB
; ============================================================
_parse_fcb:
	PUSH	BC
	PUSH	HL

	; Check for drive letter
	LD	A,(DE)
	INC	DE
	LD	B,A
	LD	A,(DE)
	CP	':'
	JR	NZ,_parse_nodrive
	; Has drive letter
	LD	A,B
	AND	0DFH		; Uppercase
	SUB	'A'-1		; A=1, B=2, etc.
	LD	(HL),A
	INC	DE		; Skip colon
	JR	_parse_name

_parse_nodrive:
	DEC	DE		; Back up
	XOR	A		; Default drive
	LD	(HL),A

_parse_name:
	INC	HL		; Point to filename
	LD	B,8		; 8 chars max
_parse_name_loop:
	LD	A,(DE)
	OR	A
	JR	Z,_parse_pad_name
	CP	'.'
	JR	Z,_parse_ext
	; Store uppercase
	AND	0DFH
	LD	(HL),A
	INC	HL
	INC	DE
	DJNZ	_parse_name_loop
	; Skip to dot or end
_parse_skip:
	LD	A,(DE)
	OR	A
	JR	Z,_parse_pad_name
	CP	'.'
	JR	Z,_parse_ext
	INC	DE
	JR	_parse_skip

_parse_pad_name:
	; Pad remaining name with spaces
	LD	A,' '
_parse_pad_n:
	LD	A,B
	OR	A
	JR	Z,_parse_ext_start
	LD	A,' '
	LD	(HL),A
	INC	HL
	DEC	B
	JR	_parse_pad_n

_parse_ext:
	INC	DE		; Skip dot
	; Pad any remaining name chars
	JR	_parse_pad_name

_parse_ext_start:
	; Now at extension position (FCB+9)
	LD	B,3		; 3 chars max
_parse_ext_loop:
	LD	A,(DE)
	OR	A
	JR	Z,_parse_pad_ext
	AND	0DFH		; Uppercase
	LD	(HL),A
	INC	HL
	INC	DE
	DJNZ	_parse_ext_loop
	JR	_parse_done

_parse_pad_ext:
	LD	A,B
	OR	A
	JR	Z,_parse_done
	LD	A,' '
	LD	(HL),A
	INC	HL
	DEC	B
	JR	_parse_pad_ext

_parse_done:
	POP	HL
	POP	BC
	RET

; ============================================================
; int fclose(FILE *stream)
; Close a file
; ============================================================
	PUBLIC	_fclose
_fclose:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	PUSH	BC
	PUSH	DE

	LD	L,(IX+4)
	LD	H,(IX+5)	; HL = stream

	; Check for NULL or console streams
	LD	A,H
	OR	L
	JR	Z,_fclose_ok
	LD	A,(HL)
	CP	3
	JR	C,_fclose_ok	; stdin/stdout/stderr

	; Check if open
	INC	HL
	LD	A,(HL)
	AND	FLAG_OPEN
	JR	Z,_fclose_ok

	; If write mode, flush buffer
	LD	A,(HL)
	AND	FLAG_WRITE
	JR	Z,_fclose_doclose

	; Flush write buffer
	DEC	HL
	PUSH	HL
	CALL	_fflush_internal
	POP	HL
	INC	HL

_fclose_doclose:
	DEC	HL		; Back to FILE start
	PUSH	HL

	; Set DMA and close
	LD	DE,FILE_FCB
	ADD	HL,DE
	EX	DE,HL		; DE = FCB

	LD	C,BDOS_CLOSE
	CALL	BDOS

	; Clear flags
	POP	HL
	INC	HL		; flags
	LD	(HL),0

_fclose_ok:
	LD	HL,0
	POP	DE
	POP	BC
	POP	IX
	RET

; ============================================================
; int fgetc(FILE *stream)
; Get character from stream
; ============================================================
	PUBLIC	_fgetc
_fgetc:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	PUSH	BC
	PUSH	DE

	LD	L,(IX+4)
	LD	H,(IX+5)	; HL = stream

	; Check for NULL
	LD	A,H
	OR	L
	JP	Z,_fgetc_eof

	; Check if stdin
	LD	A,(HL)
	OR	A
	JR	NZ,_fgetc_file

	; stdin - read from console
	LD	C,CONIN
	CALL	BDOS
	LD	L,A
	LD	H,0
	JP	_fgetc_ret

_fgetc_file:
	; Check for ungetc char first
	PUSH	HL
	INC	HL
	INC	HL		; unget
	LD	A,(HL)
	CP	0FFH
	JR	Z,_fgetc_nobuf
	; Return unget char
	LD	B,A
	LD	A,0FFH
	LD	(HL),A		; Clear unget
	POP	HL
	LD	L,B
	LD	H,0
	JP	_fgetc_ret

_fgetc_nobuf:
	POP	HL

	; Check EOF flag
	PUSH	HL
	INC	HL		; flags
	LD	A,(HL)
	AND	FLAG_EOF
	JR	NZ,_fgetc_iseof

	; Check if buffer has data
	INC	HL		; unget
	INC	HL		; bufpos
	LD	B,(HL)
	INC	HL		; bufcnt
	LD	A,(HL)
	CP	B		; bufcnt > bufpos?
	JR	Z,_fgetc_refill
	JR	C,_fgetc_refill

	; Get byte from buffer
	POP	HL
	PUSH	HL
	LD	DE,FILE_BUFFER
	ADD	HL,DE		; HL = buffer start
	LD	E,B
	LD	D,0
	ADD	HL,DE		; HL = buffer[bufpos]
	LD	A,(HL)
	; Check for Ctrl-Z (CP/M EOF marker)
	CP	1AH
	JR	Z,_fgetc_seteof
	LD	E,A		; Save char

	; Increment bufpos
	POP	HL
	PUSH	HL
	LD	BC,FILE_BUFPOS
	ADD	HL,BC
	INC	(HL)

	; Skip CR characters for Unix text compatibility
	LD	A,E
	CP	0DH
	JP	Z,_fgetc_nobuf	; Skip CR, get next char

	POP	HL
	LD	L,E
	LD	H,0
	JP	_fgetc_ret

_fgetc_refill:
	; Need to read more data
	POP	HL
	PUSH	HL

	; Set DMA to buffer
	LD	DE,FILE_BUFFER
	ADD	HL,DE
	EX	DE,HL
	LD	C,BDOS_SETDMA
	CALL	BDOS

	; Read record
	POP	HL
	PUSH	HL
	LD	DE,FILE_FCB
	ADD	HL,DE
	EX	DE,HL
	LD	C,BDOS_READ
	CALL	BDOS

	; A = 0 success, non-zero = EOF/error
	OR	A
	JR	NZ,_fgetc_seteof

	; Reset buffer position, set count
	POP	HL
	PUSH	HL
	LD	BC,FILE_BUFPOS
	ADD	HL,BC
	LD	(HL),0		; bufpos = 0
	INC	HL
	LD	(HL),128	; bufcnt = 128

	; Get first byte
	POP	HL
	PUSH	HL
	LD	DE,FILE_BUFFER
	ADD	HL,DE
	LD	A,(HL)
	; Check for Ctrl-Z (CP/M EOF marker)
	CP	1AH
	JR	Z,_fgetc_seteof
	LD	E,A

	; Increment bufpos
	POP	HL
	PUSH	HL
	LD	BC,FILE_BUFPOS
	ADD	HL,BC
	INC	(HL)

	; Skip CR characters for Unix text compatibility
	LD	A,E
	CP	0DH
	JP	Z,_fgetc_nobuf	; Skip CR, get next char

	POP	HL
	LD	L,E
	LD	H,0
	JP	_fgetc_ret

_fgetc_seteof:
	POP	HL
	PUSH	HL
	INC	HL		; flags
	LD	A,(HL)
	OR	FLAG_EOF
	LD	(HL),A
_fgetc_iseof:
	POP	HL
_fgetc_eof:
	LD	HL,-1
_fgetc_ret:
	POP	DE
	POP	BC
	POP	IX
	RET

; ============================================================
; int fputc(int c, FILE *stream)
; Put character to stream
; ============================================================
	PUBLIC	_fputc
_fputc:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	PUSH	BC
	PUSH	DE

	LD	L,(IX+6)
	LD	H,(IX+7)	; HL = stream

	; Check for NULL
	LD	A,H
	OR	L
	JP	Z,_fputc_err

	; Check if stdout/stderr
	LD	A,(HL)
	CP	3
	JR	NC,_fputc_file

	; Console output
	LD	E,(IX+4)
	LD	C,CONOUT
	CALL	BDOS
	LD	L,(IX+4)
	LD	H,0
	JP	_fputc_ret

_fputc_file:
	; Check if buffer full
	PUSH	HL
	LD	BC,FILE_BUFPOS
	ADD	HL,BC
	LD	A,(HL)
	CP	128
	JR	C,_fputc_store

	; Buffer full - flush it
	POP	HL
	PUSH	HL
	CALL	_fflush_internal
	; Check for error
	LD	A,H
	OR	L
	JR	NZ,_fputc_flerr
	POP	HL
	PUSH	HL
	LD	BC,FILE_BUFPOS
	ADD	HL,BC

_fputc_store:
	; Store byte in buffer
	LD	A,(HL)		; A = bufpos
	POP	HL
	PUSH	HL
	LD	DE,FILE_BUFFER
	ADD	HL,DE
	LD	E,A
	LD	D,0
	ADD	HL,DE		; HL = buffer[bufpos]
	LD	A,(IX+4)
	LD	(HL),A		; Store the byte

	; Increment bufpos
	POP	HL
	PUSH	HL
	LD	DE,FILE_BUFPOS
	ADD	HL,DE
	INC	(HL)		; bufpos++

	POP	HL
	LD	L,(IX+4)
	LD	H,0
	JP	_fputc_ret

_fputc_flerr:
	POP	HL
_fputc_err:
	LD	HL,-1
_fputc_ret:
	POP	DE
	POP	BC
	POP	IX
	RET

; ============================================================
; Internal: Flush write buffer
; HL = FILE*
; Returns HL=0 success, HL=-1 error
; ============================================================
_fflush_internal:
	PUSH	BC
	PUSH	DE
	PUSH	HL

	; Check bufpos
	LD	BC,FILE_BUFPOS
	ADD	HL,BC
	LD	A,(HL)
	OR	A
	JR	Z,_fflush_ok	; Nothing to flush

	; Pad rest of buffer with Ctrl-Z (CP/M EOF)
	LD	B,A		; B = bytes written
	POP	HL
	PUSH	HL
	LD	DE,FILE_BUFFER
	ADD	HL,DE
	LD	E,B
	LD	D,0
	ADD	HL,DE		; HL = buffer[bufpos]
	LD	A,128
	SUB	B
	LD	B,A		; B = bytes to pad
	JR	Z,_fflush_write
	LD	A,1AH		; Ctrl-Z
_fflush_pad:
	LD	(HL),A
	INC	HL
	DJNZ	_fflush_pad

_fflush_write:
	; Set DMA
	POP	HL
	PUSH	HL
	LD	DE,FILE_BUFFER
	ADD	HL,DE
	EX	DE,HL
	LD	C,BDOS_SETDMA
	CALL	BDOS

	; Write record
	POP	HL
	PUSH	HL
	LD	DE,FILE_FCB
	ADD	HL,DE
	EX	DE,HL
	LD	C,BDOS_WRITE
	CALL	BDOS

	OR	A
	JR	NZ,_fflush_err

	; Reset bufpos
	POP	HL
	PUSH	HL
	LD	BC,FILE_BUFPOS
	ADD	HL,BC
	LD	(HL),0

_fflush_ok:
	POP	HL
	LD	HL,0
	POP	DE
	POP	BC
	RET

_fflush_err:
	POP	HL
	PUSH	HL
	INC	HL		; flags
	LD	A,(HL)
	OR	FLAG_ERROR
	LD	(HL),A
	POP	HL
	LD	HL,-1
	POP	DE
	POP	BC
	RET

; ============================================================
; char *fgets(char *s, int size, FILE *stream)
; Read line from stream
; ============================================================
	PUBLIC	_fgets
_fgets:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	PUSH	BC
	PUSH	DE

	LD	L,(IX+8)
	LD	H,(IX+9)	; stream
	LD	A,H
	OR	L
	JR	Z,_fgets_null

	LD	E,(IX+4)	; buffer
	LD	D,(IX+5)
	LD	C,(IX+6)	; size
	LD	B,(IX+7)
	PUSH	DE		; Save for return

	DEC	BC		; Leave room for null
	LD	A,B
	OR	C
	JR	Z,_fgets_term

_fgets_loop:
	PUSH	BC
	PUSH	DE
	PUSH	HL		; Save stream
	PUSH	HL		; Pass stream as arg
	CALL	_fgetc
	POP	BC		; Discard arg
	; HL = fgetc return value, save it
	LD	A,H		; Check high byte first
	LD	B,L		; B = character (save before POP)
	POP	HL		; Restore stream to HL
	OR	A
	JR	NZ,_fgets_eof	; EOF if H != 0 (return was 0xFFxx)
	LD	A,B		; A = character
	POP	DE		; Restore dest pointer
	POP	BC		; Restore count

	LD	(DE),A
	INC	DE
	DEC	BC

	CP	0AH		; LF?
	JR	Z,_fgets_term
	CP	0DH		; CR?
	JR	Z,_fgets_term

	LD	A,B
	OR	C
	JR	NZ,_fgets_loop

_fgets_term:
	XOR	A
	LD	(DE),A
	POP	HL		; Return buffer
	POP	DE
	POP	BC
	POP	IX
	RET

_fgets_eof:
	; Stack has: [BC_count][DE_dest]
	; HL = stream (just restored)
	POP	DE		; Restore dest pointer
	POP	BC		; Restore count
	; Check if we read anything
	LD	A,(IX+4)
	CP	E
	JR	NZ,_fgets_term	; Got some data
	LD	A,(IX+5)
	CP	D
	JR	NZ,_fgets_term
	; No data read - return NULL
	; Pop saved buffer before going to _fgets_null
	POP	DE
_fgets_null:
	LD	HL,0
	POP	DE
	POP	BC
	POP	IX
	RET

; ============================================================
; int fputs(const char *s, FILE *stream)
; Write string to stream
; ============================================================
	PUBLIC	_fputs
_fputs:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	PUSH	BC
	PUSH	DE

	LD	L,(IX+6)
	LD	H,(IX+7)	; stream
	LD	A,H
	OR	L
	JR	Z,_fputs_err

	LD	E,(IX+4)	; string
	LD	D,(IX+5)

_fputs_loop:
	LD	A,(DE)
	OR	A
	JR	Z,_fputs_ok

	PUSH	DE
	PUSH	HL
	; Push args for fputc(char, stream)
	PUSH	HL		; stream
	LD	L,A
	LD	H,0
	PUSH	HL		; char
	CALL	_fputc
	POP	BC
	POP	BC
	POP	HL
	POP	DE

	; Check for error
	LD	A,H
	INC	A
	JR	Z,_fputs_err	; HL was -1

	INC	DE
	JR	_fputs_loop

_fputs_ok:
	LD	HL,0
	POP	DE
	POP	BC
	POP	IX
	RET

_fputs_err:
	LD	HL,-1
	POP	DE
	POP	BC
	POP	IX
	RET

; ============================================================
; size_t fread(void *ptr, size_t size, size_t nmemb, FILE *stream)
; Read data from stream
; ============================================================
	PUBLIC	_fread
_fread:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	PUSH	BC
	PUSH	DE

	; Calculate total bytes = size * nmemb
	LD	L,(IX+6)
	LD	H,(IX+7)	; size
	LD	E,(IX+8)
	LD	D,(IX+9)	; nmemb
	CALL	__mul16		; HL = total bytes
	LD	B,H
	LD	C,L		; BC = bytes to read

	; If zero, return 0
	LD	A,B
	OR	C
	JR	Z,_fread_done

	; Save dest pointer
	LD	L,(IX+4)
	LD	H,(IX+5)	; HL = dest ptr
	LD	(_fread_ptr),HL

	; Initialize read count
	LD	HL,0
	LD	(_fread_cnt),HL

_fread_loop:
	; Call fgetc(stream)
	LD	L,(IX+10)
	LD	H,(IX+11)	; stream
	PUSH	BC		; Save remaining count
	PUSH	HL
	CALL	_fgetc
	POP	DE		; Clean up arg

	; Check for EOF (returns -1 = 0xFFFF)
	LD	A,H
	AND	L
	INC	A		; If HL=0xFFFF, A becomes 0
	JR	Z,_fread_eof

	; Store byte
	LD	A,L
	LD	HL,(_fread_ptr)
	LD	(HL),A
	INC	HL
	LD	(_fread_ptr),HL

	; Increment count
	LD	HL,(_fread_cnt)
	INC	HL
	LD	(_fread_cnt),HL

	; Decrement BC and continue
	POP	BC		; Restore remaining count
	DEC	BC
	LD	A,B
	OR	C
	JR	NZ,_fread_loop
	JR	_fread_done

_fread_eof:
	POP	BC		; Clean up saved count

_fread_done:
	; Return items read (cnt / size)
	; __div16 does HL = DE / HL, so DE = cnt, HL = size
	LD	E,(IX+6)
	LD	D,(IX+7)	; DE = size (temporarily)
	LD	A,D
	OR	E
	JR	Z,_fread_ret
	LD	HL,(_fread_cnt)	; HL = cnt
	EX	DE,HL		; Now DE = cnt, HL = size
	CALL	__div16		; HL = cnt / size

_fread_ret:
	POP	DE
	POP	BC
	POP	IX
	RET

; ============================================================
; size_t fwrite(const void *ptr, size_t size, size_t nmemb, FILE *stream)
; Write data to stream
; ============================================================
	PUBLIC	_fwrite
	EXTRN	__div16
_fwrite:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	PUSH	BC
	PUSH	DE

	; Simple implementation - write byte by byte
	LD	L,(IX+6)
	LD	H,(IX+7)	; size
	LD	E,(IX+8)
	LD	D,(IX+9)	; nmemb
	CALL	__mul16		; HL = total bytes
	LD	B,H
	LD	C,L		; BC = bytes to write

	LD	A,B
	OR	C
	JR	Z,_fwrite_done

	LD	L,(IX+4)
	LD	H,(IX+5)	; HL = ptr (source)
	LD	(_fwrite_ptr),HL
	LD	HL,0
	LD	(_fwrite_cnt),HL

_fwrite_loop:
	LD	A,B
	OR	C
	JR	Z,_fwrite_done

	; Get byte from source
	LD	HL,(_fwrite_ptr)
	LD	A,(HL)
	INC	HL
	LD	(_fwrite_ptr),HL

	; Write to stream
	PUSH	BC
	LD	L,(IX+10)
	LD	H,(IX+11)	; stream
	PUSH	HL
	LD	L,A
	LD	H,0
	PUSH	HL
	CALL	_fputc
	POP	HL
	POP	HL
	POP	BC

	; Check error
	LD	A,H
	INC	A
	JR	Z,_fwrite_done	; Error

	LD	HL,(_fwrite_cnt)
	INC	HL
	LD	(_fwrite_cnt),HL
	DEC	BC
	JR	_fwrite_loop

_fwrite_done:
	; Return items written (cnt / size)
	; __div16 does HL = DE / HL, so DE = cnt, HL = size
	LD	E,(IX+6)
	LD	D,(IX+7)	; DE = size (temporarily)
	LD	A,D
	OR	E
	JR	Z,_fwrite_ret
	LD	HL,(_fwrite_cnt)	; HL = cnt
	EX	DE,HL		; Now DE = cnt, HL = size
	CALL	__div16		; HL = cnt / size
_fwrite_ret:
	POP	DE
	POP	BC
	POP	IX
	RET

; ============================================================
; int feof(FILE *stream)
; Check EOF flag
; ============================================================
	PUBLIC	_feof
_feof:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	LD	L,(IX+4)
	LD	H,(IX+5)
	LD	A,H
	OR	L
	JR	Z,_feof_yes
	INC	HL		; flags
	LD	A,(HL)
	AND	FLAG_EOF
	LD	L,A
	LD	H,0
	POP	IX
	RET
_feof_yes:
	LD	HL,1
	POP	IX
	RET

; ============================================================
; int ferror(FILE *stream)
; Check error flag
; ============================================================
	PUBLIC	_ferror
_ferror:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	LD	L,(IX+4)
	LD	H,(IX+5)
	LD	A,H
	OR	L
	JR	Z,_ferror_yes
	INC	HL		; flags
	LD	A,(HL)
	AND	FLAG_ERROR
	JR	Z,_ferror_no
	LD	HL,1
	POP	IX
	RET
_ferror_no:
	LD	HL,0
	POP	IX
	RET
_ferror_yes:
	LD	HL,1
	POP	IX
	RET

; ============================================================
; void clearerr(FILE *stream)
; Clear error and EOF flags
; ============================================================
	PUBLIC	_clearerr
_clearerr:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	LD	L,(IX+4)
	LD	H,(IX+5)
	LD	A,H
	OR	L
	JR	Z,_clearerr_ret
	INC	HL		; flags
	LD	A,(HL)
	AND	0FFH - FLAG_EOF - FLAG_ERROR
	LD	(HL),A
_clearerr_ret:
	POP	IX
	RET

; ============================================================
; int ungetc(int c, FILE *stream)
; Push character back to stream
; ============================================================
	PUBLIC	_ungetc
_ungetc:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	LD	L,(IX+6)
	LD	H,(IX+7)	; stream
	LD	A,H
	OR	L
	JR	Z,_ungetc_err
	INC	HL
	INC	HL		; unget
	LD	A,(IX+4)
	LD	(HL),A
	LD	L,A
	LD	H,0
	POP	IX
	RET
_ungetc_err:
	LD	HL,-1
	POP	IX
	RET

; ============================================================
; int fflush(FILE *stream)
; Flush stream buffers
; ============================================================
	PUBLIC	_fflush
_fflush:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	PUSH	BC
	PUSH	DE

	LD	L,(IX+4)
	LD	H,(IX+5)
	LD	A,H
	OR	L
	JR	Z,_fflush_done_pub

	; Check if file (not console)
	LD	A,(HL)
	CP	3
	JR	C,_fflush_done_pub

	; Check write mode
	INC	HL
	LD	A,(HL)
	AND	FLAG_WRITE
	DEC	HL
	JR	Z,_fflush_done_pub

	CALL	_fflush_internal
	POP	DE
	POP	BC
	POP	IX
	RET

_fflush_done_pub:
	LD	HL,0
	POP	DE
	POP	BC
	POP	IX
	RET

; ============================================================
; int fseek(FILE *stream, long offset, int whence)
; Seek to position in file (simplified - sector-based)
; ============================================================
	PUBLIC	_fseek
_fseek:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	PUSH	BC
	PUSH	DE

	LD	L,(IX+4)
	LD	H,(IX+5)	; stream
	LD	A,H
	OR	L
	JR	Z,_fseek_err

	; Check if file
	LD	A,(HL)
	CP	3
	JR	C,_fseek_err

	; Flush buffer first if write mode
	PUSH	HL
	INC	HL
	LD	A,(HL)
	AND	FLAG_WRITE
	JR	Z,_fseek_noflush
	DEC	HL
	CALL	_fflush_internal
	JR	_fseek_doset
_fseek_noflush:
	DEC	HL
_fseek_doset:
	POP	HL
	PUSH	HL

	; Get offset (lower 16 bits only for simplicity)
	LD	E,(IX+6)
	LD	D,(IX+7)	; offset low word

	; Check whence
	LD	A,(IX+10)
	OR	A
	JR	NZ,_fseek_err_pop	; Only SEEK_SET supported

	; Convert byte offset to record number (divide by 128)
	; Shift DE right 7 times
	SRL	D
	RR	E
	SRL	D
	RR	E
	SRL	D
	RR	E
	SRL	D
	RR	E
	SRL	D
	RR	E
	SRL	D
	RR	E
	SRL	D
	RR	E		; DE = record number

	; Set random record in FCB
	POP	HL
	PUSH	HL
	LD	BC,FILE_FCB+33	; r0, r1 in FCB
	ADD	HL,BC
	LD	(HL),E		; r0
	INC	HL
	LD	(HL),D		; r1
	INC	HL
	LD	(HL),0		; r2

	; Clear buffer
	POP	HL
	PUSH	HL
	LD	BC,FILE_BUFPOS
	ADD	HL,BC
	LD	(HL),0		; bufpos
	INC	HL
	LD	(HL),0		; bufcnt

	; Clear EOF flag
	POP	HL
	PUSH	HL
	INC	HL
	LD	A,(HL)
	AND	0FFH - FLAG_EOF
	LD	(HL),A

	POP	HL
	LD	HL,0
	POP	DE
	POP	BC
	POP	IX
	RET

_fseek_err_pop:
	POP	HL
_fseek_err:
	LD	HL,-1
	POP	DE
	POP	BC
	POP	IX
	RET

; ============================================================
; long ftell(FILE *stream)
; Return current position (simplified)
; ============================================================
	PUBLIC	_ftell
_ftell:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP

	LD	L,(IX+4)
	LD	H,(IX+5)
	LD	A,H
	OR	L
	JR	Z,_ftell_err

	LD	A,(HL)
	CP	3
	JR	C,_ftell_err

	; Get record number from FCB
	LD	DE,FILE_FCB+33
	ADD	HL,DE
	LD	E,(HL)		; r0
	INC	HL
	LD	D,(HL)		; r1

	; Convert to byte offset (multiply by 128)
	; Shift DE left 7 times, result in DEHL
	LD	H,D
	LD	L,E
	LD	DE,0

	SLA	L
	RL	H
	RL	E
	RL	D		; x2
	SLA	L
	RL	H
	RL	E
	RL	D		; x4
	SLA	L
	RL	H
	RL	E
	RL	D		; x8
	SLA	L
	RL	H
	RL	E
	RL	D		; x16
	SLA	L
	RL	H
	RL	E
	RL	D		; x32
	SLA	L
	RL	H
	RL	E
	RL	D		; x64
	SLA	L
	RL	H
	RL	E
	RL	D		; x128

	; Add buffer position
	; (simplified - not adding bufpos)
	POP	IX
	RET

_ftell_err:
	LD	HL,-1
	LD	DE,-1
	POP	IX
	RET

; ============================================================
; void rewind(FILE *stream)
; Rewind to beginning of file
; ============================================================
	PUBLIC	_rewind
_rewind:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	PUSH	BC
	PUSH	DE

	; Call fseek(stream, 0L, SEEK_SET)
	LD	L,(IX+4)
	LD	H,(IX+5)
	PUSH	HL
	LD	HL,0
	PUSH	HL		; whence = SEEK_SET
	PUSH	HL		; offset high = 0
	PUSH	HL		; offset low = 0
	LD	L,(IX+4)
	LD	H,(IX+5)
	PUSH	HL		; stream
	CALL	_fseek
	POP	HL
	POP	HL
	POP	HL
	POP	HL
	POP	HL

	POP	DE
	POP	BC
	POP	IX
	RET

; ============================================================
; int remove(const char *pathname)
; Delete a file
; Returns 0 on success, -1 on error
; ============================================================
	PUBLIC	_remove
_remove:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	PUSH	BC
	PUSH	DE

	; Parse pathname into temporary FCB
	LD	E,(IX+4)
	LD	D,(IX+5)	; DE = pathname
	LD	HL,_tmp_fcb
	CALL	_parse_fcb

	; Delete the file
	LD	DE,_tmp_fcb
	LD	C,BDOS_DELETE
	CALL	BDOS

	; A = 0xFF on error
	CP	0FFH
	JR	Z,_remove_err
	LD	HL,0
	JR	_remove_ret
_remove_err:
	LD	HL,-1
_remove_ret:
	POP	DE
	POP	BC
	POP	IX
	RET

; ============================================================
; int rename(const char *oldpath, const char *newpath)
; Rename a file
; Returns 0 on success, -1 on error
; ============================================================
	PUBLIC	_rename
_rename:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	PUSH	BC
	PUSH	DE

	; Parse old pathname into FCB (first 16 bytes)
	LD	E,(IX+4)
	LD	D,(IX+5)	; DE = oldpath
	LD	HL,_tmp_fcb
	CALL	_parse_fcb

	; Parse new pathname into FCB+16 (destination)
	LD	E,(IX+6)
	LD	D,(IX+7)	; DE = newpath
	LD	HL,_tmp_fcb+16
	CALL	_parse_fcb

	; CP/M rename uses DE pointing to FCB with old name in first 16 bytes
	; and new name in second 16 bytes
	LD	DE,_tmp_fcb
	LD	C,BDOS_RENAME
	CALL	BDOS

	; A = 0xFF on error
	CP	0FFH
	JR	Z,_rename_err
	LD	HL,0
	JR	_rename_ret
_rename_err:
	LD	HL,-1
_rename_ret:
	POP	DE
	POP	BC
	POP	IX
	RET

; ============================================================
; FILE *tmpfile(void)
; Create and open a temporary file for writing
; File is automatically deleted when closed (by using $$$ extension)
; ============================================================
	PUBLIC	_tmpfile
_tmpfile:
	PUSH	IX
	PUSH	BC
	PUSH	DE

	; Generate unique temp name
	LD	HL,_tmpfile_name
	CALL	_gen_tmpnam

	; Open with "w+" mode (create new)
	LD	HL,_tmpfile_name
	PUSH	HL
	LD	HL,_tmpfile_mode
	PUSH	HL
	CALL	_fopen
	POP	BC
	POP	BC

	; Mark this file for delete on close (use $$$ extension)
	; Actually, CP/M doesn't have auto-delete, so we rely on unique names

	POP	DE
	POP	BC
	POP	IX
	RET

_tmpfile_mode:
	DB	'w',0

; ============================================================
; char *tmpnam(char *s)
; Generate a unique temporary file name
; If s is NULL, returns pointer to internal static buffer
; ============================================================
	PUBLIC	_tmpnam
_tmpnam:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	PUSH	BC
	PUSH	DE

	; Get buffer pointer
	LD	L,(IX+4)
	LD	H,(IX+5)
	LD	A,H
	OR	L
	JR	NZ,_tmpnam_usebuf
	; Use internal buffer
	LD	HL,_tmpnam_buf
_tmpnam_usebuf:
	PUSH	HL		; Save destination
	CALL	_gen_tmpnam
	POP	HL		; Return destination

	POP	DE
	POP	BC
	POP	IX
	RET

; Internal: Generate temp name into HL
_gen_tmpnam:
	PUSH	BC
	PUSH	DE
	PUSH	HL

	; Format: TMP00000.$$$
	LD	(HL),'T'
	INC	HL
	LD	(HL),'M'
	INC	HL
	LD	(HL),'P'
	INC	HL

	; Get counter and convert to 5 digits
	LD	DE,(_tmpnam_cnt)
	INC	DE
	LD	(_tmpnam_cnt),DE

	; Convert DE to 5 decimal digits
	LD	BC,10000
	CALL	_div16
	ADD	A,'0'
	LD	(HL),A
	INC	HL
	; Remainder in DE
	LD	BC,1000
	CALL	_div16
	ADD	A,'0'
	LD	(HL),A
	INC	HL
	LD	BC,100
	CALL	_div16
	ADD	A,'0'
	LD	(HL),A
	INC	HL
	LD	BC,10
	CALL	_div16
	ADD	A,'0'
	LD	(HL),A
	INC	HL
	LD	A,E
	ADD	A,'0'
	LD	(HL),A
	INC	HL

	; Add .$$$ extension
	LD	(HL),'.'
	INC	HL
	LD	(HL),'$'
	INC	HL
	LD	(HL),'$'
	INC	HL
	LD	(HL),'$'
	INC	HL
	LD	(HL),0

	POP	HL
	POP	DE
	POP	BC
	RET

; Internal: Divide DE by BC, quotient in A, remainder in DE
_div16:
	XOR	A
_div16_loop:
	LD	H,D
	LD	L,E
	OR	A
	SBC	HL,BC
	JR	C,_div16_done
	EX	DE,HL
	INC	A
	JR	_div16_loop
_div16_done:
	RET

_tmpnam_cnt:
	DW	0
_tmpnam_buf:
	DS	13		; TMP00000.$$$ + null
_tmpfile_name:
	DS	13

; ============================================================
; FILE *freopen(const char *pathname, const char *mode, FILE *stream)
; Reopen stream with new file
; ============================================================
	PUBLIC	_freopen
_freopen:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	PUSH	BC
	PUSH	DE

	; Close current stream
	LD	L,(IX+8)
	LD	H,(IX+9)
	PUSH	HL
	CALL	_fclose
	POP	BC

	; Now reopen with new file
	; Can't use the same FILE slot reliably, so just call fopen
	LD	L,(IX+4)
	LD	H,(IX+5)	; pathname
	PUSH	HL
	LD	L,(IX+6)
	LD	H,(IX+7)	; mode
	PUSH	HL
	CALL	_fopen
	POP	BC
	POP	BC

	; HL = new FILE* or NULL
	POP	DE
	POP	BC
	POP	IX
	RET

; ============================================================
; int getc(FILE *stream)
; Get character from stream (equivalent to fgetc)
; ============================================================
	PUBLIC	_getc
_getc:
	JP	_fgetc		; Just tail-call fgetc

; ============================================================
; int putc(int c, FILE *stream)
; Put character to stream (equivalent to fputc)
; ============================================================
	PUBLIC	_putc
_putc:
	JP	_fputc		; Just tail-call fputc

; ============================================================
; int fgetpos(FILE *stream, fpos_t *pos)
; Get current file position
; Returns 0 on success, non-zero on error
; ============================================================
	PUBLIC	_fgetpos
_fgetpos:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	PUSH	BC
	PUSH	DE

	; Call ftell to get position
	LD	L,(IX+4)
	LD	H,(IX+5)	; stream
	PUSH	HL
	CALL	_ftell
	POP	BC
	; DEHL = position (long)

	; Check for error (returns -1 as 0xFFFFFFFF)
	LD	A,D
	AND	E
	AND	H
	AND	L
	INC	A
	JR	Z,_fgetpos_err

	; Store position at *pos
	LD	C,(IX+6)
	LD	B,(IX+7)	; BC = pos pointer
	LD	A,L
	LD	(BC),A
	INC	BC
	LD	A,H
	LD	(BC),A
	INC	BC
	LD	A,E
	LD	(BC),A
	INC	BC
	LD	A,D
	LD	(BC),A

	LD	HL,0		; Return success
	JR	_fgetpos_ret

_fgetpos_err:
	LD	HL,-1
_fgetpos_ret:
	POP	DE
	POP	BC
	POP	IX
	RET

; ============================================================
; int fsetpos(FILE *stream, const fpos_t *pos)
; Set file position
; Returns 0 on success, non-zero on error
; ============================================================
	PUBLIC	_fsetpos
_fsetpos:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	PUSH	BC
	PUSH	DE

	; Load position from *pos
	LD	L,(IX+6)
	LD	H,(IX+7)	; HL = pos pointer
	LD	E,(HL)
	INC	HL
	LD	D,(HL)
	INC	HL
	LD	C,(HL)
	INC	HL
	LD	B,(HL)		; BCDE = position
	PUSH	BC		; High word
	PUSH	DE		; Low word

	; Call fseek(stream, pos, SEEK_SET)
	LD	HL,0
	PUSH	HL		; whence = SEEK_SET
	LD	L,(IX+4)
	LD	H,(IX+5)
	PUSH	HL		; stream
	; Stack: stream, whence(0), pos_low, pos_high
	; fseek expects: stream, offset_low, offset_high, whence
	; Need to rearrange...

	; Actually let's redo this properly
	POP	HL		; stream
	POP	BC		; whence
	POP	DE		; pos low
	POP	BC		; pos high
	; Now push in correct order for fseek(stream, offset, whence)
	LD	A,0
	PUSH	AF		; whence = SEEK_SET (use AF as 16-bit 0)
	INC	SP		; Adjust for 1-byte push
	DEC	SP
	LD	HL,0
	PUSH	HL		; whence = 0
	PUSH	BC		; offset high
	PUSH	DE		; offset low
	LD	L,(IX+4)
	LD	H,(IX+5)
	PUSH	HL		; stream
	CALL	_fseek
	; Clean up stack (5 words = 10 bytes)
	LD	HL,10
	ADD	HL,SP
	LD	SP,HL

	; fseek returns 0 on success, -1 on error
	; HL already has return value

	POP	DE
	POP	BC
	POP	IX
	RET

; ============================================================
; void setbuf(FILE *stream, char *buf)
; Set stream buffer (no-op on CP/M - fixed buffers)
; ============================================================
	PUBLIC	_setbuf
_setbuf:
	; No-op - CP/M uses fixed 128-byte buffers
	RET

; ============================================================
; int setvbuf(FILE *stream, char *buf, int mode, size_t size)
; Set stream buffering (limited support on CP/M)
; ============================================================
	PUBLIC	_setvbuf
_setvbuf:
	; No-op - CP/M uses fixed 128-byte buffers
	; Always return 0 (success) for compatibility
	LD	HL,0
	RET

; ============================================================
; void perror(const char *s)
; Print error message to stderr
; ============================================================
	PUBLIC	_perror
_perror:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	PUSH	BC
	PUSH	DE

	; Print user string if provided
	LD	L,(IX+4)
	LD	H,(IX+5)
	LD	A,H
	OR	L
	JR	Z,_perror_errmsg
	LD	A,(HL)
	OR	A
	JR	Z,_perror_errmsg

	; Print user string
_perror_uloop:
	LD	A,(HL)
	OR	A
	JR	Z,_perror_colon
	LD	E,A
	PUSH	HL
	LD	C,CONOUT
	CALL	BDOS
	POP	HL
	INC	HL
	JR	_perror_uloop

_perror_colon:
	; Print ": "
	LD	E,':'
	LD	C,CONOUT
	CALL	BDOS
	LD	E,' '
	LD	C,CONOUT
	CALL	BDOS

_perror_errmsg:
	; Print generic error message (CP/M doesn't have errno)
	LD	HL,_perror_msg
_perror_loop:
	LD	A,(HL)
	OR	A
	JR	Z,_perror_nl
	LD	E,A
	PUSH	HL
	LD	C,CONOUT
	CALL	BDOS
	POP	HL
	INC	HL
	JR	_perror_loop

_perror_nl:
	; Print newline
	LD	E,13
	LD	C,CONOUT
	CALL	BDOS
	LD	E,10
	LD	C,CONOUT
	CALL	BDOS

	POP	DE
	POP	BC
	POP	IX
	RET

_perror_msg:
	DB	'Error',0

; Temporary FCB for remove/rename operations
_tmp_fcb:
	DS	36

; ============================================================
; int printf(const char *fmt, ...)
; Minimal printf supporting %d, %s, %c, %x, %%
; Very simplified - no field width, precision, etc.
; ============================================================
	PUBLIC	_printf
	PUBLIC	_prt_float
	PUBLIC	__ftmp
_printf:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	PUSH	BC
	PUSH	DE

	; fmt is at IX+4, first vararg at IX+6

	LD	L,(IX+4)
	LD	H,(IX+5)	; HL = format string pointer
	LD	C,6		; C = offset to next argument

_printf_loop:
	LD	A,(HL)
	OR	A
	JR	Z,_printf_done

	CP	'%'
	JR	Z,_printf_format

	; Regular character - output it
	LD	E,A
	PUSH	HL
	PUSH	BC
	LD	C,CONOUT
	CALL	BDOS
	POP	BC
	POP	HL
	INC	HL
	JR	_printf_loop

_printf_format:
	INC	HL
	; Initialize format state
	XOR	A
	LD	(_printf_width),A
	LD	(_printf_zero),A
	LD	(_printf_upper),A
	LD	(_printf_prec),A
	LD	(_printf_hasprec),A
	LD	A,(HL)
	OR	A
	JP	Z,_printf_done

	CP	'%'
	JR	Z,_printf_pct

_printf_fmt2:
	; Check for '0' flag (only when not in precision and width is 0)
	CP	'0'
	JR	NZ,_printf_not0
	PUSH	AF		; save A='0'
	LD	A,(_printf_hasprec)
	OR	A
	JR	NZ,_printf_0dig	; In precision, '0' is a digit
	LD	A,(_printf_width)
	OR	A
	JR	NZ,_printf_0dig	; Already have width, treat as digit
	; Set zero-padding flag
	LD	A,1
	LD	(_printf_zero),A
	POP	AF
	JR	_printf_skip
_printf_0dig:
	POP	AF		; restore A='0'
	JR	_printf_isdig

_printf_not0:
	; Check for precision start
	CP	'.'
	JR	NZ,_printf_notdot
	PUSH	AF
	LD	A,1
	LD	(_printf_hasprec),A
	POP	AF
	JR	_printf_skip

_printf_notdot:
	; Skip other flags: -, +, space, #
	CP	'-'
	JR	Z,_printf_skip
	CP	'+'
	JR	Z,_printf_skip
	CP	' '
	JR	Z,_printf_skip
	CP	'#'
	JR	Z,_printf_skip
	; Check for digits (1-9)
	CP	'1'
	JR	C,_printf_nodig
	CP	'9'+1
	JR	C,_printf_isdig
_printf_nodig:
	; Skip length modifiers: h, z, L (l handled separately)
	CP	'h'
	JR	Z,_printf_skip
	CP	'z'
	JR	Z,_printf_skip
	CP	'L'
	JR	Z,_printf_skip
	; Now check format specifiers
	CP	's'
	JR	Z,_printf_str

	CP	'd'
	JR	Z,_printf_dec

	CP	'i'
	JR	Z,_printf_dec

	CP	'c'
	JR	Z,_printf_chr

	CP	'x'
	JR	Z,_printf_hex

	CP	'X'
	JR	Z,_printf_hexup

	CP	'u'
	JR	Z,_printf_uns

	CP	'l'
	JR	Z,_printf_long

	CP	'p'
	JR	Z,_printf_ptr

	CP	'f'
	JP	Z,_printf_float

	CP	'g'
	JP	Z,_printf_g
	CP	'G'
	JP	Z,_printf_g

	; Unknown format - skip
	INC	HL
	JP	_printf_loop

_printf_isdig:
	; Parse digit into width or precision
	SUB	'0'
	PUSH	BC
	LD	B,A		; B = new digit
	LD	A,(_printf_hasprec)
	OR	A
	JR	NZ,_printf_precdig
	; Width digit
	LD	A,(_printf_width)
	LD	C,A
	ADD	A,A		; *2
	ADD	A,A		; *4
	ADD	A,C		; *5
	ADD	A,A		; *10
	ADD	A,B		; + digit
	LD	(_printf_width),A
	POP	BC
	JR	_printf_skip
_printf_precdig:
	; Precision digit
	LD	A,(_printf_prec)
	LD	C,A
	ADD	A,A		; *2
	ADD	A,A		; *4
	ADD	A,C		; *5
	ADD	A,A		; *10
	ADD	A,B		; + digit
	LD	(_printf_prec),A
	POP	BC
	; Fall through to _printf_skip

_printf_skip:
	INC	HL
	LD	A,(HL)
	OR	A
	JP	Z,_printf_done
	JR	_printf_fmt2

_printf_hexup:
	; Set uppercase flag and fall through to hex
	PUSH	AF
	LD	A,1
	LD	(_printf_upper),A
	POP	AF
	JR	_printf_hex

_printf_ptr:
	; Output pointer as hex (same as %x but convention)
	JR	_printf_hex

_printf_uns:
	; Output unsigned decimal with width/zero-padding support
	PUSH	HL
	LD	H,0
	LD	L,C
	PUSH	BC
	PUSH	IX
	POP	DE
	ADD	HL,DE
	LD	E,(HL)
	INC	HL
	LD	D,(HL)
	EX	DE,HL		; HL = value
	; Convert HL to decimal digits in _printf_decbuf
	PUSH	IX		; Save frame pointer
	PUSH	BC
	LD	DE,10
	LD	B,0		; digit count
	LD	IX,_printf_decbuf+5	; write pointer (end of buffer)
_printf_uns_cvt:
	CALL	_prt_div16	; HL = HL / 10, DE = remainder
	LD	A,E
	ADD	A,'0'
	DEC	IX
	LD	(IX+0),A
	INC	B
	LD	DE,10
	LD	A,H
	OR	L
	JR	NZ,_printf_uns_cvt
	; B = number of digits, IX = start of digits in buffer
	LD	(_printf_dstart),IX
	LD	A,B
	LD	(_printf_dcnt),A
	POP	BC
	; Now handle width padding
	LD	A,(_printf_width)
	OR	A
	JR	Z,_printf_uns_nopad
	LD	B,A
	LD	A,(_printf_dcnt)
	LD	C,A
	LD	A,B
	SUB	C		; A = padding needed
	JR	Z,_printf_uns_nopad
	JR	C,_printf_uns_nopad
	; A = padding count
	PUSH	BC
	LD	B,A
	LD	A,(_printf_zero)
	OR	A
	LD	A,' '
	JR	Z,_printf_uns_plp
	LD	A,'0'
_printf_uns_plp:
	LD	E,A
	PUSH	AF
	PUSH	BC
	LD	C,CONOUT
	CALL	BDOS
	POP	BC
	POP	AF
	DJNZ	_printf_uns_plp
	POP	BC
_printf_uns_nopad:
	; Output digits from buffer using HL as pointer
	LD	HL,(_printf_dstart)
	LD	A,(_printf_dcnt)
	LD	B,A
_printf_uns_digs:
	LD	E,(HL)
	PUSH	BC
	PUSH	HL
	LD	C,CONOUT
	CALL	BDOS
	POP	HL
	POP	BC
	INC	HL
	DJNZ	_printf_uns_digs
	POP	IX		; Restore frame pointer
	POP	BC		; Restore printf BC
	INC	C
	INC	C
	POP	HL
	INC	HL
	JP	_printf_loop

_printf_long:
	; Handle 'l' modifier - check next char
	INC	HL
	LD	A,(HL)
	CP	'd'
	JR	Z,_printf_ld
	CP	'x'
	JR	Z,_printf_lx
	CP	'u'
	JR	Z,_printf_lu
	CP	'l'
	JR	Z,_printf_ll	; long long
	CP	'f'
	JP	Z,_printf_float	; %lf = same as %f (double == float on Z80)
	CP	'g'
	JP	Z,_printf_g	; %lg = same as %g
	CP	'G'
	JP	Z,_printf_g	; %lG = same as %g
	; Unknown - skip
	JP	_printf_loop

_printf_ll:
	; Handle 'll' modifier - check next char
	INC	HL
	LD	A,(HL)
	CP	'x'
	JP	Z,_printf_llx
	CP	'd'
	JP	Z,_printf_lld
	CP	'u'
	JP	Z,_printf_llu
	; Unknown - skip
	JP	_printf_loop

_printf_ld:
	; Output signed long decimal
	PUSH	HL
	LD	H,0
	LD	L,C
	PUSH	BC
	PUSH	IX
	POP	DE
	ADD	HL,DE		; HL = IX + offset
	; Get 32-bit value: low word, then high word
	LD	E,(HL)
	INC	HL
	LD	D,(HL)		; DE = low word
	INC	HL
	LD	A,(HL)
	INC	HL
	LD	H,(HL)
	LD	L,A		; HL = high word
	EX	DE,HL		; DEHL = 32-bit value (DE=high, HL=low)

	; Check for negative
	BIT	7,D
	JR	Z,_printf_ld_pos

	; Negative - output minus and negate
	PUSH	HL
	PUSH	DE
	LD	E,'-'
	LD	C,CONOUT
	CALL	BDOS
	POP	DE
	POP	HL
	; Negate DEHL
	PUSH	BC
	LD	BC,0
	LD	A,C
	SUB	L
	LD	L,A
	LD	A,C
	SBC	A,H
	LD	H,A
	LD	A,C
	SBC	A,E
	LD	E,A
	LD	A,C
	SBC	A,D
	LD	D,A
	POP	BC

_printf_ld_pos:
	CALL	_prt_dec32
	POP	BC
	LD	A,C
	ADD	A,4		; Long is 4 bytes
	LD	C,A
	POP	HL
	INC	HL
	JP	_printf_loop

_printf_lu:
	; Output unsigned long decimal
	PUSH	HL
	LD	H,0
	LD	L,C
	PUSH	BC
	PUSH	IX
	POP	DE
	ADD	HL,DE
	LD	E,(HL)
	INC	HL
	LD	D,(HL)
	INC	HL
	LD	A,(HL)
	INC	HL
	LD	H,(HL)
	LD	L,A
	EX	DE,HL		; DEHL = value
	CALL	_prt_dec32
	POP	BC
	LD	A,C
	ADD	A,4
	LD	C,A
	POP	HL
	INC	HL
	JP	_printf_loop

_printf_lx:
	; Output long hex
	PUSH	HL
	LD	H,0
	LD	L,C
	PUSH	BC
	PUSH	IX
	POP	DE
	ADD	HL,DE
	LD	E,(HL)
	INC	HL
	LD	D,(HL)
	INC	HL
	LD	A,(HL)
	INC	HL
	LD	H,(HL)
	LD	L,A
	EX	DE,HL		; DEHL = value (DE=high, HL=low)
	; Print DE then HL as hex (skip leading zeros in DE)
	PUSH	HL
	EX	DE,HL
	CALL	_prt_hex
	POP	HL
	; Always print all 4 digits of low word after high word
	CALL	_prt_hex4
	POP	BC
	LD	A,C
	ADD	A,4
	LD	C,A
	POP	HL
	INC	HL
	JP	_printf_loop

_printf_llx:
	; Output 64-bit hex (%llx)
	PUSH	HL
	LD	H,0
	LD	L,C
	PUSH	BC
	PUSH	IX
	POP	DE
	ADD	HL,DE
	; Read 8 bytes (64 bits) from stack: bytes 0-1=word0, 2-3=word1, 4-5=word2, 6-7=word3
	LD	E,(HL)
	INC	HL
	LD	D,(HL)
	INC	HL
	LD	(_printf_ll_w0),DE	; Word 0 (lowest)
	LD	E,(HL)
	INC	HL
	LD	D,(HL)
	INC	HL
	LD	(_printf_ll_w1),DE	; Word 1
	LD	E,(HL)
	INC	HL
	LD	D,(HL)
	INC	HL
	LD	(_printf_ll_w2),DE	; Word 2
	LD	E,(HL)
	INC	HL
	LD	D,(HL)
	LD	(_printf_ll_w3),DE	; Word 3 (highest)
	; Print from highest word to lowest, skipping leading zeros
	; Word 3 (highest)
	LD	HL,(_printf_ll_w3)
	LD	A,H
	OR	L
	JR	Z,_printf_llx_w2
	CALL	_prt_hex
	LD	HL,(_printf_ll_w2)
	CALL	_prt_hex4
	LD	HL,(_printf_ll_w1)
	CALL	_prt_hex4
	LD	HL,(_printf_ll_w0)
	CALL	_prt_hex4
	JR	_printf_llx_done
_printf_llx_w2:
	LD	HL,(_printf_ll_w2)
	LD	A,H
	OR	L
	JR	Z,_printf_llx_w1
	CALL	_prt_hex
	LD	HL,(_printf_ll_w1)
	CALL	_prt_hex4
	LD	HL,(_printf_ll_w0)
	CALL	_prt_hex4
	JR	_printf_llx_done
_printf_llx_w1:
	LD	HL,(_printf_ll_w1)
	LD	A,H
	OR	L
	JR	Z,_printf_llx_w0
	CALL	_prt_hex
	LD	HL,(_printf_ll_w0)
	CALL	_prt_hex4
	JR	_printf_llx_done
_printf_llx_w0:
	LD	HL,(_printf_ll_w0)
	CALL	_prt_hex
_printf_llx_done:
	POP	BC
	LD	A,C
	ADD	A,8		; Long long is 8 bytes
	LD	C,A
	POP	HL
	INC	HL
	JP	_printf_loop

_printf_lld:
	; Output signed 64-bit decimal (%lld)
	PUSH	HL
	LD	H,0
	LD	L,C
	PUSH	BC
	PUSH	IX
	POP	DE
	ADD	HL,DE
	; Read 8 bytes (64 bits) into _prt64_val
	LD	E,(HL)
	INC	HL
	LD	D,(HL)
	INC	HL
	LD	(_prt64_val),DE
	LD	E,(HL)
	INC	HL
	LD	D,(HL)
	INC	HL
	LD	(_prt64_val+2),DE
	LD	E,(HL)
	INC	HL
	LD	D,(HL)
	INC	HL
	LD	(_prt64_val+4),DE
	LD	E,(HL)
	INC	HL
	LD	D,(HL)
	LD	(_prt64_val+6),DE
	; Check sign (bit 7 of highest byte)
	LD	A,D
	AND	80H
	JR	Z,_printf_lld_pos
	; Negative - print minus sign
	PUSH	BC
	LD	E,'-'
	LD	C,CONOUT
	CALL	BDOS
	POP	BC
	; Negate 64-bit value
	XOR	A
	LD	HL,0
	LD	DE,(_prt64_val)
	SBC	HL,DE
	LD	(_prt64_val),HL
	LD	HL,0
	LD	DE,(_prt64_val+2)
	SBC	HL,DE
	LD	(_prt64_val+2),HL
	LD	HL,0
	LD	DE,(_prt64_val+4)
	SBC	HL,DE
	LD	(_prt64_val+4),HL
	LD	HL,0
	LD	DE,(_prt64_val+6)
	SBC	HL,DE
	LD	(_prt64_val+6),HL
_printf_lld_pos:
	CALL	_prt_dec64
	POP	BC
	LD	A,C
	ADD	A,8
	LD	C,A
	POP	HL
	INC	HL
	JP	_printf_loop

_printf_llu:
	; Output unsigned 64-bit decimal (%llu)
	PUSH	HL
	LD	H,0
	LD	L,C
	PUSH	BC
	PUSH	IX
	POP	DE
	ADD	HL,DE
	; Read 8 bytes (64 bits) into _prt64_val
	LD	E,(HL)
	INC	HL
	LD	D,(HL)
	INC	HL
	LD	(_prt64_val),DE
	LD	E,(HL)
	INC	HL
	LD	D,(HL)
	INC	HL
	LD	(_prt64_val+2),DE
	LD	E,(HL)
	INC	HL
	LD	D,(HL)
	INC	HL
	LD	(_prt64_val+4),DE
	LD	E,(HL)
	INC	HL
	LD	D,(HL)
	LD	(_prt64_val+6),DE
	CALL	_prt_dec64
	POP	BC
	LD	A,C
	ADD	A,8
	LD	C,A
	POP	HL
	INC	HL
	JP	_printf_loop

_printf_float:
	; Output float value (%f format)
	; Float is 32 bits (4 bytes) on stack
	PUSH	HL
	LD	H,0
	LD	L,C
	PUSH	BC
	PUSH	IX
	POP	DE
	ADD	HL,DE		; HL = IX + offset (points to float)
	; Load 32-bit float from (HL) into __ftmp
	LD	E,(HL)
	INC	HL
	LD	D,(HL)
	INC	HL
	LD	(__ftmp),DE	; Store low 2 bytes
	LD	E,(HL)
	INC	HL
	LD	D,(HL)
	LD	(__ftmp+2),DE	; Store high 2 bytes
	; Set precision: if specified use it, else default 6
	LD	A,(_printf_hasprec)
	OR	A
	JR	Z,_printf_float_defprec
	LD	A,(_printf_prec)
	LD	(_prt_float_prec),A
	JR	_printf_float_go
_printf_float_defprec:
	LD	A,6
	LD	(_prt_float_prec),A
_printf_float_go:
	CALL	_prt_float
	POP	BC
	LD	A,C
	ADD	A,4		; Float is 4 bytes
	LD	C,A
	POP	HL
	INC	HL
	JP	_printf_loop

_printf_g:
	; Output float using %g format (strip trailing zeros)
	PUSH	HL
	LD	H,0
	LD	L,C
	PUSH	BC
	PUSH	IX
	POP	DE
	ADD	HL,DE		; HL = IX + offset (points to float)
	; Load 32-bit float from (HL) into __ftmp
	LD	E,(HL)
	INC	HL
	LD	D,(HL)
	INC	HL
	LD	(__ftmp),DE
	LD	E,(HL)
	INC	HL
	LD	D,(HL)
	LD	(__ftmp+2),DE
	; Use precision 6 for %g (default significant digits)
	LD	A,6
	LD	(_prt_float_prec),A
	; Switch to buffer mode
	LD	A,1
	LD	(_prt_out_mode),A
	XOR	A
	LD	(_prt_bufpos),A
	; Call _prt_float (output goes to buffer)
	CALL	_prt_float
	; Switch back to console mode
	XOR	A
	LD	(_prt_out_mode),A
	; Null-terminate buffer
	LD	A,(_prt_bufpos)
	LD	L,A
	LD	H,0
	LD	DE,_prt_gbuf
	ADD	HL,DE
	LD	(HL),0
	; Strip trailing zeros after decimal point
	; First check if there's a decimal point
	LD	HL,_prt_gbuf
	LD	B,0		; Track if decimal point found
_printf_g_scan:
	LD	A,(HL)
	OR	A
	JR	Z,_printf_g_strip
	CP	'.'
	JR	NZ,_printf_g_s2
	LD	B,1		; Found decimal point
_printf_g_s2:
	INC	HL
	JR	_printf_g_scan
_printf_g_strip:
	; HL points to null terminator
	; B = 1 if decimal point found
	LD	A,B
	OR	A
	JR	Z,_printf_g_out	; No decimal point, nothing to strip
	; Scan backward removing trailing zeros
_printf_g_st2:
	DEC	HL
	LD	A,(HL)
	CP	'0'
	JR	NZ,_printf_g_st3
	LD	(HL),0		; Remove trailing zero
	JR	_printf_g_st2
_printf_g_st3:
	; Check if decimal point is now last char
	CP	'.'
	JR	NZ,_printf_g_out
	LD	(HL),0		; Remove trailing decimal point
_printf_g_out:
	; Output the buffer
	LD	HL,_prt_gbuf
_printf_g_olp:
	LD	A,(HL)
	OR	A
	JR	Z,_printf_g_done
	LD	E,A
	PUSH	HL
	LD	C,CONOUT
	CALL	BDOS
	POP	HL
	INC	HL
	JR	_printf_g_olp
_printf_g_done:
	POP	BC
	LD	A,C
	ADD	A,4		; Float is 4 bytes
	LD	C,A
	POP	HL
	INC	HL
	JP	_printf_loop

_printf_pct:
	; Output literal %
	LD	E,'%'
	PUSH	HL
	PUSH	BC
	LD	C,CONOUT
	CALL	BDOS
	POP	BC
	POP	HL
	INC	HL
	JR	_printf_loop

_printf_chr:
	; Output character
	PUSH	HL
	; Get argument
	LD	H,0
	LD	L,C
	PUSH	BC
	PUSH	IX
	POP	DE		; DE = IX
	ADD	HL,DE		; HL = IX + offset
	LD	E,(HL)		; Get character
	LD	C,CONOUT
	CALL	BDOS
	POP	BC
	INC	C
	INC	C		; Advance to next arg
	POP	HL
	INC	HL
	JR	_printf_loop

_printf_str:
	; Output string with optional precision limit
	PUSH	HL
	; Get argument (pointer)
	LD	H,0
	LD	L,C
	PUSH	BC
	PUSH	IX
	POP	DE
	ADD	HL,DE		; HL = IX + offset
	LD	E,(HL)
	INC	HL
	LD	D,(HL)		; DE = string pointer

	; Load precision limit into B (0 = unlimited)
	LD	A,(_printf_hasprec)
	OR	A
	JR	Z,_printf_str_nop
	LD	A,(_printf_prec)
	LD	B,A
	JR	_printf_str_loop
_printf_str_nop:
	LD	B,0		; B=0 means no limit

	; Output string
_printf_str_loop:
	; Check precision limit
	LD	A,(_printf_hasprec)
	OR	A
	JR	Z,_printf_str_nolim
	LD	A,B
	OR	A
	JR	Z,_printf_str_done	; Hit precision limit
	DEC	B
_printf_str_nolim:
	LD	A,(DE)
	OR	A
	JR	Z,_printf_str_done
	PUSH	DE
	PUSH	BC
	LD	E,A
	LD	C,CONOUT
	CALL	BDOS
	POP	BC
	POP	DE
	INC	DE
	JR	_printf_str_loop

_printf_str_done:
	POP	BC
	INC	C
	INC	C
	POP	HL
	INC	HL
	JP	_printf_loop

_printf_dec:
	; Output signed decimal with width/zero-padding support
	PUSH	HL
	LD	H,0
	LD	L,C
	PUSH	BC
	PUSH	IX
	POP	DE
	ADD	HL,DE		; HL = IX + offset
	LD	E,(HL)
	INC	HL
	LD	D,(HL)		; DE = value
	EX	DE,HL		; HL = value

	; Check for negative
	XOR	A
	LD	(_printf_neg),A
	BIT	7,H
	JR	Z,_printf_dec_pos

	; Negative - set flag and negate
	LD	A,1
	LD	(_printf_neg),A
	PUSH	DE
	EX	DE,HL
	LD	HL,0
	OR	A
	SBC	HL,DE
	POP	DE

_printf_dec_pos:
	; Convert HL to decimal digits in _printf_decbuf
	; Write digits right-to-left into buffer
	PUSH	IX		; Save frame pointer
	PUSH	BC
	LD	DE,10
	LD	B,0		; digit count
	LD	(_printf_dptr),IX	; Save IX
	LD	IX,_printf_decbuf+5	; write pointer (end of buffer)
_printf_dec_cvt:
	CALL	_prt_div16	; HL = HL / 10, DE = remainder
	LD	A,E
	ADD	A,'0'
	DEC	IX
	LD	(IX+0),A
	INC	B
	LD	DE,10
	LD	A,H
	OR	L
	JR	NZ,_printf_dec_cvt
	; B = number of digits, IX = start of digits in buffer
	; Save digit start pointer
	LD	(_printf_dstart),IX
	LD	A,B
	LD	(_printf_dcnt),A
	LD	IX,(_printf_dptr)	; Restore frame pointer
	POP	BC

	; Now handle width padding
	LD	A,(_printf_neg)
	LD	D,A		; D = neg flag (1 if negative)
	; Total chars = digits + sign
	LD	A,(_printf_dcnt)
	ADD	A,D		; A = total output chars
	LD	E,A		; E = total output chars
	LD	A,(_printf_width)
	OR	A
	JR	Z,_printf_dec_nopad
	SUB	E		; A = padding needed
	JR	Z,_printf_dec_nopad
	JR	C,_printf_dec_nopad
	; A = padding count
	PUSH	BC
	LD	B,A		; B = pad count
	LD	A,(_printf_zero)
	OR	A
	JR	NZ,_printf_dec_zpad
	; Space padding (before sign)
_printf_dec_spad:
	PUSH	BC
	PUSH	DE
	LD	E,' '
	LD	C,CONOUT
	CALL	BDOS
	POP	DE
	POP	BC
	DJNZ	_printf_dec_spad
	POP	BC
	JR	_printf_dec_nopad
_printf_dec_zpad:
	; Zero padding: output sign first, then zeros
	LD	A,D
	OR	A
	JR	Z,_printf_dec_zpd2
	; Output minus sign before zeros
	PUSH	BC
	PUSH	DE
	LD	E,'-'
	LD	C,CONOUT
	CALL	BDOS
	POP	DE
	POP	BC
	XOR	A
	LD	D,A		; Clear neg flag (already output)
_printf_dec_zpd2:
	PUSH	BC
	PUSH	DE
	LD	E,'0'
	LD	C,CONOUT
	CALL	BDOS
	POP	DE
	POP	BC
	DJNZ	_printf_dec_zpd2
	POP	BC
_printf_dec_nopad:
	; Output minus sign if negative and not already output
	LD	A,D
	OR	A
	JR	Z,_printf_dec_digs
	PUSH	BC
	LD	E,'-'
	LD	C,CONOUT
	CALL	BDOS
	POP	BC
_printf_dec_digs:
	; Output digits from buffer using HL as pointer
	LD	HL,(_printf_dstart)
	LD	A,(_printf_dcnt)
	LD	B,A
_printf_dec_dlp:
	LD	E,(HL)
	PUSH	BC
	PUSH	HL
	LD	C,CONOUT
	CALL	BDOS
	POP	HL
	POP	BC
	INC	HL
	DJNZ	_printf_dec_dlp
	POP	IX		; Restore frame pointer
	POP	BC		; Restore printf BC
	INC	C
	INC	C
	POP	HL
	INC	HL
	JP	_printf_loop

_printf_hex:
	; Output hex with width/zero-padding/uppercase support
	PUSH	HL
	LD	H,0
	LD	L,C
	PUSH	BC
	PUSH	IX
	POP	DE
	ADD	HL,DE
	LD	E,(HL)
	INC	HL
	LD	D,(HL)
	EX	DE,HL
	CALL	_printf_prt_hex
	POP	BC
	INC	C
	INC	C
	POP	HL
	INC	HL
	JP	_printf_loop

_printf_done:
	LD	HL,0		; Return 0
	POP	DE
	POP	BC
	POP	IX
	RET

; Printf hex with width/zero-padding/uppercase support
; Input: HL = value to print
_printf_prt_hex:
	PUSH	BC
	; Convert 4 hex nibbles to ASCII in buffer
	LD	DE,_printf_hexbuf
	LD	A,H
	RRCA
	RRCA
	RRCA
	RRCA
	AND	0FH
	CALL	_printf_nib2a
	LD	A,H
	AND	0FH
	CALL	_printf_nib2a
	LD	A,L
	RRCA
	RRCA
	RRCA
	RRCA
	AND	0FH
	CALL	_printf_nib2a
	LD	A,L
	AND	0FH
	CALL	_printf_nib2a
	; Buffer has 4 ASCII hex chars
	; Find first significant digit (skip leading '0' but keep last)
	LD	HL,_printf_hexbuf
	LD	B,4		; Digits remaining
_printf_hx_lz:
	LD	A,B
	CP	1
	JR	Z,_printf_hx_pad	; Last digit, always print
	LD	A,(HL)
	CP	'0'
	JR	NZ,_printf_hx_pad	; Non-zero, stop skipping
	INC	HL
	DEC	B
	JR	_printf_hx_lz
_printf_hx_pad:
	; B = significant digits, HL = pointer to first
	; Check if padding is needed
	LD	A,(_printf_width)
	OR	A
	JR	Z,_printf_hx_out	; No width, just print
	SUB	B		; A = width - sig_digits
	JR	Z,_printf_hx_out	; Exact fit
	JR	C,_printf_hx_out	; More digits than width
	; A = padding count
	PUSH	HL
	PUSH	BC
	LD	B,A
	LD	A,(_printf_zero)
	OR	A
	LD	A,' '
	JR	Z,_printf_hx_plp
	LD	A,'0'
_printf_hx_plp:
	LD	E,A
	PUSH	AF
	LD	C,CONOUT
	CALL	BDOS
	POP	AF
	DJNZ	_printf_hx_plp
	POP	BC
	POP	HL
_printf_hx_out:
	; Print B digits starting at HL
	LD	A,(HL)
	LD	E,A
	PUSH	BC
	PUSH	HL
	LD	C,CONOUT
	CALL	BDOS
	POP	HL
	POP	BC
	INC	HL
	DJNZ	_printf_hx_out
	POP	BC
	RET

; Convert nibble (0-15) in A to ASCII hex char, store at (DE), advance DE
_printf_nib2a:
	ADD	A,'0'
	CP	'9'+1
	JR	C,_printf_nib_ok
	PUSH	BC
	LD	B,A
	LD	A,(_printf_upper)
	OR	A
	LD	A,B
	POP	BC
	JR	Z,_printf_nib_lo
	ADD	A,7		; Uppercase: 'A'-'0'-10 = 7
	JR	_printf_nib_ok
_printf_nib_lo:
	ADD	A,39		; Lowercase: 'a'-'0'-10 = 39
_printf_nib_ok:
	LD	(DE),A
	INC	DE
	RET

_printf_hexbuf:	DS	4
_printf_decbuf:	DS	6	; Buffer for decimal digits (max 5 for 16-bit + 1)
_printf_neg:	DB	0	; Negative flag for decimal
_printf_dptr:	DS	2	; Saved IX frame pointer
_printf_dstart:	DS	2	; Start of digits in buffer
_printf_dcnt:	DB	0	; Number of digits
_printf_width:	DB	0
_printf_zero:	DB	0
_printf_upper:	DB	0
_printf_prec:	DB	0
_printf_hasprec:	DB	0
_printf_ll_w0:	DS	2
_printf_ll_w1:	DS	2
_printf_ll_w2:	DS	2
_printf_ll_w3:	DS	2
_prt_float_prec:	DB	6	; Default float precision

; Print HL as 4-digit hex (always prints all 4 digits with leading zeros)
_prt_hex4:
	PUSH	BC
	LD	A,H
	CALL	_prt_hex4_byte
	LD	A,L
	CALL	_prt_hex4_byte
	POP	BC
	RET
_prt_hex4_byte:
	PUSH	AF
	RRCA
	RRCA
	RRCA
	RRCA
	CALL	_prt_hex4_nib
	POP	AF
_prt_hex4_nib:
	AND	0FH
	ADD	A,'0'
	CP	'9'+1
	JR	C,_prt_hex4_out
	ADD	A,39		; lowercase a-f
_prt_hex4_out:
	LD	E,A
	LD	C,CONOUT
	CALL	BDOS
	RET

; ============================================================
; int fprintf(FILE *stream, const char *fmt, ...)
; Print formatted output to a file stream
; Supports %d, %s, %c, %x, %%
; ============================================================
	PUBLIC	_fprintf
_fprintf:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	PUSH	BC
	PUSH	DE

	; stream at IX+4, fmt at IX+6, first vararg at IX+8
	LD	E,(IX+4)
	LD	D,(IX+5)
	LD	(_fprintf_stream),DE	; Save stream
	LD	L,(IX+6)
	LD	H,(IX+7)	; HL = format string pointer
	LD	C,8		; C = offset to next argument

_fprintf_loop:
	LD	A,(HL)
	OR	A
	JP	Z,_fprintf_done

	CP	'%'
	JR	Z,_fprintf_format

	; Regular character - output via fputc
	PUSH	HL
	PUSH	BC
	LD	DE,(_fprintf_stream)
	PUSH	DE		; stream arg
	LD	E,A
	LD	D,0
	PUSH	DE		; char arg
	CALL	_fputc
	POP	DE
	POP	DE
	POP	BC
	POP	HL
	INC	HL
	JR	_fprintf_loop

_fprintf_format:
	INC	HL
	LD	A,(HL)
	OR	A
	JP	Z,_fprintf_done

	CP	'%'
	JR	Z,_fprintf_pct

_fprintf_fmt2:
	; Skip flags: -, +, space, #, 0
	CP	'-'
	JR	Z,_fprintf_fskip
	CP	'+'
	JR	Z,_fprintf_fskip
	CP	' '
	JR	Z,_fprintf_fskip
	CP	'#'
	JR	Z,_fprintf_fskip
	CP	'0'
	JR	Z,_fprintf_fskip
	; Skip field width digits
	CP	'1'
	JR	C,_fprintf_nodig
	CP	'9'+1
	JR	C,_fprintf_fskip
_fprintf_nodig:
	; Skip precision
	CP	'.'
	JR	Z,_fprintf_fskip
	; Skip length modifiers: h, l, z
	CP	'h'
	JR	Z,_fprintf_fskip
	CP	'l'
	JR	Z,_fprintf_fskip
	CP	'z'
	JR	Z,_fprintf_fskip
	; Now check format specifiers
	CP	's'
	JR	Z,_fprintf_str

	CP	'd'
	JR	Z,_fprintf_dec

	CP	'i'
	JR	Z,_fprintf_dec

	CP	'c'
	JR	Z,_fprintf_chr

	CP	'x'
	JR	Z,_fprintf_hex

	CP	'X'
	JR	Z,_fprintf_hex

	CP	'u'
	JR	Z,_fprintf_dec	; %u same as %d for now

	; Unknown format - skip
	INC	HL
	JP	_fprintf_loop

_fprintf_fskip:
	INC	HL
	LD	A,(HL)
	OR	A
	JP	Z,_fprintf_done
	JR	_fprintf_fmt2

_fprintf_pct:
	; Output literal %
	PUSH	HL
	PUSH	BC
	LD	DE,(_fprintf_stream)
	PUSH	DE
	LD	DE,'%'
	PUSH	DE
	CALL	_fputc
	POP	DE
	POP	DE
	POP	BC
	POP	HL
	INC	HL
	JP	_fprintf_loop

_fprintf_chr:
	; Output character argument
	PUSH	HL
	LD	H,0
	LD	L,C
	PUSH	BC
	PUSH	IX
	POP	DE
	ADD	HL,DE
	LD	E,(HL)		; E = char
	LD	D,0
	LD	BC,(_fprintf_stream)
	PUSH	BC		; stream
	PUSH	DE		; char
	CALL	_fputc
	POP	DE
	POP	DE
	POP	BC
	INC	C
	INC	C
	POP	HL
	INC	HL
	JP	_fprintf_loop

_fprintf_str:
	; Output string argument
	PUSH	HL
	LD	H,0
	LD	L,C
	PUSH	BC
	PUSH	IX
	POP	DE
	ADD	HL,DE
	LD	E,(HL)
	INC	HL
	LD	D,(HL)		; DE = string pointer
_fprintf_str_lp:
	LD	A,(DE)
	OR	A
	JR	Z,_fprintf_str_end
	PUSH	DE
	LD	BC,(_fprintf_stream)
	PUSH	BC
	LD	E,A
	LD	D,0
	PUSH	DE
	CALL	_fputc
	POP	DE
	POP	DE
	POP	DE
	INC	DE
	JR	_fprintf_str_lp
_fprintf_str_end:
	POP	BC
	INC	C
	INC	C
	POP	HL
	INC	HL
	JP	_fprintf_loop

_fprintf_dec:
	; Output decimal number
	PUSH	HL
	LD	H,0
	LD	L,C
	PUSH	BC
	PUSH	IX
	POP	DE
	ADD	HL,DE
	LD	E,(HL)
	INC	HL
	LD	D,(HL)
	EX	DE,HL		; HL = value
	CALL	_fprintf_prt_dec
	POP	BC
	INC	C
	INC	C
	POP	HL
	INC	HL
	JP	_fprintf_loop

_fprintf_hex:
	; Output hex number
	PUSH	HL
	LD	H,0
	LD	L,C
	PUSH	BC
	PUSH	IX
	POP	DE
	ADD	HL,DE
	LD	E,(HL)
	INC	HL
	LD	D,(HL)
	EX	DE,HL		; HL = value
	CALL	_fprintf_prt_hex
	POP	BC
	INC	C
	INC	C
	POP	HL
	INC	HL
	JP	_fprintf_loop

_fprintf_done:
	LD	HL,0		; Return 0
	POP	DE
	POP	BC
	POP	IX
	RET

; fprintf helper: print HL as decimal to stream
_fprintf_prt_dec:
	PUSH	BC
	PUSH	DE
	; Check for negative
	BIT	7,H
	JR	Z,_fprintf_dec_pos
	; Negative - print minus sign
	PUSH	HL
	LD	DE,(_fprintf_stream)
	PUSH	DE
	LD	DE,'-'
	PUSH	DE
	CALL	_fputc
	POP	DE
	POP	DE
	POP	HL
	; Negate HL
	LD	A,L
	CPL
	LD	L,A
	LD	A,H
	CPL
	LD	H,A
	INC	HL
_fprintf_dec_pos:
	; Convert to decimal digits on stack
	LD	DE,10
	LD	B,0		; Digit counter
_fprintf_dec_lp:
	CALL	_prt_div16	; HL = HL / 10, DE = remainder
	PUSH	DE		; Push digit
	INC	B
	LD	A,H
	OR	L
	JR	NZ,_fprintf_dec_lp
	; Pop and print digits
_fprintf_dec_pr:
	POP	DE		; Get digit
	LD	A,E
	ADD	A,'0'
	PUSH	BC
	LD	DE,(_fprintf_stream)
	PUSH	DE
	LD	E,A
	LD	D,0
	PUSH	DE
	CALL	_fputc
	POP	DE
	POP	DE
	POP	BC
	DJNZ	_fprintf_dec_pr
	POP	DE
	POP	BC
	RET

; fprintf helper: print HL as hex to stream
_fprintf_prt_hex:
	PUSH	BC
	PUSH	DE
	LD	B,4		; 4 hex digits
	LD	C,H		; Save high byte
_fprintf_hex_lp:
	; Rotate left 4 bits
	ADD	HL,HL
	RL	C
	ADD	HL,HL
	RL	C
	ADD	HL,HL
	RL	C
	ADD	HL,HL
	RL	C
	; Get top nibble
	LD	A,C
	AND	0FH
	ADD	A,'0'
	CP	'9'+1
	JR	C,_fprintf_hex_dig
	ADD	A,7		; A-F
_fprintf_hex_dig:
	PUSH	HL
	PUSH	BC
	LD	DE,(_fprintf_stream)
	PUSH	DE
	LD	E,A
	LD	D,0
	PUSH	DE
	CALL	_fputc
	POP	DE
	POP	DE
	POP	BC
	POP	HL
	DJNZ	_fprintf_hex_lp
	POP	DE
	POP	BC
	RET

; ============================================================
; vprintf family - formatted output with va_list
; int vprintf(const char *fmt, va_list ap)
; int vfprintf(FILE *stream, const char *fmt, va_list ap)
; int vsprintf(char *str, const char *fmt, va_list ap)
; ============================================================

; vprintf: output to stdout using va_list
	PUBLIC	_vprintf
_vprintf:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	; fmt at IX+4, ap at IX+6
	LD	L,(IX+4)
	LD	H,(IX+5)	; HL = format string
	LD	E,(IX+6)
	LD	D,(IX+7)	; DE = va_list (pointer to args)
	LD	(_vprintf_ap),DE
	LD	BC,0		; Character count

_vprintf_loop:
	LD	A,(HL)
	OR	A
	JP	Z,_vprintf_done

	CP	'%'
	JP	Z,_vprintf_fmt

	; Regular char - output
	PUSH	HL
	PUSH	BC
	LD	E,A
	LD	C,2
	CALL	5
	POP	BC
	POP	HL
	INC	BC
	INC	HL
	JP	_vprintf_loop

_vprintf_fmt:
	INC	HL
	LD	A,(HL)
	OR	A
	JP	Z,_vprintf_done

	CP	'%'
	JR	NZ,_vprintf_fmt2
	; Literal %
	PUSH	HL
	PUSH	BC
	LD	E,'%'
	LD	C,2
	CALL	5
	POP	BC
	POP	HL
	INC	BC
	INC	HL
	JP	_vprintf_loop

_vprintf_fmt2:
	; Skip flags: -, +, space, #, 0
	CP	'-'
	JR	Z,_vprintf_skip
	CP	'+'
	JR	Z,_vprintf_skip
	CP	' '
	JR	Z,_vprintf_skip
	CP	'#'
	JR	Z,_vprintf_skip
	CP	'0'
	JR	Z,_vprintf_skip
	; Skip field width digits
	CP	'1'
	JR	C,_vprintf_nodig
	CP	'9'+1
	JR	C,_vprintf_skip
_vprintf_nodig:
	; Skip precision
	CP	'.'
	JR	Z,_vprintf_skip
	; Skip length modifiers: h, z (l handled separately for long)
	CP	'h'
	JR	Z,_vprintf_skip
	CP	'z'
	JR	Z,_vprintf_skip
	; Now check format specifiers
	CP	's'
	JP	Z,_vprintf_str
	CP	'd'
	JP	Z,_vprintf_dec
	CP	'i'
	JP	Z,_vprintf_dec
	CP	'c'
	JP	Z,_vprintf_chr
	CP	'x'
	JP	Z,_vprintf_hex
	CP	'X'
	JP	Z,_vprintf_hex
	CP	'u'
	JP	Z,_vprintf_uns
	CP	'l'
	JP	Z,_vprintf_long
	; Unknown - skip
	INC	HL
	JP	_vprintf_loop
_vprintf_skip:
	INC	HL
	LD	A,(HL)
	OR	A
	JP	Z,_vprintf_done
	JP	_vprintf_fmt2

_vprintf_str:
	; Print string
	PUSH	HL
	PUSH	BC
	LD	HL,(_vprintf_ap)
	LD	E,(HL)
	INC	HL
	LD	D,(HL)
	INC	HL
	LD	(_vprintf_ap),HL
	EX	DE,HL		; HL = string
_vprintf_str_lp:
	LD	A,(HL)
	OR	A
	JR	Z,_vprintf_str_dn
	LD	E,A
	PUSH	HL
	LD	C,2
	CALL	5
	POP	HL
	INC	HL
	JR	_vprintf_str_lp
_vprintf_str_dn:
	POP	BC
	POP	HL
	INC	HL
	JP	_vprintf_loop

_vprintf_dec:
	; Print signed int
	PUSH	HL
	PUSH	BC
	LD	HL,(_vprintf_ap)
	LD	E,(HL)
	INC	HL
	LD	D,(HL)
	INC	HL
	LD	(_vprintf_ap),HL
	EX	DE,HL
	CALL	_prt_dec
	POP	BC
	POP	HL
	INC	HL
	JP	_vprintf_loop

_vprintf_chr:
	; Print character
	PUSH	HL
	PUSH	BC
	LD	HL,(_vprintf_ap)
	LD	E,(HL)
	INC	HL
	INC	HL
	LD	(_vprintf_ap),HL
	LD	C,2
	CALL	5
	POP	BC
	POP	HL
	INC	HL
	JP	_vprintf_loop

_vprintf_hex:
	; Print hex
	PUSH	HL
	PUSH	BC
	LD	HL,(_vprintf_ap)
	LD	E,(HL)
	INC	HL
	LD	D,(HL)
	INC	HL
	LD	(_vprintf_ap),HL
	EX	DE,HL
	CALL	_prt_hex
	POP	BC
	POP	HL
	INC	HL
	JP	_vprintf_loop

_vprintf_uns:
	; Same as dec for now
	JP	_vprintf_dec

_vprintf_long:
	; Handle 'l' modifier
	INC	HL
	LD	A,(HL)
	CP	'd'
	JP	Z,_vprintf_ld
	CP	'x'
	JP	Z,_vprintf_lx
	JP	_vprintf_loop

_vprintf_ld:
	; Print long decimal
	PUSH	HL
	PUSH	BC
	LD	HL,(_vprintf_ap)
	LD	E,(HL)
	INC	HL
	LD	D,(HL)
	INC	HL
	LD	C,(HL)
	INC	HL
	LD	B,(HL)
	INC	HL
	LD	(_vprintf_ap),HL
	; DEHL = low, BC = high (need to swap)
	PUSH	BC
	EX	DE,HL
	POP	DE		; Now DEHL is 32-bit value
	CALL	_prt_dec32
	POP	BC
	POP	HL
	INC	HL
	JP	_vprintf_loop

_vprintf_lx:
	; Print long hex
	PUSH	HL
	PUSH	BC
	LD	HL,(_vprintf_ap)
	LD	E,(HL)
	INC	HL
	LD	D,(HL)
	INC	HL
	LD	C,(HL)
	INC	HL
	LD	B,(HL)
	INC	HL
	LD	(_vprintf_ap),HL
	; Print BC (high), then DE (low)
	PUSH	DE
	LD	H,B
	LD	L,C
	CALL	_prt_hex
	POP	HL
	CALL	_prt_hex
	POP	BC
	POP	HL
	INC	HL
	JP	_vprintf_loop

_vprintf_done:
	LD	H,B
	LD	L,C		; Return count
	POP	IX
	RET

; vfprintf: output to file using va_list
	PUBLIC	_vfprintf
_vfprintf:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	; stream at IX+4, fmt at IX+6, ap at IX+8
	LD	L,(IX+4)
	LD	H,(IX+5)
	LD	(_fprintf_stream),HL
	LD	L,(IX+6)
	LD	H,(IX+7)	; HL = format
	LD	E,(IX+8)
	LD	D,(IX+9)	; DE = va_list
	LD	(_vprintf_ap),DE
	LD	BC,0		; Count

_vfprintf_loop:
	LD	A,(HL)
	OR	A
	JP	Z,_vfprintf_done
	CP	'%'
	JP	Z,_vfprintf_fmt
	; Regular char
	PUSH	HL
	PUSH	BC
	LD	DE,(_fprintf_stream)
	PUSH	DE
	LD	E,A
	LD	D,0
	PUSH	DE
	CALL	_fputc
	POP	DE
	POP	DE
	POP	BC
	POP	HL
	INC	BC
	INC	HL
	JP	_vfprintf_loop

_vfprintf_fmt:
	INC	HL
	LD	A,(HL)
	OR	A
	JP	Z,_vfprintf_done
	CP	'%'
	JR	NZ,_vfprintf_fmt2
	PUSH	HL
	PUSH	BC
	LD	DE,(_fprintf_stream)
	PUSH	DE
	LD	DE,'%'
	PUSH	DE
	CALL	_fputc
	POP	DE
	POP	DE
	POP	BC
	POP	HL
	INC	BC
	INC	HL
	JP	_vfprintf_loop

_vfprintf_fmt2:
	; Skip flags: -, +, space, #, 0
	CP	'-'
	JR	Z,_vfprintf_skip
	CP	'+'
	JR	Z,_vfprintf_skip
	CP	' '
	JR	Z,_vfprintf_skip
	CP	'#'
	JR	Z,_vfprintf_skip
	CP	'0'
	JR	Z,_vfprintf_skip
	; Skip field width digits
	CP	'1'
	JR	C,_vfprintf_nodig
	CP	'9'+1
	JR	C,_vfprintf_skip
_vfprintf_nodig:
	; Skip precision
	CP	'.'
	JR	Z,_vfprintf_skip
	; Skip length modifiers: l, h, z
	CP	'l'
	JR	Z,_vfprintf_skip
	CP	'h'
	JR	Z,_vfprintf_skip
	CP	'z'
	JR	Z,_vfprintf_skip
	; Now check format specifiers
	CP	's'
	JP	Z,_vfprintf_str
	CP	'd'
	JP	Z,_vfprintf_dec
	CP	'i'
	JP	Z,_vfprintf_dec
	CP	'u'
	JP	Z,_vfprintf_dec
	CP	'x'
	JP	Z,_vfprintf_hex
	CP	'X'
	JP	Z,_vfprintf_hex
	CP	'c'
	JP	Z,_vfprintf_chr
	; Unknown specifier - skip it
	INC	HL
	JP	_vfprintf_loop
_vfprintf_skip:
	INC	HL
	LD	A,(HL)
	OR	A
	JP	Z,_vfprintf_done
	JP	_vfprintf_fmt2

_vfprintf_str:
	PUSH	HL
	PUSH	BC
	LD	HL,(_vprintf_ap)
	LD	E,(HL)
	INC	HL
	LD	D,(HL)
	INC	HL
	LD	(_vprintf_ap),HL
	EX	DE,HL
_vfprintf_str_lp:
	LD	A,(HL)
	OR	A
	JR	Z,_vfprintf_str_dn
	PUSH	HL
	LD	DE,(_fprintf_stream)
	PUSH	DE
	LD	E,A
	LD	D,0
	PUSH	DE
	CALL	_fputc
	POP	DE
	POP	DE
	POP	HL
	INC	HL
	JR	_vfprintf_str_lp
_vfprintf_str_dn:
	POP	BC
	POP	HL
	INC	HL
	JP	_vfprintf_loop

_vfprintf_dec:
	PUSH	HL
	PUSH	BC
	LD	HL,(_vprintf_ap)
	LD	E,(HL)
	INC	HL
	LD	D,(HL)
	INC	HL
	LD	(_vprintf_ap),HL
	EX	DE,HL
	CALL	_fprintf_prt_dec
	POP	BC
	POP	HL
	INC	HL
	JP	_vfprintf_loop

_vfprintf_chr:
	PUSH	HL
	PUSH	BC
	LD	HL,(_vprintf_ap)
	LD	E,(HL)
	INC	HL
	INC	HL
	LD	(_vprintf_ap),HL
	LD	DE,(_fprintf_stream)
	PUSH	DE
	LD	D,0
	PUSH	DE
	CALL	_fputc
	POP	DE
	POP	DE
	POP	BC
	POP	HL
	INC	HL
	JP	_vfprintf_loop

_vfprintf_hex:
	PUSH	HL
	PUSH	BC
	LD	HL,(_vprintf_ap)
	LD	E,(HL)
	INC	HL
	LD	D,(HL)
	INC	HL
	LD	(_vprintf_ap),HL
	EX	DE,HL
	CALL	_fprintf_prt_hex
	POP	BC
	POP	HL
	INC	HL
	JP	_vfprintf_loop

_vfprintf_done:
	LD	H,B
	LD	L,C
	POP	IX
	RET

; vsprintf: output to string using va_list
	PUBLIC	_vsprintf
_vsprintf:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	; str at IX+4, fmt at IX+6, ap at IX+8
	LD	L,(IX+4)
	LD	H,(IX+5)
	LD	(_sprintf_out),HL
	LD	L,(IX+6)
	LD	H,(IX+7)	; HL = format
	LD	E,(IX+8)
	LD	D,(IX+9)	; DE = va_list
	LD	(_vprintf_ap),DE
	LD	BC,0		; Count
	LD	(_sprintf_cnt),BC

_vsprintf_loop:
	LD	A,(HL)
	OR	A
	JP	Z,_vsprintf_done
	CP	'%'
	JP	Z,_vsprintf_fmt
	; Regular char
	CALL	_sprintf_putc
	INC	HL
	JP	_vsprintf_loop

_vsprintf_fmt:
	INC	HL
	LD	A,(HL)
	OR	A
	JP	Z,_vsprintf_done
	CP	'%'
	JR	NZ,_vsprintf_fmt2
	LD	A,'%'
	CALL	_sprintf_putc
	INC	HL
	JP	_vsprintf_loop

_vsprintf_fmt2:
	; Skip flags: -, +, space, #, 0
	CP	'-'
	JR	Z,_vsprintf_skip
	CP	'+'
	JR	Z,_vsprintf_skip
	CP	' '
	JR	Z,_vsprintf_skip
	CP	'#'
	JR	Z,_vsprintf_skip
	CP	'0'
	JR	Z,_vsprintf_skip
	; Skip field width digits
	CP	'1'
	JR	C,_vsprintf_nodig
	CP	'9'+1
	JR	C,_vsprintf_skip
_vsprintf_nodig:
	; Skip precision
	CP	'.'
	JR	Z,_vsprintf_skip
	; Skip length modifiers: l, h, z
	CP	'l'
	JR	Z,_vsprintf_skip
	CP	'h'
	JR	Z,_vsprintf_skip
	CP	'z'
	JR	Z,_vsprintf_skip
	; Now check format specifiers
	CP	's'
	JP	Z,_vsprintf_str
	CP	'd'
	JP	Z,_vsprintf_dec
	CP	'i'
	JP	Z,_vsprintf_dec
	CP	'u'
	JP	Z,_vsprintf_dec
	CP	'x'
	JP	Z,_vsprintf_hex
	CP	'X'
	JP	Z,_vsprintf_hex
	CP	'c'
	JP	Z,_vsprintf_chr
	; Unknown specifier - skip it
	INC	HL
	JP	_vsprintf_loop
_vsprintf_skip:
	INC	HL
	LD	A,(HL)
	OR	A
	JP	Z,_vsprintf_done
	JP	_vsprintf_fmt2

_vsprintf_str:
	PUSH	HL
	LD	HL,(_vprintf_ap)
	LD	E,(HL)
	INC	HL
	LD	D,(HL)
	INC	HL
	LD	(_vprintf_ap),HL
	EX	DE,HL
_vsprintf_str_lp:
	LD	A,(HL)
	OR	A
	JR	Z,_vsprintf_str_dn
	CALL	_sprintf_putc
	INC	HL
	JR	_vsprintf_str_lp
_vsprintf_str_dn:
	POP	HL
	INC	HL
	JP	_vsprintf_loop

_vsprintf_dec:
	PUSH	HL
	LD	HL,(_vprintf_ap)
	LD	E,(HL)
	INC	HL
	LD	D,(HL)
	INC	HL
	LD	(_vprintf_ap),HL
	EX	DE,HL
	CALL	_sprintf_prt_dec
	POP	HL
	INC	HL
	JP	_vsprintf_loop

_vsprintf_chr:
	PUSH	HL
	LD	HL,(_vprintf_ap)
	LD	A,(HL)
	INC	HL
	INC	HL
	LD	(_vprintf_ap),HL
	CALL	_sprintf_putc
	POP	HL
	INC	HL
	JP	_vsprintf_loop

_vsprintf_hex:
	PUSH	HL
	LD	HL,(_vprintf_ap)
	LD	E,(HL)
	INC	HL
	LD	D,(HL)
	INC	HL
	LD	(_vprintf_ap),HL
	EX	DE,HL
	CALL	_sprintf_prt_hex
	POP	HL
	INC	HL
	JP	_vsprintf_loop

_vsprintf_done:
	; Null terminate
	XOR	A
	CALL	_sprintf_putc
	; Return count
	LD	HL,(_sprintf_cnt)
	DEC	HL		; Don't count null
	POP	IX
	RET

; ============================================================
; Internal: output character with mode-aware routing
; Input: A = character to output
; Preserves: BC, DE, HL
; ============================================================
_prt_outch:
	PUSH	HL
	PUSH	DE
	PUSH	BC
	PUSH	AF
	LD	HL,_prt_out_mode
	LD	A,(HL)
	OR	A
	JR	NZ,_prt_outch_buf
	; Console mode
	POP	AF
	LD	E,A
	LD	C,CONOUT
	CALL	BDOS
	JR	_prt_outch_ret
_prt_outch_buf:
	; Buffer mode
	POP	AF
	LD	HL,_prt_bufpos
	LD	L,(HL)
	LD	H,0
	PUSH	DE
	LD	DE,_prt_gbuf
	ADD	HL,DE
	POP	DE
	LD	(HL),A
	LD	HL,_prt_bufpos
	INC	(HL)
_prt_outch_ret:
	POP	BC
	POP	DE
	POP	HL
	RET

; ============================================================
; Internal: print HL as decimal
; ============================================================
_prt_dec:
	PUSH	BC
	PUSH	DE

	; Convert to decimal digits on stack
	LD	DE,10
	LD	B,0		; Digit counter

_prt_dec_loop:
	CALL	_prt_div16	; HL = HL / 10, DE = remainder
	PUSH	DE		; Push digit
	INC	B
	LD	A,H
	OR	L
	JR	NZ,_prt_dec_loop

	; Pop and print digits
_prt_dec_out:
	POP	DE
	LD	A,E
	ADD	A,'0'
	CALL	_prt_outch
	DJNZ	_prt_dec_out

	POP	DE
	POP	BC
	RET

; Simple division: HL = HL / 10, DE = HL % 10
; (Optimized for divide by 10)
_prt_div16:
	PUSH	BC
	LD	BC,0		; Result
	LD	DE,0		; Remainder

_prt_div16_lp:
	; Subtract 10 from HL repeatedly
	LD	A,H
	OR	A
	JR	NZ,_prt_div16_sub
	LD	A,L
	CP	10
	JR	C,_prt_div16_dn

_prt_div16_sub:
	LD	A,L
	SUB	10
	LD	L,A
	LD	A,H
	SBC	A,0
	LD	H,A
	INC	BC
	JR	_prt_div16_lp

_prt_div16_dn:
	; Remainder in L
	LD	E,L
	LD	D,0
	LD	H,B
	LD	L,C		; HL = quotient
	POP	BC
	RET

; ============================================================
; Internal: print float from __ftmp (IEEE 754 single precision)
; Format: [-]d.dddddd (6 decimal places)
; ============================================================
	EXTRN	__fmul
	EXTRN	__fsub
	EXTRN	__ftoi
	EXTRN	__itof
	EXTRN	__tmp32
_prt_float:
	PUSH	BC
	PUSH	DE
	PUSH	IX

	; Load float from __ftmp into HLDE (H=high byte with sign/exp)
	LD	DE,(__ftmp)
	LD	HL,(__ftmp+2)

	; Check for zero (exponent=0 and mantissa=0)
	LD	A,H
	AND	7FH		; Mask sign bit
	OR	L
	OR	D
	OR	E
	JP	Z,_prt_float_zero

	; Check sign bit (bit 7 of H)
	BIT	7,H
	JR	Z,_prt_float_pos

	; Print minus sign
	LD	A,'-'
	CALL	_prt_outch
	RES	7,H		; Clear sign bit

_prt_float_pos:
	; Now HLDE is positive float (HLDE format: H=high with sign/exp)
	; Save in __fwork for later fractional printing (convert to DEHL format)
	EX	DE,HL		; Now DEHL format: D=high
	LD	(__fwork),HL
	LD	(__fwork+2),DE

	; Pre-round: add 0.5 * 10^(-precision) for correct rounding
	; Start with 0.5f = 0x3F000000
	PUSH	DE
	PUSH	HL
	LD	DE,3F00H
	LD	HL,0
	; Divide by 10 for each precision digit
	LD	A,(_prt_float_prec)
	OR	A
	JR	Z,_prt_round_add
	LD	B,A
_prt_round_lp:
	LD	(__tmp32),HL
	LD	(__tmp32+2),DE
	LD	DE,3DCCH	; 0.1f = 0x3DCCCCCD
	LD	HL,0CCCDH
	CALL	__fmul
	DJNZ	_prt_round_lp
_prt_round_add:
	; DEHL = rounding value, add to __fwork
	LD	(__tmp32),HL
	LD	(__tmp32+2),DE
	LD	HL,(__fwork)
	LD	DE,(__fwork+2)
	CALL	__fadd
	LD	(__fwork),HL
	LD	(__fwork+2),DE
	POP	HL		; Discard saved float
	POP	DE

	; Reload rounded value into HLDE format
	LD	HL,(__fwork)
	LD	DE,(__fwork+2)
	EX	DE,HL		; DEHL -> HLDE

	; H = sign(0)|exp[7:1], L = exp[0]|mant[22:16], D = mant[15:8], E = mant[7:0]
	; Extract exponent: bits 30-23 -> (H<<1) | (L>>7)
	LD	A,H
	ADD	A,A		; A = H<<1
	LD	B,A		; Save
	LD	A,L
	RLCA			; Carry = L bit 7
	LD	A,B
	ADC	A,0		; A = exponent (biased)
	LD	B,A		; B = exponent

	; Check for special values
	CP	255		; Infinity or NaN
	JP	Z,_prt_float_inf

	; Check for zero exponent (denormal)
	OR	A
	JP	Z,_prt_float_zero

	; Extract mantissa: (L&0x7F)|0x80 in high byte, DE in low
	LD	A,L
	AND	7FH
	OR	80H		; Add implicit 1
	LD	L,A		; Now LDE = 24-bit mantissa (with leading 1)

	; Calculate actual exponent (unbiased)
	LD	A,B
	SUB	127		; A = actual exponent (can be negative)

	; Store mantissa in __fman (3 bytes: low, mid, high)
	LD	(__fman),DE	; Low 2 bytes
	LD	A,L
	LD	(__fman+2),A	; High byte

	; Calculate actual exponent (unbiased)
	LD	A,B
	SUB	127		; A = actual exponent
	LD	B,A

	; Now mantissa in __fman[0..2] (E,D,L order), exponent in B
	; Value = mantissa * 2^(B-23)

	; Check if exponent is negative (value < 1)
	BIT	7,B
	JP	NZ,_prt_float_small

	; Exponent >= 0
	LD	A,B
	CP	24		; Check if >= 24
	JP	NC,_prt_float_large

	; 0 <= exponent < 24
	; Integer part = mantissa >> (23 - exponent)
	; Fractional part = mantissa & ((1 << (23-exp)) - 1)

	LD	A,23
	SUB	B		; A = shift count (23-B), 0..23
	LD	B,A		; B = shift count

	; Load 24-bit mantissa into HLE (H=high, L=mid, E=low)
	LD	A,(__fman+2)
	LD	H,A
	LD	A,(__fman+1)
	LD	L,A
	LD	A,(__fman)
	LD	E,A

	; Save original mantissa for fractional calc
	PUSH	HL
	PUSH	DE

	; Shift HLE right by B bits to get integer part
	LD	A,B
	OR	A
	JR	Z,_prt_float_noshr
_prt_float_shrloop:
	SRL	H
	RR	L
	RR	E
	DEC	A
	JR	NZ,_prt_float_shrloop
_prt_float_noshr:

	; Now HLE = integer part (24 bits total)
	; After shifting right, the result may be in L and E (if H=0)
	; or just in E (if H=L=0). Need to assemble result into HL.
	; For most practical values (exponent 0-16), result fits in 16 bits.
	LD	A,H
	OR	A
	JR	NZ,_prt_float_use_hl	; H non-zero, use HL as is
	; H is zero, result is in LE
	LD	H,L
	LD	L,E
_prt_float_use_hl:

	; Move result to HL for printing
	PUSH	HL
	CALL	_prt_dec

	; Print decimal point
	LD	A,'.'
	CALL	_prt_outch
	POP	HL		; Restore integer part

	; Now calculate fractional part
	; We saved original float in __fwork, integer part already in HL (from POP above)
	; Need to: frac = original - integer, then print frac digits
	; First discard the saved mantissa from stack
	POP	DE		; Discard saved mantissa (from line 3695)
	POP	DE		; Discard saved mantissa (from line 3694)
	; HL still has integer part from line 3729

	; Convert integer part to float
	LD	DE,0		; DEHL = integer as 32-bit
	CALL	__itof		; DEHL = integer as float

	; Store in __tmp32 for subtraction
	LD	(__tmp32),HL
	LD	(__tmp32+2),DE

	; Load original float from __fwork
	LD	HL,(__fwork)
	LD	DE,(__fwork+2)
	; DEHL = original float

	; Subtract: DEHL = original - integer = fractional part
	CALL	__fsub

	; Store fractional float for digit extraction
	LD	(__fwork),HL
	LD	(__fwork+2),DE

	; Print fractional digits using multiply-by-10
	LD	A,(_prt_float_prec)
	LD	B,A
	OR	A
	JP	Z,_prt_float_done	; Precision 0: no decimal point or digits
_prt_float_frac:
	PUSH	BC

	; Load current fractional value
	LD	HL,(__fwork)
	LD	DE,(__fwork+2)

	; Store in __tmp32 for multiplication
	LD	(__tmp32),HL
	LD	(__tmp32+2),DE

	; Load 10.0 (0x41200000) into DEHL
	LD	DE,4120H
	LD	HL,0
	; Multiply: DEHL = DEHL * __tmp32
	CALL	__fmul

	; Save multiplied value
	LD	(__fwork),HL
	LD	(__fwork+2),DE

	; Extract integer digit
	CALL	__ftoi		; HL = integer part (0-9)
	LD	A,L
	PUSH	AF		; Save digit

	; Print digit
	ADD	A,'0'
	CALL	_prt_outch

	; Subtract digit from multiplied value to keep fractional part
	POP	AF		; A = digit
	LD	L,A
	LD	H,0
	LD	DE,0
	CALL	__itof		; DEHL = digit as float

	LD	(__tmp32),HL
	LD	(__tmp32+2),DE

	LD	HL,(__fwork)
	LD	DE,(__fwork+2)
	CALL	__fsub		; DEHL = value - digit

	LD	(__fwork),HL
	LD	(__fwork+2),DE

	POP	BC
	DJNZ	_prt_float_frac

	JP	_prt_float_done

_prt_float_small:
	; Exponent < 0, value < 1.0
	; Print "0." then calculate fractional digits
	LD	A,'0'
	CALL	_prt_outch
	LD	A,'.'
	CALL	_prt_outch

	; Reconstruct float from __fman (mantissa) and B (unbiased exponent)
	; Runtime uses DEHL format: D=sign|exp[7:1], E=exp[0]|mant[22:16], H=mant[15:8], L=mant[7:0]
	; Biased exponent = B + 127
	LD	A,B
	ADD	A,127		; A = biased exponent
	LD	B,A		; B = biased exponent

	; Pack into DEHL format (runtime format)
	LD	A,B
	SRL	A		; A = exp >> 1 (D gets sign=0 | exp[7:1])
	LD	D,A

	LD	A,B
	AND	1		; A = exp[0]
	RLCA
	RLCA
	RLCA
	RLCA
	RLCA
	RLCA
	RLCA			; A = exp[0] << 7
	LD	C,A		; Save
	LD	A,(__fman+2)	; High byte of mantissa (with implicit 1)
	AND	7FH		; Remove implicit 1
	OR	C		; Combine with exp[0]
	LD	E,A		; E = exp[0] | mant[22:16]

	LD	A,(__fman+1)
	LD	H,A		; H = mant[15:8]
	LD	A,(__fman)
	LD	L,A		; L = mant[7:0]
	; Now DEHL = packed positive float in runtime format

	; Store in working area __fwork (as DEHL: __fwork[0..1]=HL, __fwork[2..3]=DE)
	LD	(__fwork),HL
	LD	(__fwork+2),DE

	; Loop precision times to print digits
	LD	A,(_prt_float_prec)
	LD	B,A
	OR	A
	JP	Z,_prt_float_done
_prt_float_sm_lp:
	PUSH	BC

	; Load current value from __fwork into DEHL
	LD	HL,(__fwork)
	LD	DE,(__fwork+2)
	; DEHL = float in runtime format

	; Store in __tmp32 for multiplication
	LD	(__tmp32),HL
	LD	(__tmp32+2),DE

	; Load 10.0 (0x41200000) into DEHL
	; 10.0 = sign=0, exp=130, mant=0x200000
	; D = 0|10000010>>1 = 0x41, E = 0<<7|0x20 = 0x20, H=0, L=0
	LD	DE,4120H
	LD	HL,0
	; Multiply: DEHL = DEHL * __tmp32
	CALL	__fmul

	; Result in DEHL is value * 10
	; Save result
	LD	(__fwork),HL
	LD	(__fwork+2),DE

	; Extract integer part (0-9) using __ftoi
	; DEHL already has the value
	CALL	__ftoi		; HL = integer part
	LD	A,L		; A = digit (should be 0-9)
	PUSH	AF		; Save digit

	; Print digit
	ADD	A,'0'
	CALL	_prt_outch

	; Subtract integer part from float to get fractional part
	; Need to convert integer back to float and subtract
	POP	AF		; A = digit
	LD	L,A
	LD	H,0
	LD	DE,0		; DEHL = digit as 32-bit integer
	CALL	__itof		; DEHL = digit as float

	; Store digit-as-float in __tmp32
	LD	(__tmp32),HL
	LD	(__tmp32+2),DE

	; Load current value and subtract
	LD	HL,(__fwork)
	LD	DE,(__fwork+2)
	CALL	__fsub		; DEHL = value - digit

	; Store back
	LD	(__fwork),HL
	LD	(__fwork+2),DE

	POP	BC
	DJNZ	_prt_float_sm_lp
	JP	_prt_float_done

_prt_float_large:
	; Exponent >= 24, very large integer
	; Print mantissa shifted left
	LD	A,(__fman+2)
	LD	H,A
	LD	A,(__fman+1)
	LD	L,A
	; HL = upper 16 bits of mantissa

	LD	A,B
	SUB	23		; shift left count
	LD	B,A
	OR	A
	JR	Z,_prt_float_lg2
_prt_float_shlloop:
	SLA	L
	RL	H
	DJNZ	_prt_float_shlloop

_prt_float_lg2:
	CALL	_prt_dec

	; Print .000... (precision digits)
	LD	A,'.'
	CALL	_prt_outch
	LD	A,(_prt_float_prec)
	LD	B,A
	OR	A
	JR	Z,_prt_float_done
_prt_float_lg3:
	LD	A,'0'
	CALL	_prt_outch
	DJNZ	_prt_float_lg3
	JR	_prt_float_done

_prt_float_zero:
	; Print "0.000..."
	LD	A,'0'
	CALL	_prt_outch
	LD	A,'.'
	CALL	_prt_outch
	LD	A,(_prt_float_prec)
	LD	B,A
	OR	A
	JR	Z,_prt_float_done
_prt_float_z2:
	LD	A,'0'
	CALL	_prt_outch
	DJNZ	_prt_float_z2
	JR	_prt_float_done

_prt_float_inf:
	; Print "inf"
	LD	A,'i'
	CALL	_prt_outch
	LD	A,'n'
	CALL	_prt_outch
	LD	A,'f'
	CALL	_prt_outch

_prt_float_done:
	POP	IX
	POP	DE
	POP	BC
	RET

; ============================================================
; Internal: print HL as hex (no leading zeros)
; ============================================================
_prt_hex:
	PUSH	BC
	LD	B,0		; B=1 means we've printed a non-zero digit
	LD	A,H
	RRCA
	RRCA
	RRCA
	RRCA
	AND	0FH
	CALL	_prt_hexd
	LD	A,H
	AND	0FH
	CALL	_prt_hexd
	LD	A,L
	RRCA
	RRCA
	RRCA
	RRCA
	AND	0FH
	CALL	_prt_hexd
	LD	A,L
	AND	0FH
	; Always print last digit
	; A = digit value (0-15)
	; If digit is non-zero, print it
	OR	A
	JR	NZ,_prt_hexf
	; Digit is 0. If we've printed something, print '0'. Otherwise print single '0'.
	; Either way, we need to print '0', so just fall through or jump with A=0
	; Check if B is non-zero (already printed)
	PUSH	AF		; Save A=0
	LD	A,B
	OR	A
	POP	AF		; Restore A=0
	JR	NZ,_prt_hexf	; If B!=0, print the '0'
	; Value is 0, print single '0'
	LD	A,'0'
	LD	E,A
	LD	C,CONOUT
	CALL	BDOS
	POP	BC
	RET
_prt_hexf:
	LD	B,1		; Mark we've printed
	ADD	A,'0'
	CP	'9'+1
	JR	C,_prt_hex_o2
	ADD	A,39		; 'a' - '0' - 10 = 39 (lowercase)
_prt_hex_o2:
	LD	E,A
	LD	C,CONOUT
	CALL	BDOS
	POP	BC
	RET
; Helper: print hex digit if non-zero or already printed
_prt_hexd:
	OR	A
	JR	NZ,_prt_hexd1
	LD	A,B
	OR	A
	RET	Z		; Skip leading zeros
	XOR	A		; Print '0' if we've started
_prt_hexd1:
	LD	B,1		; Mark we've printed
	ADD	A,'0'
	CP	'9'+1
	JR	C,_prt_hexd2
	ADD	A,39		; 'a' - '0' - 10 = 39 (lowercase)
_prt_hexd2:
	LD	E,A
	PUSH	BC
	LD	C,CONOUT
	CALL	BDOS
	POP	BC
	RET

; ============================================================
; Internal: print DEHL as 32-bit decimal
; DEHL = value (DE=high, HL=low)
; ============================================================
_prt_dec32:
	PUSH	BC
	PUSH	IX

	; Store value in work area
	LD	(_prt32_val),HL
	LD	(_prt32_val+2),DE

	LD	B,0		; Digit counter

_prt32_loop:
	; Divide _prt32_val by 10, remainder is next digit
	CALL	_div32_10
	PUSH	AF		; Save digit (remainder)
	INC	B

	; Check if quotient is zero
	LD	HL,(_prt32_val)
	LD	A,H
	OR	L
	JR	NZ,_prt32_loop
	LD	HL,(_prt32_val+2)
	LD	A,H
	OR	L
	JR	NZ,_prt32_loop

	; Pop and print digits
_prt32_out:
	POP	AF
	ADD	A,'0'
	LD	E,A
	PUSH	BC
	LD	C,CONOUT
	CALL	BDOS
	POP	BC
	DJNZ	_prt32_out

	POP	IX
	POP	BC
	RET

; Internal: divide _prt32_val by 10
; Returns remainder in A, quotient stored back in _prt32_val
_div32_10:
	PUSH	BC
	PUSH	DE
	PUSH	HL

	; 32-bit division by 10 using shift-subtract
	; Process bit by bit from MSB to LSB
	LD	DE,0		; DE = running remainder
	LD	B,32		; 32 bits

_div32_10_loop:
	; Shift remainder left by 1
	EX	DE,HL
	ADD	HL,HL
	EX	DE,HL		; DE <<= 1

	; Shift 32-bit dividend left by 1, MSB goes to remainder
	; Low word first, its carry goes to high word
	LD	HL,(_prt32_val)
	ADD	HL,HL
	LD	(_prt32_val),HL
	; High word with carry from low word
	LD	HL,(_prt32_val+2)
	ADC	HL,HL
	LD	(_prt32_val+2),HL
	; Carry from high word goes to remainder
	JR	NC,_div32_10_nc1
	INC	DE
_div32_10_nc1:

	; Check if remainder >= 10
	LD	A,D
	OR	A
	JR	NZ,_div32_10_sub	; DE >= 256, definitely >= 10
	LD	A,E
	CP	10
	JR	C,_div32_10_nosub

_div32_10_sub:
	; Subtract 10 from remainder
	LD	A,E
	SUB	10
	LD	E,A
	LD	A,D
	SBC	A,0
	LD	D,A

	; Set LSB of quotient (stored in _prt32_val)
	LD	HL,(_prt32_val)
	INC	HL
	LD	(_prt32_val),HL

_div32_10_nosub:
	DJNZ	_div32_10_loop

	; Remainder in E (D should be 0)
	LD	A,E

	POP	HL
	POP	DE
	POP	BC
	RET

; ============================================================
; Internal: print 64-bit value as unsigned decimal
; Value must be pre-loaded into _prt64_val (8 bytes)
; ============================================================
_prt_dec64:
	PUSH	BC
	PUSH	IX

	LD	B,0		; Digit counter

_prt64_loop:
	CALL	_div64_10
	PUSH	AF		; Save digit (remainder)
	INC	B

	; Check if quotient is zero (all 8 bytes)
	LD	HL,(_prt64_val)
	LD	A,H
	OR	L
	JR	NZ,_prt64_loop
	LD	HL,(_prt64_val+2)
	LD	A,H
	OR	L
	JR	NZ,_prt64_loop
	LD	HL,(_prt64_val+4)
	LD	A,H
	OR	L
	JR	NZ,_prt64_loop
	LD	HL,(_prt64_val+6)
	LD	A,H
	OR	L
	JR	NZ,_prt64_loop

	; Pop and print digits
_prt64_out:
	POP	AF
	ADD	A,'0'
	LD	E,A
	PUSH	BC
	LD	C,CONOUT
	CALL	BDOS
	POP	BC
	DJNZ	_prt64_out

	POP	IX
	POP	BC
	RET

; Internal: divide _prt64_val (8 bytes) by 10
; Returns remainder in A, quotient stored back in _prt64_val
_div64_10:
	PUSH	BC
	PUSH	DE
	PUSH	HL

	LD	DE,0		; DE = running remainder
	LD	B,64

_div64_10_loop:
	; Shift remainder left by 1
	EX	DE,HL
	ADD	HL,HL
	EX	DE,HL

	; Shift _prt64_val left by 1 (64 bits, MSB first carries into DE)
	LD	HL,(_prt64_val)
	ADD	HL,HL
	LD	(_prt64_val),HL
	LD	HL,(_prt64_val+2)
	ADC	HL,HL
	LD	(_prt64_val+2),HL
	LD	HL,(_prt64_val+4)
	ADC	HL,HL
	LD	(_prt64_val+4),HL
	LD	HL,(_prt64_val+6)
	ADC	HL,HL
	LD	(_prt64_val+6),HL
	JR	NC,_div64_10_nc
	INC	DE
_div64_10_nc:

	; Check if DE >= 10
	LD	A,D
	OR	A
	JR	NZ,_div64_10_sub
	LD	A,E
	CP	10
	JR	C,_div64_10_nosub

_div64_10_sub:
	LD	A,E
	SUB	10
	LD	E,A
	LD	A,D
	SBC	A,0
	LD	D,A

	; Set bit 0 of quotient (lowest byte of _prt64_val)
	LD	HL,(_prt64_val)
	INC	HL
	LD	(_prt64_val),HL

_div64_10_nosub:
	DJNZ	_div64_10_loop

	LD	A,E		; Remainder

	POP	HL
	POP	DE
	POP	BC
	RET

; ============================================================
; size_t strlen(const char *s)
; ============================================================
	PUBLIC	_strlen
_strlen:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP

	LD	L,(IX+4)
	LD	H,(IX+5)	; HL = string pointer
	LD	BC,0		; Counter

_strlen_loop:
	LD	A,(HL)
	OR	A
	JR	Z,_strlen_done
	INC	HL
	INC	BC
	JR	_strlen_loop

_strlen_done:
	LD	H,B
	LD	L,C
	POP	IX
	RET

; ============================================================
; void exit(int status)
; Calls atexit handlers then terminates
; ============================================================
	PUBLIC	_exit
_exit:
	; Call atexit handlers in reverse order
	LD	A,(_atexit_cnt)
	OR	A
	JR	Z,_exit_done

_exit_loop:
	DEC	A
	LD	(_atexit_cnt),A
	; Get handler address: _atexit_tab + A*2
	LD	L,A
	LD	H,0
	ADD	HL,HL		; HL = A*2
	LD	DE,_atexit_tab
	ADD	HL,DE		; HL = address of handler pointer
	LD	E,(HL)
	INC	HL
	LD	D,(HL)		; DE = handler address
	; Call handler
	PUSH	AF
	LD	HL,_exit_loop_ret
	PUSH	HL		; Push return address
	PUSH	DE		; Push handler address
	RET			; "Call" the handler
_exit_loop_ret:
	POP	AF
	OR	A
	JR	NZ,_exit_loop

_exit_done:
	; Return to CP/M (warm boot)
	JP	0

; ============================================================
; void abort(void)
; Abnormal program termination
; ============================================================
	PUBLIC	_abort
_abort:
	; Print abort message
	LD	DE,_abort_msg
	LD	C,PRTSTR
	CALL	BDOS
	; Exit
	JP	0

; ============================================================
; int atexit(void (*func)(void))
; Register function to be called at exit
; Returns 0 on success, non-zero on failure
; ============================================================
	PUBLIC	_atexit
_atexit:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP

	; Check if we have room
	LD	A,(_atexit_cnt)
	CP	4		; Max 4 handlers
	JR	NC,_atexit_fail

	; Get handler address: _atexit_tab + cnt*2
	LD	L,A
	LD	H,0
	ADD	HL,HL
	LD	DE,_atexit_tab
	ADD	HL,DE		; HL = slot address

	; Store function pointer
	LD	E,(IX+4)
	LD	D,(IX+5)
	LD	(HL),E
	INC	HL
	LD	(HL),D

	; Increment count
	LD	A,(_atexit_cnt)
	INC	A
	LD	(_atexit_cnt),A

	; Return success
	LD	HL,0
	POP	IX
	RET

_atexit_fail:
	LD	HL,1
	POP	IX
	RET

; ============================================================
; int rand(void)
; Returns pseudo-random number 0 to RAND_MAX (32767)
; Uses 16-bit linear congruential generator
; seed = (seed * 25173 + 13849) & 0x7FFF
; ============================================================
	PUBLIC	_rand
	EXTRN	__mul16
_rand:
	LD	HL,(_rand_seed)
	LD	DE,25173
	CALL	__mul16		; HL = seed * 25173
	LD	DE,13849
	ADD	HL,DE		; HL = seed * 25173 + 13849
	LD	A,H
	AND	7FH		; Mask to 0-32767
	LD	H,A
	LD	(_rand_seed),HL
	RET

; ============================================================
; void srand(unsigned int seed)
; Initialize random seed
; ============================================================
	PUBLIC	_srand
_srand:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	LD	L,(IX+4)
	LD	H,(IX+5)
	LD	(_rand_seed),HL
	POP	IX
	RET

; ============================================================
; int abs(int n)
; Return absolute value
; ============================================================
	PUBLIC	_abs
_abs:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	LD	L,(IX+4)
	LD	H,(IX+5)
	BIT	7,H
	JR	Z,_abs_done
	; Negate
	LD	DE,0
	EX	DE,HL
	OR	A
	SBC	HL,DE
_abs_done:
	POP	IX
	RET

; ============================================================
; long labs(long n)
; Return absolute value of long
; Returns in DEHL
; ============================================================
	PUBLIC	_labs
_labs:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	LD	L,(IX+4)
	LD	H,(IX+5)
	LD	E,(IX+6)
	LD	D,(IX+7)	; DEHL = n
	BIT	7,D
	JR	Z,_labs_done
	; Negate DEHL
	PUSH	BC
	LD	BC,0
	LD	A,C
	SUB	L
	LD	L,A
	LD	A,C
	SBC	A,H
	LD	H,A
	LD	A,C
	SBC	A,E
	LD	E,A
	LD	A,C
	SBC	A,D
	LD	D,A
	POP	BC
_labs_done:
	POP	IX
	RET

; ============================================================
; div_t div(int numer, int denom)
; Compute quotient and remainder
; Returns: pointer to static div_t in HL
; (div_t.quot at _div_result, div_t.rem at _div_result+2)
; ============================================================
	PUBLIC	_div
	EXTRN	__sdiv16
	EXTRN	__smod16
_div:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	PUSH	BC

	LD	L,(IX+4)	; HL = numer
	LD	H,(IX+5)
	LD	E,(IX+6)	; DE = denom
	LD	D,(IX+7)

	; Compute quotient
	PUSH	HL
	PUSH	DE
	CALL	__sdiv16
	LD	(_div_result),HL
	POP	DE
	POP	HL

	; Compute remainder
	CALL	__smod16
	LD	(_div_result+2),HL

	LD	HL,_div_result
	POP	BC
	POP	IX
	RET

; ============================================================
; ldiv_t ldiv(long numer, long denom)
; Compute quotient and remainder for long
; Returns: pointer to static ldiv_t in HL
; (ldiv_t.quot at _ldiv_result, ldiv_t.rem at _ldiv_result+4)
; Runtime uses: DEHL / __tmp32 for 32-bit ops
; ============================================================
	PUBLIC	_ldiv
	EXTRN	__sdiv32
	EXTRN	__smod32
	EXTRN	__tmp32
_ldiv:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	PUSH	BC

	; Store denom in __tmp32
	LD	A,(IX+8)
	LD	(__tmp32),A
	LD	A,(IX+9)
	LD	(__tmp32+1),A
	LD	A,(IX+10)
	LD	(__tmp32+2),A
	LD	A,(IX+11)
	LD	(__tmp32+3),A

	; Load numer into DEHL
	LD	L,(IX+4)
	LD	H,(IX+5)
	LD	E,(IX+6)
	LD	D,(IX+7)

	; Save numer for mod computation
	PUSH	DE
	PUSH	HL

	; Compute quotient: DEHL / __tmp32
	CALL	__sdiv32
	LD	(_ldiv_result),HL
	LD	(_ldiv_result+2),DE

	; Restore numer
	POP	HL
	POP	DE

	; Compute remainder: DEHL % __tmp32 (denom still in __tmp32)
	CALL	__smod32
	LD	(_ldiv_result+4),HL
	LD	(_ldiv_result+6),DE

	LD	HL,_ldiv_result
	POP	BC
	POP	IX
	RET

; ============================================================
; char *strcpy(char *dest, const char *src)
; Copy string from src to dest
; Returns: dest
; ============================================================
	PUBLIC	_strcpy
_strcpy:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP

	LD	E,(IX+4)	; DE = dest
	LD	D,(IX+5)
	LD	L,(IX+6)	; HL = src
	LD	H,(IX+7)

_strcpy_loop:
	LD	A,(HL)		; Get source char
	LD	(DE),A		; Store to dest
	OR	A
	JR	Z,_strcpy_done	; Done if null
	INC	HL
	INC	DE
	JR	_strcpy_loop

_strcpy_done:
	LD	L,(IX+4)	; Return dest
	LD	H,(IX+5)
	POP	IX
	RET

; ============================================================
; char *strncpy(char *dest, const char *src, size_t n)
; Copy at most n chars from src to dest
; Returns: dest
; ============================================================
	PUBLIC	_strncpy
_strncpy:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	PUSH	BC

	LD	E,(IX+4)	; DE = dest
	LD	D,(IX+5)
	LD	L,(IX+6)	; HL = src
	LD	H,(IX+7)
	LD	C,(IX+8)	; BC = n
	LD	B,(IX+9)

_strncpy_loop:
	LD	A,B		; Check if n == 0
	OR	C
	JR	Z,_strncpy_done

	LD	A,(HL)		; Get source char
	LD	(DE),A		; Store to dest
	DEC	BC
	OR	A
	JR	Z,_strncpy_pad	; Null found, pad with zeros
	INC	HL
	INC	DE
	JR	_strncpy_loop

_strncpy_pad:
	; Pad remaining with zeros
	LD	A,B
	OR	C
	JR	Z,_strncpy_done
	INC	DE
	XOR	A
	LD	(DE),A
	DEC	BC
	JR	_strncpy_pad

_strncpy_done:
	LD	L,(IX+4)	; Return dest
	LD	H,(IX+5)
	POP	BC
	POP	IX
	RET

; ============================================================
; int strcmp(const char *s1, const char *s2)
; Compare two strings
; Returns: <0 if s1<s2, 0 if s1==s2, >0 if s1>s2
; ============================================================
	PUBLIC	_strcmp
_strcmp:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP

	LD	E,(IX+4)	; DE = s1
	LD	D,(IX+5)
	LD	L,(IX+6)	; HL = s2
	LD	H,(IX+7)

_strcmp_loop:
	LD	A,(DE)		; Get s1 char
	LD	B,(HL)		; Get s2 char
	SUB	B		; Compare
	JR	NZ,_strcmp_diff	; Different

	LD	A,(DE)		; Check if null
	OR	A
	JR	Z,_strcmp_equal	; Both null, equal

	INC	DE
	INC	HL
	JR	_strcmp_loop

_strcmp_equal:
	LD	HL,0
	POP	IX
	RET

_strcmp_diff:
	; A contains s1[i] - s2[i]
	; Sign-extend to HL
	LD	L,A
	RLA			; Sign to carry
	SBC	A,A		; A = 0xFF if neg, 0 if pos
	LD	H,A
	POP	IX
	RET

; ============================================================
; int strncmp(const char *s1, const char *s2, size_t n)
; Compare at most n chars of two strings
; ============================================================
	PUBLIC	_strncmp
_strncmp:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	PUSH	BC

	LD	E,(IX+4)	; DE = s1
	LD	D,(IX+5)
	LD	L,(IX+6)	; HL = s2
	LD	H,(IX+7)
	LD	C,(IX+8)	; BC = n
	LD	B,(IX+9)

_strncmp_loop:
	LD	A,B		; Check if n == 0
	OR	C
	JR	Z,_strncmp_equal

	LD	A,(DE)		; Get s1 char
	PUSH	HL
	LD	H,(HL)		; H = s2 char
	SUB	H		; Compare
	POP	HL
	JR	NZ,_strncmp_diff

	LD	A,(DE)		; Check if null
	OR	A
	JR	Z,_strncmp_equal

	DEC	BC
	INC	DE
	INC	HL
	JR	_strncmp_loop

_strncmp_equal:
	LD	HL,0
	POP	BC
	POP	IX
	RET

_strncmp_diff:
	LD	L,A
	RLA
	SBC	A,A
	LD	H,A
	POP	BC
	POP	IX
	RET

; ============================================================
; char *strcat(char *dest, const char *src)
; Append src to dest
; Returns: dest
; ============================================================
	PUBLIC	_strcat
_strcat:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP

	LD	E,(IX+4)	; DE = dest
	LD	D,(IX+5)

	; Find end of dest
_strcat_find:
	LD	A,(DE)
	OR	A
	JR	Z,_strcat_copy
	INC	DE
	JR	_strcat_find

_strcat_copy:
	LD	L,(IX+6)	; HL = src
	LD	H,(IX+7)

_strcat_loop:
	LD	A,(HL)
	LD	(DE),A
	OR	A
	JR	Z,_strcat_done
	INC	HL
	INC	DE
	JR	_strcat_loop

_strcat_done:
	LD	L,(IX+4)	; Return dest
	LD	H,(IX+5)
	POP	IX
	RET

; ============================================================
; char *strchr(const char *s, int c)
; Find first occurrence of c in s
; Returns: pointer to char, or NULL if not found
; ============================================================
	PUBLIC	_strchr
_strchr:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP

	LD	L,(IX+4)	; HL = s
	LD	H,(IX+5)
	LD	C,(IX+6)	; C = char to find

_strchr_loop:
	LD	A,(HL)
	CP	C
	JR	Z,_strchr_found	; Found it
	OR	A
	JR	Z,_strchr_notfound	; End of string
	INC	HL
	JR	_strchr_loop

_strchr_found:
	POP	IX
	RET			; HL already points to char

_strchr_notfound:
	LD	HL,0		; Return NULL
	POP	IX
	RET

; ============================================================
; void *memcpy(void *dest, const void *src, size_t n)
; Copy n bytes from src to dest
; Returns: dest
; ============================================================
	PUBLIC	_memcpy
_memcpy:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	PUSH	BC

	LD	E,(IX+4)	; DE = dest
	LD	D,(IX+5)
	LD	L,(IX+6)	; HL = src
	LD	H,(IX+7)
	LD	C,(IX+8)	; BC = n
	LD	B,(IX+9)

	LD	A,B		; Check if n == 0
	OR	C
	JR	Z,_memcpy_done

	LDIR			; Block copy

_memcpy_done:
	LD	L,(IX+4)	; Return dest
	LD	H,(IX+5)
	POP	BC
	POP	IX
	RET

; ============================================================
; void *memset(void *s, int c, size_t n)
; Fill n bytes of s with c
; Returns: s
; ============================================================
	PUBLIC	_memset
_memset:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	PUSH	BC

	LD	L,(IX+4)	; HL = dest
	LD	H,(IX+5)
	LD	A,(IX+6)	; A = fill byte
	LD	C,(IX+8)	; BC = n
	LD	B,(IX+9)

	PUSH	HL		; Save dest for return

	PUSH	AF		; Save fill byte
	LD	A,B		; Check if n == 0
	OR	C
	JR	Z,_memset_done_pop

	POP	AF		; Restore fill byte
	LD	(HL),A		; Store first byte
	LD	D,H		; DE = HL + 1
	LD	E,L
	INC	DE
	DEC	BC		; n - 1
	LD	A,B
	OR	C
	JR	Z,_memset_done
	LDIR			; Copy first byte to rest
	JR	_memset_done

_memset_done_pop:
	POP	AF		; Discard saved fill byte

_memset_done:
	POP	HL		; Return dest
	POP	BC
	POP	IX
	RET

; ============================================================
; int memcmp(const void *s1, const void *s2, size_t n)
; Compare n bytes of s1 and s2
; Returns: <0 if s1<s2, 0 if s1==s2, >0 if s1>s2
; ============================================================
	PUBLIC	_memcmp
_memcmp:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	PUSH	BC

	LD	E,(IX+4)	; DE = s1
	LD	D,(IX+5)
	LD	L,(IX+6)	; HL = s2
	LD	H,(IX+7)
	LD	C,(IX+8)	; BC = n
	LD	B,(IX+9)

_memcmp_loop:
	LD	A,B
	OR	C
	JR	Z,_memcmp_equal	; n == 0, equal

	LD	A,(DE)
	PUSH	HL
	LD	H,(HL)
	SUB	H
	POP	HL
	JR	NZ,_memcmp_diff

	DEC	BC
	INC	DE
	INC	HL
	JR	_memcmp_loop

_memcmp_equal:
	LD	HL,0
	POP	BC
	POP	IX
	RET

_memcmp_diff:
	LD	L,A
	RLA
	SBC	A,A
	LD	H,A
	POP	BC
	POP	IX
	RET

; ============================================================
; void *malloc(size_t size)
; Allocate memory from heap
; Simple bump allocator - memory is never freed
; Argument: size on stack at IX+4
; Returns: pointer to allocated memory, or NULL (0) if failed
; ============================================================
	PUBLIC	_malloc
_malloc:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP

	; Get size
	LD	C,(IX+4)
	LD	B,(IX+5)

	; Get current heap pointer
	LD	HL,(_heap_ptr)

	; If heap_ptr is 0, initialize it
	LD	A,H
	OR	L
	JR	NZ,_malloc_have_heap
	; Initialize heap to start after our data
	LD	HL,_heap_start
	LD	(_heap_ptr),HL

_malloc_have_heap:
	; HL = current heap pointer (return value)
	PUSH	HL		; Save return address

	; Advance heap pointer by size
	ADD	HL,BC
	; Check if we would exceed stack (rough check)
	; SP is approximate limit
	PUSH	HL
	EX	DE,HL
	LD	HL,0
	ADD	HL,SP
	; DE = new heap ptr, HL = SP
	; If new_ptr >= SP - 256, fail (leave some stack margin)
	LD	BC,256
	OR	A
	SBC	HL,BC		; HL = SP - 256
	EX	DE,HL		; DE = SP - 256, HL = new heap ptr
	OR	A
	SBC	HL,DE		; If new_heap > limit, carry clear and result positive
	POP	HL		; HL = new heap ptr
	JR	NC,_malloc_oom

	; Store new heap pointer
	LD	(_heap_ptr),HL

	; Return saved pointer
	POP	HL
	POP	IX
	RET

_malloc_oom:
	; Out of memory - return NULL
	POP	HL		; Discard saved pointer
	LD	HL,0
	POP	IX
	RET

; ============================================================
; void *calloc(size_t nmemb, size_t size)
; Allocate zeroed memory
; Arguments: nmemb at IX+4, size at IX+6
; Returns: pointer to zeroed memory, or NULL
; ============================================================
	PUBLIC	_calloc
_calloc:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP

	; Calculate total size = nmemb * size
	LD	L,(IX+4)	; HL = nmemb
	LD	H,(IX+5)
	LD	E,(IX+6)	; DE = size
	LD	D,(IX+7)

	; 16-bit multiply: HL = HL * DE
	PUSH	BC
	LD	B,H
	LD	C,L		; BC = nmemb
	LD	HL,0
_calloc_mult:
	LD	A,B
	OR	C
	JR	Z,_calloc_mult_done
	ADD	HL,DE
	DEC	BC
	JR	_calloc_mult
_calloc_mult_done:
	; HL = total size
	POP	BC

	; Call malloc with size in HL
	PUSH	HL		; Push size as argument
	CALL	_malloc
	POP	DE		; Pop size into DE (we need it for clearing)

	; Check if malloc returned NULL
	LD	A,H
	OR	L
	JR	Z,_calloc_ret	; Return NULL

	; Zero the memory: HL = ptr, DE = size
	PUSH	HL		; Save return value
	EX	DE,HL		; HL = size, DE = ptr

	; Zero BC bytes at (DE)
	LD	B,H
	LD	C,L		; BC = size
	EX	DE,HL		; HL = ptr

_calloc_zero:
	LD	A,B
	OR	C
	JR	Z,_calloc_zero_done
	LD	(HL),0
	INC	HL
	DEC	BC
	JR	_calloc_zero

_calloc_zero_done:
	POP	HL		; Restore return value

_calloc_ret:
	POP	IX
	RET

; ============================================================
; void free(void *ptr)
; Free memory - no-op in bump allocator
; ============================================================
	PUBLIC	_free
_free:
	RET			; No-op: bump allocator never frees

; ============================================================
; void *realloc(void *ptr, size_t size)
; Resize allocated memory
; Simple implementation: always allocates new block and copies
; ============================================================
	PUBLIC	_realloc
_realloc:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	PUSH	BC
	PUSH	DE

	LD	L,(IX+4)	; HL = ptr
	LD	H,(IX+5)
	LD	C,(IX+6)	; BC = size
	LD	B,(IX+7)

	; If ptr is NULL, just malloc
	LD	A,H
	OR	L
	JR	NZ,_realloc_check_size
	; malloc(size)
	PUSH	BC
	CALL	_malloc
	POP	DE
	JR	_realloc_done

_realloc_check_size:
	; If size is 0, free and return NULL
	LD	A,B
	OR	C
	JR	NZ,_realloc_do
	; size is 0, return NULL
	LD	HL,0
	JR	_realloc_done

_realloc_do:
	; Save old pointer
	PUSH	HL

	; Allocate new block
	PUSH	BC
	CALL	_malloc
	POP	DE		; DE = size (for copy)
	LD	B,D
	LD	C,E		; BC = size

	; Check if malloc failed
	LD	A,H
	OR	L
	JR	Z,_realloc_fail

	; Copy old data to new block
	; HL = new ptr, need old ptr
	EX	DE,HL		; DE = new ptr
	POP	HL		; HL = old ptr

	; Copy BC bytes from HL to DE
	; But BC might be larger than old allocation!
	; Since we don't track sizes, copy the minimum
	; For safety, just copy size bytes (user's responsibility)
	PUSH	DE		; Save new ptr to return
	LDIR			; Copy BC bytes from HL to DE
	POP	HL		; HL = new ptr
	JR	_realloc_done

_realloc_fail:
	POP	DE		; Discard old ptr
	; HL is already 0

_realloc_done:
	POP	DE
	POP	BC
	POP	IX
	RET

; ============================================================
; int atoi(const char *nptr)
; Convert string to integer
; Handles optional leading whitespace and sign
; ============================================================
	PUBLIC	_atoi
_atoi:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP

	LD	L,(IX+4)	; HL = string pointer
	LD	H,(IX+5)

	; Skip leading whitespace
_atoi_skip:
	LD	A,(HL)
	CP	' '
	JR	Z,_atoi_skipnext
	CP	09H		; tab
	JR	Z,_atoi_skipnext
	CP	0AH		; newline
	JR	Z,_atoi_skipnext
	CP	0DH		; carriage return
	JR	Z,_atoi_skipnext
	JR	_atoi_sign
_atoi_skipnext:
	INC	HL
	JR	_atoi_skip

_atoi_sign:
	LD	C,0		; C = sign flag (0=positive)
	LD	A,(HL)
	CP	'-'
	JR	NZ,_atoi_chkplus
	LD	C,1		; Negative
	INC	HL
	JR	_atoi_digits
_atoi_chkplus:
	CP	'+'
	JR	NZ,_atoi_digits
	INC	HL

_atoi_digits:
	; DE = accumulator (result)
	LD	DE,0

_atoi_loop:
	LD	A,(HL)
	SUB	'0'
	JR	C,_atoi_done	; < '0'
	CP	10
	JR	NC,_atoi_done	; > '9'

	; DE = DE * 10 + digit
	PUSH	HL
	PUSH	BC
	PUSH	AF		; Save digit

	; DE * 10 = DE * 8 + DE * 2
	LD	H,D
	LD	L,E		; HL = DE
	ADD	HL,HL		; HL = DE * 2
	LD	B,H
	LD	C,L		; BC = DE * 2
	ADD	HL,HL		; HL = DE * 4
	ADD	HL,HL		; HL = DE * 8
	ADD	HL,BC		; HL = DE * 10
	EX	DE,HL		; DE = DE * 10

	POP	AF		; Get digit back
	LD	L,A
	LD	H,0
	ADD	HL,DE		; HL = DE * 10 + digit
	EX	DE,HL		; DE = result

	POP	BC
	POP	HL
	INC	HL
	JR	_atoi_loop

_atoi_done:
	; Apply sign
	LD	H,D
	LD	L,E		; HL = result
	LD	A,C
	OR	A
	JR	Z,_atoi_ret
	; Negate: 0 - HL
	EX	DE,HL
	LD	HL,0
	OR	A
	SBC	HL,DE

_atoi_ret:
	POP	IX
	RET

; ============================================================
; long atol(const char *nptr)
; Convert string to long (32-bit)
; Returns result in DEHL
; ============================================================
	PUBLIC	_atol
_atol:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	PUSH	BC

	LD	L,(IX+4)	; HL = string pointer
	LD	H,(IX+5)

	; Skip leading whitespace
_atol_skip:
	LD	A,(HL)
	CP	' '
	JR	Z,_atol_skipnext
	CP	09H
	JR	Z,_atol_skipnext
	CP	0AH
	JR	Z,_atol_skipnext
	CP	0DH
	JR	Z,_atol_skipnext
	JR	_atol_sign
_atol_skipnext:
	INC	HL
	JR	_atol_skip

_atol_sign:
	LD	C,0		; C = sign flag
	LD	A,(HL)
	CP	'-'
	JR	NZ,_atol_chkplus
	LD	C,1
	INC	HL
	JR	_atol_digits
_atol_chkplus:
	CP	'+'
	JR	NZ,_atol_digits
	INC	HL

_atol_digits:
	; Result in __atol_acc (32-bit)
	XOR	A
	LD	(_atol_acc),A
	LD	(_atol_acc+1),A
	LD	(_atol_acc+2),A
	LD	(_atol_acc+3),A

_atol_loop:
	LD	A,(HL)
	SUB	'0'
	JR	C,_atol_done
	CP	10
	JR	NC,_atol_done

	; acc = acc * 10 + digit
	PUSH	HL
	PUSH	BC
	PUSH	AF		; Save digit

	; Multiply acc by 10 using shifts: x*10 = x*8 + x*2
	; First, copy acc to tmp
	LD	HL,(_atol_acc)
	LD	(_atol_tmp),HL
	LD	HL,(_atol_acc+2)
	LD	(_atol_tmp+2),HL

	; acc = acc * 2
	LD	HL,(_atol_acc)
	ADD	HL,HL
	LD	(_atol_acc),HL
	LD	HL,(_atol_acc+2)
	ADC	HL,HL
	LD	(_atol_acc+2),HL

	; tmp = tmp * 8 (shift left 3 more times = total 4)
	; Actually: acc*2 already done, so tmp*8 means shift tmp left 3 times
	LD	B,3
_atol_shift8:
	LD	HL,(_atol_tmp)
	ADD	HL,HL
	LD	(_atol_tmp),HL
	LD	HL,(_atol_tmp+2)
	ADC	HL,HL
	LD	(_atol_tmp+2),HL
	DJNZ	_atol_shift8

	; acc = acc + tmp (acc*2 + acc*8 = acc*10)
	LD	HL,(_atol_acc)
	LD	DE,(_atol_tmp)
	ADD	HL,DE
	LD	(_atol_acc),HL
	LD	HL,(_atol_acc+2)
	LD	DE,(_atol_tmp+2)
	ADC	HL,DE
	LD	(_atol_acc+2),HL

	; Add digit
	POP	AF
	LD	E,A
	LD	D,0
	LD	HL,(_atol_acc)
	ADD	HL,DE
	LD	(_atol_acc),HL
	JR	NC,_atol_noc
	LD	HL,(_atol_acc+2)
	INC	HL
	LD	(_atol_acc+2),HL
_atol_noc:
	POP	BC
	POP	HL
	INC	HL
	JR	_atol_loop

_atol_done:
	; Load result into DEHL
	LD	HL,(_atol_acc)
	LD	DE,(_atol_acc+2)

	; Apply sign
	LD	A,C
	OR	A
	JR	Z,_atol_ret

	; Negate DEHL
	PUSH	BC
	LD	BC,0
	LD	A,C
	SUB	L
	LD	L,A
	LD	A,C
	SBC	A,H
	LD	H,A
	LD	A,C
	SBC	A,E
	LD	E,A
	LD	A,C
	SBC	A,D
	LD	D,A
	POP	BC

_atol_ret:
	POP	BC
	POP	IX
	RET

; ============================================================
; long strtol(const char *nptr, char **endptr, int base)
; Convert string to long (32-bit signed)
; Supports base 0 (auto-detect), 8, 10, 16
; Returns result in DEHL
; ============================================================
	PUBLIC	_strtol
_strtol:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	PUSH	BC

	LD	L,(IX+4)	; HL = nptr
	LD	H,(IX+5)
	LD	A,(IX+8)	; A = base (low byte only matters)
	LD	(_strtol_base),A
	XOR	A
	LD	(_strtol_neg),A	; Clear negative flag

	; Skip leading whitespace
_strtol_skip:
	LD	A,(HL)
	CP	' '
	JR	Z,_strtol_skipnext
	CP	09H
	JR	Z,_strtol_skipnext
	CP	0AH
	JR	Z,_strtol_skipnext
	CP	0DH
	JR	Z,_strtol_skipnext
	JR	_strtol_sign
_strtol_skipnext:
	INC	HL
	JR	_strtol_skip

_strtol_sign:
	LD	A,(HL)
	CP	'-'
	JR	NZ,_strtol_chkplus
	LD	A,1
	LD	(_strtol_neg),A
	INC	HL
	JR	_strtol_prefix
_strtol_chkplus:
	CP	'+'
	JR	NZ,_strtol_prefix
	INC	HL

_strtol_prefix:
	; Check for 0x or 0 prefix if base==0 or base==16/8
	LD	A,(_strtol_base)
	OR	A
	JR	Z,_strtol_auto	; Auto-detect base
	CP	16
	JR	Z,_strtol_chk0x
	JR	_strtol_init

_strtol_auto:
	LD	A,(HL)
	CP	'0'
	JR	NZ,_strtol_base10
	INC	HL
	LD	A,(HL)
	CP	'x'
	JR	Z,_strtol_hexauto
	CP	'X'
	JR	Z,_strtol_hexauto
	; Octal
	DEC	HL
	LD	A,8
	LD	(_strtol_base),A
	JR	_strtol_init

_strtol_hexauto:
	INC	HL		; Skip 'x'
	LD	A,16
	LD	(_strtol_base),A
	JR	_strtol_init

_strtol_base10:
	LD	A,10
	LD	(_strtol_base),A
	JR	_strtol_init

_strtol_chk0x:
	; For explicit base 16, skip optional 0x prefix
	LD	A,(HL)
	CP	'0'
	JR	NZ,_strtol_init
	INC	HL
	LD	A,(HL)
	CP	'x'
	JR	Z,_strtol_skip0x
	CP	'X'
	JR	Z,_strtol_skip0x
	DEC	HL
	JR	_strtol_init
_strtol_skip0x:
	INC	HL

_strtol_init:
	; Initialize result to 0
	XOR	A
	LD	(_strtol_acc),A
	LD	(_strtol_acc+1),A
	LD	(_strtol_acc+2),A
	LD	(_strtol_acc+3),A

_strtol_loop:
	LD	A,(HL)
	; Convert digit
	CP	'0'
	JR	C,_strtol_done
	CP	'9'+1
	JR	C,_strtol_digit
	; Check for hex digits
	CP	'A'
	JR	C,_strtol_done
	CP	'Z'+1
	JR	C,_strtol_upper
	CP	'a'
	JR	C,_strtol_done
	CP	'z'+1
	JR	NC,_strtol_done
	SUB	'a'-10
	JR	_strtol_gotdig

_strtol_upper:
	SUB	'A'-10
	JR	_strtol_gotdig

_strtol_digit:
	SUB	'0'

_strtol_gotdig:
	; A = digit value, check against base
	LD	B,A
	LD	A,(_strtol_base)
	CP	B
	JR	C,_strtol_done	; digit >= base
	JR	Z,_strtol_done	; digit >= base
	LD	A,B

	; acc = acc * base + digit
	PUSH	HL
	PUSH	AF		; Save digit

	; Multiply acc by base
	LD	A,(_strtol_base)
	CALL	_strtol_mult

	; Add digit
	POP	AF
	LD	E,A
	LD	D,0
	LD	HL,(_strtol_acc)
	ADD	HL,DE
	LD	(_strtol_acc),HL
	JR	NC,_strtol_noc
	LD	HL,(_strtol_acc+2)
	INC	HL
	LD	(_strtol_acc+2),HL
_strtol_noc:
	POP	HL
	INC	HL
	JR	_strtol_loop

_strtol_done:
	; Save end pointer if endptr != NULL
	LD	E,(IX+6)	; DE = endptr
	LD	D,(IX+7)
	LD	A,D
	OR	E
	JR	Z,_strtol_noend
	; *endptr = HL
	EX	DE,HL
	LD	(HL),E
	INC	HL
	LD	(HL),D
_strtol_noend:

	; Load result into DEHL
	LD	HL,(_strtol_acc)
	LD	DE,(_strtol_acc+2)

	; Apply sign
	LD	A,(_strtol_neg)
	OR	A
	JR	Z,_strtol_ret

	; Negate DEHL
	PUSH	BC
	LD	BC,0
	LD	A,C
	SUB	L
	LD	L,A
	LD	A,C
	SBC	A,H
	LD	H,A
	LD	A,C
	SBC	A,E
	LD	E,A
	LD	A,C
	SBC	A,D
	LD	D,A
	POP	BC

_strtol_ret:
	POP	BC
	POP	IX
	RET

; Internal: multiply _strtol_acc by A
_strtol_mult:
	PUSH	BC
	LD	B,A		; B = multiplier

	; Copy acc to tmp
	LD	HL,(_strtol_acc)
	LD	(_strtol_tmp),HL
	LD	HL,(_strtol_acc+2)
	LD	(_strtol_tmp+2),HL

	; Clear acc
	XOR	A
	LD	(_strtol_acc),A
	LD	(_strtol_acc+1),A
	LD	(_strtol_acc+2),A
	LD	(_strtol_acc+3),A

	; Multiply by shifts and adds
_strtol_mult_loop:
	LD	A,B
	OR	A
	JR	Z,_strtol_mult_done
	RRA			; Carry = LSB
	LD	B,A
	JR	NC,_strtol_mult_shift

	; Add tmp to acc
	LD	HL,(_strtol_acc)
	LD	DE,(_strtol_tmp)
	ADD	HL,DE
	LD	(_strtol_acc),HL
	LD	HL,(_strtol_acc+2)
	LD	DE,(_strtol_tmp+2)
	ADC	HL,DE
	LD	(_strtol_acc+2),HL

_strtol_mult_shift:
	; tmp = tmp * 2
	LD	HL,(_strtol_tmp)
	ADD	HL,HL
	LD	(_strtol_tmp),HL
	LD	HL,(_strtol_tmp+2)
	ADC	HL,HL
	LD	(_strtol_tmp+2),HL
	JR	_strtol_mult_loop

_strtol_mult_done:
	POP	BC
	RET

; ============================================================
; unsigned long strtoul(const char *nptr, char **endptr, int base)
; Convert string to unsigned long (32-bit)
; Same as strtol but ignores minus sign
; ============================================================
	PUBLIC	_strtoul
_strtoul:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	PUSH	BC

	LD	L,(IX+4)	; HL = nptr
	LD	H,(IX+5)
	LD	A,(IX+8)	; A = base
	LD	(_strtol_base),A
	XOR	A
	LD	(_strtol_neg),A	; Always unsigned

	; Skip leading whitespace
_strtoul_skip:
	LD	A,(HL)
	CP	' '
	JR	Z,_strtoul_skipnext
	CP	09H
	JR	Z,_strtoul_skipnext
	CP	0AH
	JR	Z,_strtoul_skipnext
	CP	0DH
	JR	Z,_strtoul_skipnext
	JR	_strtoul_sign
_strtoul_skipnext:
	INC	HL
	JR	_strtoul_skip

_strtoul_sign:
	; Skip optional + sign, ignore - sign
	LD	A,(HL)
	CP	'+'
	JR	NZ,_strtoul_pref
	INC	HL

_strtoul_pref:
	JP	_strtol_prefix	; Share the rest of strtol code

; ============================================================
; double atof(const char *nptr)
; Convert string to double (IEEE 754 single precision)
; ============================================================
	PUBLIC	_atof
_atof:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	PUSH	BC

	; Call strtod with NULL endptr
	LD	L,(IX+4)
	LD	H,(IX+5)	; HL = nptr
	PUSH	HL
	LD	HL,0
	PUSH	HL		; endptr = NULL
	CALL	_strtod
	POP	BC
	POP	BC

	POP	BC
	POP	IX
	RET

; ============================================================
; double strtod(const char *nptr, char **endptr)
; Convert string to double (IEEE 754 single precision)
; Format: [ws][sign][digits][.digits][e[sign]digits]
; Returns result in DEHL
; ============================================================
	PUBLIC	_strtod
	PUBLIC	_strtof		; Same as strtod for our implementation
	PUBLIC	_strtold	; Same as strtod for our implementation
_strtof:
_strtold:
_strtod:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	PUSH	BC

	LD	L,(IX+4)
	LD	H,(IX+5)	; HL = nptr
	XOR	A
	LD	(_strtod_neg),A	; Clear negative flag
	LD	(_strtod_expneg),A	; Clear exponent negative
	LD	A,1
	LD	(_strtod_expadj),A	; Exponent adjustment (1.0 default)
	LD	(_strtod_expadj+1),A

	; Initialize result to 0.0
	XOR	A
	LD	(_strtod_result),A
	LD	(_strtod_result+1),A
	LD	(_strtod_result+2),A
	LD	(_strtod_result+3),A

	; Skip leading whitespace
_strtod_skip:
	LD	A,(HL)
	CP	' '
	JR	Z,_strtod_skipnext
	CP	09H
	JR	Z,_strtod_skipnext
	CP	0AH
	JR	Z,_strtod_skipnext
	CP	0DH
	JR	Z,_strtod_skipnext
	JR	_strtod_sign
_strtod_skipnext:
	INC	HL
	JR	_strtod_skip

_strtod_sign:
	PUSH	HL		; Save start position for endptr
	LD	A,(HL)
	CP	'-'
	JR	NZ,_strtod_chkplus
	LD	A,1
	LD	(_strtod_neg),A
	INC	HL
	JR	_strtod_intpart
_strtod_chkplus:
	CP	'+'
	JR	NZ,_strtod_intpart
	INC	HL

_strtod_intpart:
	; Parse integer part: accumulate digits
	; Use 32-bit integer accumulator first
	XOR	A
	LD	(_strtod_intacc),A
	LD	(_strtod_intacc+1),A
	LD	(_strtod_intacc+2),A
	LD	(_strtod_intacc+3),A
	LD	(_strtod_gotdigit),A	; No digits yet

_strtod_intloop:
	LD	A,(HL)
	CP	'0'
	JR	C,_strtod_intdone
	CP	'9'+1
	JR	NC,_strtod_intdone
	; Got a digit
	LD	B,1
	LD	(_strtod_gotdigit),A
	SUB	'0'
	LD	C,A		; C = digit value

	; Multiply accumulator by 10 and add digit
	PUSH	HL
	PUSH	BC

	; Load accumulator
	LD	HL,(_strtod_intacc)
	LD	DE,(_strtod_intacc+2)
	; Multiply by 10: DEHL * 10
	; Save original
	PUSH	DE
	PUSH	HL
	; *2
	ADD	HL,HL
	RL	E
	RL	D
	; *4
	ADD	HL,HL
	RL	E
	RL	D
	; *8 + *2 = *10
	POP	BC		; Original low
	EX	(SP),HL		; Swap with original high, get *8 low
	ADD	HL,BC		; *8 low + *2 low
	EX	DE,HL		; DE = new low
	POP	BC		; Original high
	LD	A,H
	ADC	A,C
	LD	H,A
	LD	A,L
	ADC	A,B
	LD	L,A		; HL = high, DE = low (wrong order)
	EX	DE,HL		; DEHL = result*10
	; Now add digit in C
	POP	BC		; Get digit back
	LD	A,L
	ADD	A,C
	LD	L,A
	JR	NC,_strtod_noc1
	INC	H
	JR	NZ,_strtod_noc1
	INC	DE
_strtod_noc1:
	; Store back
	LD	(_strtod_intacc),HL
	LD	(_strtod_intacc+2),DE
	POP	HL
	INC	HL
	JR	_strtod_intloop

_strtod_intdone:
	; Check for decimal point
	LD	A,(HL)
	CP	'.'
	JR	NZ,_strtod_chkexp

	INC	HL		; Skip decimal point
	; Parse fractional part
	LD	DE,1		; Divisor starts at 1
	LD	(_strtod_divisor),DE
	LD	DE,0
	LD	(_strtod_divisor+2),DE
	XOR	A
	LD	(_strtod_fracacc),A
	LD	(_strtod_fracacc+1),A
	LD	(_strtod_fracacc+2),A
	LD	(_strtod_fracacc+3),A

_strtod_fracloop:
	LD	A,(HL)
	CP	'0'
	JR	C,_strtod_fracdone
	CP	'9'+1
	JR	NC,_strtod_fracdone
	; Got a fractional digit
	LD	B,1
	LD	(_strtod_gotdigit),A
	SUB	'0'
	LD	C,A

	; Multiply divisor by 10
	PUSH	HL
	PUSH	BC
	LD	HL,(_strtod_divisor)
	LD	DE,(_strtod_divisor+2)
	; *10 (same as above)
	PUSH	DE
	PUSH	HL
	ADD	HL,HL
	RL	E
	RL	D
	ADD	HL,HL
	RL	E
	RL	D
	POP	BC
	EX	(SP),HL
	ADD	HL,BC
	EX	DE,HL
	POP	BC
	LD	A,H
	ADC	A,C
	LD	H,A
	LD	A,L
	ADC	A,B
	LD	L,A
	EX	DE,HL
	LD	(_strtod_divisor),HL
	LD	(_strtod_divisor+2),DE

	; Multiply fracacc by 10 and add digit
	LD	HL,(_strtod_fracacc)
	LD	DE,(_strtod_fracacc+2)
	PUSH	DE
	PUSH	HL
	ADD	HL,HL
	RL	E
	RL	D
	ADD	HL,HL
	RL	E
	RL	D
	POP	BC
	EX	(SP),HL
	ADD	HL,BC
	EX	DE,HL
	POP	BC
	LD	A,H
	ADC	A,C
	LD	H,A
	LD	A,L
	ADC	A,B
	LD	L,A
	EX	DE,HL
	; Add digit
	POP	BC
	LD	A,L
	ADD	A,C
	LD	L,A
	JR	NC,_strtod_noc2
	INC	H
	JR	NZ,_strtod_noc2
	INC	DE
_strtod_noc2:
	LD	(_strtod_fracacc),HL
	LD	(_strtod_fracacc+2),DE
	POP	HL
	INC	HL
	JR	_strtod_fracloop

_strtod_fracdone:

_strtod_chkexp:
	; Check for exponent
	LD	A,(HL)
	CP	'e'
	JR	Z,_strtod_parseexp
	CP	'E'
	JR	Z,_strtod_parseexp
	JR	_strtod_convert

_strtod_parseexp:
	INC	HL		; Skip 'e'
	XOR	A
	LD	(_strtod_expneg),A
	LD	(_strtod_exp),A
	LD	(_strtod_exp+1),A

	LD	A,(HL)
	CP	'-'
	JR	NZ,_strtod_expplus
	LD	A,1
	LD	(_strtod_expneg),A
	INC	HL
	JR	_strtod_expdigits
_strtod_expplus:
	CP	'+'
	JR	NZ,_strtod_expdigits
	INC	HL

_strtod_expdigits:
	LD	A,(HL)
	CP	'0'
	JR	C,_strtod_convert
	CP	'9'+1
	JR	NC,_strtod_convert
	SUB	'0'
	LD	C,A
	; exp = exp * 10 + digit
	PUSH	HL
	LD	HL,(_strtod_exp)
	LD	D,H
	LD	E,L
	ADD	HL,HL		; *2
	ADD	HL,HL		; *4
	ADD	HL,DE		; *5
	ADD	HL,HL		; *10
	LD	D,0
	LD	E,C
	ADD	HL,DE
	LD	(_strtod_exp),HL
	POP	HL
	INC	HL
	JR	_strtod_expdigits

_strtod_convert:
	; Save end position
	EX	(SP),HL		; HL = start, (SP) = end

	; Check if we got any digits
	LD	A,(_strtod_gotdigit)
	OR	A
	JR	NZ,_strtod_hasdigits
	; No digits - return 0.0 with endptr = nptr
	POP	HL		; Discard end
	; HL = start (nptr)
	JR	_strtod_storendptr

_strtod_hasdigits:
	POP	HL		; HL = end position
	PUSH	HL		; Save it back

	; Convert integer part to float
	PUSH	HL
	LD	HL,(_strtod_intacc)
	LD	DE,(_strtod_intacc+2)
	CALL	__ltof		; Convert long to float
	LD	(_strtod_result),HL
	LD	(_strtod_result+2),DE
	POP	HL

	; Add fractional part if any
	LD	A,(_strtod_divisor)
	DEC	A
	OR	A
	JR	NZ,_strtod_addfrac
	LD	A,(_strtod_divisor+1)
	OR	A
	JR	NZ,_strtod_addfrac
	LD	A,(_strtod_divisor+2)
	OR	A
	JR	NZ,_strtod_addfrac
	LD	A,(_strtod_divisor+3)
	OR	A
	JR	Z,_strtod_applyexp

_strtod_addfrac:
	; Convert fracacc to float
	PUSH	HL
	LD	HL,(_strtod_fracacc)
	LD	DE,(_strtod_fracacc+2)
	CALL	__ltof
	; Divide by divisor
	LD	(_strtod_tmp),HL
	LD	(_strtod_tmp+2),DE
	LD	HL,(_strtod_divisor)
	LD	DE,(_strtod_divisor+2)
	CALL	__ltof
	LD	(__tmp32),HL
	LD	(__tmp32+2),DE
	LD	HL,(_strtod_tmp)
	LD	DE,(_strtod_tmp+2)
	CALL	__fdiv
	; Add to result
	LD	(__tmp32),HL
	LD	(__tmp32+2),DE
	LD	HL,(_strtod_result)
	LD	DE,(_strtod_result+2)
	CALL	__fadd
	LD	(_strtod_result),HL
	LD	(_strtod_result+2),DE
	POP	HL

_strtod_applyexp:
	; Apply exponent if any
	LD	DE,(_strtod_exp)
	LD	A,D
	OR	E
	JR	Z,_strtod_applysign

	; Build 10^exp
	PUSH	HL
	LD	HL,(_strtod_result)
	LD	DE,(_strtod_result+2)
	LD	BC,(_strtod_exp)

_strtod_exploop:
	LD	A,B
	OR	C
	JR	Z,_strtod_expdone
	; Multiply or divide by 10
	LD	A,(_strtod_expneg)
	OR	A
	JR	NZ,_strtod_expdiv

	; Multiply by 10
	PUSH	BC
	LD	BC,00004120H	; 10.0 in IEEE 754
	LD	(__tmp32),BC
	LD	BC,00000000H
	LD	(__tmp32+2),BC
	CALL	__fmul
	POP	BC
	DEC	BC
	JR	_strtod_exploop

_strtod_expdiv:
	; Divide by 10
	PUSH	BC
	LD	BC,00004120H	; 10.0 in IEEE 754
	LD	(__tmp32),BC
	LD	BC,00000000H
	LD	(__tmp32+2),BC
	CALL	__fdiv
	POP	BC
	DEC	BC
	JR	_strtod_exploop

_strtod_expdone:
	LD	(_strtod_result),HL
	LD	(_strtod_result+2),DE
	POP	HL

_strtod_applysign:
	; Apply negative sign if needed
	LD	A,(_strtod_neg)
	OR	A
	JR	Z,_strtod_storendptr

	; Negate: flip sign bit
	LD	HL,(_strtod_result+2)
	LD	A,H
	XOR	80H
	LD	H,A
	LD	(_strtod_result+2),HL

_strtod_storendptr:
	; Store endptr if not NULL
	POP	HL		; HL = end position
	LD	C,(IX+6)
	LD	B,(IX+7)	; BC = endptr
	LD	A,B
	OR	C
	JR	Z,_strtod_retval
	; Store HL at *endptr
	LD	A,L
	LD	(BC),A
	INC	BC
	LD	A,H
	LD	(BC),A

_strtod_retval:
	LD	HL,(_strtod_result)
	LD	DE,(_strtod_result+2)
	POP	BC
	POP	IX
	RET

	EXTRN	__ltof
	EXTRN	__fadd
	EXTRN	__fsub
	EXTRN	__fmul
	EXTRN	__fdiv
	EXTRN	__tmp32

; strtod work variables
_strtod_neg:	DB	0
_strtod_expneg:	DB	0
_strtod_gotdigit: DB	0
_strtod_exp:	DW	0
_strtod_expadj:	DW	1
_strtod_intacc:	DS	4
_strtod_fracacc: DS	4
_strtod_divisor: DS	4
_strtod_result:	DS	4
_strtod_tmp:	DS	4

; ============================================================
; Multibyte/Wide Character Conversion Functions
; Minimal implementation for C locale (1:1 char mapping)
; ============================================================

; int mblen(const char *s, size_t n)
; Determine bytes in multibyte character
; C locale: always returns 1 for non-null char, 0 for null, -1 if s==NULL
	PUBLIC	_mblen
_mblen:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP

	LD	L,(IX+4)
	LD	H,(IX+5)	; HL = s
	LD	A,H
	OR	L
	JR	Z,_mblen_null	; s == NULL

	; Check if n >= 1
	LD	C,(IX+6)
	LD	B,(IX+7)	; BC = n
	LD	A,B
	OR	C
	JR	Z,_mblen_zero	; n == 0

	; Check character
	LD	A,(HL)
	OR	A
	JR	Z,_mblen_zero	; null character

	; Valid single-byte character
	LD	HL,1
	POP	IX
	RET

_mblen_null:
	; s == NULL: return 0 (stateless encoding)
	LD	HL,0
	POP	IX
	RET

_mblen_zero:
	LD	HL,0
	POP	IX
	RET

; int mbtowc(wchar_t *pwc, const char *s, size_t n)
; Convert multibyte to wide character
; C locale: just copy byte to wchar_t
	PUBLIC	_mbtowc
_mbtowc:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP

	LD	L,(IX+6)
	LD	H,(IX+7)	; HL = s
	LD	A,H
	OR	L
	JR	Z,_mbtowc_null	; s == NULL

	; Check n
	LD	C,(IX+8)
	LD	B,(IX+9)	; BC = n
	LD	A,B
	OR	C
	JR	Z,_mbtowc_err	; n == 0

	; Get character
	LD	A,(HL)
	OR	A
	JR	Z,_mbtowc_nul	; null character

	; Store in pwc if not NULL
	LD	C,A		; Save char
	LD	L,(IX+4)
	LD	H,(IX+5)	; HL = pwc
	LD	A,H
	OR	L
	JR	Z,_mbtowc_ret1
	; Store as wide char (16-bit)
	LD	(HL),C
	INC	HL
	XOR	A
	LD	(HL),A

_mbtowc_ret1:
	LD	HL,1
	POP	IX
	RET

_mbtowc_nul:
	; Store 0 in pwc if not NULL
	LD	L,(IX+4)
	LD	H,(IX+5)
	LD	A,H
	OR	L
	JR	Z,_mbtowc_ret0
	XOR	A
	LD	(HL),A
	INC	HL
	LD	(HL),A
_mbtowc_ret0:
	LD	HL,0
	POP	IX
	RET

_mbtowc_null:
	; s == NULL: return 0 (stateless)
	LD	HL,0
	POP	IX
	RET

_mbtowc_err:
	LD	HL,-1
	POP	IX
	RET

; int wctomb(char *s, wchar_t wc)
; Convert wide character to multibyte
; C locale: just copy low byte if <= 255
	PUBLIC	_wctomb
_wctomb:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP

	LD	L,(IX+4)
	LD	H,(IX+5)	; HL = s
	LD	A,H
	OR	L
	JR	Z,_wctomb_null	; s == NULL

	; Get wchar_t
	LD	C,(IX+6)	; Low byte of wc
	LD	A,(IX+7)	; High byte
	OR	A
	JR	NZ,_wctomb_err	; > 255: invalid for C locale

	; Store character
	LD	(HL),C
	LD	HL,1
	POP	IX
	RET

_wctomb_null:
	; s == NULL: return 0 (stateless)
	LD	HL,0
	POP	IX
	RET

_wctomb_err:
	LD	HL,-1
	POP	IX
	RET

; size_t mbstowcs(wchar_t *dest, const char *src, size_t n)
; Convert multibyte string to wide string
; C locale: copy bytes to wchar_t array
	PUBLIC	_mbstowcs
_mbstowcs:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	PUSH	BC

	LD	E,(IX+4)
	LD	D,(IX+5)	; DE = dest
	LD	L,(IX+6)
	LD	H,(IX+7)	; HL = src
	LD	C,(IX+8)
	LD	B,(IX+9)	; BC = n
	PUSH	BC		; Save n

	LD	BC,0		; Count = 0

_mbstowcs_loop:
	; Check if count < n
	POP	HL		; n
	PUSH	HL
	OR	A
	SBC	HL,BC
	JR	Z,_mbstowcs_done
	JR	C,_mbstowcs_done

	; Get source pointer back
	LD	L,(IX+6)
	LD	H,(IX+7)
	ADD	HL,BC		; HL = src + count
	LD	A,(HL)		; Get char

	; Check for null terminator
	OR	A
	JR	Z,_mbstowcs_term

	; Store in dest if not NULL
	LD	L,(IX+4)
	LD	H,(IX+5)	; HL = dest
	LD	E,A
	LD	A,H
	OR	L
	JR	Z,_mbstowcs_nodest
	; dest[count] = char
	PUSH	BC
	SLA	C
	RL	B		; BC * 2 for wchar_t offset
	ADD	HL,BC
	LD	(HL),E		; Low byte
	INC	HL
	XOR	A
	LD	(HL),A		; High byte = 0
	POP	BC

_mbstowcs_nodest:
	INC	BC		; count++
	JR	_mbstowcs_loop

_mbstowcs_term:
	; Null terminate dest if not NULL
	LD	L,(IX+4)
	LD	H,(IX+5)
	LD	A,H
	OR	L
	JR	Z,_mbstowcs_done
	PUSH	BC
	SLA	C
	RL	B
	ADD	HL,BC
	XOR	A
	LD	(HL),A
	INC	HL
	LD	(HL),A
	POP	BC

_mbstowcs_done:
	POP	HL		; Discard saved n
	LD	H,B
	LD	L,C		; Return count
	POP	BC
	POP	IX
	RET

; size_t wcstombs(char *dest, const wchar_t *src, size_t n)
; Convert wide string to multibyte string
; C locale: copy low bytes if <= 255
	PUBLIC	_wcstombs
_wcstombs:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	PUSH	BC

	LD	BC,0		; Count = 0

_wcstombs_loop:
	; Check if count < n
	LD	L,(IX+8)
	LD	H,(IX+9)	; HL = n
	OR	A
	SBC	HL,BC
	JR	Z,_wcstombs_done
	JR	C,_wcstombs_done

	; Get wchar at src[count]
	LD	L,(IX+6)
	LD	H,(IX+7)	; HL = src
	PUSH	BC
	SLA	C
	RL	B		; BC * 2 for wchar_t
	ADD	HL,BC
	POP	BC
	LD	E,(HL)		; Low byte
	INC	HL
	LD	A,(HL)		; High byte
	OR	A
	JR	NZ,_wcstombs_err	; > 255

	; Check for null terminator
	LD	A,E
	OR	A
	JR	Z,_wcstombs_term

	; Store in dest if not NULL
	LD	L,(IX+4)
	LD	H,(IX+5)
	LD	A,H
	OR	L
	JR	Z,_wcstombs_nodest
	ADD	HL,BC
	LD	(HL),E

_wcstombs_nodest:
	INC	BC
	JR	_wcstombs_loop

_wcstombs_term:
	; Null terminate
	LD	L,(IX+4)
	LD	H,(IX+5)
	LD	A,H
	OR	L
	JR	Z,_wcstombs_done
	ADD	HL,BC
	XOR	A
	LD	(HL),A

_wcstombs_done:
	LD	H,B
	LD	L,C
	POP	BC
	POP	IX
	RET

_wcstombs_err:
	LD	HL,-1
	POP	BC
	POP	IX
	RET

; ============================================================
; char *strrchr(const char *s, int c)
; Find last occurrence of c in s
; Returns: pointer to char, or NULL if not found
; ============================================================
	PUBLIC	_strrchr
_strrchr:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP

	LD	L,(IX+4)	; HL = s
	LD	H,(IX+5)
	LD	C,(IX+6)	; C = char to find
	LD	DE,0		; DE = last match (NULL initially)

_strrchr_loop:
	LD	A,(HL)
	CP	C
	JR	NZ,_strrchr_nomatch
	LD	D,H		; Save this match
	LD	E,L
_strrchr_nomatch:
	OR	A		; Check for end of string
	JR	Z,_strrchr_done
	INC	HL
	JR	_strrchr_loop

_strrchr_done:
	EX	DE,HL		; HL = last match (or NULL)
	POP	IX
	RET

; ============================================================
; char *strstr(const char *haystack, const char *needle)
; Find first occurrence of needle in haystack
; Returns: pointer to start of match, or NULL if not found
; ============================================================
	PUBLIC	_strstr
_strstr:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	PUSH	BC

	LD	L,(IX+4)	; HL = haystack
	LD	H,(IX+5)
	LD	E,(IX+6)	; DE = needle
	LD	D,(IX+7)

	; Check if needle is empty
	LD	A,(DE)
	OR	A
	JR	Z,_strstr_found	; Empty needle matches at start

_strstr_outer:
	LD	A,(HL)
	OR	A
	JR	Z,_strstr_notfound	; End of haystack

	; Try to match needle at current position
	PUSH	HL		; Save haystack position
	PUSH	DE		; Save needle start

_strstr_inner:
	LD	A,(DE)
	OR	A
	JR	Z,_strstr_match	; End of needle = match!

	LD	B,(HL)		; B = haystack char
	CP	B
	JR	NZ,_strstr_nomatch

	INC	HL
	INC	DE
	JR	_strstr_inner

_strstr_nomatch:
	POP	DE		; Restore needle start
	POP	HL		; Restore haystack position
	INC	HL		; Try next position
	JR	_strstr_outer

_strstr_match:
	POP	DE		; Discard needle start
	POP	HL		; HL = start of match
_strstr_found:
	POP	BC
	POP	IX
	RET

_strstr_notfound:
	LD	HL,0
	POP	BC
	POP	IX
	RET

; ============================================================
; char *strdup(const char *s)
; Duplicate a string (allocate memory and copy)
; Returns: pointer to new string, or NULL if allocation fails
; ============================================================
	PUBLIC	_strdup
_strdup:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	PUSH	BC
	PUSH	DE

	; Get string pointer
	LD	L,(IX+4)
	LD	H,(IX+5)	; HL = s

	; Find length (including null terminator)
	PUSH	HL
	CALL	_strlen		; HL = length (not including null)
	INC	HL		; Add 1 for null terminator

	; Allocate memory
	PUSH	HL		; Push size argument
	CALL	_malloc		; HL = allocated pointer or NULL
	POP	DE		; Clean up argument

	; Check if malloc failed
	LD	A,H
	OR	L
	JR	Z,_strdup_done	; Return NULL

	; Copy string to new memory
	; HL = dest (from malloc)
	; Stack has source string address
	EX	DE,HL		; DE = dest
	POP	HL		; HL = source (was pushed earlier)
	PUSH	DE		; Save dest to return

	; Copy loop
_strdup_copy:
	LD	A,(HL)
	LD	(DE),A
	OR	A
	JR	Z,_strdup_copydone
	INC	HL
	INC	DE
	JR	_strdup_copy

_strdup_copydone:
	POP	HL		; HL = dest (return value)
	JR	_strdup_ret

_strdup_done:
	; NULL result - need to pop saved source
	POP	DE		; Discard saved source
	; HL is already 0

_strdup_ret:
	POP	DE
	POP	BC
	POP	IX
	RET

; ============================================================
; size_t strcspn(const char *s, const char *reject)
; Return length of initial segment of s not containing any chars from reject
; ============================================================
	PUBLIC	_strcspn
_strcspn:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	PUSH	BC
	PUSH	DE

	LD	L,(IX+4)	; HL = s
	LD	H,(IX+5)
	LD	E,(IX+6)	; DE = reject
	LD	D,(IX+7)
	LD	BC,0		; BC = count

_strcspn_loop:
	LD	A,(HL)
	OR	A
	JR	Z,_strcspn_done	; End of s

	; Check if A is in reject string
	PUSH	HL
	PUSH	DE
	POP	HL		; HL = reject
_strcspn_check:
	LD	D,(HL)
	LD	A,D
	OR	A
	JR	Z,_strcspn_ok	; End of reject, char not found
	POP	DE
	PUSH	DE
	LD	A,(DE)		; A = current char from s
	CP	D
	JR	Z,_strcspn_found	; Found in reject
	INC	HL
	JR	_strcspn_check

_strcspn_ok:
	; Char not in reject, continue
	POP	HL
	INC	HL
	INC	BC
	JR	_strcspn_loop

_strcspn_found:
	POP	HL		; Discard saved s pointer
_strcspn_done:
	LD	H,B
	LD	L,C		; HL = count
	POP	DE
	POP	BC
	POP	IX
	RET

; ============================================================
; size_t strspn(const char *s, const char *accept)
; Return length of initial segment of s containing only chars from accept
; ============================================================
	PUBLIC	_strspn
_strspn:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	PUSH	BC

	LD	L,(IX+4)	; HL = s
	LD	H,(IX+5)
	LD	BC,0		; BC = count

_strspn_loop:
	LD	A,(HL)
	OR	A
	JR	Z,_strspn_done	; End of s
	LD	E,A		; E = current char from s

	; Check if E is in accept string
	PUSH	HL		; Save s pointer
	LD	L,(IX+6)	; HL = accept (reload from stack frame)
	LD	H,(IX+7)
_strspn_check:
	LD	A,(HL)
	OR	A
	JR	Z,_strspn_notfound	; End of accept, char not found
	CP	E		; Compare accept char with s char
	JR	Z,_strspn_ok	; Found in accept
	INC	HL
	JR	_strspn_check

_strspn_ok:
	; Char in accept, continue
	POP	HL		; Restore s pointer
	INC	HL
	INC	BC
	JR	_strspn_loop

_strspn_notfound:
	POP	HL		; Discard saved s pointer
_strspn_done:
	LD	H,B
	LD	L,C		; HL = count
	POP	BC
	POP	IX
	RET

; ============================================================
; char *strtok(char *str, const char *delim)
; Tokenize a string. First call with str, subsequent with NULL.
; Uses _strtok_next for state, _strtok_tok for token start
; ============================================================
	PUBLIC	_strtok
_strtok:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	PUSH	BC
	PUSH	DE

	; Get str parameter or use saved position
	LD	L,(IX+4)
	LD	H,(IX+5)
	LD	A,H
	OR	L
	JR	NZ,_strtok_have_str
	LD	HL,(_strtok_next)
	LD	A,H
	OR	L
	JP	Z,_strtok_null		; No more tokens

_strtok_have_str:
	; HL = current position, skip leading delimiters
_strtok_skip:
	LD	A,(HL)
	OR	A
	JP	Z,_strtok_null		; End of string

	; Check if current char is a delimiter
	LD	B,A			; B = char to check
	LD	E,(IX+6)
	LD	D,(IX+7)		; DE = delim
_strtok_skip_loop:
	LD	A,(DE)
	OR	A
	JR	Z,_strtok_token_start	; Not a delimiter
	CP	B
	JR	Z,_strtok_skip_found
	INC	DE
	JR	_strtok_skip_loop
_strtok_skip_found:
	INC	HL
	JR	_strtok_skip

_strtok_token_start:
	; HL points to start of token, save it
	LD	(_strtok_tok),HL

	; Find end of token
_strtok_scan:
	LD	A,(HL)
	OR	A
	JR	Z,_strtok_end_of_str

	; Check if current char is a delimiter
	LD	B,A
	LD	E,(IX+6)
	LD	D,(IX+7)
_strtok_scan_loop:
	LD	A,(DE)
	OR	A
	JR	Z,_strtok_scan_next	; Not a delimiter
	CP	B
	JR	Z,_strtok_found_delim
	INC	DE
	JR	_strtok_scan_loop

_strtok_scan_next:
	INC	HL
	JR	_strtok_scan

_strtok_found_delim:
	; Null-terminate token
	LD	(HL),0
	INC	HL
	LD	(_strtok_next),HL
	JR	_strtok_return

_strtok_end_of_str:
	; No more tokens after this one
	LD	HL,0
	LD	(_strtok_next),HL

_strtok_return:
	LD	HL,(_strtok_tok)
	POP	DE
	POP	BC
	POP	IX
	RET

_strtok_null:
	LD	HL,0
	LD	(_strtok_next),HL
	POP	DE
	POP	BC
	POP	IX
	RET

; ============================================================
; char *strpbrk(const char *s, const char *accept)
; Find first occurrence of any char from accept in s
; Returns: pointer to char, or NULL if not found
; ============================================================
	PUBLIC	_strpbrk
_strpbrk:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	PUSH	BC
	PUSH	DE

	LD	L,(IX+4)	; HL = s
	LD	H,(IX+5)

_strpbrk_loop:
	LD	A,(HL)
	OR	A
	JR	Z,_strpbrk_notfound	; End of s

	; Check if char is in accept
	LD	B,A		; B = char to find
	LD	E,(IX+6)	; DE = accept
	LD	D,(IX+7)

_strpbrk_check:
	LD	A,(DE)
	OR	A
	JR	Z,_strpbrk_next	; End of accept, not found
	CP	B
	JR	Z,_strpbrk_found
	INC	DE
	JR	_strpbrk_check

_strpbrk_next:
	INC	HL
	JR	_strpbrk_loop

_strpbrk_found:
	; HL points to matching char
	POP	DE
	POP	BC
	POP	IX
	RET

_strpbrk_notfound:
	LD	HL,0
	POP	DE
	POP	BC
	POP	IX
	RET

; ============================================================
; char *strerror(int errnum)
; Return string describing error number
; ============================================================
	PUBLIC	_strerror
_strerror:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP

	LD	A,(IX+4)	; A = errnum (low byte)

	; Check common error codes
	OR	A
	JR	Z,_strerror_ok	; 0 = success
	CP	2		; ENOENT
	JR	Z,_strerror_noent
	CP	5		; EIO
	JR	Z,_strerror_io
	CP	12		; ENOMEM
	JR	Z,_strerror_nomem
	CP	13		; EACCES
	JR	Z,_strerror_acces
	CP	22		; EINVAL
	JR	Z,_strerror_inval
	CP	28		; ENOSPC
	JR	Z,_strerror_nospc
	CP	38		; ENOSYS
	JR	Z,_strerror_nosys
	; Default - unknown error
	LD	HL,_strerr_unknown
	JR	_strerror_ret

_strerror_ok:
	LD	HL,_strerr_ok
	JR	_strerror_ret
_strerror_noent:
	LD	HL,_strerr_noent
	JR	_strerror_ret
_strerror_io:
	LD	HL,_strerr_io
	JR	_strerror_ret
_strerror_nomem:
	LD	HL,_strerr_nomem
	JR	_strerror_ret
_strerror_acces:
	LD	HL,_strerr_acces
	JR	_strerror_ret
_strerror_inval:
	LD	HL,_strerr_inval
	JR	_strerror_ret
_strerror_nospc:
	LD	HL,_strerr_nospc
	JR	_strerror_ret
_strerror_nosys:
	LD	HL,_strerr_nosys

_strerror_ret:
	POP	IX
	RET

; ============================================================
; Locale support (minimal "C" locale only)
; ============================================================

; char *setlocale(int category, const char *locale)
; Only supports "C" and "" (null string = default = "C")
; Returns "C" on success, NULL on failure
	PUBLIC	_setlocale
_setlocale:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	; category at IX+4, locale at IX+6
	LD	L,(IX+6)
	LD	H,(IX+7)	; HL = locale string
	; NULL means query current locale (return "C")
	LD	A,H
	OR	L
	JR	Z,_setlocale_ok
	; "" means use default (return "C")
	LD	A,(HL)
	OR	A
	JR	Z,_setlocale_ok
	; Check for "C"
	CP	'C'
	JR	NZ,_setlocale_check_posix
	INC	HL
	LD	A,(HL)
	OR	A
	JR	Z,_setlocale_ok
	JR	_setlocale_fail
_setlocale_check_posix:
	; Check for "POSIX"
	LD	DE,_locale_posix
	LD	B,5
_setlocale_cmp:
	LD	A,(DE)
	CP	(HL)
	JR	NZ,_setlocale_fail
	INC	HL
	INC	DE
	DJNZ	_setlocale_cmp
	LD	A,(HL)
	OR	A
	JR	NZ,_setlocale_fail
_setlocale_ok:
	LD	HL,_locale_c_str
	POP	IX
	RET
_setlocale_fail:
	LD	HL,0		; Return NULL
	POP	IX
	RET

; struct lconv *localeconv(void)
; Returns pointer to static lconv structure
	PUBLIC	_localeconv
_localeconv:
	LD	HL,_lconv_data
	RET

; ============================================================
; char *strncat(char *dest, const char *src, size_t n)
; Append at most n chars from src to dest
; Returns: dest
; ============================================================
	PUBLIC	_strncat
_strncat:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	PUSH	BC

	LD	E,(IX+4)	; DE = dest
	LD	D,(IX+5)

	; Find end of dest
_strncat_find:
	LD	A,(DE)
	OR	A
	JR	Z,_strncat_copy
	INC	DE
	JR	_strncat_find

_strncat_copy:
	LD	L,(IX+6)	; HL = src
	LD	H,(IX+7)
	LD	C,(IX+8)	; BC = n
	LD	B,(IX+9)

_strncat_loop:
	LD	A,B		; Check if n == 0
	OR	C
	JR	Z,_strncat_done

	LD	A,(HL)
	OR	A
	JR	Z,_strncat_done	; End of src

	LD	(DE),A
	INC	HL
	INC	DE
	DEC	BC
	JR	_strncat_loop

_strncat_done:
	; Null terminate
	XOR	A
	LD	(DE),A

	LD	L,(IX+4)	; Return dest
	LD	H,(IX+5)
	POP	BC
	POP	IX
	RET

; ============================================================
; void *memmove(void *dest, const void *src, size_t n)
; Copy n bytes, handles overlapping regions
; Returns: dest
; ============================================================
	PUBLIC	_memmove
_memmove:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	PUSH	BC

	LD	E,(IX+4)	; DE = dest
	LD	D,(IX+5)
	LD	L,(IX+6)	; HL = src
	LD	H,(IX+7)
	LD	C,(IX+8)	; BC = n
	LD	B,(IX+9)

	; Check if n == 0
	LD	A,B
	OR	C
	JR	Z,_memmove_done

	; Check if we need to copy backwards
	; If dest > src and dest < src + n, copy backwards
	PUSH	HL
	OR	A
	SBC	HL,DE		; HL = src - dest
	POP	HL
	JR	NC,_memmove_fwd	; src >= dest, copy forward

	; dest > src, check if overlapping
	PUSH	HL
	ADD	HL,BC		; HL = src + n
	OR	A
	SBC	HL,DE		; If src + n > dest, overlapping
	POP	HL
	JR	C,_memmove_fwd	; No overlap, forward is fine
	JR	Z,_memmove_fwd

	; Copy backwards
	; Move pointers to end
	ADD	HL,BC
	DEC	HL		; HL = src + n - 1
	EX	DE,HL
	ADD	HL,BC
	DEC	HL		; HL = dest + n - 1
	EX	DE,HL		; HL = src end, DE = dest end

_memmove_bwd:
	LD	A,B
	OR	C
	JR	Z,_memmove_done
	LD	A,(HL)
	LD	(DE),A
	DEC	HL
	DEC	DE
	DEC	BC
	JR	_memmove_bwd

_memmove_fwd:
	; Copy forward using LDIR
	LDIR

_memmove_done:
	LD	L,(IX+4)	; Return dest
	LD	H,(IX+5)
	POP	BC
	POP	IX
	RET

; ============================================================
; void *memchr(const void *s, int c, size_t n)
; Find first occurrence of c in first n bytes of s
; Returns: pointer to byte, or NULL if not found
; ============================================================
	PUBLIC	_memchr
_memchr:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	PUSH	BC

	LD	L,(IX+4)	; HL = s
	LD	H,(IX+5)
	LD	E,(IX+6)	; E = char to find
	LD	C,(IX+8)	; BC = n
	LD	B,(IX+9)

_memchr_loop:
	LD	A,B
	OR	C
	JR	Z,_memchr_notfound

	LD	A,(HL)
	CP	E
	JR	Z,_memchr_found

	INC	HL
	DEC	BC
	JR	_memchr_loop

_memchr_found:
	POP	BC
	POP	IX
	RET			; HL already points to match

_memchr_notfound:
	LD	HL,0
	POP	BC
	POP	IX
	RET

; ============================================================
; int sprintf(char *str, const char *fmt, ...)
; Format string into buffer
; Supports %d, %s, %c, %x, %%
; Returns: number of characters written (excluding null)
; ============================================================
	PUBLIC	_sprintf
_sprintf:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	PUSH	BC
	PUSH	DE

	; str is at IX+4, fmt at IX+6, first vararg at IX+8
	LD	E,(IX+4)
	LD	D,(IX+5)	; DE = output buffer pointer
	LD	(_sprintf_out),DE
	LD	L,(IX+6)
	LD	H,(IX+7)	; HL = format string pointer
	LD	C,8		; C = offset to next argument

	; Character counter
	LD	DE,0
	LD	(_sprintf_cnt),DE

_sprintf_loop:
	LD	A,(HL)
	OR	A
	JP	Z,_sprintf_done

	CP	'%'
	JR	Z,_sprintf_format

	; Regular character - output it
	CALL	_sprintf_putc
	INC	HL
	JR	_sprintf_loop

_sprintf_format:
	INC	HL
	LD	A,(HL)
	OR	A
	JP	Z,_sprintf_done

	CP	'%'
	JR	Z,_sprintf_pct

	; Initialize width and zero-flag
	PUSH	AF		; Save current char
	XOR	A
	LD	(_sprintf_width),A
	LD	(_sprintf_zero),A
	POP	AF		; Restore current char

_sprintf_fmt2:
	; Check for zero-padding flag (only at start)
	CP	'0'
	JR	NZ,_sprintf_chk_dig
	; Check if we haven't started parsing width yet
	LD	A,(_sprintf_width)
	OR	A
	JR	NZ,_sprintf_is_digit	; Already have width, this is a digit
	; This is the zero-padding flag
	LD	A,1
	LD	(_sprintf_zero),A
	INC	HL
	LD	A,(HL)
	OR	A
	JP	Z,_sprintf_done
	JR	_sprintf_fmt2

_sprintf_chk_dig:
	; Check for digit (1-9 first, then 0-9)
	CP	'1'
	JR	C,_sprintf_nodig
	CP	'9'+1
	JR	NC,_sprintf_nodig
_sprintf_is_digit:
	; Parse width digit: width = width * 10 + digit
	SUB	'0'
	PUSH	BC
	LD	B,A		; B = new digit
	LD	A,(_sprintf_width)
	; A = A * 10
	LD	C,A
	ADD	A,A		; A * 2
	ADD	A,A		; A * 4
	ADD	A,C		; A * 5
	ADD	A,A		; A * 10
	ADD	A,B		; A * 10 + digit
	LD	(_sprintf_width),A
	POP	BC
	INC	HL
	LD	A,(HL)
	OR	A
	JP	Z,_sprintf_done
	; Continue parsing - might be another digit
	CP	'0'
	JR	C,_sprintf_nodig
	CP	'9'+1
	JR	C,_sprintf_is_digit

_sprintf_nodig:
	; Skip flags: -, +, space, #
	CP	'-'
	JR	Z,_sprintf_fskip
	CP	'+'
	JR	Z,_sprintf_fskip
	CP	' '
	JR	Z,_sprintf_fskip
	CP	'#'
	JR	Z,_sprintf_fskip
	; Skip precision
	CP	'.'
	JR	Z,_sprintf_fskip
	; Skip length modifiers: h, l, z
	CP	'h'
	JR	Z,_sprintf_fskip
	CP	'l'
	JR	Z,_sprintf_fskip
	CP	'z'
	JR	Z,_sprintf_fskip
	; Now check format specifiers
	CP	's'
	JR	Z,_sprintf_str

	CP	'd'
	JR	Z,_sprintf_dec

	CP	'i'
	JR	Z,_sprintf_dec

	CP	'c'
	JR	Z,_sprintf_chr

	CP	'x'
	JR	Z,_sprintf_hex

	CP	'X'
	JR	Z,_sprintf_hex

	CP	'u'
	JR	Z,_sprintf_uns

	CP	'p'
	JR	Z,_sprintf_hex	; %p is same as %x

	; Unknown format - skip
	INC	HL
	JP	_sprintf_loop

_sprintf_fskip:
	INC	HL
	LD	A,(HL)
	OR	A
	JP	Z,_sprintf_done
	JR	_sprintf_fmt2

_sprintf_pct:
	; Output literal %
	LD	A,'%'
	CALL	_sprintf_putc
	INC	HL
	JP	_sprintf_loop

_sprintf_chr:
	; Output character
	PUSH	HL
	; Get argument
	LD	H,0
	LD	L,C
	PUSH	BC
	PUSH	IX
	POP	DE
	ADD	HL,DE		; HL = IX + offset
	LD	A,(HL)		; Get character
	CALL	_sprintf_putc
	POP	BC
	INC	C
	INC	C		; Advance to next arg
	POP	HL
	INC	HL
	JP	_sprintf_loop

_sprintf_str:
	; Output string
	PUSH	HL
	LD	H,0
	LD	L,C
	PUSH	BC
	PUSH	IX
	POP	DE
	ADD	HL,DE		; HL = IX + offset
	LD	E,(HL)
	INC	HL
	LD	D,(HL)		; DE = string pointer

_sprintf_str_loop:
	LD	A,(DE)
	OR	A
	JR	Z,_sprintf_str_done
	CALL	_sprintf_putc
	INC	DE
	JR	_sprintf_str_loop

_sprintf_str_done:
	POP	BC
	INC	C
	INC	C
	POP	HL
	INC	HL
	JP	_sprintf_loop

_sprintf_dec:
	; Output signed decimal
	PUSH	HL
	LD	H,0
	LD	L,C
	PUSH	BC
	PUSH	IX
	POP	DE
	ADD	HL,DE
	LD	E,(HL)
	INC	HL
	LD	D,(HL)		; DE = value
	EX	DE,HL		; HL = value

	; Check for negative
	BIT	7,H
	JR	Z,_sprintf_dec_pos

	; Negative - output minus and negate
	LD	A,'-'
	CALL	_sprintf_putc
	PUSH	DE
	EX	DE,HL
	LD	HL,0
	OR	A
	SBC	HL,DE
	POP	DE

_sprintf_dec_pos:
	CALL	_sprintf_prt_dec
	POP	BC
	INC	C
	INC	C
	POP	HL
	INC	HL
	JP	_sprintf_loop

_sprintf_uns:
	; Output unsigned decimal
	PUSH	HL
	LD	H,0
	LD	L,C
	PUSH	BC
	PUSH	IX
	POP	DE
	ADD	HL,DE
	LD	E,(HL)
	INC	HL
	LD	D,(HL)
	EX	DE,HL		; HL = value
	CALL	_sprintf_prt_dec
	POP	BC
	INC	C
	INC	C
	POP	HL
	INC	HL
	JP	_sprintf_loop

_sprintf_hex:
	; Output hex
	PUSH	HL
	LD	H,0
	LD	L,C
	PUSH	BC
	PUSH	IX
	POP	DE
	ADD	HL,DE
	LD	E,(HL)
	INC	HL
	LD	D,(HL)
	EX	DE,HL
	CALL	_sprintf_prt_hex
	POP	BC
	INC	C
	INC	C
	POP	HL
	INC	HL
	JP	_sprintf_loop

_sprintf_done:
	; Null terminate
	LD	HL,(_sprintf_out)
	LD	(HL),0

	; Return count
	LD	HL,(_sprintf_cnt)
	POP	DE
	POP	BC
	POP	IX
	RET

; Internal: put character to buffer
_sprintf_putc:
	PUSH	HL
	LD	HL,(_sprintf_out)
	LD	(HL),A
	INC	HL
	LD	(_sprintf_out),HL
	LD	HL,(_sprintf_cnt)
	INC	HL
	LD	(_sprintf_cnt),HL
	POP	HL
	RET

; Internal: print HL as decimal to buffer with optional width padding
_sprintf_prt_dec:
	PUSH	BC
	PUSH	DE

	; Convert to decimal digits on stack
	LD	DE,10
	LD	B,0		; Digit counter

_sprintf_dec_loop:
	CALL	_sprintf_div16
	PUSH	DE		; Push digit
	INC	B
	LD	A,H
	OR	L
	JR	NZ,_sprintf_dec_loop

	; B = digit count, check if we need padding
	LD	A,(_sprintf_width)
	OR	A
	JR	Z,_sprintf_dec_out	; No width specified

	; Calculate padding needed: width - digit_count
	SUB	B		; A = width - digit_count
	JR	Z,_sprintf_dec_out	; No padding needed
	JR	C,_sprintf_dec_out	; Digit count > width, no padding

	; A = number of padding chars needed
	PUSH	BC		; Save digit count
	LD	B,A		; B = padding count
	LD	A,(_sprintf_zero)
	OR	A
	LD	A,' '		; Default pad with space
	JR	Z,_sprintf_pad_lp
	LD	A,'0'		; Pad with zero

_sprintf_pad_lp:
	CALL	_sprintf_putc
	DJNZ	_sprintf_pad_lp
	POP	BC		; Restore digit count

	; Pop and output digits
_sprintf_dec_out:
	POP	DE
	LD	A,E
	ADD	A,'0'
	CALL	_sprintf_putc
	DJNZ	_sprintf_dec_out

	POP	DE
	POP	BC
	RET

; Simple division: HL = HL / 10, DE = HL % 10
_sprintf_div16:
	PUSH	BC
	LD	BC,0		; Result

_sprintf_div_lp:
	LD	A,H
	OR	A
	JR	NZ,_sprintf_div_sub
	LD	A,L
	CP	10
	JR	C,_sprintf_div_dn

_sprintf_div_sub:
	LD	A,L
	SUB	10
	LD	L,A
	LD	A,H
	SBC	A,0
	LD	H,A
	INC	BC
	JR	_sprintf_div_lp

_sprintf_div_dn:
	LD	E,L
	LD	D,0
	LD	H,B
	LD	L,C
	POP	BC
	RET

; Internal: print HL as 4-digit hex to buffer
_sprintf_prt_hex:
	PUSH	BC
	LD	A,H
	CALL	_sprintf_hex2
	LD	A,L
	CALL	_sprintf_hex2
	POP	BC
	RET

_sprintf_hex2:
	PUSH	AF
	RRCA
	RRCA
	RRCA
	RRCA
	CALL	_sprintf_hex1
	POP	AF
_sprintf_hex1:
	AND	0FH
	ADD	A,'0'
	CP	'9'+1
	JR	C,_sprintf_hex_out
	ADD	A,7
_sprintf_hex_out:
	JP	_sprintf_putc

; ============================================================
; int snprintf(char *str, size_t size, const char *fmt, ...)
; Format string into buffer with size limit
; Supports %d, %s, %c, %x, %u, %p, %%
; Returns: number of chars that would have been written (excl. null)
; Stack: str(IX+4), size(IX+6), fmt(IX+8), args start at IX+10
; ============================================================
	PUBLIC	_snprintf
_snprintf:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	PUSH	BC
	PUSH	DE

	; str is at IX+4, size at IX+6, fmt at IX+8, first vararg at IX+10
	LD	E,(IX+4)
	LD	D,(IX+5)	; DE = output buffer pointer
	LD	(_snprintf_out),DE
	LD	E,(IX+6)
	LD	D,(IX+7)	; DE = size
	LD	(_snprintf_max),DE
	LD	L,(IX+8)
	LD	H,(IX+9)	; HL = format string pointer
	LD	C,10		; C = offset to next argument

	; Character counter and remaining counter
	LD	DE,0
	LD	(_snprintf_cnt),DE

_snprintf_loop:
	LD	A,(HL)
	OR	A
	JP	Z,_snprintf_done

	CP	'%'
	JR	Z,_snprintf_format

	; Regular character - output it
	CALL	_snprintf_putc
	INC	HL
	JR	_snprintf_loop

_snprintf_format:
	INC	HL
	LD	A,(HL)
	OR	A
	JP	Z,_snprintf_done

	CP	'%'
	JR	Z,_snprintf_pct

_snprintf_fmt2:
	; Skip flags: -, +, space, #, 0
	CP	'-'
	JR	Z,_snprintf_fskip
	CP	'+'
	JR	Z,_snprintf_fskip
	CP	' '
	JR	Z,_snprintf_fskip
	CP	'#'
	JR	Z,_snprintf_fskip
	CP	'0'
	JR	Z,_snprintf_fskip
	; Skip field width digits
	CP	'1'
	JR	C,_snprintf_nodig
	CP	'9'+1
	JR	C,_snprintf_fskip
_snprintf_nodig:
	; Skip precision
	CP	'.'
	JR	Z,_snprintf_fskip
	; Skip length modifiers: h, l, z
	CP	'h'
	JR	Z,_snprintf_fskip
	CP	'l'
	JR	Z,_snprintf_fskip
	CP	'z'
	JR	Z,_snprintf_fskip
	; Now check format specifiers
	CP	's'
	JR	Z,_snprintf_str

	CP	'd'
	JR	Z,_snprintf_dec

	CP	'i'
	JR	Z,_snprintf_dec

	CP	'c'
	JR	Z,_snprintf_chr

	CP	'x'
	JR	Z,_snprintf_hex

	CP	'X'
	JR	Z,_snprintf_hex

	CP	'u'
	JR	Z,_snprintf_uns

	CP	'p'
	JR	Z,_snprintf_hex	; %p same as %x

	; Unknown format - skip
	INC	HL
	JP	_snprintf_loop

_snprintf_fskip:
	INC	HL
	LD	A,(HL)
	OR	A
	JP	Z,_snprintf_done
	JR	_snprintf_fmt2

_snprintf_pct:
	LD	A,'%'
	CALL	_snprintf_putc
	INC	HL
	JP	_snprintf_loop

_snprintf_chr:
	PUSH	HL
	LD	H,0
	LD	L,C
	PUSH	BC
	PUSH	IX
	POP	DE
	ADD	HL,DE
	LD	A,(HL)
	CALL	_snprintf_putc
	POP	BC
	INC	C
	INC	C
	POP	HL
	INC	HL
	JP	_snprintf_loop

_snprintf_str:
	PUSH	HL
	LD	H,0
	LD	L,C
	PUSH	BC
	PUSH	IX
	POP	DE
	ADD	HL,DE
	LD	E,(HL)
	INC	HL
	LD	D,(HL)		; DE = string pointer

_snprintf_str_loop:
	LD	A,(DE)
	OR	A
	JR	Z,_snprintf_str_done
	CALL	_snprintf_putc
	INC	DE
	JR	_snprintf_str_loop

_snprintf_str_done:
	POP	BC
	INC	C
	INC	C
	POP	HL
	INC	HL
	JP	_snprintf_loop

_snprintf_dec:
	PUSH	HL
	LD	H,0
	LD	L,C
	PUSH	BC
	PUSH	IX
	POP	DE
	ADD	HL,DE
	LD	E,(HL)
	INC	HL
	LD	D,(HL)
	EX	DE,HL		; HL = value

	BIT	7,H
	JR	Z,_snprintf_dec_pos

	LD	A,'-'
	CALL	_snprintf_putc
	PUSH	DE
	EX	DE,HL
	LD	HL,0
	OR	A
	SBC	HL,DE
	POP	DE

_snprintf_dec_pos:
	CALL	_snprintf_prt_dec
	POP	BC
	INC	C
	INC	C
	POP	HL
	INC	HL
	JP	_snprintf_loop

_snprintf_uns:
	PUSH	HL
	LD	H,0
	LD	L,C
	PUSH	BC
	PUSH	IX
	POP	DE
	ADD	HL,DE
	LD	E,(HL)
	INC	HL
	LD	D,(HL)
	EX	DE,HL
	CALL	_snprintf_prt_dec
	POP	BC
	INC	C
	INC	C
	POP	HL
	INC	HL
	JP	_snprintf_loop

_snprintf_hex:
	PUSH	HL
	LD	H,0
	LD	L,C
	PUSH	BC
	PUSH	IX
	POP	DE
	ADD	HL,DE
	LD	E,(HL)
	INC	HL
	LD	D,(HL)
	EX	DE,HL
	CALL	_snprintf_prt_hex
	POP	BC
	INC	C
	INC	C
	POP	HL
	INC	HL
	JP	_snprintf_loop

_snprintf_done:
	; Null terminate (if room)
	LD	HL,(_snprintf_max)
	LD	A,H
	OR	L
	JR	Z,_snprintf_ret	; size was 0, don't write null
	LD	HL,(_snprintf_out)
	LD	(HL),0

_snprintf_ret:
	; Return count (what would have been written)
	LD	HL,(_snprintf_cnt)
	POP	DE
	POP	BC
	POP	IX
	RET

; Internal: put character to buffer if room
_snprintf_putc:
	PUSH	HL
	PUSH	DE

	; Always increment count
	LD	HL,(_snprintf_cnt)
	INC	HL
	LD	(_snprintf_cnt),HL

	; Check if we have room (need 1 for char + 1 for null)
	LD	HL,(_snprintf_max)
	LD	DE,2
	OR	A
	SBC	HL,DE
	JR	C,_snprintf_putc_skip	; No room

	; Write character
	LD	HL,(_snprintf_out)
	LD	(HL),A
	INC	HL
	LD	(_snprintf_out),HL

	; Decrement remaining size
	LD	HL,(_snprintf_max)
	DEC	HL
	LD	(_snprintf_max),HL

_snprintf_putc_skip:
	POP	DE
	POP	HL
	RET

; Internal: print HL as decimal to buffer
_snprintf_prt_dec:
	PUSH	BC
	PUSH	DE
	LD	DE,10
	LD	B,0
_snprintf_dec_loop:
	CALL	_sprintf_div16	; Reuse sprintf's div16
	PUSH	DE
	INC	B
	LD	A,H
	OR	L
	JR	NZ,_snprintf_dec_loop
_snprintf_dec_out:
	POP	DE
	LD	A,E
	ADD	A,'0'
	CALL	_snprintf_putc
	DJNZ	_snprintf_dec_out
	POP	DE
	POP	BC
	RET

; Internal: print HL as 4-digit hex to buffer
_snprintf_prt_hex:
	PUSH	BC
	LD	A,H
	CALL	_snprintf_hex2
	LD	A,L
	CALL	_snprintf_hex2
	POP	BC
	RET

_snprintf_hex2:
	PUSH	AF
	RRCA
	RRCA
	RRCA
	RRCA
	CALL	_snprintf_hex1
	POP	AF
_snprintf_hex1:
	AND	0FH
	ADD	A,'0'
	CP	'9'+1
	JR	C,_snprintf_hex_out
	ADD	A,7
_snprintf_hex_out:
	JP	_snprintf_putc

; ============================================================
; scanf family - formatted input
; int scanf(const char *fmt, ...)
; int sscanf(const char *str, const char *fmt, ...)
; int fscanf(FILE *stream, const char *fmt, ...)
; ============================================================

	PUBLIC	_scanf
_scanf:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	; fmt at IX+4, args start at IX+6
	LD	L,(IX+4)
	LD	H,(IX+5)	; HL = format string
	LD	C,6		; C = offset to next argument
	XOR	A
	LD	(_scanf_count),A ; matched count
	LD	(_scanf_mode),A  ; mode=0: stdin

_scanf_loop:
	LD	A,(HL)
	OR	A
	JP	Z,_scanf_done

	CP	'%'
	JP	Z,_scanf_format

	CP	' '
	JP	Z,_scanf_white
	CP	9		; tab
	JP	Z,_scanf_white
	CP	10		; newline
	JP	Z,_scanf_white
	CP	13		; CR
	JP	Z,_scanf_white

	; Literal match required
	PUSH	HL
	PUSH	BC
	CALL	_scanf_getc
	POP	BC
	POP	HL
	CP	(HL)
	JP	NZ,_scanf_done	; Mismatch
	INC	HL
	JP	_scanf_loop

_scanf_white:
	; Skip whitespace in format and input
	INC	HL
	PUSH	HL
	PUSH	BC
_scanf_skip_ws:
	CALL	_scanf_getc
	CP	' '
	JR	Z,_scanf_skip_ws
	CP	9
	JR	Z,_scanf_skip_ws
	CP	10
	JR	Z,_scanf_skip_ws
	CP	13
	JR	Z,_scanf_skip_ws
	; Unget non-whitespace char
	CALL	_scanf_ungetc
	POP	BC
	POP	HL
	JP	_scanf_loop

_scanf_format:
	INC	HL
	LD	A,(HL)
	OR	A
	JP	Z,_scanf_done

	CP	'%'
	JP	Z,_scanf_pct

	CP	'd'
	JP	Z,_scanf_int
	CP	'i'
	JP	Z,_scanf_int

	CP	's'
	JP	Z,_scanf_str

	CP	'c'
	JP	Z,_scanf_chr

	CP	'u'
	JP	Z,_scanf_uint

	CP	'x'
	JP	Z,_scanf_hex

	CP	'l'
	JP	Z,_scanf_long

	CP	'*'
	JP	Z,_scanf_star

	; Unknown - skip
	INC	HL
	JP	_scanf_loop

_scanf_pct:
	; Match literal %
	PUSH	HL
	PUSH	BC
	CALL	_scanf_getc
	POP	BC
	POP	HL
	CP	'%'
	JP	NZ,_scanf_done
	INC	HL
	JP	_scanf_loop

_scanf_star:
	; Suppressed assignment - read but don't store
	INC	HL
	LD	A,(HL)
	CP	'd'
	JP	Z,_scanf_star_int
	CP	's'
	JP	Z,_scanf_star_str
	; Default: skip one int
_scanf_star_int:
	PUSH	HL
	PUSH	BC
	CALL	_scanf_skip_ws
	CALL	_scanf_read_int
	POP	BC
	POP	HL
	INC	HL
	JP	_scanf_loop
_scanf_star_str:
	PUSH	HL
	PUSH	BC
	CALL	_scanf_skip_ws
_scanf_star_str_loop:
	CALL	_scanf_getc
	CP	' '
	JR	Z,_scanf_star_str_done
	CP	9
	JR	Z,_scanf_star_str_done
	CP	10
	JR	Z,_scanf_star_str_done
	CP	13
	JR	Z,_scanf_star_str_done
	OR	A
	JR	NZ,_scanf_star_str_loop
_scanf_star_str_done:
	CALL	_scanf_ungetc
	POP	BC
	POP	HL
	INC	HL
	JP	_scanf_loop

_scanf_int:
	; Read signed integer
	PUSH	HL
	PUSH	BC
	CALL	_scanf_skip_ws
	CALL	_scanf_read_int	; Result in HL
	PUSH	HL
	; Get destination pointer
	LD	H,0
	LD	L,C
	PUSH	IX
	POP	DE
	ADD	HL,DE
	LD	E,(HL)
	INC	HL
	LD	D,(HL)		; DE = destination pointer
	POP	HL		; HL = value
	EX	DE,HL		; HL = dest, DE = value
	LD	(HL),E
	INC	HL
	LD	(HL),D
	; Increment count
	LD	A,(_scanf_count)
	INC	A
	LD	(_scanf_count),A
	POP	BC
	INC	C
	INC	C
	POP	HL
	INC	HL
	JP	_scanf_loop

_scanf_uint:
	; Read unsigned integer (same as int for now)
	JP	_scanf_int

_scanf_hex:
	; Read hex integer
	PUSH	HL
	PUSH	BC
	CALL	_scanf_skip_ws
	CALL	_scanf_read_hex	; Result in HL
	PUSH	HL
	; Get destination pointer
	LD	H,0
	LD	L,C
	PUSH	IX
	POP	DE
	ADD	HL,DE
	LD	E,(HL)
	INC	HL
	LD	D,(HL)
	POP	HL
	EX	DE,HL
	LD	(HL),E
	INC	HL
	LD	(HL),D
	LD	A,(_scanf_count)
	INC	A
	LD	(_scanf_count),A
	POP	BC
	INC	C
	INC	C
	POP	HL
	INC	HL
	JP	_scanf_loop

_scanf_str:
	; Read string (non-whitespace)
	PUSH	HL
	PUSH	BC
	CALL	_scanf_skip_ws
	; Get destination pointer
	LD	H,0
	LD	L,C
	PUSH	IX
	POP	DE
	ADD	HL,DE
	LD	E,(HL)
	INC	HL
	LD	D,(HL)		; DE = destination pointer
	EX	DE,HL		; HL = dest
_scanf_str_loop:
	PUSH	HL
	CALL	_scanf_getc
	POP	HL
	CP	' '
	JR	Z,_scanf_str_end
	CP	9
	JR	Z,_scanf_str_end
	CP	10
	JR	Z,_scanf_str_end
	CP	13
	JR	Z,_scanf_str_end
	CP	0FFH
	JR	Z,_scanf_str_end
	OR	A
	JR	Z,_scanf_str_end
	LD	(HL),A
	INC	HL
	JR	_scanf_str_loop
_scanf_str_end:
	LD	(HL),0		; Null terminate
	CALL	_scanf_ungetc
	LD	A,(_scanf_count)
	INC	A
	LD	(_scanf_count),A
	POP	BC
	INC	C
	INC	C
	POP	HL
	INC	HL
	JP	_scanf_loop

_scanf_chr:
	; Read single character
	PUSH	HL
	PUSH	BC
	CALL	_scanf_getc
	PUSH	AF
	; Get destination pointer
	LD	H,0
	LD	L,C
	PUSH	IX
	POP	DE
	ADD	HL,DE
	LD	E,(HL)
	INC	HL
	LD	D,(HL)
	EX	DE,HL
	POP	AF
	LD	(HL),A
	LD	A,(_scanf_count)
	INC	A
	LD	(_scanf_count),A
	POP	BC
	INC	C
	INC	C
	POP	HL
	INC	HL
	JP	_scanf_loop

_scanf_long:
	; Handle 'l' modifier
	INC	HL
	LD	A,(HL)
	CP	'd'
	JP	Z,_scanf_ld
	CP	'x'
	JP	Z,_scanf_lx
	; Unknown - skip
	JP	_scanf_loop

_scanf_ld:
	; Read long signed integer
	PUSH	HL
	PUSH	BC
	CALL	_scanf_skip_ws
	CALL	_scanf_read_long	; Result in DEHL
	PUSH	DE
	PUSH	HL
	; Get destination pointer
	LD	H,0
	LD	L,C
	PUSH	IX
	POP	DE
	ADD	HL,DE
	LD	E,(HL)
	INC	HL
	LD	D,(HL)
	EX	DE,HL		; HL = dest
	POP	DE		; DE = low word
	LD	(HL),E
	INC	HL
	LD	(HL),D
	INC	HL
	POP	DE		; DE = high word
	LD	(HL),E
	INC	HL
	LD	(HL),D
	LD	A,(_scanf_count)
	INC	A
	LD	(_scanf_count),A
	POP	BC
	INC	C
	INC	C
	POP	HL
	INC	HL
	JP	_scanf_loop

_scanf_lx:
	; Read long hex
	PUSH	HL
	PUSH	BC
	CALL	_scanf_skip_ws
	CALL	_scanf_read_long_hex
	PUSH	DE
	PUSH	HL
	LD	H,0
	LD	L,C
	PUSH	IX
	POP	DE
	ADD	HL,DE
	LD	E,(HL)
	INC	HL
	LD	D,(HL)
	EX	DE,HL
	POP	DE
	LD	(HL),E
	INC	HL
	LD	(HL),D
	INC	HL
	POP	DE
	LD	(HL),E
	INC	HL
	LD	(HL),D
	LD	A,(_scanf_count)
	INC	A
	LD	(_scanf_count),A
	POP	BC
	INC	C
	INC	C
	POP	HL
	INC	HL
	JP	_scanf_loop

_scanf_done:
	LD	A,(_scanf_count)
	LD	L,A
	LD	H,0
	POP	IX
	RET

; Internal: get a character based on mode
_scanf_getc:
	LD	A,(_scanf_mode)
	OR	A
	JR	NZ,_scanf_getc_str
	; Mode 0: stdin
	LD	C,1		; CONIN
	CALL	5
	RET
_scanf_getc_str:
	CP	1
	JR	NZ,_scanf_getc_file
	; Mode 1: string
	LD	HL,(_scanf_src)
	LD	A,(HL)
	OR	A
	JR	Z,_scanf_getc_eof
	INC	HL
	LD	(_scanf_src),HL
	RET
_scanf_getc_file:
	; Mode 2: file
	LD	HL,(_scanf_fp)
	PUSH	HL
	CALL	_fgetc
	POP	BC
	RET
_scanf_getc_eof:
	LD	A,0FFH
	RET

; Internal: unget character
_scanf_ungetc:
	LD	(_scanf_ungot),A
	RET

; Internal: read signed integer into HL
_scanf_read_int:
	LD	HL,0
	LD	D,0		; D = sign (0=positive, 1=negative)
	; Check for sign
	CALL	_scanf_getc
	CP	'-'
	JR	NZ,_scanf_ri_notneg
	LD	D,1
	JR	_scanf_ri_loop
_scanf_ri_notneg:
	CP	'+'
	JR	Z,_scanf_ri_loop
	; Not a sign - first digit
	JR	_scanf_ri_digit

_scanf_ri_loop:
	CALL	_scanf_getc
_scanf_ri_digit:
	CP	'0'
	JR	C,_scanf_ri_done
	CP	'9'+1
	JR	NC,_scanf_ri_done
	; Digit - accumulate
	SUB	'0'
	PUSH	DE
	LD	E,A
	; HL = HL * 10 + digit
	ADD	HL,HL		; *2
	LD	B,H
	LD	C,L
	ADD	HL,HL		; *4
	ADD	HL,HL		; *8
	ADD	HL,BC		; *10
	LD	D,0
	ADD	HL,DE
	POP	DE
	JR	_scanf_ri_loop

_scanf_ri_done:
	; Unget the non-digit
	CALL	_scanf_ungetc
	; Apply sign
	LD	A,D
	OR	A
	RET	Z
	; Negate HL
	XOR	A
	LD	D,A
	LD	E,A
	EX	DE,HL
	SBC	HL,DE
	RET

; Internal: read hex integer into HL
_scanf_read_hex:
	LD	HL,0
	; Skip optional 0x prefix
	CALL	_scanf_getc
	CP	'0'
	JR	NZ,_scanf_rh_digit
	CALL	_scanf_getc
	CP	'x'
	JR	Z,_scanf_rh_loop
	CP	'X'
	JR	Z,_scanf_rh_loop
	; Not 0x - process as digit
	CALL	_scanf_ungetc
	LD	A,'0'
	JR	_scanf_rh_digit

_scanf_rh_loop:
	CALL	_scanf_getc
_scanf_rh_digit:
	CP	'0'
	JR	C,_scanf_rh_done
	CP	'9'+1
	JR	C,_scanf_rh_09
	CP	'A'
	JR	C,_scanf_rh_done
	CP	'F'+1
	JR	C,_scanf_rh_AF
	CP	'a'
	JR	C,_scanf_rh_done
	CP	'f'+1
	JR	NC,_scanf_rh_done
	; a-f
	SUB	'a'-10
	JR	_scanf_rh_acc
_scanf_rh_AF:
	SUB	'A'-10
	JR	_scanf_rh_acc
_scanf_rh_09:
	SUB	'0'
_scanf_rh_acc:
	; HL = HL * 16 + digit
	ADD	HL,HL
	ADD	HL,HL
	ADD	HL,HL
	ADD	HL,HL
	OR	L
	LD	L,A
	JR	_scanf_rh_loop
_scanf_rh_done:
	CALL	_scanf_ungetc
	RET

; Internal: read long integer into DEHL
_scanf_read_long:
	LD	HL,0
	LD	DE,0
	LD	B,0		; sign
	CALL	_scanf_getc
	CP	'-'
	JR	NZ,_scanf_rl_notneg
	LD	B,1
	JR	_scanf_rl_loop
_scanf_rl_notneg:
	CP	'+'
	JR	Z,_scanf_rl_loop
	JR	_scanf_rl_digit

_scanf_rl_loop:
	CALL	_scanf_getc
_scanf_rl_digit:
	CP	'0'
	JP	C,_scanf_rl_done
	CP	'9'+1
	JP	NC,_scanf_rl_done
	SUB	'0'
	PUSH	BC
	LD	C,A
	; DEHL = DEHL * 10 + digit
	; First *10 = *8 + *2
	PUSH	DE
	PUSH	HL		; Save original
	SLA	L
	RL	H
	RL	E
	RL	D		; *2
	PUSH	DE
	PUSH	HL		; Save *2
	SLA	L
	RL	H
	RL	E
	RL	D		; *4
	SLA	L
	RL	H
	RL	E
	RL	D		; *8
	; Add *2
	POP	BC		; BC = *2 low
	ADD	HL,BC
	EX	(SP),HL		; Stack *8+*2 low, get *2 high
	EX	DE,HL
	POP	BC		; BC = *8+*2 low
	ADC	HL,DE		; HL = *10 high
	EX	DE,HL		; DE = *10 high
	LD	H,B
	LD	L,C		; HL = *10 low
	POP	BC		; Discard saved original high
	POP	BC		; Discard saved original low
	; Add digit
	LD	B,0
	ADD	HL,BC
	JR	NC,_scanf_rl_noc
	INC	DE
_scanf_rl_noc:
	POP	BC		; Restore sign
	JP	_scanf_rl_loop

_scanf_rl_done:
	CALL	_scanf_ungetc
	LD	A,B
	OR	A
	RET	Z
	; Negate DEHL
	PUSH	BC
	LD	A,L
	CPL
	LD	L,A
	LD	A,H
	CPL
	LD	H,A
	LD	A,E
	CPL
	LD	E,A
	LD	A,D
	CPL
	LD	D,A
	LD	BC,1
	ADD	HL,BC
	JR	NC,_scanf_rl_neg_done
	INC	DE
_scanf_rl_neg_done:
	POP	BC
	RET

; Internal: read long hex into DEHL
_scanf_read_long_hex:
	LD	HL,0
	LD	DE,0
	; Skip optional 0x
	CALL	_scanf_getc
	CP	'0'
	JR	NZ,_scanf_rlh_digit
	CALL	_scanf_getc
	CP	'x'
	JR	Z,_scanf_rlh_loop
	CP	'X'
	JR	Z,_scanf_rlh_loop
	CALL	_scanf_ungetc
	LD	A,'0'
	JR	_scanf_rlh_digit

_scanf_rlh_loop:
	CALL	_scanf_getc
_scanf_rlh_digit:
	CP	'0'
	JR	C,_scanf_rlh_done
	CP	'9'+1
	JR	C,_scanf_rlh_09
	CP	'A'
	JR	C,_scanf_rlh_done
	CP	'F'+1
	JR	C,_scanf_rlh_AF
	CP	'a'
	JR	C,_scanf_rlh_done
	CP	'f'+1
	JR	NC,_scanf_rlh_done
	SUB	'a'-10
	JR	_scanf_rlh_acc
_scanf_rlh_AF:
	SUB	'A'-10
	JR	_scanf_rlh_acc
_scanf_rlh_09:
	SUB	'0'
_scanf_rlh_acc:
	; DEHL = DEHL * 16 + digit
	SLA	L
	RL	H
	RL	E
	RL	D
	SLA	L
	RL	H
	RL	E
	RL	D
	SLA	L
	RL	H
	RL	E
	RL	D
	SLA	L
	RL	H
	RL	E
	RL	D
	OR	L
	LD	L,A
	JR	_scanf_rlh_loop
_scanf_rlh_done:
	CALL	_scanf_ungetc
	RET

; ============================================================
; sscanf - read from string
; ============================================================
	PUBLIC	_sscanf
_sscanf:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	; str at IX+4, fmt at IX+6, args at IX+8
	LD	L,(IX+4)
	LD	H,(IX+5)
	LD	(_scanf_src),HL
	LD	A,1
	LD	(_scanf_mode),A
	; Setup format and args offset
	LD	L,(IX+6)
	LD	H,(IX+7)	; HL = format
	LD	C,8		; args start at IX+8
	XOR	A
	LD	(_scanf_count),A
	JP	_scanf_loop

; ============================================================
; fscanf - read from file
; ============================================================
	PUBLIC	_fscanf
_fscanf:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	; stream at IX+4, fmt at IX+6, args at IX+8
	LD	L,(IX+4)
	LD	H,(IX+5)
	LD	(_scanf_fp),HL
	LD	A,2
	LD	(_scanf_mode),A
	LD	L,(IX+6)
	LD	H,(IX+7)
	LD	C,8
	XOR	A
	LD	(_scanf_count),A
	JP	_scanf_loop

; ============================================================
; void _assert_fail(const char *file, int line)
; Called when an assertion fails
; Prints message and exits
; ============================================================
	PUBLIC	__assert_fail
__assert_fail:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP

	; Print "Assert: "
	LD	HL,_assert_msg
	CALL	_assert_puts

	; Print filename
	LD	L,(IX+4)
	LD	H,(IX+5)
	CALL	_assert_puts

	; Print ":"
	LD	E,':'
	LD	C,2
	CALL	5

	; Print line number
	LD	L,(IX+6)
	LD	H,(IX+7)
	CALL	_assert_prt_dec

	; Print newline
	LD	E,0DH
	LD	C,2
	CALL	5
	LD	E,0AH
	LD	C,2
	CALL	5

	; Exit
	JP	0

; Internal: print string at HL
_assert_puts:
	LD	A,(HL)
	OR	A
	RET	Z
	LD	E,A
	PUSH	HL
	LD	C,2
	CALL	5
	POP	HL
	INC	HL
	JR	_assert_puts

; Internal: print HL as decimal
_assert_prt_dec:
	PUSH	BC
	PUSH	DE
	LD	DE,10
	LD	B,0
_assert_dec_loop:
	CALL	_assert_div
	PUSH	DE
	INC	B
	LD	A,H
	OR	L
	JR	NZ,_assert_dec_loop
_assert_dec_out:
	POP	DE
	LD	A,E
	ADD	A,'0'
	LD	E,A
	PUSH	BC
	LD	C,2
	CALL	5
	POP	BC
	DJNZ	_assert_dec_out
	POP	DE
	POP	BC
	RET

; Simple division: HL = HL / 10, DE = HL % 10
_assert_div:
	PUSH	BC
	LD	BC,0
_assert_div_lp:
	LD	A,H
	OR	A
	JR	NZ,_assert_div_sub
	LD	A,L
	CP	10
	JR	C,_assert_div_dn
_assert_div_sub:
	LD	A,L
	SUB	10
	LD	L,A
	LD	A,H
	SBC	A,0
	LD	H,A
	INC	BC
	JR	_assert_div_lp
_assert_div_dn:
	LD	E,L
	LD	D,0
	LD	H,B
	LD	L,C
	POP	BC
	RET

; ============================================================
; time_t time(time_t *tloc)
; Return current time (stub - returns 0 on CP/M)
; ============================================================
	PUBLIC	_time
_time:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	; Return 0 in DEHL (32-bit)
	LD	HL,0
	LD	DE,0
	; If tloc != NULL, store result
	LD	A,(IX+4)
	OR	(IX+5)
	JR	Z,_time_ret
	; Store 0 at *tloc
	PUSH	HL
	LD	L,(IX+4)
	LD	H,(IX+5)
	LD	(HL),0
	INC	HL
	LD	(HL),0
	INC	HL
	LD	(HL),0
	INC	HL
	LD	(HL),0
	POP	HL
_time_ret:
	POP	IX
	RET

; ============================================================
; clock_t clock(void)
; Return CPU time used (stub - returns 0)
; ============================================================
	PUBLIC	_clock
_clock:
	LD	HL,0
	LD	DE,0
	RET

; ============================================================
; char *getenv(const char *name)
; Get environment variable (stub - returns NULL on CP/M)
; ============================================================
	PUBLIC	_getenv
_getenv:
	LD	HL,0		; Always return NULL
	RET

; ============================================================
; int system(const char *command)
; Execute shell command (stub - returns -1 on CP/M)
; ============================================================
	PUBLIC	_system
_system:
	LD	HL,-1		; Return -1 (failure)
	RET

; ============================================================
; void qsort(void *base, size_t nmemb, size_t size,
;            int (*compar)(const void *, const void *))
; Sort array using selection sort (simpler for Z80)
; Stack: base(IX+4), nmemb(IX+6), size(IX+8), compar(IX+10)
; ============================================================
	PUBLIC	_qsort
	EXTRN	__callhl
_qsort:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	PUSH	BC
	PUSH	DE

	; Check if nmemb <= 1, nothing to sort
	LD	L,(IX+6)
	LD	H,(IX+7)
	LD	A,H
	OR	A
	JR	NZ,_qsort_start
	LD	A,L
	CP	2
	JP	C,_qsort_done	; nmemb < 2

_qsort_start:
	; Outer loop: i = 0 to nmemb-2
	LD	HL,0
	LD	(_qsort_i),HL

_qsort_outer:
	; Check if i >= nmemb - 1
	LD	HL,(_qsort_i)
	INC	HL		; i + 1
	LD	E,(IX+6)	; nmemb (low word only, assume < 65536)
	LD	D,(IX+7)
	OR	A
	SBC	HL,DE
	JP	NC,_qsort_done	; i + 1 >= nmemb, done

	; min_idx = i
	LD	HL,(_qsort_i)
	LD	(_qsort_min),HL

	; Inner loop: j = i + 1 to nmemb - 1
	LD	HL,(_qsort_i)
	INC	HL
	LD	(_qsort_j),HL

_qsort_inner:
	; Check if j >= nmemb
	LD	HL,(_qsort_j)
	LD	E,(IX+6)
	LD	D,(IX+7)
	OR	A
	SBC	HL,DE
	JP	NC,_qsort_swap	; j >= nmemb, do swap

	; Compare base[j] with base[min_idx]
	; Calculate address of base[j]
	LD	HL,(_qsort_j)
	CALL	_qsort_addr	; HL = base + j*size
	PUSH	HL		; First arg to compare

	; Calculate address of base[min_idx]
	LD	HL,(_qsort_min)
	CALL	_qsort_addr	; HL = base + min_idx*size
	PUSH	HL		; Second arg

	; Call compare function
	LD	L,(IX+10)
	LD	H,(IX+11)
	CALL	__callhl
	POP	DE		; Clean up args
	POP	DE

	; If result < 0, update min_idx
	BIT	7,H
	JR	Z,_qsort_inner_next
	; arr[j] < arr[min_idx], update min_idx
	LD	HL,(_qsort_j)
	LD	(_qsort_min),HL

_qsort_inner_next:
	LD	HL,(_qsort_j)
	INC	HL
	LD	(_qsort_j),HL
	JR	_qsort_inner

_qsort_swap:
	; Swap base[i] with base[min_idx] if min_idx != i
	LD	HL,(_qsort_i)
	LD	DE,(_qsort_min)
	OR	A
	SBC	HL,DE
	JR	Z,_qsort_outer_next	; Same, no swap needed

	; Get addresses
	LD	HL,(_qsort_i)
	CALL	_qsort_addr
	LD	(_qsort_ptr1),HL

	LD	HL,(_qsort_min)
	CALL	_qsort_addr
	LD	(_qsort_ptr2),HL

	; Swap size bytes
	LD	L,(IX+8)
	LD	H,(IX+9)	; HL = size
	LD	B,H
	LD	C,L		; BC = size counter

_qsort_swap_loop:
	LD	A,B
	OR	C
	JR	Z,_qsort_outer_next

	LD	HL,(_qsort_ptr1)
	LD	D,(HL)		; D = byte from ptr1
	LD	HL,(_qsort_ptr2)
	LD	E,(HL)		; E = byte from ptr2
	LD	(HL),D		; Store D at ptr2
	LD	HL,(_qsort_ptr1)
	LD	(HL),E		; Store E at ptr1

	; Advance pointers
	LD	HL,(_qsort_ptr1)
	INC	HL
	LD	(_qsort_ptr1),HL
	LD	HL,(_qsort_ptr2)
	INC	HL
	LD	(_qsort_ptr2),HL

	DEC	BC
	JR	_qsort_swap_loop

_qsort_outer_next:
	LD	HL,(_qsort_i)
	INC	HL
	LD	(_qsort_i),HL
	JP	_qsort_outer

_qsort_done:
	POP	DE
	POP	BC
	POP	IX
	RET

; Internal: calculate base + index*size
; Input: HL = index
; Output: HL = address
; Uses: size from IX+8
_qsort_addr:
	PUSH	DE
	PUSH	BC
	; Multiply HL by size
	LD	E,(IX+8)
	LD	D,(IX+9)	; DE = size
	CALL	__mul16		; HL = index * size
	; Add base
	LD	E,(IX+4)
	LD	D,(IX+5)
	ADD	HL,DE
	POP	BC
	POP	DE
	RET

; ============================================================
; void *bsearch(const void *key, const void *base, size_t nmemb,
;               size_t size, int (*compar)(const void *, const void *))
; Binary search in sorted array
; Stack: key(IX+4), base(IX+6), nmemb(IX+8), size(IX+10), compar(IX+12)
; Returns: pointer to found element, or NULL
; ============================================================
	PUBLIC	_bsearch
_bsearch:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	PUSH	BC
	PUSH	DE

	; low = 0
	LD	HL,0
	LD	(_bsearch_low),HL

	; high = nmemb
	LD	L,(IX+8)
	LD	H,(IX+9)
	LD	(_bsearch_high),HL

_bsearch_loop:
	; Check if low >= high
	LD	HL,(_bsearch_low)
	LD	DE,(_bsearch_high)
	OR	A
	SBC	HL,DE
	JP	NC,_bsearch_notfound	; low >= high

	; mid = (low + high) / 2
	LD	HL,(_bsearch_low)
	LD	DE,(_bsearch_high)
	ADD	HL,DE
	SRL	H
	RR	L		; HL = (low + high) / 2
	LD	(_bsearch_mid),HL

	; Calculate address of base[mid]
	LD	E,(IX+10)
	LD	D,(IX+11)	; DE = size
	CALL	__mul16		; HL = mid * size
	LD	E,(IX+6)
	LD	D,(IX+7)
	ADD	HL,DE		; HL = base + mid*size
	PUSH	HL		; Save mid address

	; Call compare(key, &base[mid])
	PUSH	HL		; Second arg: &base[mid]
	LD	L,(IX+4)
	LD	H,(IX+5)
	PUSH	HL		; First arg: key
	LD	L,(IX+12)
	LD	H,(IX+13)
	CALL	__callhl
	POP	DE		; Clean up first arg
	POP	DE		; Clean up second arg

	POP	DE		; Restore mid address into DE

	; Check result
	LD	A,H
	OR	L
	JR	Z,_bsearch_found	; cmp == 0, found!

	BIT	7,H
	JR	NZ,_bsearch_left	; cmp < 0, search left

	; cmp > 0, search right: low = mid + 1
	LD	HL,(_bsearch_mid)
	INC	HL
	LD	(_bsearch_low),HL
	JR	_bsearch_loop

_bsearch_left:
	; cmp < 0, search left: high = mid
	LD	HL,(_bsearch_mid)
	LD	(_bsearch_high),HL
	JR	_bsearch_loop

_bsearch_found:
	; Return mid address (saved in DE)
	EX	DE,HL
	JR	_bsearch_ret

_bsearch_notfound:
	LD	HL,0		; Return NULL

_bsearch_ret:
	POP	DE
	POP	BC
	POP	IX
	RET

	DSEG

; Float printing working storage
__ftmp:		DS	4	; Temp float storage
__fman:		DS	4	; Mantissa work area
__fwork:	DS	4	; Float working storage for printf

; Static return buffer for struct-by-value returns
	PUBLIC	__sret_buf
__sret_buf:	DS	64	; Enough for any returned struct

; qsort working storage
_qsort_i:	DS	2
_qsort_j:	DS	2
_qsort_min:	DS	2
_qsort_ptr1:	DS	2
_qsort_ptr2:	DS	2

; bsearch working storage
_bsearch_low:	DS	2
_bsearch_high:	DS	2
_bsearch_mid:	DS	2

	CSEG

; ============================================================
; Character classification functions
; These are also available as macros in ctype.h but provided
; as functions for use with function pointers
; ============================================================

; int isdigit(int c)
	PUBLIC	_isdigit
_isdigit:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	LD	A,(IX+4)
	CP	'0'
	JR	C,_isdigit_no
	CP	'9'+1
	JR	NC,_isdigit_no
	LD	HL,1
	POP	IX
	RET
_isdigit_no:
	LD	HL,0
	POP	IX
	RET

; int isalpha(int c)
	PUBLIC	_isalpha
_isalpha:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	LD	A,(IX+4)
	; Check uppercase
	CP	'A'
	JR	C,_isalpha_lower
	CP	'Z'+1
	JR	C,_isalpha_yes
_isalpha_lower:
	; Check lowercase
	CP	'a'
	JR	C,_isalpha_no
	CP	'z'+1
	JR	NC,_isalpha_no
_isalpha_yes:
	LD	HL,1
	POP	IX
	RET
_isalpha_no:
	LD	HL,0
	POP	IX
	RET

; int isalnum(int c)
	PUBLIC	_isalnum
_isalnum:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	LD	A,(IX+4)
	; Check digit
	CP	'0'
	JR	C,_isalnum_alpha
	CP	'9'+1
	JR	C,_isalnum_yes
_isalnum_alpha:
	; Check uppercase
	CP	'A'
	JR	C,_isalnum_lower
	CP	'Z'+1
	JR	C,_isalnum_yes
_isalnum_lower:
	CP	'a'
	JR	C,_isalnum_no
	CP	'z'+1
	JR	NC,_isalnum_no
_isalnum_yes:
	LD	HL,1
	POP	IX
	RET
_isalnum_no:
	LD	HL,0
	POP	IX
	RET

; int isspace(int c)
	PUBLIC	_isspace
_isspace:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	LD	A,(IX+4)
	CP	' '
	JR	Z,_isspace_yes
	CP	09H		; TAB
	JR	Z,_isspace_yes
	CP	0AH		; LF
	JR	Z,_isspace_yes
	CP	0BH		; VT
	JR	Z,_isspace_yes
	CP	0CH		; FF
	JR	Z,_isspace_yes
	CP	0DH		; CR
	JR	Z,_isspace_yes
	LD	HL,0
	POP	IX
	RET
_isspace_yes:
	LD	HL,1
	POP	IX
	RET

; int isupper(int c)
	PUBLIC	_isupper
_isupper:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	LD	A,(IX+4)
	CP	'A'
	JR	C,_isupper_no
	CP	'Z'+1
	JR	NC,_isupper_no
	LD	HL,1
	POP	IX
	RET
_isupper_no:
	LD	HL,0
	POP	IX
	RET

; int islower(int c)
	PUBLIC	_islower
_islower:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	LD	A,(IX+4)
	CP	'a'
	JR	C,_islower_no
	CP	'z'+1
	JR	NC,_islower_no
	LD	HL,1
	POP	IX
	RET
_islower_no:
	LD	HL,0
	POP	IX
	RET

; int toupper(int c)
	PUBLIC	_toupper
_toupper:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	LD	A,(IX+4)
	CP	'a'
	JR	C,_toupper_ret
	CP	'z'+1
	JR	NC,_toupper_ret
	SUB	'a'-'A'		; Convert to uppercase
_toupper_ret:
	LD	L,A
	LD	H,0
	POP	IX
	RET

; int tolower(int c)
	PUBLIC	_tolower
_tolower:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	LD	A,(IX+4)
	CP	'A'
	JR	C,_tolower_ret
	CP	'Z'+1
	JR	NC,_tolower_ret
	ADD	A,'a'-'A'	; Convert to lowercase
_tolower_ret:
	LD	L,A
	LD	H,0
	POP	IX
	RET

; int isprint(int c)
	PUBLIC	_isprint
_isprint:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	LD	A,(IX+4)
	CP	' '
	JR	C,_isprint_no
	CP	7FH		; DEL
	JR	NC,_isprint_no
	LD	HL,1
	POP	IX
	RET
_isprint_no:
	LD	HL,0
	POP	IX
	RET

; int isxdigit(int c)
	PUBLIC	_isxdigit
_isxdigit:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	LD	A,(IX+4)
	; Check digit
	CP	'0'
	JR	C,_isxdigit_hex
	CP	'9'+1
	JR	C,_isxdigit_yes
_isxdigit_hex:
	; Check A-F
	CP	'A'
	JR	C,_isxdigit_lower
	CP	'F'+1
	JR	C,_isxdigit_yes
_isxdigit_lower:
	; Check a-f
	CP	'a'
	JR	C,_isxdigit_no
	CP	'f'+1
	JR	NC,_isxdigit_no
_isxdigit_yes:
	LD	HL,1
	POP	IX
	RET
_isxdigit_no:
	LD	HL,0
	POP	IX
	RET

; ============================================================
; Signal handling for CP/M
; Software signal system - no hardware signals but full API support
; ============================================================

; Signal handler table - 7 entries (signals 0-6), each a 2-byte function pointer
; Initialized to SIG_DFL (0) = default handling
_sig_handlers:
	DW	0		; Signal 0 (unused)
	DW	0		; SIGABRT (1)
	DW	0		; SIGFPE (2)
	DW	0		; SIGILL (3)
	DW	0		; SIGINT (4)
	DW	0		; SIGSEGV (5)
	DW	0		; SIGTERM (6)

; sig_handler_t signal(int sig, sig_handler_t handler)
; Sets signal handler, returns previous handler
; Returns SIG_ERR (-1) for invalid signal numbers
	PUBLIC	_signal
_signal:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	; Get signal number
	LD	L,(IX+4)
	LD	H,(IX+5)
	; Validate signal (must be 1-6)
	LD	A,L
	OR	H		; H must be 0
	JR	NZ,_sig_err
	LD	A,L
	OR	A
	JR	Z,_sig_err	; 0 is invalid
	CP	7
	JR	NC,_sig_err	; >= 7 is invalid
	; Calculate table offset: sig * 2
	ADD	A,A		; A = sig * 2
	LD	E,A
	LD	D,0
	LD	HL,_sig_handlers
	ADD	HL,DE		; HL = &_sig_handlers[sig]
	; Save old handler to return
	LD	E,(HL)
	INC	HL
	LD	D,(HL)
	DEC	HL		; HL back to start
	; Store new handler
	LD	A,(IX+6)
	LD	(HL),A
	INC	HL
	LD	A,(IX+7)
	LD	(HL),A
	; Return old handler in HL
	EX	DE,HL
	POP	IX
	RET
_sig_err:
	; Return SIG_ERR (-1)
	LD	HL,-1
	POP	IX
	RET

; int raise(int sig)
; Raises a signal - calls the registered handler
; Returns 0 on success, -1 on error
	PUBLIC	_raise
_raise:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	; Get signal number
	LD	L,(IX+4)
	LD	H,(IX+5)
	; Validate signal (must be 1-6)
	LD	A,L
	OR	H
	JR	NZ,_raise_err
	LD	A,L
	OR	A
	JR	Z,_raise_err
	CP	7
	JR	NC,_raise_err
	; Save signal number
	PUSH	AF
	; Get handler: _sig_handlers[sig]
	ADD	A,A		; A = sig * 2
	LD	E,A
	LD	D,0
	LD	HL,_sig_handlers
	ADD	HL,DE
	LD	E,(HL)
	INC	HL
	LD	D,(HL)		; DE = handler
	; Check handler type
	LD	A,D
	OR	E
	JR	Z,_raise_dfl	; SIG_DFL (0) - default handling
	LD	A,D
	AND	E
	INC	A
	JR	Z,_raise_ign	; SIG_IGN (-1 = 0xFFFF) - ignore (but that's SIG_ERR)
	; Check if SIG_IGN (1)
	LD	A,D
	OR	A
	JR	NZ,_raise_call
	LD	A,E
	CP	1
	JR	Z,_raise_ign	; SIG_IGN (1) - ignore
	; Fall through to call handler
_raise_call:
	; Reset to SIG_DFL before calling (ANSI behavior)
	POP	AF		; Get signal number back
	PUSH	AF
	ADD	A,A
	LD	C,A
	LD	B,0
	LD	HL,_sig_handlers
	ADD	HL,BC
	XOR	A
	LD	(HL),A
	INC	HL
	LD	(HL),A		; Reset to SIG_DFL
	; Call handler with signal number as argument
	POP	AF		; Signal number
	PUSH	AF
	LD	L,A
	LD	H,0
	PUSH	HL		; Push signal argument
	; Call handler (DE has address)
	PUSH	DE
	POP	HL		; HL = handler address
	CALL	_raise_callhl
	POP	BC		; Clean up argument
	POP	AF		; Clean up saved signal
	; Return success
	LD	HL,0
	POP	IX
	RET
_raise_callhl:
	JP	(HL)		; Call handler

_raise_dfl:
	; Default handling - depends on signal type
	POP	AF		; Get signal number
	CP	1		; SIGABRT?
	JR	Z,_raise_abort
	CP	2		; SIGFPE?
	JR	Z,_raise_abort
	CP	3		; SIGILL?
	JR	Z,_raise_abort
	CP	5		; SIGSEGV?
	JR	Z,_raise_abort
	CP	6		; SIGTERM?
	JR	Z,_raise_abort
	; SIGINT (4) - default is ignore in CP/M context
	LD	HL,0
	POP	IX
	RET
_raise_abort:
	; Abort - warm boot CP/M
	LD	C,0		; BDOS function 0 - warm boot
	CALL	5
	; Should not return, but just in case
	LD	HL,0
	POP	IX
	RET

_raise_ign:
	; Signal ignored - just return success
	POP	AF		; Clean up saved signal
	LD	HL,0
	POP	IX
	RET

_raise_err:
	; Invalid signal number
	LD	HL,-1
	POP	IX
	RET

; ============================================================
; Math functions - IEEE 754 single precision implementations
; Using Taylor series, Newton-Raphson, and polynomial approximations
; ============================================================

	PUBLIC	_sin
	PUBLIC	_cos
	PUBLIC	_tan
	PUBLIC	_asin
	PUBLIC	_acos
	PUBLIC	_atan
	PUBLIC	_atan2
	PUBLIC	_sinh
	PUBLIC	_cosh
	PUBLIC	_tanh
	PUBLIC	_exp
	PUBLIC	_log
	PUBLIC	_log10
	PUBLIC	_log2
	PUBLIC	_pow
	PUBLIC	_sqrt
	PUBLIC	_cbrt
	PUBLIC	_hypot
	PUBLIC	_ceil
	PUBLIC	_floor
	PUBLIC	_trunc
	PUBLIC	_round
	PUBLIC	_fmod
	PUBLIC	_remainder
	PUBLIC	_fabs
	PUBLIC	_copysign
	PUBLIC	_frexp
	PUBLIC	_ldexp
	PUBLIC	_modf
	PUBLIC	_sinf
	PUBLIC	_cosf
	PUBLIC	_tanf
	PUBLIC	_asinf
	PUBLIC	_acosf
	PUBLIC	_atanf
	PUBLIC	_atan2f
	PUBLIC	_sinhf
	PUBLIC	_coshf
	PUBLIC	_tanhf
	PUBLIC	_sqrtf
	PUBLIC	_cbrtf
	PUBLIC	_hypotf
	PUBLIC	_powf
	PUBLIC	_fabsf
	PUBLIC	_copysignf
	PUBLIC	_floorf
	PUBLIC	_ceilf
	PUBLIC	_truncf
	PUBLIC	_roundf
	PUBLIC	_fmodf
	PUBLIC	_remainderf
	PUBLIC	_expf
	PUBLIC	_logf
	PUBLIC	_log2f
	PUBLIC	_log10f
	PUBLIC	_frexpf
	PUBLIC	_ldexpf
	PUBLIC	_modff
	PUBLIC	_sinl
	PUBLIC	_cosl
	PUBLIC	_tanl
	PUBLIC	_sqrtl
	PUBLIC	_powl
	PUBLIC	_fabsl
	PUBLIC	_floorl
	PUBLIC	_ceill
	PUBLIC	_truncl
	PUBLIC	_roundl
	PUBLIC	_fmodl
	PUBLIC	_expl
	PUBLIC	_logl
	PUBLIC	_log10l

	EXTRN	__fadd
	EXTRN	__fsub
	EXTRN	__fmul
	EXTRN	__fdiv
	EXTRN	__fcmp
	EXTRN	__itof
	EXTRN	__ftoi
	EXTRN	__tmp32

; Helper: Load float argument from stack into DEHL
; Call with IX pointing to stack frame (after PUSH IX only)
_math_getarg:
	; Stack: +0,+1=IX, +2,+3=retaddr, +4..+7=arg
	LD	L,(IX+4)
	LD	H,(IX+5)
	LD	E,(IX+6)
	LD	D,(IX+7)
	RET

; Helper: Load second float argument into __tmp32
_math_getarg2:
	LD	A,(IX+8)
	LD	(__tmp32),A
	LD	A,(IX+9)
	LD	(__tmp32+1),A
	LD	A,(IX+10)
	LD	(__tmp32+2),A
	LD	A,(IX+11)
	LD	(__tmp32+3),A
	RET

; ============================================================
; _reduce_trig - Reduce |x| in DEHL to [-pi, pi] range
; Input:  DEHL = |x| (non-negative float)
; Output: DEHL = reduced angle in [0, pi]
;         _trig_negate = 1 if result should be negated
; Uses __tmp32, _trig_* temporaries
; ============================================================
_reduce_trig:
	; Check if x <= pi (40490FDB): no reduction needed
	LD	(_trig_x),HL
	LD	(_trig_x+2),DE
	XOR	A
	LD	(_trig_negate),A

	; Compare |x| with pi (40490FDB) as unsigned integer
	; For positive IEEE 754 floats, integer comparison works
	LD	A,D
	CP	40H
	JR	C,_reduce_done	; D < 40H: definitely < pi
	JR	NZ,_reduce_needed ; D > 40H: definitely > pi
	; D == 40H, compare E
	LD	A,E
	CP	49H
	JR	C,_reduce_done	; E < 49H: < pi
	JR	NZ,_reduce_needed ; E > 49H: > pi
	; D=40H, E=49H, compare H
	LD	A,H
	CP	0FH
	JR	C,_reduce_done
	JR	NZ,_reduce_needed
	; D=40H,E=49H,H=0FH, compare L
	LD	A,L
	CP	0DCH		; DBH rounded up
	JR	C,_reduce_done
_reduce_needed:

	; Compute fmod(x, 2*pi)
	; __tmp32 = 2*pi (40C90FDB)
	LD	A,0DBH
	LD	(__tmp32),A
	LD	A,0FH
	LD	(__tmp32+1),A
	LD	A,0C9H
	LD	(__tmp32+2),A
	LD	A,40H
	LD	(__tmp32+3),A
	; DEHL = x
	LD	HL,(_trig_x)
	LD	DE,(_trig_x+2)
	CALL	__fdiv		; x / (2*pi)

	CALL	__ftoi		; trunc(x / 2*pi)
	CALL	__itof		; float(trunc)

	; * 2*pi
	LD	A,0DBH
	LD	(__tmp32),A
	LD	A,0FH
	LD	(__tmp32+1),A
	LD	A,0C9H
	LD	(__tmp32+2),A
	LD	A,40H
	LD	(__tmp32+3),A
	CALL	__fmul		; trunc(x/2pi) * 2pi

	; x - trunc(x/2pi)*2pi
	LD	(__tmp32),HL
	LD	(__tmp32+2),DE
	LD	HL,(_trig_x)
	LD	DE,(_trig_x+2)
	CALL	__fsub		; DEHL = fmod(x, 2*pi) in [0, 2*pi)

	; If result > pi, subtract pi and set negate flag
	LD	(_trig_x),HL
	LD	(_trig_x+2),DE
	; Compare with pi (40490FDB)
	LD	A,D
	CP	40H
	JR	C,_reduce_done	; < 40H means < pi
	JR	NZ,_reduce_sub_pi	; > 40H means > pi
	; D == 40H, compare E
	LD	A,E
	CP	49H
	JR	C,_reduce_done

_reduce_sub_pi:
	; x -= pi
	LD	A,0DBH
	LD	(__tmp32),A
	LD	A,0FH
	LD	(__tmp32+1),A
	LD	A,49H
	LD	(__tmp32+2),A
	LD	A,40H
	LD	(__tmp32+3),A
	LD	HL,(_trig_x)
	LD	DE,(_trig_x+2)
	CALL	__fsub
	LD	(_trig_x),HL
	LD	(_trig_x+2),DE
	LD	A,1
	LD	(_trig_negate),A

_reduce_done:
	LD	HL,(_trig_x)
	LD	DE,(_trig_x+2)
	RET

; ============================================================
; fabs(x) - return absolute value
; For 32-bit float, clear sign bit (bit 31)
; ============================================================
_fabs:
_fabsf:
_fabsl:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	LD	L,(IX+4)
	LD	H,(IX+5)
	LD	E,(IX+6)
	LD	A,(IX+7)
	AND	7FH		; Clear sign bit
	LD	D,A
	POP	IX
	RET

; ============================================================
; copysign(x, y) - return x with sign of y
; ============================================================
_copysign:
_copysignf:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	LD	L,(IX+4)
	LD	H,(IX+5)
	LD	E,(IX+6)
	LD	A,(IX+7)
	AND	7FH		; Clear x sign
	LD	B,A
	LD	A,(IX+11)	; y high byte
	AND	80H		; Get y sign
	OR	B		; Combine
	LD	D,A
	POP	IX
	RET

; ============================================================
; sqrt(x) - Square root using Newton-Raphson
; x_{n+1} = (x_n + S/x_n) / 2
; ============================================================
_sqrt:
_sqrtf:
_sqrtl:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP

	CALL	_math_getarg
	PUSH	BC	; x in DEHL

	; Check for zero or negative
	LD	A,D
	AND	7FH
	OR	E
	OR	H
	OR	L
	JR	Z,_sqrt_zero
	BIT	7,D
	JR	NZ,_sqrt_neg	; Negative -> return NaN (0)

	; Save x
	LD	(_sqrt_x),HL
	LD	(_sqrt_x+2),DE

	; Initial guess: float with exponent = exp/2 + 64, mantissa = 0
	; Extract full 8-bit biased exponent
	LD	A,D
	ADD	A,A		; A = E6..E0.0, carry = sign
	BIT	7,E		; Test low exponent bit
	JR	Z,_sqrt_gexp
	OR	1		; Set low bit
_sqrt_gexp:
	; A = full 8-bit exponent
	SRL	A		; A = exp/2
	ADD	A,64		; A = exp/2 + 64 (new biased exponent)
	; Reconstruct float: D = new_exp >> 1, E = (new_exp & 1) << 7
	LD	B,A
	SRL	A		; A = top 7 bits for D
	LD	D,A
	LD	A,B
	AND	1
	RRCA			; 1 -> 0x80, 0 -> 0x00
	LD	E,A
	LD	H,0
	LD	L,0
	LD	(_sqrt_guess),HL
	LD	(_sqrt_guess+2),DE

_sqrt_iterate:
	; Newton-Raphson: 8 iterations for convergence
	LD	B,8

_sqrt_loop:
	PUSH	BC

	; Compute x / guess
	LD	HL,(_sqrt_x)
	LD	DE,(_sqrt_x+2)
	LD	A,(_sqrt_guess)
	LD	(__tmp32),A
	LD	A,(_sqrt_guess+1)
	LD	(__tmp32+1),A
	LD	A,(_sqrt_guess+2)
	LD	(__tmp32+2),A
	LD	A,(_sqrt_guess+3)
	LD	(__tmp32+3),A
	CALL	__fdiv		; DEHL = x / guess

	; Add guess
	LD	A,(_sqrt_guess)
	LD	(__tmp32),A
	LD	A,(_sqrt_guess+1)
	LD	(__tmp32+1),A
	LD	A,(_sqrt_guess+2)
	LD	(__tmp32+2),A
	LD	A,(_sqrt_guess+3)
	LD	(__tmp32+3),A
	CALL	__fadd		; DEHL = (x/guess + guess)

	; Divide by 2 (subtract 1 from exponent)
	; IEEE 754: D=SEEEEEEE E=EMMMMMMM
	; Exponent = D[6:0]*2 + E[7]
	BIT	7,E		; Test low bit of exponent
	JR	NZ,_sqrt_exp_odd
	; Exponent low bit is 0: set it and decrement D[6:0]
	SET	7,E
	LD	A,D
	AND	80H		; Save sign bit
	LD	C,A
	LD	A,D
	AND	7FH		; Get upper 7 exponent bits
	DEC	A		; Decrement
	OR	C		; Restore sign
	LD	D,A
	JR	_sqrt_exp_done
_sqrt_exp_odd:
	; Exponent low bit is 1: just clear it
	RES	7,E
_sqrt_exp_done:

	; Update guess
	LD	(_sqrt_guess),HL
	LD	(_sqrt_guess+2),DE

	POP	BC
	DJNZ	_sqrt_loop

	; Result in DEHL
	LD	HL,(_sqrt_guess)
	LD	DE,(_sqrt_guess+2)
	JR	_sqrt_done

_sqrt_zero:
_sqrt_neg:
	LD	HL,0
	LD	DE,0

_sqrt_done:
	POP	BC
	POP	IX
	RET

; ============================================================
; sin(x) - Sine using Taylor series
; sin(x) = x - x^3/3! + x^5/5! - x^7/7! + ...
; ============================================================
_sin:
_sinf:
_sinl:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP

	CALL	_math_getarg
	PUSH	BC	; x in DEHL

	; Save sign and work with |x|
	LD	A,D
	AND	80H
	LD	(_sin_sign),A
	LD	A,D
	AND	7FH
	LD	D,A

	; Reduce |x| to [0, pi] range
	CALL	_reduce_trig
	; If _trig_negate is set, flip the sign (sin in [pi,2pi] = -sin in [0,pi])
	LD	A,(_trig_negate)
	OR	A
	JR	Z,_sin_no_flip
	LD	A,(_sin_sign)
	XOR	80H
	LD	(_sin_sign),A
_sin_no_flip:
	LD	(_sin_x),HL
	LD	(_sin_x+2),DE

	; Start with sum = x
	LD	(_sin_sum),HL
	LD	(_sin_sum+2),DE

	; term = x
	LD	(_sin_term),HL
	LD	(_sin_term+2),DE

	; Compute x^2 for subsequent terms
	LD	A,L
	LD	(__tmp32),A
	LD	A,H
	LD	(__tmp32+1),A
	LD	A,E
	LD	(__tmp32+2),A
	LD	A,D
	LD	(__tmp32+3),A
	CALL	__fmul		; DEHL = x^2
	LD	(_sin_x2),HL
	LD	(_sin_x2+2),DE

	; Taylor series: 6 terms for single-precision
	; term *= -x^2 / (n*(n+1))
	LD	A,2
	LD	(_sin_iter),A	; n starts at 2
	LD	B,6		; loop count

_sin_loop:
	PUSH	BC		; Save loop counter only

	; term *= x^2
	LD	HL,(_sin_term)
	LD	DE,(_sin_term+2)
	LD	A,(_sin_x2)
	LD	(__tmp32),A
	LD	A,(_sin_x2+1)
	LD	(__tmp32+1),A
	LD	A,(_sin_x2+2)
	LD	(__tmp32+2),A
	LD	A,(_sin_x2+3)
	LD	(__tmp32+3),A
	CALL	__fmul
	LD	(_sin_term),HL
	LD	(_sin_term+2),DE

	; Divide by n*(n+1)
	LD	A,(_sin_iter)	; Get n
	LD	L,A
	LD	H,0
	LD	D,0
	LD	E,0		; DEHL = n as 32-bit integer
	CALL	__itof		; Convert n to float
	LD	(_sin_n),HL
	LD	(_sin_n+2),DE
	LD	A,(_sin_iter)
	INC	A		; n+1
	LD	L,A
	LD	H,0
	LD	D,0
	LD	E,0		; DEHL = n+1 as 32-bit
	CALL	__itof		; Convert n+1 to float
	; Multiply n * (n+1)
	LD	A,(_sin_n)
	LD	(__tmp32),A
	LD	A,(_sin_n+1)
	LD	(__tmp32+1),A
	LD	A,(_sin_n+2)
	LD	(__tmp32+2),A
	LD	A,(_sin_n+3)
	LD	(__tmp32+3),A
	CALL	__fmul		; n*(n+1) in DEHL

	; Advance n by 2 for next iteration
	LD	A,(_sin_iter)
	ADD	A,2
	LD	(_sin_iter),A

	; Divide term by n*(n+1)
	; __fdiv expects: DEHL = dividend, __tmp32 = divisor
	; We have n*(n+1) in DEHL, need term / n*(n+1)
	LD	(__tmp32),HL	; Store n*(n+1) as divisor
	LD	(__tmp32+2),DE
	LD	HL,(_sin_term)	; Load term as dividend
	LD	DE,(_sin_term+2)
	CALL	__fdiv		; DEHL = term / n*(n+1)

	; Negate term (alternate signs)
	LD	A,D
	XOR	80H
	LD	D,A
	LD	(_sin_term),HL
	LD	(_sin_term+2),DE

	; Add to sum
	LD	A,(_sin_sum)
	LD	(__tmp32),A
	LD	A,(_sin_sum+1)
	LD	(__tmp32+1),A
	LD	A,(_sin_sum+2)
	LD	(__tmp32+2),A
	LD	A,(_sin_sum+3)
	LD	(__tmp32+3),A
	CALL	__fadd
	LD	(_sin_sum),HL
	LD	(_sin_sum+2),DE

	POP	BC		; Restore loop counter
	DJNZ	_sin_loop

	; Apply original sign
	LD	HL,(_sin_sum)
	LD	DE,(_sin_sum+2)
	LD	A,(_sin_sign)
	OR	D
	LD	D,A

	POP	BC
	POP	IX
	RET

; ============================================================
; cos(x) - Cosine using Taylor series
; cos(x) = 1 - x^2/2! + x^4/4! - x^6/6! + ...
; ============================================================
_cos:
_cosf:
_cosl:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP

	CALL	_math_getarg
	PUSH	BC	; x in DEHL

	; Work with |x| (cos is even)
	LD	A,D
	AND	7FH
	LD	D,A

	; Reduce |x| to [0, pi] range
	CALL	_reduce_trig

	LD	(_cos_x),HL
	LD	(_cos_x+2),DE

	; Start with sum = 1.0 (3F800000)
	LD	HL,0
	LD	DE,3F80H
	LD	(_cos_sum),HL
	LD	(_cos_sum+2),DE

	; term = 1.0
	LD	(_cos_term),HL
	LD	(_cos_term+2),DE

	; Compute x^2
	LD	HL,(_cos_x)
	LD	DE,(_cos_x+2)
	LD	(__tmp32),HL
	LD	(__tmp32+2),DE
	CALL	__fmul
	LD	(_cos_x2),HL
	LD	(_cos_x2+2),DE

	; Taylor series: 6 terms for single-precision
	LD	B,6
	LD	C,1		; n starts at 1

_cos_loop:
	PUSH	BC

	; term *= x^2
	LD	HL,(_cos_term)
	LD	DE,(_cos_term+2)
	LD	A,(_cos_x2)
	LD	(__tmp32),A
	LD	A,(_cos_x2+1)
	LD	(__tmp32+1),A
	LD	A,(_cos_x2+2)
	LD	(__tmp32+2),A
	LD	A,(_cos_x2+3)
	LD	(__tmp32+3),A
	CALL	__fmul
	LD	(_cos_term),HL
	LD	(_cos_term+2),DE

	; Divide by (2n-1)*(2n)
	POP	BC
	LD	A,C
	ADD	A,A		; 2n
	DEC	A		; 2n-1
	LD	H,0
	LD	L,A
	PUSH	BC		; temp save for __itof
	LD	D,H
	LD	E,H		; DEHL = (2n-1) as 32-bit int
	CALL	__itof
	LD	(_cos_n),HL
	LD	(_cos_n+2),DE
	POP	BC		; temp restore
	LD	A,C
	ADD	A,A		; 2n
	INC	C		; Advance n
	PUSH	BC		; save with incremented C for end-of-loop
	LD	H,0
	LD	L,A
	LD	D,H
	LD	E,H		; DEHL = (2n) as 32-bit int
	CALL	__itof
	; Multiply
	LD	A,(_cos_n)
	LD	(__tmp32),A
	LD	A,(_cos_n+1)
	LD	(__tmp32+1),A
	LD	A,(_cos_n+2)
	LD	(__tmp32+2),A
	LD	A,(_cos_n+3)
	LD	(__tmp32+3),A
	CALL	__fmul

	; Divide term by (2n-1)*(2n)
	LD	(__tmp32),HL
	LD	(__tmp32+2),DE
	LD	HL,(_cos_term)
	LD	DE,(_cos_term+2)
	CALL	__fdiv

	; Negate
	LD	A,D
	XOR	80H
	LD	D,A
	LD	(_cos_term),HL
	LD	(_cos_term+2),DE

	; Add to sum
	LD	A,(_cos_sum)
	LD	(__tmp32),A
	LD	A,(_cos_sum+1)
	LD	(__tmp32+1),A
	LD	A,(_cos_sum+2)
	LD	(__tmp32+2),A
	LD	A,(_cos_sum+3)
	LD	(__tmp32+3),A
	CALL	__fadd
	LD	(_cos_sum),HL
	LD	(_cos_sum+2),DE

	POP	BC
	DJNZ	_cos_loop

	LD	HL,(_cos_sum)
	LD	DE,(_cos_sum+2)

	; If angle was in [pi, 2pi], negate result: cos(pi+t) = -cos(t)
	LD	A,(_trig_negate)
	OR	A
	JR	Z,_cos_done
	LD	A,D
	XOR	80H
	LD	D,A
_cos_done:
	POP	BC
	POP	IX
	RET

; ============================================================
; tan(x) = sin(x) / cos(x)
; ============================================================
_tan:
_tanf:
_tanl:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP

	CALL	_math_getarg

	; Save x
	LD	(_tan_x),HL
	LD	(_tan_x+2),DE

	; Compute sin(x)
	PUSH	DE
	PUSH	HL
	CALL	_sinf
	POP	BC
	POP	BC
	LD	(_tan_sin),HL
	LD	(_tan_sin+2),DE

	; Compute cos(x)
	LD	HL,(_tan_x+2)
	PUSH	HL		; push high word (DE) first
	LD	HL,(_tan_x)
	PUSH	HL		; push low word (HL) on top
	CALL	_cosf
	POP	BC
	POP	BC

	; Divide sin/cos
	LD	(__tmp32),HL
	LD	(__tmp32+2),DE
	LD	HL,(_tan_sin)
	LD	DE,(_tan_sin+2)
	CALL	__fdiv

	POP	IX
	RET

; ============================================================
; exp(x) - Exponential with range reduction
; k = round(x / ln(2)), r = x - k*ln(2)
; exp(x) = exp(r) * 2^k, where |r| <= ln(2)/2
; exp(r) via Taylor: 1 + r + r^2/2! + r^3/3! + ...
; ============================================================
_exp:
_expf:
_expl:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP

	CALL	_math_getarg
	PUSH	BC

	LD	(_exp_x),HL
	LD	(_exp_x+2),DE

	; k = round(x / ln(2))
	; x * (1/ln(2))
	LD	A,3BH
	LD	(__tmp32),A
	LD	A,0AAH
	LD	(__tmp32+1),A
	LD	A,0B8H
	LD	(__tmp32+2),A
	LD	A,3FH
	LD	(__tmp32+3),A	; 1/ln(2) = 3FB8AA3B
	CALL	__fmul		; x / ln(2)

	; Round to nearest integer: add 0.5 and truncate
	; But need to handle negative: add 0.5 if positive, sub 0.5 if negative
	LD	(_exp_tmp),HL
	LD	(_exp_tmp+2),DE
	BIT	7,D
	JR	NZ,_exp_neg_round
	; Positive: add 0.5
	LD	A,0
	LD	(__tmp32),A
	LD	(__tmp32+1),A
	LD	(__tmp32+2),A
	LD	A,3FH
	LD	(__tmp32+3),A	; 0.5 = 3F000000
	CALL	__fadd
	JR	_exp_trunc
_exp_neg_round:
	; Negative: subtract 0.5
	LD	A,0
	LD	(__tmp32),A
	LD	(__tmp32+1),A
	LD	(__tmp32+2),A
	LD	A,3FH
	LD	(__tmp32+3),A	; 0.5
	LD	HL,(_exp_tmp)
	LD	DE,(_exp_tmp+2)
	CALL	__fsub
_exp_trunc:
	CALL	__ftoi		; k as integer in DEHL
	LD	(_exp_k),HL	; save k (only need L really, 16-bit)

	; r = x - k * ln(2)
	CALL	__itof		; k as float
	LD	A,18H
	LD	(__tmp32),A
	LD	A,72H
	LD	(__tmp32+1),A
	LD	A,31H
	LD	(__tmp32+2),A
	LD	A,3FH
	LD	(__tmp32+3),A	; ln(2) = 3F317218
	CALL	__fmul		; k * ln(2)
	LD	(__tmp32),HL
	LD	(__tmp32+2),DE
	LD	HL,(_exp_x)
	LD	DE,(_exp_x+2)
	CALL	__fsub		; r = x - k*ln(2)

	; Now compute exp(r) via Taylor series (|r| < 0.347)
	LD	(_exp_x),HL	; reuse _exp_x for r
	LD	(_exp_x+2),DE

	; Start with sum = 1.0, term = 1.0
	LD	HL,0
	LD	DE,3F80H
	LD	(_exp_sum),HL
	LD	(_exp_sum+2),DE
	LD	(_exp_term),HL
	LD	(_exp_term+2),DE

	; 10 iterations (plenty for |r| < 0.347)
	LD	B,10
	LD	C,1

_exp_loop:
	PUSH	BC

	; term *= r
	LD	HL,(_exp_term)
	LD	DE,(_exp_term+2)
	LD	A,(_exp_x)
	LD	(__tmp32),A
	LD	A,(_exp_x+1)
	LD	(__tmp32+1),A
	LD	A,(_exp_x+2)
	LD	(__tmp32+2),A
	LD	A,(_exp_x+3)
	LD	(__tmp32+3),A
	CALL	__fmul
	LD	(_exp_term),HL
	LD	(_exp_term+2),DE

	; Divide by n
	POP	BC
	LD	H,0
	LD	L,C		; HL = current n
	INC	C		; Advance n for next iteration
	PUSH	BC		; Save with incremented C
	LD	D,H
	LD	E,H		; DEHL = n as 32-bit int
	CALL	__itof
	LD	(__tmp32),HL
	LD	(__tmp32+2),DE
	LD	HL,(_exp_term)
	LD	DE,(_exp_term+2)
	CALL	__fdiv
	LD	(_exp_term),HL
	LD	(_exp_term+2),DE

	; Add to sum
	LD	A,(_exp_sum)
	LD	(__tmp32),A
	LD	A,(_exp_sum+1)
	LD	(__tmp32+1),A
	LD	A,(_exp_sum+2)
	LD	(__tmp32+2),A
	LD	A,(_exp_sum+3)
	LD	(__tmp32+3),A
	CALL	__fadd
	LD	(_exp_sum),HL
	LD	(_exp_sum+2),DE

	POP	BC
	DJNZ	_exp_loop

	; Now multiply by 2^k by adjusting IEEE 754 exponent
	; IEEE float: SEEEEEEE EMMMMMMM MMMMMMMM MMMMMMMM
	; Exponent field = D[6:0]*2 + E[7], biased by 127
	; Adding k to exponent = multiply by 2^k
	LD	HL,(_exp_sum)
	LD	DE,(_exp_sum+2)

	LD	A,(_exp_k)	; k (signed byte)
	OR	A
	JR	Z,_exp_done
	LD	C,A		; loop counter

	; Check sign of k
	BIT	7,C
	JR	NZ,_exp_dec_loop

_exp_inc_loop:
	; Multiply by 2: increment exponent
	BIT	7,E
	JR	Z,_exp_inc_noc
	; Low exponent bit is 1: clear it and increment D[6:0]
	RES	7,E
	LD	A,D
	AND	80H		; save sign
	LD	B,A
	LD	A,D
	AND	7FH
	INC	A
	OR	B
	LD	D,A
	JR	_exp_inc_next
_exp_inc_noc:
	; Low exponent bit is 0: just set it
	SET	7,E
_exp_inc_next:
	DEC	C
	JR	NZ,_exp_inc_loop
	JR	_exp_done

_exp_dec_loop:
	; Divide by 2: decrement exponent
	BIT	7,E
	JR	NZ,_exp_dec_nob
	; Low exponent bit is 0: set it and decrement D[6:0]
	SET	7,E
	LD	A,D
	AND	80H
	LD	B,A
	LD	A,D
	AND	7FH
	DEC	A
	OR	B
	LD	D,A
	JR	_exp_dec_next
_exp_dec_nob:
	; Low exponent bit is 1: just clear it
	RES	7,E
_exp_dec_next:
	INC	C
	JR	NZ,_exp_dec_loop

_exp_done:
	POP	BC
	POP	IX
	RET

; ============================================================
; log(x) - Natural logarithm with range reduction
; log(x) = e*ln(2) + log(m), where x = m * 2^e, m in [1,2)
; log(m) = 2*atanh((m-1)/(m+1)), series converges fast
; ============================================================
_log:
_logf:
_logl:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP

	CALL	_math_getarg
	PUSH	BC

	; Check for x <= 0
	LD	A,D
	AND	7FH
	OR	E
	OR	H
	OR	L
	JR	Z,_log_err
	BIT	7,D
	JR	NZ,_log_err

	LD	(_log_x),HL
	LD	(_log_x+2),DE

	; Extract exponent from IEEE 754: SEEEEEEE EMMMMMMM
	; exponent = D[6:0]*2 + E[7], biased by 127
	LD	A,D
	AND	7FH
	LD	B,A		; B = D[6:0]
	LD	A,E
	RLCA			; Carry = E[7]
	LD	A,B
	RLA			; A = D[6:0]*2 + E[7] = biased exponent
	SUB	127		; A = unbiased exponent (signed)
	LD	(_log_exp),A

	; Set mantissa m = x with exponent = 127 (bias)
	; i.e., replace exponent with 01111111 so m is in [1, 2)
	; New D = 0 (sign) + 0111111 (upper 7 bits of 01111111) = 3FH
	; New E[7] = 1 (low bit of 01111111)
	LD	A,E
	OR	80H		; Set E[7] = 1
	LD	E,A
	LD	D,3FH		; D = 3FH (sign=0, upper exp = 0111111)
	; Now DEHL = m in [1.0, 2.0)

	; Compute log(m) = 2*atanh((m-1)/(m+1))
	; Compute (m-1)
	LD	(_log_x),HL
	LD	(_log_x+2),DE
	LD	A,0
	LD	(__tmp32),A
	LD	(__tmp32+1),A
	LD	(__tmp32+2),A
	LD	A,3FH
	LD	(__tmp32+3),A	; 1.0 = 3F800000... wait
	; Actually 1.0 = 3F800000: D=3F, E=80, H=00, L=00
	; __tmp32 stores as: [+0]=00, [+1]=00, [+2]=80, [+3]=3F
	LD	A,0
	LD	(__tmp32),A
	LD	(__tmp32+1),A
	LD	A,80H
	LD	(__tmp32+2),A
	LD	A,3FH
	LD	(__tmp32+3),A
	LD	HL,(_log_x)
	LD	DE,(_log_x+2)
	CALL	__fsub		; m-1
	LD	(_log_num),HL
	LD	(_log_num+2),DE

	; Compute (m+1)
	LD	A,0
	LD	(__tmp32),A
	LD	(__tmp32+1),A
	LD	A,80H
	LD	(__tmp32+2),A
	LD	A,3FH
	LD	(__tmp32+3),A
	LD	HL,(_log_x)
	LD	DE,(_log_x+2)
	CALL	__fadd		; m+1
	LD	(_log_den),HL
	LD	(_log_den+2),DE

	; y = (m-1)/(m+1)
	LD	(__tmp32),HL
	LD	(__tmp32+2),DE
	LD	HL,(_log_num)
	LD	DE,(_log_num+2)
	CALL	__fdiv
	LD	(_log_y),HL
	LD	(_log_y+2),DE

	; y^2
	LD	(__tmp32),HL
	LD	(__tmp32+2),DE
	CALL	__fmul
	LD	(_log_y2),HL
	LD	(_log_y2+2),DE

	; atanh series: y + y^3/3 + y^5/5 + ...
	; sum = y, term = y
	LD	HL,(_log_y)
	LD	DE,(_log_y+2)
	LD	(_log_sum),HL
	LD	(_log_sum+2),DE
	LD	(_log_term),HL
	LD	(_log_term+2),DE

	LD	B,10		; 10 terms (y < 1/3, converges fast)
	LD	C,3

_log_loop:
	PUSH	BC

	; term *= y^2
	LD	HL,(_log_term)
	LD	DE,(_log_term+2)
	LD	A,(_log_y2)
	LD	(__tmp32),A
	LD	A,(_log_y2+1)
	LD	(__tmp32+1),A
	LD	A,(_log_y2+2)
	LD	(__tmp32+2),A
	LD	A,(_log_y2+3)
	LD	(__tmp32+3),A
	CALL	__fmul
	LD	(_log_term),HL
	LD	(_log_term+2),DE

	; Divide by n (odd number)
	POP	BC
	LD	H,0
	LD	L,C
	INC	C
	INC	C		; Next odd
	PUSH	BC		; Save with incremented C
	LD	D,H
	LD	E,H		; DEHL = n as 32-bit int
	CALL	__itof
	LD	(__tmp32),HL
	LD	(__tmp32+2),DE
	LD	HL,(_log_term)
	LD	DE,(_log_term+2)
	CALL	__fdiv

	; Add to sum
	LD	A,(_log_sum)
	LD	(__tmp32),A
	LD	A,(_log_sum+1)
	LD	(__tmp32+1),A
	LD	A,(_log_sum+2)
	LD	(__tmp32+2),A
	LD	A,(_log_sum+3)
	LD	(__tmp32+3),A
	CALL	__fadd
	LD	(_log_sum),HL
	LD	(_log_sum+2),DE

	POP	BC
	DJNZ	_log_loop

	; log(m) = 2 * sum
	LD	HL,(_log_sum)
	LD	DE,(_log_sum+2)
	LD	(__tmp32),HL
	LD	(__tmp32+2),DE
	CALL	__fadd		; 2*sum = log(m)

	; Result = e * ln(2) + log(m)
	LD	(_log_sum),HL	; save log(m) temporarily
	LD	(_log_sum+2),DE

	; Convert e to float
	LD	A,(_log_exp)
	LD	L,A
	; Sign-extend to 16 bits
	RLA			; carry = sign
	SBC	A,A		; A = FF if neg, 00 if pos
	LD	H,A
	LD	D,A
	LD	E,A		; DEHL = signed 32-bit e
	CALL	__itof		; e as float

	; e * ln(2)
	LD	A,18H
	LD	(__tmp32),A
	LD	A,72H
	LD	(__tmp32+1),A
	LD	A,31H
	LD	(__tmp32+2),A
	LD	A,3FH
	LD	(__tmp32+3),A	; ln(2) = 3F317218
	CALL	__fmul		; e * ln(2)

	; + log(m)
	LD	A,(_log_sum)
	LD	(__tmp32),A
	LD	A,(_log_sum+1)
	LD	(__tmp32+1),A
	LD	A,(_log_sum+2)
	LD	(__tmp32+2),A
	LD	A,(_log_sum+3)
	LD	(__tmp32+3),A
	CALL	__fadd		; e*ln(2) + log(m)

	JR	_log_done

_log_err:
	; Return negative infinity or NaN
	LD	HL,0
	LD	DE,0FF80H	; -inf

_log_done:
	POP	BC
	POP	IX
	RET

; ============================================================
; log10(x) = log(x) / log(10)
; log(10) = 2.302585...
; ============================================================
_log10:
_log10f:
_log10l:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP

	CALL	_math_getarg
	PUSH	DE
	PUSH	HL
	CALL	_logf
	POP	BC
	POP	BC

	; Divide by log(10) = 2.302585 (40135D8E)
	LD	A,8EH
	LD	(__tmp32),A
	LD	A,5DH
	LD	(__tmp32+1),A
	LD	A,13H
	LD	(__tmp32+2),A
	LD	A,40H
	LD	(__tmp32+3),A
	CALL	__fdiv

	POP	IX
	RET

; ============================================================
; log2(x) = log(x) / log(2)
; log(2) = 0.693147...
; ============================================================
_log2:
_log2f:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP

	CALL	_math_getarg
	PUSH	DE
	PUSH	HL
	CALL	_logf
	POP	BC
	POP	BC

	; Divide by log(2) = 0.693147 (3F317218)
	LD	A,18H
	LD	(__tmp32),A
	LD	A,72H
	LD	(__tmp32+1),A
	LD	A,31H
	LD	(__tmp32+2),A
	LD	A,3FH
	LD	(__tmp32+3),A
	CALL	__fdiv

	POP	IX
	RET

; ============================================================
; pow(x, y) = exp(y * log(x))
; ============================================================
_pow:
_powf:
_powl:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP

	; Get x
	CALL	_math_getarg
	LD	(_pow_x),HL
	LD	(_pow_x+2),DE

	; Get y
	CALL	_math_getarg2
	LD	HL,(__tmp32)
	LD	DE,(__tmp32+2)
	LD	(_pow_y),HL
	LD	(_pow_y+2),DE

	; Compute log(x)
	LD	HL,(_pow_x)
	LD	DE,(_pow_x+2)
	PUSH	DE
	PUSH	HL
	CALL	_logf
	POP	BC
	POP	BC

	; Multiply by y
	LD	A,(_pow_y)
	LD	(__tmp32),A
	LD	A,(_pow_y+1)
	LD	(__tmp32+1),A
	LD	A,(_pow_y+2)
	LD	(__tmp32+2),A
	LD	A,(_pow_y+3)
	LD	(__tmp32+3),A
	CALL	__fmul

	; Compute exp(y*log(x))
	PUSH	DE
	PUSH	HL
	CALL	_expf
	POP	BC
	POP	BC

	POP	IX
	RET

; ============================================================
; Hyperbolic functions using exp
; sinh(x) = (e^x - e^-x) / 2
; cosh(x) = (e^x + e^-x) / 2
; tanh(x) = sinh(x) / cosh(x)
; ============================================================
_sinh:
_sinhf:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP

	CALL	_math_getarg
	LD	(_hyp_x),HL
	LD	(_hyp_x+2),DE

	; e^x
	PUSH	DE
	PUSH	HL
	CALL	_expf
	POP	BC
	POP	BC
	LD	(_hyp_ep),HL
	LD	(_hyp_ep+2),DE

	; e^-x
	LD	HL,(_hyp_x)
	LD	DE,(_hyp_x+2)
	LD	A,D
	XOR	80H
	LD	D,A
	PUSH	DE
	PUSH	HL
	CALL	_expf
	POP	BC
	POP	BC
	LD	(_hyp_em),HL
	LD	(_hyp_em+2),DE

	; e^x - e^-x
	LD	(__tmp32),HL
	LD	(__tmp32+2),DE
	LD	HL,(_hyp_ep)
	LD	DE,(_hyp_ep+2)
	CALL	__fsub

	; Divide by 2 (subtract 1 from exponent)
	BIT	7,E
	JR	NZ,_sinh_exp_odd
	SET	7,E
	LD	A,D
	AND	80H
	LD	C,A
	LD	A,D
	AND	7FH
	DEC	A
	OR	C
	LD	D,A
	JR	_sinh_done
_sinh_exp_odd:
	RES	7,E
_sinh_done:
	POP	IX
	RET

_cosh:
_coshf:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP

	CALL	_math_getarg
	LD	(_hyp_x),HL
	LD	(_hyp_x+2),DE

	; e^x
	PUSH	DE
	PUSH	HL
	CALL	_expf
	POP	BC
	POP	BC
	LD	(_hyp_ep),HL
	LD	(_hyp_ep+2),DE

	; e^-x
	LD	HL,(_hyp_x)
	LD	DE,(_hyp_x+2)
	LD	A,D
	XOR	80H
	LD	D,A
	PUSH	DE
	PUSH	HL
	CALL	_expf
	POP	BC
	POP	BC

	; e^x + e^-x
	LD	(__tmp32),HL
	LD	(__tmp32+2),DE
	LD	HL,(_hyp_ep)
	LD	DE,(_hyp_ep+2)
	CALL	__fadd

	; Divide by 2 (subtract 1 from exponent)
	BIT	7,E
	JR	NZ,_cosh_exp_odd
	SET	7,E
	LD	A,D
	AND	80H
	LD	C,A
	LD	A,D
	AND	7FH
	DEC	A
	OR	C
	LD	D,A
	JR	_cosh_done
_cosh_exp_odd:
	RES	7,E
_cosh_done:
	POP	IX
	RET

_tanh:
_tanhf:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP

	CALL	_math_getarg
	PUSH	DE
	PUSH	HL

	; sinh
	CALL	_sinhf
	POP	BC
	POP	BC
	LD	(_hyp_s),HL
	LD	(_hyp_s+2),DE

	; cosh - reload original argument from caller's stack frame
	LD	D,(IX+7)
	LD	E,(IX+6)
	LD	H,(IX+5)
	LD	L,(IX+4)
	PUSH	DE
	PUSH	HL
	CALL	_coshf
	POP	BC
	POP	BC

	; sinh/cosh
	LD	(__tmp32),HL
	LD	(__tmp32+2),DE
	LD	HL,(_hyp_s)
	LD	DE,(_hyp_s+2)
	CALL	__fdiv

	POP	IX
	RET

; ============================================================
; Inverse trig functions (simplified implementations)
; ============================================================
_asin:
_asinf:
	; asin(x) = atan(x / sqrt(1-x^2))
	PUSH	IX
	LD	IX,0
	ADD	IX,SP

	CALL	_math_getarg
	LD	(_asin_x),HL
	LD	(_asin_x+2),DE

	; 1 - x^2
	LD	(__tmp32),HL
	LD	(__tmp32+2),DE
	CALL	__fmul		; x^2
	LD	(__tmp32),HL
	LD	(__tmp32+2),DE
	LD	HL,0
	LD	DE,3F80H	; 1.0
	CALL	__fsub		; 1-x^2

	; sqrt(1-x^2)
	PUSH	DE
	PUSH	HL
	CALL	_sqrtf
	POP	BC
	POP	BC

	; x / sqrt(1-x^2)
	LD	(__tmp32),HL
	LD	(__tmp32+2),DE
	LD	HL,(_asin_x)
	LD	DE,(_asin_x+2)
	CALL	__fdiv

	; atan
	PUSH	DE
	PUSH	HL
	CALL	_atanf
	POP	BC
	POP	BC

	POP	IX
	RET

_acos:
_acosf:
	; acos(x) = pi/2 - asin(x)
	PUSH	IX
	LD	IX,0
	ADD	IX,SP

	CALL	_math_getarg
	PUSH	DE
	PUSH	HL
	CALL	_asinf
	POP	BC
	POP	BC

	; pi/2 - result (pi/2 = 1.5707963 = 3FC90FDB)
	LD	(__tmp32),HL
	LD	(__tmp32+2),DE
	LD	HL,0FDBH
	LD	DE,3FC9H
	CALL	__fsub

	POP	IX
	RET

_atan:
_atanf:
	; atan(x) with range reduction:
	;   Save sign, work with |x|
	;   If |x| > 1: atan(x) = pi/2 - atan(1/|x|), set _atan_big=1
	;   Then use Taylor series: x - x^3/3 + x^5/5 - ...
	PUSH	IX
	LD	IX,0
	ADD	IX,SP

	CALL	_math_getarg
	PUSH	BC

	; Save sign and take |x|
	LD	A,D
	AND	80H
	LD	(_atan_sign),A
	LD	A,D
	AND	7FH
	LD	D,A

	; Check if |x| > 1.0 (3F800000)
	; Special case: if x == 1.0 exactly, return pi/4
	LD	A,D
	CP	3FH
	JR	NZ,_atan_not1
	LD	A,E
	CP	80H
	JR	NZ,_atan_not1
	LD	A,H
	OR	L
	JR	NZ,_atan_not1
	; x == 1.0 exactly: return pi/4 = 3F490FDB
	LD	HL,0FDBH
	LD	DE,3F49H
	LD	(_atan_sum),HL
	LD	(_atan_sum+2),DE
	JP	_atan_apply_sign

_atan_not1:
	; Compare exponent byte D with 3F
	XOR	A
	LD	(_atan_big),A		; assume small
	LD	A,D
	CP	3FH
	JR	C,_atan_small		; D < 3F: definitely < 1
	JR	NZ,_atan_do_recip	; D > 3F: definitely > 1
	; D == 3F, check E (already know not exactly 1.0)
	LD	A,E
	CP	80H
	JR	C,_atan_small		; < 1.0
	; > 1.0, compute 1/x
_atan_do_recip:
	; Compute 1/|x|: load 1.0 into DEHL, |x| into __tmp32
	LD	(_atan_x),HL
	LD	(_atan_x+2),DE
	LD	A,1
	LD	(_atan_big),A
	LD	HL,(_atan_x)
	LD	(__tmp32),HL
	LD	HL,(_atan_x+2)
	LD	(__tmp32+2),HL
	LD	HL,0
	LD	DE,3F80H		; 1.0
	CALL	__fdiv			; DEHL = 1.0 / |x|

_atan_small:
	; DEHL = value to compute atan of (|x| or 1/|x|)
	; Taylor series: atan(t) = t - t^3/3 + t^5/5 - ...
	LD	(_atan_sum),HL
	LD	(_atan_sum+2),DE
	LD	(_atan_term),HL
	LD	(_atan_term+2),DE

	; t^2
	LD	(__tmp32),HL
	LD	(__tmp32+2),DE
	CALL	__fmul
	LD	(_atan_x2),HL
	LD	(_atan_x2+2),DE

	LD	B,15
	LD	C,3

_atan_loop:
	PUSH	BC

	; term *= t^2
	LD	HL,(_atan_term)
	LD	DE,(_atan_term+2)
	LD	A,(_atan_x2)
	LD	(__tmp32),A
	LD	A,(_atan_x2+1)
	LD	(__tmp32+1),A
	LD	A,(_atan_x2+2)
	LD	(__tmp32+2),A
	LD	A,(_atan_x2+3)
	LD	(__tmp32+3),A
	CALL	__fmul

	; Negate
	LD	A,D
	XOR	80H
	LD	D,A
	LD	(_atan_term),HL
	LD	(_atan_term+2),DE

	; Divide by n (n = 3, 5, 7, ...)
	POP	BC
	LD	H,0
	LD	L,C
	INC	C
	INC	C
	PUSH	BC		; Save with incremented C
	LD	D,H
	LD	E,H		; DEHL = n as 32-bit int
	CALL	__itof
	LD	(__tmp32),HL
	LD	(__tmp32+2),DE
	LD	HL,(_atan_term)
	LD	DE,(_atan_term+2)
	CALL	__fdiv

	; Add to sum
	LD	A,(_atan_sum)
	LD	(__tmp32),A
	LD	A,(_atan_sum+1)
	LD	(__tmp32+1),A
	LD	A,(_atan_sum+2)
	LD	(__tmp32+2),A
	LD	A,(_atan_sum+3)
	LD	(__tmp32+3),A
	CALL	__fadd
	LD	(_atan_sum),HL
	LD	(_atan_sum+2),DE

	POP	BC
	DJNZ	_atan_loop

	; If |x| > 1, result = pi/2 - atan(1/|x|)
	LD	A,(_atan_big)
	OR	A
	JR	Z,_atan_apply_sign

	; pi/2 - sum: load pi/2 into DEHL, sum into __tmp32
	LD	HL,(_atan_sum)
	LD	(__tmp32),HL
	LD	HL,(_atan_sum+2)
	LD	(__tmp32+2),HL
	LD	HL,0FDBH		; pi/2 = 3FC90FDB
	LD	DE,3FC9H
	CALL	__fsub
	LD	(_atan_sum),HL
	LD	(_atan_sum+2),DE

_atan_apply_sign:
	LD	HL,(_atan_sum)
	LD	DE,(_atan_sum+2)
	LD	A,(_atan_sign)
	OR	D
	LD	D,A

	POP	BC
	POP	IX
	RET

_atan2:
_atan2f:
	; atan2(y, x) - two-argument arctangent
	PUSH	IX
	LD	IX,0
	ADD	IX,SP

	; y at IX+4, x at IX+8
	CALL	_math_getarg	; y
	LD	(_atan2_y),HL
	LD	(_atan2_y+2),DE
	CALL	_math_getarg2	; x to __tmp32
	LD	HL,(__tmp32)
	LD	DE,(__tmp32+2)
	LD	(_atan2_x),HL
	LD	(_atan2_x+2),DE

	; Compute y/x
	LD	(__tmp32),HL
	LD	(__tmp32+2),DE
	LD	HL,(_atan2_y)
	LD	DE,(_atan2_y+2)
	CALL	__fdiv

	; atan(y/x)
	PUSH	DE
	PUSH	HL
	CALL	_atanf
	POP	BC
	POP	BC

	; Adjust quadrant based on signs (simplified - just return atan(y/x))
	POP	IX
	RET

; ============================================================
; cbrt(x) - Cube root
; Uses Newton-Raphson: x_{n+1} = (2*x_n + S/x_n^2) / 3
; ============================================================
_cbrt:
_cbrtf:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP

	CALL	_math_getarg
	PUSH	BC

	; Save sign and work with |x|
	LD	A,D
	AND	80H
	LD	(_cbrt_sign),A
	LD	A,D
	AND	7FH
	LD	D,A

	; Check for zero
	OR	E
	OR	H
	OR	L
	JR	Z,_cbrt_zero

	LD	(_cbrt_x),HL
	LD	(_cbrt_x+2),DE

	; Initial guess: x/3 (rough)
	; Better: use exponent/3
	LD	(_cbrt_g),HL
	LD	(_cbrt_g+2),DE

	LD	B,8

_cbrt_loop:
	PUSH	BC

	; g^2
	LD	HL,(_cbrt_g)
	LD	DE,(_cbrt_g+2)
	LD	(__tmp32),HL
	LD	(__tmp32+2),DE
	CALL	__fmul
	LD	(_cbrt_g2),HL
	LD	(_cbrt_g2+2),DE

	; x / g^2
	LD	(__tmp32),HL
	LD	(__tmp32+2),DE
	LD	HL,(_cbrt_x)
	LD	DE,(_cbrt_x+2)
	CALL	__fdiv
	LD	(_cbrt_t),HL
	LD	(_cbrt_t+2),DE

	; 2*g
	LD	HL,(_cbrt_g)
	LD	DE,(_cbrt_g+2)
	LD	(__tmp32),HL
	LD	(__tmp32+2),DE
	CALL	__fadd

	; 2*g + x/g^2
	LD	A,(_cbrt_t)
	LD	(__tmp32),A
	LD	A,(_cbrt_t+1)
	LD	(__tmp32+1),A
	LD	A,(_cbrt_t+2)
	LD	(__tmp32+2),A
	LD	A,(_cbrt_t+3)
	LD	(__tmp32+3),A
	CALL	__fadd

	; Divide by 3
	LD	A,0
	LD	(__tmp32),A
	LD	A,0
	LD	(__tmp32+1),A
	LD	A,40H
	LD	(__tmp32+2),A
	LD	A,40H		; 3.0 = 40400000
	LD	(__tmp32+3),A
	CALL	__fdiv

	LD	(_cbrt_g),HL
	LD	(_cbrt_g+2),DE

	POP	BC
	DJNZ	_cbrt_loop

	LD	HL,(_cbrt_g)
	LD	DE,(_cbrt_g+2)
	LD	A,(_cbrt_sign)
	OR	D
	LD	D,A
	JR	_cbrt_done

_cbrt_zero:
	LD	HL,0
	LD	DE,0

_cbrt_done:
	POP	BC
	POP	IX
	RET

; ============================================================
; hypot(x, y) = sqrt(x^2 + y^2)
; ============================================================
_hypot:
_hypotf:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP

	CALL	_math_getarg	; x
	LD	(__tmp32),HL
	LD	(__tmp32+2),DE
	CALL	__fmul		; x^2
	LD	(_hypot_x2),HL
	LD	(_hypot_x2+2),DE

	CALL	_math_getarg2	; y
	LD	HL,(__tmp32)
	LD	DE,(__tmp32+2)
	LD	(__tmp32),HL
	LD	(__tmp32+2),DE
	CALL	__fmul		; y^2

	; x^2 + y^2
	LD	A,(_hypot_x2)
	LD	(__tmp32),A
	LD	A,(_hypot_x2+1)
	LD	(__tmp32+1),A
	LD	A,(_hypot_x2+2)
	LD	(__tmp32+2),A
	LD	A,(_hypot_x2+3)
	LD	(__tmp32+3),A
	CALL	__fadd

	; sqrt
	PUSH	DE
	PUSH	HL
	CALL	_sqrtf
	POP	BC
	POP	BC

	POP	IX
	RET

; ============================================================
; floor, ceil, trunc, round - rounding functions
; ============================================================
_floor:
_floorf:
_floorl:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP

	CALL	_math_getarg
	PUSH	BC

	; Save original for comparison
	LD	(_floor_x),HL
	LD	(_floor_x+2),DE

	; Truncate toward zero
	CALL	__ftoi

	; If original was positive, truncation IS floor
	LD	A,(_floor_x+3)
	BIT	7,A
	JR	Z,_floor_pos

	; Negative: check if truncated == original
	LD	(_floor_i),HL
	LD	(_floor_i+2),DE
	CALL	__itof		; convert int back to float

	; Compare with original (byte-by-byte)
	LD	A,(_floor_x)
	CP	L
	JR	NZ,_floor_sub1
	LD	A,(_floor_x+1)
	CP	H
	JR	NZ,_floor_sub1
	LD	A,(_floor_x+2)
	CP	E
	JR	NZ,_floor_sub1
	LD	A,(_floor_x+3)
	CP	D
	JR	Z,_floor_done	; exact integer, result in DEHL

_floor_sub1:
	; Not exact: subtract 1 from integer result
	LD	HL,(_floor_i)
	LD	DE,(_floor_i+2)
	LD	A,L
	SUB	1
	LD	L,A
	LD	A,H
	SBC	A,0
	LD	H,A
	LD	A,E
	SBC	A,0
	LD	E,A
	LD	A,D
	SBC	A,0
	LD	D,A
_floor_pos:
	CALL	__itof
_floor_done:
	POP	BC
	POP	IX
	RET

_ceil:
_ceilf:
_ceill:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP

	CALL	_math_getarg
	PUSH	BC
	LD	(_ceil_x),HL
	LD	(_ceil_x+2),DE

	; Negate
	LD	A,D
	XOR	80H
	LD	D,A

	; floor(-x)
	PUSH	DE
	PUSH	HL
	CALL	_floorf
	POP	BC
	POP	BC

	; Negate result
	LD	A,D
	XOR	80H
	LD	D,A

	POP	BC
	POP	IX
	RET

_trunc:
_truncf:
_truncl:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP

	CALL	_math_getarg
	CALL	__ftoi
	CALL	__itof

	POP	IX
	RET

_round:
_roundf:
_roundl:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP

	CALL	_math_getarg

	; Add 0.5 (or -0.5 if negative)
	LD	A,D
	AND	80H
	LD	B,A		; Save sign

	; 0.5 = 3F000000
	LD	A,0
	LD	(__tmp32),A
	LD	(__tmp32+1),A
	LD	A,0
	LD	(__tmp32+2),A
	LD	A,3FH
	OR	B		; Apply sign
	LD	(__tmp32+3),A
	CALL	__fadd

	; Truncate
	CALL	__ftoi
	CALL	__itof

	POP	IX
	RET

; ============================================================
; fmod(x, y) - floating-point remainder
; fmod(x, y) = x - trunc(x/y) * y
; ============================================================
_fmod:
_fmodf:
_fmodl:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP

	CALL	_math_getarg	; x
	LD	(_fmod_x),HL
	LD	(_fmod_x+2),DE

	CALL	_math_getarg2	; y
	LD	HL,(__tmp32)
	LD	DE,(__tmp32+2)
	LD	(_fmod_y),HL
	LD	(_fmod_y+2),DE

	; x / y
	LD	(__tmp32),HL
	LD	(__tmp32+2),DE
	LD	HL,(_fmod_x)
	LD	DE,(_fmod_x+2)
	CALL	__fdiv

	; trunc(x/y)
	CALL	__ftoi
	CALL	__itof

	; * y
	LD	A,(_fmod_y)
	LD	(__tmp32),A
	LD	A,(_fmod_y+1)
	LD	(__tmp32+1),A
	LD	A,(_fmod_y+2)
	LD	(__tmp32+2),A
	LD	A,(_fmod_y+3)
	LD	(__tmp32+3),A
	CALL	__fmul

	; x - trunc(x/y)*y
	LD	(__tmp32),HL
	LD	(__tmp32+2),DE
	LD	HL,(_fmod_x)
	LD	DE,(_fmod_x+2)
	CALL	__fsub

	POP	IX
	RET

_remainder:
_remainderf:
	; Same as fmod for now
	JP	_fmod

; ============================================================
; frexp, ldexp, modf - IEEE 754 manipulation
; ============================================================
_frexp:
_frexpf:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP

	CALL	_math_getarg

	; Extract exponent
	LD	A,D
	ADD	A,A		; Shift sign out
	LD	B,A
	LD	A,E
	RLA
	LD	C,A
	LD	A,B
	RRA			; A = biased exponent

	; Unbias: exp = biased - 127
	SUB	126		; Actually we want mantissa in [0.5,1), so -126
	LD	B,A

	; Store exponent
	LD	A,(IX+8)
	LD	C,A
	LD	A,(IX+9)
	PUSH	HL
	LD	H,A
	LD	L,C
	LD	(HL),B
	INC	HL
	LD	A,B
	RLA			; Sign extend
	SBC	A,A
	LD	(HL),A
	POP	HL

	; Set exponent to 126 (gives [0.5, 1))
	LD	A,D
	AND	80H		; Keep sign
	OR	3EH		; Exponent 126 >> 1
	LD	D,A
	LD	A,E
	OR	80H		; Set exp bit 0
	LD	E,A

	POP	IX
	RET

_ldexp:
_ldexpf:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP

	CALL	_math_getarg

	; Get int exponent
	LD	A,(IX+8)
	LD	B,A

	; Add to float exponent
	LD	A,D
	ADD	A,A
	LD	C,A
	LD	A,E
	RLA
	LD	(__tmp32),A	; Save mantissa bit
	LD	A,C
	RRA
	ADD	A,B		; Add exponent
	LD	C,A
	RLCA
	AND	1
	LD	B,A
	LD	A,D
	AND	80H
	OR	C
	LD	D,A
	LD	A,(__tmp32)
	AND	7FH
	OR	B
	RLA
	LD	A,E
	RRA
	LD	E,A

	POP	IX
	RET

_modf:
_modff:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP

	CALL	_math_getarg
	LD	(_modf_x),HL
	LD	(_modf_x+2),DE

	; Get integer part
	CALL	__ftoi
	CALL	__itof
	LD	(_modf_i),HL
	LD	(_modf_i+2),DE

	; Store to *iptr
	LD	A,(IX+8)
	LD	C,A
	LD	A,(IX+9)
	LD	B,A
	LD	A,L
	LD	(BC),A
	INC	BC
	LD	A,H
	LD	(BC),A
	INC	BC
	LD	A,E
	LD	(BC),A
	INC	BC
	LD	A,D
	LD	(BC),A

	; Return fractional part: x - int
	LD	(__tmp32),HL
	LD	(__tmp32+2),DE
	LD	HL,(_modf_x)
	LD	DE,(_modf_x+2)
	CALL	__fsub

	POP	IX
	RET

; ============================================================
; Complex number functions
; Complex is 8 bytes: real (4 bytes) + imaginary (4 bytes)
; Arguments passed by pointer on stack, result returned as pointer in HL
; ============================================================

	PUBLIC	_creal,_crealf,_creall
	PUBLIC	_cimag,_cimagf,_cimagl
	PUBLIC	_cabs,_cabsf,_cabsl
	PUBLIC	_carg,_cargf,_cargl
	PUBLIC	_conj,_conjf,_conjl
	PUBLIC	_cproj,_cprojf,_cprojl
	PUBLIC	_cexp,_cexpf
	PUBLIC	_clog,_clogf
	PUBLIC	_cpow,_cpowf
	PUBLIC	_csqrt,_csqrtf
	PUBLIC	_csin,_csinf
	PUBLIC	_ccos,_ccosf
	PUBLIC	_ctan,_ctanf
	PUBLIC	_casin,_cacos,_catan
	PUBLIC	_csinh,_ccosh,_ctanh
	PUBLIC	_casinh,_cacosh,_catanh

; __I_const: Imaginary unit constant (0.0 + 1.0i)
; real = 0x00000000 (0.0), imag = 0x3F800000 (1.0)
	PUBLIC	___I_const
___I_const:
	DW	0,0		; Real = 0.0
	DW	0,3F80H		; Imag = 1.0

; __make_complex: Create complex from two doubles
; Input: real at IX+4 (4 bytes), imag at IX+8 (4 bytes)
; Output: pointer to result in HL
	PUBLIC	___make_complex,___make_complexf
___make_complex:
___make_complexf:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	LD	L,(IX+4)
	LD	H,(IX+5)
	LD	(_cplx_res),HL
	LD	L,(IX+6)
	LD	H,(IX+7)
	LD	(_cplx_res+2),HL
	LD	L,(IX+8)
	LD	H,(IX+9)
	LD	(_cplx_res+4),HL
	LD	L,(IX+10)
	LD	H,(IX+11)
	LD	(_cplx_res+6),HL
	LD	HL,_cplx_res
	POP	IX
	RET

; creal: Get real part of complex
; Input: complex pointer at IX+4
; Output: float in DEHL
_creal:
_crealf:
_creall:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	LD	L,(IX+4)
	LD	H,(IX+5)
	LD	E,(HL)
	INC	HL
	LD	D,(HL)
	INC	HL
	PUSH	DE
	LD	E,(HL)
	INC	HL
	LD	D,(HL)
	POP	HL
	POP	IX
	RET

; cimag: Get imaginary part of complex
; Input: complex pointer at IX+4
; Output: float in DEHL
_cimag:
_cimagf:
_cimagl:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	LD	L,(IX+4)
	LD	H,(IX+5)
	LD	BC,4
	ADD	HL,BC
	LD	E,(HL)
	INC	HL
	LD	D,(HL)
	INC	HL
	PUSH	DE
	LD	E,(HL)
	INC	HL
	LD	D,(HL)
	POP	HL
	POP	IX
	RET

; cabs: |z| = sqrt(re² + im²)
_cabs:
_cabsf:
_cabsl:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	LD	L,(IX+4)
	LD	H,(IX+5)
	; Get real part
	LD	E,(HL)
	INC	HL
	LD	D,(HL)
	INC	HL
	LD	C,(HL)
	INC	HL
	LD	B,(HL)
	INC	HL
	PUSH	BC
	PUSH	DE
	POP	HL
	POP	DE		; DEHL = real
	LD	(__tmp32),HL
	LD	(__tmp32+2),DE
	CALL	__fmul		; real²
	LD	(_cplx_z),HL
	LD	(_cplx_z+2),DE
	; Get imag part
	LD	L,(IX+4)
	LD	H,(IX+5)
	LD	BC,4
	ADD	HL,BC
	LD	E,(HL)
	INC	HL
	LD	D,(HL)
	INC	HL
	LD	C,(HL)
	INC	HL
	LD	B,(HL)
	PUSH	BC
	PUSH	DE
	POP	HL
	POP	DE		; DEHL = imag
	LD	(__tmp32),HL
	LD	(__tmp32+2),DE
	CALL	__fmul		; imag²
	; Add real² + imag²
	LD	(__tmp32),HL
	LD	(__tmp32+2),DE
	LD	HL,(_cplx_z)
	LD	DE,(_cplx_z+2)
	CALL	__fadd
	; sqrt
	PUSH	DE
	PUSH	HL
	CALL	_sqrt
	POP	BC
	POP	BC
	POP	IX
	RET

; carg: arg(z) = atan2(im, re)
_carg:
_cargf:
_cargl:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	LD	L,(IX+4)
	LD	H,(IX+5)
	; Push real (x) first
	LD	E,(HL)
	INC	HL
	LD	D,(HL)
	INC	HL
	LD	C,(HL)
	INC	HL
	LD	B,(HL)
	INC	HL
	PUSH	BC
	PUSH	DE
	; Push imag (y)
	LD	E,(HL)
	INC	HL
	LD	D,(HL)
	INC	HL
	LD	C,(HL)
	INC	HL
	LD	B,(HL)
	PUSH	BC
	PUSH	DE
	CALL	_atan2
	POP	BC
	POP	BC
	POP	BC
	POP	BC
	POP	IX
	RET

; conj: conjugate z* = re - i*im
_conj:
_conjf:
_conjl:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	LD	L,(IX+4)
	LD	H,(IX+5)
	; Copy real unchanged
	LD	DE,_cplx_res
	LD	BC,4
	LDIR
	; Copy and negate imag
	LD	E,(HL)
	INC	HL
	LD	D,(HL)
	INC	HL
	LD	C,(HL)
	INC	HL
	LD	B,(HL)
	LD	A,B
	XOR	80H
	LD	B,A
	LD	HL,_cplx_res+4
	LD	(HL),E
	INC	HL
	LD	(HL),D
	INC	HL
	LD	(HL),C
	INC	HL
	LD	(HL),B
	LD	HL,_cplx_res
	POP	IX
	RET

; cproj: projection (for finite numbers returns input)
_cproj:
_cprojf:
_cprojl:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	LD	L,(IX+4)
	LD	H,(IX+5)
	POP	IX
	RET

; cexp: e^z = e^re * (cos(im) + i*sin(im))
_cexp:
_cexpf:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	LD	L,(IX+4)
	LD	H,(IX+5)
	LD	DE,_cplx_z
	LD	BC,8
	LDIR
	; e^re
	LD	HL,(_cplx_z)
	LD	DE,(_cplx_z+2)
	PUSH	DE
	PUSH	HL
	CALL	_exp
	POP	BC
	POP	BC
	LD	(_cplx_w),HL
	LD	(_cplx_w+2),DE
	; cos(im)
	LD	HL,(_cplx_z+4)
	LD	DE,(_cplx_z+6)
	PUSH	DE
	PUSH	HL
	CALL	_cos
	POP	BC
	POP	BC
	; Real = e^re * cos(im)
	LD	(__tmp32),HL
	LD	(__tmp32+2),DE
	LD	HL,(_cplx_w)
	LD	DE,(_cplx_w+2)
	CALL	__fmul
	LD	(_cplx_res),HL
	LD	(_cplx_res+2),DE
	; sin(im)
	LD	HL,(_cplx_z+4)
	LD	DE,(_cplx_z+6)
	PUSH	DE
	PUSH	HL
	CALL	_sin
	POP	BC
	POP	BC
	; Imag = e^re * sin(im)
	LD	(__tmp32),HL
	LD	(__tmp32+2),DE
	LD	HL,(_cplx_w)
	LD	DE,(_cplx_w+2)
	CALL	__fmul
	LD	(_cplx_res+4),HL
	LD	(_cplx_res+6),DE
	LD	HL,_cplx_res
	POP	IX
	RET

; clog: log(z) = log(|z|) + i*arg(z)
_clog:
_clogf:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	LD	L,(IX+4)
	LD	H,(IX+5)
	PUSH	HL
	; |z|
	PUSH	HL
	CALL	_cabs
	POP	BC
	; log(|z|)
	PUSH	DE
	PUSH	HL
	CALL	_log
	POP	BC
	POP	BC
	LD	(_cplx_res),HL
	LD	(_cplx_res+2),DE
	; arg(z)
	POP	HL
	PUSH	HL
	CALL	_carg
	POP	BC
	LD	(_cplx_res+4),HL
	LD	(_cplx_res+6),DE
	LD	HL,_cplx_res
	POP	IX
	RET

; csqrt: sqrt(z) using polar form
_csqrt:
_csqrtf:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	LD	L,(IX+4)
	LD	H,(IX+5)
	PUSH	HL
	; sqrt(|z|)
	PUSH	HL
	CALL	_cabs
	POP	BC
	PUSH	DE
	PUSH	HL
	CALL	_sqrt
	POP	BC
	POP	BC
	LD	(_cplx_w),HL	; r = sqrt(|z|)
	LD	(_cplx_w+2),DE
	; arg(z)/2
	POP	HL
	PUSH	HL
	CALL	_carg
	POP	BC
	; Divide by 2: multiply by 0.5 (0x3F000000)
	LD	(__tmp32),HL
	LD	(__tmp32+2),DE
	LD	HL,0
	LD	DE,3F00H
	CALL	__fmul
	LD	(_cplx_w+4),HL
	LD	(_cplx_w+6),DE
	; Real = r * cos(θ/2)
	PUSH	DE
	PUSH	HL
	CALL	_cos
	POP	BC
	POP	BC
	LD	(__tmp32),HL
	LD	(__tmp32+2),DE
	LD	HL,(_cplx_w)
	LD	DE,(_cplx_w+2)
	CALL	__fmul
	LD	(_cplx_res),HL
	LD	(_cplx_res+2),DE
	; Imag = r * sin(θ/2)
	LD	HL,(_cplx_w+4)
	LD	DE,(_cplx_w+6)
	PUSH	DE
	PUSH	HL
	CALL	_sin
	POP	BC
	POP	BC
	LD	(__tmp32),HL
	LD	(__tmp32+2),DE
	LD	HL,(_cplx_w)
	LD	DE,(_cplx_w+2)
	CALL	__fmul
	LD	(_cplx_res+4),HL
	LD	(_cplx_res+6),DE
	LD	HL,_cplx_res
	POP	IX
	RET

; cpow: z^w = e^(w*log(z))
_cpow:
_cpowf:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	; z at IX+4, w at IX+6
	LD	L,(IX+4)
	LD	H,(IX+5)
	; log(z)
	PUSH	HL
	CALL	_clog
	POP	BC
	LD	DE,__cplx_l
	LD	BC,8
	LDIR
	; Load w
	LD	L,(IX+6)
	LD	H,(IX+7)
	LD	DE,__cplx_r
	LD	BC,8
	LDIR
	; w * log(z)
	CALL	__cmul
	; e^(w*log(z))
	LD	HL,__cplx_result
	PUSH	HL
	CALL	_cexp
	POP	BC
	POP	IX
	RET

; csin: sin(z) = sin(re)*cosh(im) + i*cos(re)*sinh(im)
_csin:
_csinf:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	LD	L,(IX+4)
	LD	H,(IX+5)
	LD	DE,_cplx_z
	LD	BC,8
	LDIR
	; sin(re)
	LD	HL,(_cplx_z)
	LD	DE,(_cplx_z+2)
	PUSH	DE
	PUSH	HL
	CALL	_sin
	POP	BC
	POP	BC
	LD	(_cplx_w),HL
	LD	(_cplx_w+2),DE
	; cosh(im)
	LD	HL,(_cplx_z+4)
	LD	DE,(_cplx_z+6)
	PUSH	DE
	PUSH	HL
	CALL	_cosh
	POP	BC
	POP	BC
	; Real = sin(re) * cosh(im)
	LD	(__tmp32),HL
	LD	(__tmp32+2),DE
	LD	HL,(_cplx_w)
	LD	DE,(_cplx_w+2)
	CALL	__fmul
	LD	(_cplx_res),HL
	LD	(_cplx_res+2),DE
	; cos(re)
	LD	HL,(_cplx_z)
	LD	DE,(_cplx_z+2)
	PUSH	DE
	PUSH	HL
	CALL	_cos
	POP	BC
	POP	BC
	LD	(_cplx_w),HL
	LD	(_cplx_w+2),DE
	; sinh(im)
	LD	HL,(_cplx_z+4)
	LD	DE,(_cplx_z+6)
	PUSH	DE
	PUSH	HL
	CALL	_sinh
	POP	BC
	POP	BC
	; Imag = cos(re) * sinh(im)
	LD	(__tmp32),HL
	LD	(__tmp32+2),DE
	LD	HL,(_cplx_w)
	LD	DE,(_cplx_w+2)
	CALL	__fmul
	LD	(_cplx_res+4),HL
	LD	(_cplx_res+6),DE
	LD	HL,_cplx_res
	POP	IX
	RET

; ccos: cos(z) = cos(re)*cosh(im) - i*sin(re)*sinh(im)
_ccos:
_ccosf:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	LD	L,(IX+4)
	LD	H,(IX+5)
	LD	DE,_cplx_z
	LD	BC,8
	LDIR
	; cos(re)
	LD	HL,(_cplx_z)
	LD	DE,(_cplx_z+2)
	PUSH	DE
	PUSH	HL
	CALL	_cos
	POP	BC
	POP	BC
	LD	(_cplx_w),HL
	LD	(_cplx_w+2),DE
	; cosh(im)
	LD	HL,(_cplx_z+4)
	LD	DE,(_cplx_z+6)
	PUSH	DE
	PUSH	HL
	CALL	_cosh
	POP	BC
	POP	BC
	; Real = cos(re) * cosh(im)
	LD	(__tmp32),HL
	LD	(__tmp32+2),DE
	LD	HL,(_cplx_w)
	LD	DE,(_cplx_w+2)
	CALL	__fmul
	LD	(_cplx_res),HL
	LD	(_cplx_res+2),DE
	; sin(re)
	LD	HL,(_cplx_z)
	LD	DE,(_cplx_z+2)
	PUSH	DE
	PUSH	HL
	CALL	_sin
	POP	BC
	POP	BC
	LD	(_cplx_w),HL
	LD	(_cplx_w+2),DE
	; sinh(im)
	LD	HL,(_cplx_z+4)
	LD	DE,(_cplx_z+6)
	PUSH	DE
	PUSH	HL
	CALL	_sinh
	POP	BC
	POP	BC
	; Imag = -sin(re) * sinh(im)
	LD	(__tmp32),HL
	LD	(__tmp32+2),DE
	LD	HL,(_cplx_w)
	LD	DE,(_cplx_w+2)
	CALL	__fmul
	LD	A,D
	XOR	80H
	LD	D,A
	LD	(_cplx_res+4),HL
	LD	(_cplx_res+6),DE
	LD	HL,_cplx_res
	POP	IX
	RET

; ctan: tan(z) = sin(z) / cos(z)
_ctan:
_ctanf:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	LD	L,(IX+4)
	LD	H,(IX+5)
	; sin(z)
	PUSH	HL
	CALL	_csin
	POP	BC
	LD	DE,__cplx_l
	LD	BC,8
	LDIR
	; cos(z)
	LD	L,(IX+4)
	LD	H,(IX+5)
	PUSH	HL
	CALL	_ccos
	POP	BC
	LD	DE,__cplx_r
	LD	BC,8
	LDIR
	CALL	__cdiv
	LD	DE,_cplx_res
	LD	BC,8
	LDIR
	LD	HL,_cplx_res
	POP	IX
	RET

; csinh: sinh(z) = sinh(re)*cos(im) + i*cosh(re)*sin(im)
_csinh:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	LD	L,(IX+4)
	LD	H,(IX+5)
	LD	DE,_cplx_z
	LD	BC,8
	LDIR
	; sinh(re)
	LD	HL,(_cplx_z)
	LD	DE,(_cplx_z+2)
	PUSH	DE
	PUSH	HL
	CALL	_sinh
	POP	BC
	POP	BC
	LD	(_cplx_w),HL
	LD	(_cplx_w+2),DE
	; cos(im)
	LD	HL,(_cplx_z+4)
	LD	DE,(_cplx_z+6)
	PUSH	DE
	PUSH	HL
	CALL	_cos
	POP	BC
	POP	BC
	; Real = sinh(re) * cos(im)
	LD	(__tmp32),HL
	LD	(__tmp32+2),DE
	LD	HL,(_cplx_w)
	LD	DE,(_cplx_w+2)
	CALL	__fmul
	LD	(_cplx_res),HL
	LD	(_cplx_res+2),DE
	; cosh(re)
	LD	HL,(_cplx_z)
	LD	DE,(_cplx_z+2)
	PUSH	DE
	PUSH	HL
	CALL	_cosh
	POP	BC
	POP	BC
	LD	(_cplx_w),HL
	LD	(_cplx_w+2),DE
	; sin(im)
	LD	HL,(_cplx_z+4)
	LD	DE,(_cplx_z+6)
	PUSH	DE
	PUSH	HL
	CALL	_sin
	POP	BC
	POP	BC
	; Imag = cosh(re) * sin(im)
	LD	(__tmp32),HL
	LD	(__tmp32+2),DE
	LD	HL,(_cplx_w)
	LD	DE,(_cplx_w+2)
	CALL	__fmul
	LD	(_cplx_res+4),HL
	LD	(_cplx_res+6),DE
	LD	HL,_cplx_res
	POP	IX
	RET

; ccosh: cosh(z) = cosh(re)*cos(im) + i*sinh(re)*sin(im)
_ccosh:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	LD	L,(IX+4)
	LD	H,(IX+5)
	LD	DE,_cplx_z
	LD	BC,8
	LDIR
	; cosh(re)
	LD	HL,(_cplx_z)
	LD	DE,(_cplx_z+2)
	PUSH	DE
	PUSH	HL
	CALL	_cosh
	POP	BC
	POP	BC
	LD	(_cplx_w),HL
	LD	(_cplx_w+2),DE
	; cos(im)
	LD	HL,(_cplx_z+4)
	LD	DE,(_cplx_z+6)
	PUSH	DE
	PUSH	HL
	CALL	_cos
	POP	BC
	POP	BC
	; Real = cosh(re) * cos(im)
	LD	(__tmp32),HL
	LD	(__tmp32+2),DE
	LD	HL,(_cplx_w)
	LD	DE,(_cplx_w+2)
	CALL	__fmul
	LD	(_cplx_res),HL
	LD	(_cplx_res+2),DE
	; sinh(re)
	LD	HL,(_cplx_z)
	LD	DE,(_cplx_z+2)
	PUSH	DE
	PUSH	HL
	CALL	_sinh
	POP	BC
	POP	BC
	LD	(_cplx_w),HL
	LD	(_cplx_w+2),DE
	; sin(im)
	LD	HL,(_cplx_z+4)
	LD	DE,(_cplx_z+6)
	PUSH	DE
	PUSH	HL
	CALL	_sin
	POP	BC
	POP	BC
	; Imag = sinh(re) * sin(im)
	LD	(__tmp32),HL
	LD	(__tmp32+2),DE
	LD	HL,(_cplx_w)
	LD	DE,(_cplx_w+2)
	CALL	__fmul
	LD	(_cplx_res+4),HL
	LD	(_cplx_res+6),DE
	LD	HL,_cplx_res
	POP	IX
	RET

; ctanh: tanh(z) = sinh(z) / cosh(z)
_ctanh:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	LD	L,(IX+4)
	LD	H,(IX+5)
	; sinh(z)
	PUSH	HL
	CALL	_csinh
	POP	BC
	LD	DE,__cplx_l
	LD	BC,8
	LDIR
	; cosh(z)
	LD	L,(IX+4)
	LD	H,(IX+5)
	PUSH	HL
	CALL	_ccosh
	POP	BC
	LD	DE,__cplx_r
	LD	BC,8
	LDIR
	CALL	__cdiv
	LD	DE,_cplx_res
	LD	BC,8
	LDIR
	LD	HL,_cplx_res
	POP	IX
	RET

; Inverse trig/hyperbolic - simplified placeholders that return input
_casin:
_cacos:
_catan:
_casinh:
_cacosh:
_catanh:
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	LD	L,(IX+4)
	LD	H,(IX+5)
	LD	DE,_cplx_res
	LD	BC,8
	LDIR
	LD	HL,_cplx_res
	POP	IX
	RET

; Complex multiply: __cplx_l * __cplx_r -> __cplx_result
; Stub implementation - returns __cplx_l
__cmul:
	LD	HL,__cplx_l
	LD	DE,__cplx_result
	LD	BC,8
	LDIR
	RET

; Complex divide: __cplx_l / __cplx_r -> __cplx_result
; Stub implementation - returns __cplx_l
__cdiv:
	LD	HL,__cplx_l
	LD	DE,__cplx_result
	LD	BC,8
	LDIR
	RET

	DSEG

_assert_msg:	DB	'Assert: ',0

; sprintf working storage
_sprintf_out:	DS	2	; Current output pointer
_sprintf_cnt:	DS	2	; Character count
_sprintf_width:	DS	1	; Field width (0 = no width)
_sprintf_zero:	DS	1	; Zero-padding flag (non-zero = pad with '0')

; snprintf working storage
_snprintf_out:	DS	2	; Current output pointer
_snprintf_max:	DS	2	; Remaining space in buffer
_snprintf_cnt:	DS	2	; Total character count

; fprintf working storage
_fprintf_stream: DS	2	; Current output stream

; atol working storage
_atol_acc:	DS	4
_atol_tmp:	DS	4

; strtol working storage
_strtol_acc:	DS	4
_strtol_tmp:	DS	4
_strtol_base:	DS	1
_strtol_neg:	DS	1

; strtok state
_strtok_next:	DS	2	; Next position in string
_strtok_tok:	DS	2	; Start of current token

; atexit handler table (max 4 handlers)
_atexit_cnt:	DB	0	; Number of registered handlers
_atexit_tab:	DS	8	; 4 function pointers (2 bytes each)

; abort message
_abort_msg:	DB	'Aborted',0DH,0AH,'$'

; strerror messages
_strerr_ok:	DB	'Success',0
_strerr_noent:	DB	'No such file',0
_strerr_io:	DB	'I/O error',0
_strerr_nomem:	DB	'Out of memory',0
_strerr_acces:	DB	'Permission denied',0
_strerr_inval:	DB	'Invalid argument',0
_strerr_nospc:	DB	'No space left',0
_strerr_nosys:	DB	'Not implemented',0
_strerr_unknown: DB	'Unknown error',0

; div/ldiv result storage
_div_result:	DS	4	; div_t: quot (2), rem (2)
_ldiv_result:	DS	8	; ldiv_t: quot (4), rem (4)

; File I/O working storage
_file_slots:	DS	680	; 4 FILE structures * 170 bytes each
_fread_ptr:	DS	2	; fread dest pointer temp
_fread_cnt:	DS	2	; fread byte counter temp
_fwrite_ptr:	DS	2	; fwrite source pointer temp
_fwrite_cnt:	DS	2	; fwrite byte counter temp

; Standard FILE structures
; Each FILE: fd(1), flags(1), unget(1), mode(1) = 4 bytes
	PUBLIC	_stdin_data
_stdin_data:	DB	0,0,0FFH,0	; fd=0 (stdin), flags=0, unget=none, mode=0
	PUBLIC	_stdout_data
_stdout_data:	DB	1,0,0FFH,0	; fd=1 (stdout)
	PUBLIC	_stderr_data
_stderr_data:	DB	2,0,0FFH,0	; fd=2 (stderr)
; Pointers to FILE structures
	PUBLIC	_stdin
_stdin:		DW	_stdin_data
	PUBLIC	_stdout
_stdout:	DW	_stdout_data
	PUBLIC	_stderr
_stderr:	DW	_stderr_data

; printf 32-bit working storage
_prt32_val:	DS	4
_prt64_val:	DS	8
_prt_out_mode:	DS	1	; 0=console, 1=buffer
_prt_bufpos:	DS	1	; Current position in buffer
_prt_gbuf:	DS	24	; Buffer for %g output

; rand seed
_rand_seed:	DW	1		; Default seed = 1

; errno
	PUBLIC	_errno
_errno:		DW	0

; Heap management
_heap_ptr:	DS	2	; Current heap pointer (0 = uninitialized)
_heap_start:			; Heap starts here (after all static data)

; Math function work areas
_trig_x:	DS	4
_trig_negate:	DS	1
_sqrt_x:	DS	4
_sqrt_guess:	DS	4
_sin_sign:	DS	1
_sin_x:		DS	4
_sin_x2:	DS	4
_sin_sum:	DS	4
_sin_term:	DS	4
